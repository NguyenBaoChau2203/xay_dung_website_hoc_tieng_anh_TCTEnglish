<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuizletClone</title>
    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/layout.css" />
    <script src="~/js/layout.js"></script>
</head>
<body>
    <!-- HEADER -->
    <header class="header">
        <div class="header-left">
            <i class="fas fa-bars menu-icon"></i>
            <a asp-controller="Home" asp-action="Index" class="logo">TCT</a>
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search for study guides">
            </div>
        </div>
        <div class="header-right">
            <button class="btn-circle"><i class="fas fa-plus"></i></button>
            <button class="btn-upgrade">Upgrade: free 7-day trial</button>
            <div class="avatar"></div>
        </div>
    </header>
    <div class="layout">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <nav>
                <a class="nav-item active">
                    <i class="fas fa-home"></i>
                    <span>Home</span>
                </a>
                <a class="nav-item">
                    <i class="fas fa-layer-group"></i>
                    <span>Your library</span>
                </a>
                <a class="nav-item">
                    <i class="fas fa-bell"></i>
                    <span>Notifications</span>
                </a>
            </nav>
            <hr>
            <div class="workspace">
                <p class="workspace-title">Workspace</p>
                <button class="workspace-btn">
                    <span class="icon-circle">
                        <i class="fas fa-plus"></i>
                    </span>
                    New folder
                </button>
                <button class="workspace-btn">
                    <span class="icon-circle">
                        <i class="fas fa-clone"></i>
                    </span>
                    Add flashcard
                </button>
            </div>
            <div class="sidebar-footer">
                Tận dụng Flashcards để ghi nhớ kiến thức nhanh hơn 3 lần.
            </div>
        </aside>
        <!-- MAIN -->
        <main class="main">
            @RenderBody()
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>