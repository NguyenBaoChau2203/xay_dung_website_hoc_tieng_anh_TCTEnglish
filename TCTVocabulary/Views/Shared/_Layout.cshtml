
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuizletClone</title>

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/layout.css" />

    <script src="~/js/layout.js"></script>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <partial name="_Loader" />
    <!-- ================= HEADER ================= -->
    <header class="header">
        <div class="header-left">
            <i class="fas fa-bars menu-icon"></i>
            <a asp-controller="Home" asp-action="Index" class="logo">TCT</a>
        </div>

        <form asp-controller="Home"
              asp-action="Search"
              method="get"
              class="search-box">

            <i class="fas fa-search"></i>

            <input type="text"
                   name="q"
                   value="@Context.Request.Query["q"]"
                   placeholder="Search for folders, classes, users"
                   autocomplete="off" />
        </form>

        <div class="header-right">
            <button class="btn-circle">
                <i class="fas fa-plus"></i>
            </button>

            <button class="btn-upgrade">
                Upgrade: free 7-day trial
            </button>

            @if (User.Identity!.IsAuthenticated)
            {
                var avatarUrl = User.Claims.FirstOrDefault(c => c.Type == "AvatarUrl")?.Value;
                var avatarStyle = !string.IsNullOrEmpty(avatarUrl)
                    ? $"background-image: url('{avatarUrl}'); background-size: cover; background-position: center; background-color: transparent;"
                    : "";

                <div class="user-menu-container">
                    <div class="user-profile" id="userProfileBtn">
                        <div class="avatar" style="@avatarStyle"></div>
                        <span class="user-name-display">@User.Identity.Name</span>
                        <i class="fas fa-chevron-down" style="font-size: 12px; color: #6b7280;"></i>
                    </div>

                    <div class="user-dropdown" id="userDropdown">
                        <div class="dropdown-header">
                            <div class="avatar small" style="@avatarStyle"></div>
                            <div class="user-info-text">
                                <div class="name">@User.Identity.Name</div>
                                <div class="email">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value</div>
                            </div>
                        </div>
                        <hr />
                        <a href="#" class="dropdown-item">
                            <i class="fas fa-user"></i> Hồ sơ của tôi
                        </a>
                        <a href="#" class="dropdown-item">
                            <i class="fas fa-cog"></i> Cài đặt
                        </a>
                        <a href="#" class="dropdown-item">
                            <i class="fas fa-layer-group"></i> Chủ đề đã học
                        </a>
                        <hr />
                        <a asp-controller="Account" asp-action="Logout" class="dropdown-item logout">
                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            }
            else
            {
                 <a asp-controller="Account" asp-action="Login" class="btn-upgrade" style="background: #e0e7ff; color: #4255ff; margin-left: 10px;">Đăng nhập</a>
            }
        </div>
    </header>

    <div class="layout">
        <!-- ================= SIDEBAR ================= -->
        <aside class="sidebar">
            <nav>
                <div class="nav-dropdown" id="coursesDropdown">
                    <div class="nav-dropdown-item" id="coursesDropdownBtn">
                        <div class="nav-dropdown-title">
                            <i class="fas fa-book-open"></i>
                            <span>Courses</span>
                        </div>
                        <i class="fas fa-chevron-down dropdown-arrow"></i>
                    </div>
                    
                    <div class="nav-dropdown-menu" id="coursesDropdownMenu">
                        <a class="nav-sub-item" asp-controller="Home" asp-action="Grammar">
                            <span>Grammar</span>
                        </a>
                        <a class="nav-sub-item" asp-controller="Home" asp-action="Listening">
                            <span>Listening</span>
                        </a>
                        <a class="nav-sub-item" asp-controller="Home" asp-action="Reading">
                            <span>Reading</span>
                        </a>
                        <a class="nav-sub-item" asp-controller="Home" asp-action="Writing">
                            <span>Writing <i class="fas fa-fire" style="color:#f97316; font-size:14px; margin-left:6px;"></i></span>
                        </a>
                        <a class="nav-sub-item" asp-controller="Speaking" asp-action="Index">
                            <span>Speaking</span>
                        </a>
                    </div>
                </div>

                <hr style="margin: 10px 0;" />

                <a class="nav-item">
                    <i class="fas fa-layer-group"></i>
                    <span>Your library</span>
                </a>

                <a class="nav-item">
                    <i class="fas fa-bell"></i>
                    <span>Notifications</span>
                </a>

                <a class="nav-item" asp-controller="Goals" asp-action="Index">
                    <i class="fas fa-bullseye"></i>
                    <span>Goals</span>
                </a>

                <a class="nav-item " asp-controller="Ranking" asp-action="Index">
                    <i class="fas fa-trophy"></i>
                    <span>Ranking</span>
                </a>

                <a class="nav-item" asp-controller="Home" asp-action="Class">
                    <i class="fas fa-chalkboard-teacher"></i>
                    <span>Class</span>
                </a>

                <a class="nav-item" asp-controller="Home" asp-action="Folder">
                    <i class="fas fa-folder"></i>
                    <span>Folder</span>
                </a>

                <a class="nav-item" asp-controller="Vocabulary" asp-action="Index">
                    <i class="fas fa-book"></i>
                    <span>Từ vựng (Hệ thống)</span>
                </a>
            </nav>

            <hr />

            <!-- ================= WORKSPACE ================= -->
            <div class="workspace">
                <p class="workspace-title">Workspace</p>

                <!-- New Folder -->
                <button class="workspace-btn" id="newFolderBtn">
                    <span class="icon-circle">
                        <i class="fas fa-plus"></i>
                    </span>
                    New folder
                </button>

                <button class="workspace-btn"
                        onclick="location.href='@Url.Action("CreateClass", "Home")'">
                    <span class="icon-circle">
                        <i class="fas fa-plus"></i>
                    </span>
                    New class
                </button>

                <button class="workspace-btn">
                    <span class="icon-circle">
                        <i class="fas fa-clone"></i>
                    </span>
                    Add flashcard
                </button>
            </div>

            <div class="sidebar-footer">
                Tận dụng Flashcards để ghi nhớ kiến thức nhanh hơn 3 lần.
            </div>
        </aside>

        <!-- ================= MAIN ================= -->
        <main class="main">
            @RenderBody()
        </main>
    </div>

    <!-- ================= CREATE FOLDER MODAL ================= -->
    <div id="folderModal" class="modal-overlay">
        <div class="modal">
            <h3 class="modal-title">Create new folder</h3>

            <form asp-controller="Home"
                  asp-action="CreateFolder"
                  method="post">

                <input type="text"
                       name="folderName"
                       class="modal-input"
                       placeholder="Folder name"
                       required />

                <div class="modal-actions">
                    <button type="button"
                            class="btn-decline"
                            id="cancelFolderBtn">
                        Decline
                    </button>

                    <button type="submit"
                            class="btn-confirm">
                        Confirm
                    </button>
                </div>
            </form>
        </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
