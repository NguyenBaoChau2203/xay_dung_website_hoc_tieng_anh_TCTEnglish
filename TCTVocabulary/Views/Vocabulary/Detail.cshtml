@model TCTVocabulary.Models.Set
@{
    ViewData["Title"] = Model.SetName;
    var tags = (Model.Description ?? "")
                   .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                   .Where(t => t.StartsWith("#"))
                   .ToList();

    var totalCards = Model.Cards?.Count ?? 0;
    var learnedCards = Model.Cards?.Count(c => c.LearningProgresses.FirstOrDefault()?.Status == "Learned" || c.LearningProgresses.FirstOrDefault()?.Status == "Mastered") ?? 0;
    var remainingCards = totalCards - learnedCards;
    var accuracy = totalCards > 0 ? (learnedCards * 100) / totalCards : 0;

    var newCards = Model.Cards?.Count(c => c.LearningProgresses.FirstOrDefault() == null || c.LearningProgresses.FirstOrDefault()?.Status == "New") ?? 0;
    var reviewingCards = Model.Cards?.Count(c => c.LearningProgresses.FirstOrDefault()?.Status == "Reviewing") ?? 0;
    var masteredCards = Model.Cards?.Count(c => c.LearningProgresses.FirstOrDefault()?.Status == "Mastered") ?? 0;
    var dueToday = Model.Cards?.Count(c => c.LearningProgresses.FirstOrDefault()?.LastReviewedDate <= DateTime.Today.AddDays(-1)) ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/vocabulary-system.css" />
}

<div class="set-detail-modern">
    <!-- Breadcrumb -->
    <nav class="breadcrumb-nav">
        <a href="@Url.Action("Index", "Vocabulary")">
            <i class="fas fa-home"></i> Trang chủ
        </a>
        <i class="fas fa-chevron-right separator"></i>
        <a href="#">@(Model.Folder?.FolderName ?? "Từ vựng")</a>
        <i class="fas fa-chevron-right separator"></i>
        <span>@Model.SetName</span>
    </nav>

    <!-- Hero Section -->
    <div class="set-hero">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="set-badge">
                <i class="fas fa-layer-group"></i>
                <span>@totalCards từ vựng</span>
            </div>
            <h1 class="set-title">@Model.SetName</h1>
            <div class="set-tags">
                @foreach (var tag in tags)
                {
                    <span class="tag">@tag</span>
                }
            </div>

            <!-- Study Stats -->
            <div class="study-stats">
                <div class="stat-group">
                    <div class="stat-item">
                        <span class="stat-value">@learnedCards</span>
                        <span class="stat-label">Đã học</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-value">@remainingCards</span>
                        <span class="stat-label">Còn lại</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-value">@accuracy%</span>
                        <span class="stat-label">Độ chính xác</span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="hero-actions">
                <a href="@Url.Action("Study", "Vocabulary", new { id = Model.SetId })" class="btn-study">
                    <i class="fas fa-play"></i>
                    <span>@(learnedCards > 0 ? "Tiếp tục học" : "Bắt đầu học")</span>
                </a>
                <button class="btn-bookmark">
                    <i class="far fa-bookmark"></i>
                </button>
                <button class="btn-share">
                    <i class="fas fa-share-alt"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Quick Stats Cards -->
    <div class="quick-stats">
        <div class="stat-card new">
            <div class="stat-icon">
                <i class="fas fa-star"></i>
            </div>
            <div class="stat-detail">
                <span class="stat-number">@newCards</span>
                <span class="stat-label">Từ mới</span>
            </div>
        </div>
        <div class="stat-card reviewing">
            <div class="stat-icon">
                <i class="fas fa-sync-alt"></i>
            </div>
            <div class="stat-detail">
                <span class="stat-number">@reviewingCards</span>
                <span class="stat-label">Đang ôn</span>
            </div>
        </div>
        <div class="stat-card mastered">
            <div class="stat-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-detail">
                <span class="stat-number">@masteredCards</span>
                <span class="stat-label">Thành thạo</span>
            </div>
        </div>
        <div class="stat-card due">
            <div class="stat-icon">
                <i class="fas fa-clock"></i>
            </div>
            <div class="stat-detail">
                <span class="stat-number">@dueToday</span>
                <span class="stat-label">Đến hạn</span>
            </div>
        </div>
    </div>

    <!-- Study Progress Section -->
    <div class="study-progress-section">
        <div class="section-header">
            <h2>Tiến độ học tập</h2>
            <div class="progress-summary">
                <span class="completed">@learnedCards hoàn thành</span>
                <span class="total">/ @totalCards từ</span>
            </div>
        </div>

        <div class="progress-visual">
            <div class="progress-circle" data-progress="@accuracy">
                <div class="progress-circle-inner">
                    <span class="percentage">@accuracy%</span>
                    <span class="label">Hoàn thành</span>
                </div>
            </div>
            <div class="progress-bars">
                <div class="progress-bar-item">
                    <div class="bar-label">
                        <span><i class="fas fa-circle" style="color: #4facfe"></i> Mới</span>
                        <span>@newCards từ</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width: @((newCards * 100) / (totalCards > 0 ? totalCards : 1))%"></div>
                    </div>
                </div>
                <div class="progress-bar-item">
                    <div class="bar-label">
                        <span><i class="fas fa-circle" style="color: #fbbf24"></i> Đang học</span>
                        <span>@reviewingCards từ</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width: @((reviewingCards * 100) / (totalCards > 0 ? totalCards : 1))%; background: #fbbf24"></div>
                    </div>
                </div>
                <div class="progress-bar-item">
                    <div class="bar-label">
                        <span><i class="fas fa-circle" style="color: #43e97b"></i> Thành thạo</span>
                        <span>@masteredCards từ</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width: @((masteredCards * 100) / (totalCards > 0 ? totalCards : 1))%; background: #43e97b"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Vocabulary List -->
    <div class="vocabulary-section">
        <div class="section-header">
            <div class="header-left">
                <h2>Danh sách từ vựng</h2>
                <span class="word-count">@Model.Cards.Count từ</span>
            </div>
            <div class="header-actions">
                <a href="@Url.Action("Create", "Card", new { setId = Model.SetId })" class="btn-add">
                    <i class="fas fa-plus"></i>
                    <span>Thêm từ mới</span>
                </a>
                <a href="@Url.Action("Import", "Card", new { setId = Model.SetId })" class="btn-import">
                    <i class="fas fa-upload"></i>
                    <span>Import</span>
                </a>
            </div>
        </div>

        @if (!Model.Cards.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">📚</div>
                <h3>Chưa có từ vựng nào</h3>
                <p>Hãy thêm từ vựng đầu tiên để bắt đầu học!</p>
                <a href="@Url.Action("Create", "Card", new { setId = Model.SetId })" class="btn-add-first">
                    <i class="fas fa-plus"></i> Thêm từ vựng đầu tiên
                </a>
            </div>
        }
        else
        {
            <div class="word-list">
                @foreach (var card in Model.Cards.OrderBy(c => c.Term))
                {
                    <div class="word-card">
                        <div class="word-card-front">
                            <div class="word-info">
                                <span class="word-term">@card.Term</span>
                                @if (!string.IsNullOrEmpty(card.ImageUrl))
                                {
                                    <img src="@card.ImageUrl" alt="@card.Term" class="word-image" />
                                }
                            </div>
                            <button class="expand-btn">
                                <i class="fas fa-chevron-down"></i>
                            </button>
                        </div>
                        <div class="word-card-back">
                            <div class="definition">
                                <span class="label">Định nghĩa:</span>
                                <p>@card.Definition</p>
                            </div>
                            
                            <div class="word-meta">
                                <span class="status-badge @(card.LearningProgresses.FirstOrDefault()?.Status?.ToLower() ?? "new")">
                                    @(card.LearningProgresses.FirstOrDefault()?.Status ?? "Chưa học")
                                </span>
                                <div class="word-actions">
                                    <a href="@Url.Action("Edit", "Card", new { id = card.CardId })" class="action-btn edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", "Card", new { id = card.CardId })"
                                       class="action-btn delete"
                                       onclick="return confirm('Bạn có chắc muốn xóa từ này?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.Cards.Count > 10)
            {
                <div class="pagination">
                    <button class="page-btn prev" disabled>
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <button class="page-btn active">1</button>
                    <button class="page-btn">2</button>
                    <button class="page-btn">3</button>
                    <span class="dots">...</span>
                    <button class="page-btn">10</button>
                    <button class="page-btn next">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            }
        }
    </div>

    <!-- Related Sets -->
    @if (Model.Folder?.Sets != null && Model.Folder.Sets.Count > 1)
    {
        <div class="related-section">
            <h2>Bộ từ cùng danh mục</h2>
            <div class="related-grid">
                @foreach (var relatedSet in Model.Folder.Sets.Where(s => s.SetId != Model.SetId).Take(3))
                {
                    var relatedTags = (relatedSet.Description ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries)
                    .Where(t => t.StartsWith("#")).ToList();

                    <div class="related-card">
                        <div class="related-header">
                            <span class="related-icon">📚</span>
                        </div>
                        <div class="related-body">
                            <h3>@relatedSet.SetName</h3>
                            <div class="related-meta">
                                <span><i class="fas fa-layer-group"></i> @(relatedSet.Cards?.Count ?? 0) từ</span>
                                @if (relatedTags.Any())
                                {
                                    <span class="related-tag">@relatedTags.First()</span>
                                }
                            </div>
                            <a href="@Url.Action("Detail", "Vocabulary", new { setId = relatedSet.SetId })" class="related-link">
                                Xem chi tiết <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Expand/collapse word cards
        document.querySelectorAll('.expand-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const wordCard = this.closest('.word-card');
                wordCard.classList.toggle('expanded');

                const icon = this.querySelector('i');
                if (wordCard.classList.contains('expanded')) {
                    icon.classList.remove('fa-chevron-down');
                    icon.classList.add('fa-chevron-up');
                } else {
                    icon.classList.remove('fa-chevron-up');
                    icon.classList.add('fa-chevron-down');
                }
            });
        });

        // Animate progress circle
        const circle = document.querySelector('.progress-circle');
        if (circle) {
            const progress = circle.dataset.progress;
            const radius = 15.9155;
            const circumference = 2 * Math.PI * radius;
            const offset = circumference - (progress / 100) * circumference;

            const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            svg.setAttribute('viewBox', '0 0 36 36');
            svg.classList.add('progress-svg');

            const bgCircle = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            bgCircle.setAttribute('d', 'M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831');
            bgCircle.classList.add('progress-bg');

            const fillCircle = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            fillCircle.setAttribute('d', 'M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831');
            fillCircle.classList.add('progress-fill');
            fillCircle.setAttribute('stroke-dasharray', `${circumference}`);
            fillCircle.setAttribute('stroke-dashoffset', offset);

            svg.appendChild(bgCircle);
            svg.appendChild(fillCircle);
            circle.prepend(svg);
        }
    </script>
}