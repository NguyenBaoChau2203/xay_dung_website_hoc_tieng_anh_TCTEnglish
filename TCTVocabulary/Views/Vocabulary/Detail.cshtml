@model TCTVocabulary.Models.Set
@using System.Linq
@using System.Collections.Generic
@{
    ViewData["Title"] = Model.SetName;

    // Kiểm tra Model.Cards có null không
    var cards = Model.Cards ?? new List<TCTVocabulary.Models.Card>();

    // Tính toán Learning Progress
    var learnedStatuses = new[] { "Mastered", "Learned" };

    // Nhóm các thẻ theo Topic
    var topics = cards
        .GroupBy(c => string.IsNullOrEmpty(c.Topic) ? "Chưa phân loại" : c.Topic)
        .Select(g =>
        {
            var learnedCount = g.Count(c => c.LearningProgresses != null
                && c.LearningProgresses.Any(lp => learnedStatuses.Contains(lp.Status)));
            var totalCount = g.Count();

            return new
            {
                TopicName = g.Key,
                Cards = g.ToList(),
                TotalCards = totalCount,
                LearnedCards = learnedCount,
                Progress = totalCount > 0 ? (learnedCount * 100) / totalCount : 0
            };
        })
        .OrderBy(t => t.TopicName)
        .ToList();

    var topicsCount = topics.Count;

    // Các biến khác
    var tags = (Model.Description ?? "")
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Where(t => t.StartsWith("#"))
        .ToList();

    var totalCards = cards.Count;
    var learnedCards = cards.Count(c => c.LearningProgresses != null
        && c.LearningProgresses.Any(lp => learnedStatuses.Contains(lp.Status)));
    var remainingCards = totalCards - learnedCards;
    var accuracy = totalCards > 0 ? (learnedCards * 100) / totalCards : 0;

    var newCards = cards.Count(c => c.LearningProgresses == null
        || !c.LearningProgresses.Any());
    var reviewingCards = cards.Count(c => c.LearningProgresses != null
        && c.LearningProgresses.Any(lp => lp.Status == "Reviewing" || lp.Status == "Learning"));
    var masteredCards = cards.Count(c => c.LearningProgresses != null
        && c.LearningProgresses.Any(lp => lp.Status == "Mastered"));
    var dueToday = ViewBag.DueToday ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/vocabulary-system.css" />
    <style>
        /* Additional styles for phonetic and examples */
        .word-phonetic {
            font-size: 0.9rem;
            color: #64748b;
            font-family: 'Courier New', monospace;
            margin-left: 0.5rem;
            font-weight: normal;
        }

        .example {
            margin: 1rem 0;
            padding: 1rem;
            background: rgba(14, 165, 233, 0.05);
            border-radius: 12px;
            border-left: 4px solid #0EA5E9;
        }

            .example .label {
                font-weight: 600;
                color: #0EA5E9;
                font-size: 0.85rem;
                display: block;
                margin-bottom: 0.5rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

        .example-text {
            font-style: italic;
            color: #1e293b;
            margin-bottom: 0.5rem;
            line-height: 1.6;
            font-size: 1rem;
        }

        .example-translation {
            color: #64748b;
            font-size: 0.95rem;
            padding-left: 1rem;
            border-left: 2px solid #cbd5e1;
            margin-top: 0.25rem;
        }

        .word-info {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .word-term {
            font-size: 1.2rem;
            font-weight: 600;
            color: #0f172a;
        }

        /* Topics preview styles */
        .topics-preview-section {
            margin: 2rem 0;
            padding: 1.5rem;
            background: white;
            border-radius: 24px;
            box-shadow: 0 4px 6px -2px rgba(0,0,0,0.05);
            border: 1px solid #e2e8f0;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

            .section-header h2 {
                font-size: 1.25rem;
                font-weight: 600;
                color: #0f172a;
                display: flex;
                align-items: center;
                gap: 0.5rem;
                margin: 0;
            }

                .section-header h2 i {
                    color: #0EA5E9;
                    background: #F0F9FF;
                    padding: 0.5rem;
                    border-radius: 12px;
                }

        .view-all-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: #0EA5E9;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            padding: 0.5rem 1rem;
            border-radius: 100px;
            background: #F8FAFC;
            border: 1px solid #e2e8f0;
            transition: all 0.2s;
        }

            .view-all-link:hover {
                background: #F0F9FF;
                border-color: #0EA5E9;
                transform: translateY(-2px);
            }

        .topics-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }

        .topic-preview-card {
            background: #F8FAFC;
            border-radius: 16px;
            padding: 1.25rem;
            border: 1px solid #e2e8f0;
            text-decoration: none;
            color: inherit;
            transition: all 0.2s;
            display: block;
        }

            .topic-preview-card:hover {
                border-color: #0EA5E9;
                box-shadow: 0 4px 12px rgba(14, 165, 233, 0.1);
                transform: translateY(-2px);
                background: white;
            }

        .topic-preview-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .topic-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #F0F9FF 0%, #E0F2FE 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0EA5E9;
            font-size: 1.2rem;
        }

        .topic-preview-name {
            font-weight: 600;
            color: #0f172a;
            font-size: 1rem;
        }

        .topic-preview-stats {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
        }

        .topic-count {
            color: #64748b;
            font-size: 0.9rem;
        }

            .topic-count strong {
                color: #0f172a;
                font-weight: 600;
            }

        .topic-percent {
            color: #0EA5E9;
            font-weight: 600;
            background: #F0F9FF;
            padding: 0.2rem 0.6rem;
            border-radius: 100px;
            font-size: 0.8rem;
        }

        .progress-bar-mini {
            height: 6px;
            background: #e2e8f0;
            border-radius: 100px;
            overflow: hidden;
        }

        .progress-fill-mini {
            height: 100%;
            background: linear-gradient(90deg, #0EA5E9, #38BDF8);
            border-radius: 100px;
        }

        .view-all-container {
            margin-top: 1.5rem;
            text-align: center;
        }

        .btn-view-all {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            color: #0EA5E9;
            text-decoration: none;
            font-weight: 500;
            padding: 0.75rem 2rem;
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 100px;
            transition: all 0.2s;
        }

            .btn-view-all:hover {
                background: #F0F9FF;
                border-color: #0EA5E9;
                gap: 1rem;
            }

        /* Responsive */
        @@media (max-width: 640px) {
            .topics-grid {
                grid-template-columns: 1fr;
            }

            .section-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }
        }
    </style>

    <style>
        .due-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            animation: fadeIn 0.3s ease-out;
        }
        .due-modal-card {
            background: white;
            border-radius: 20px;
            padding: 40px 36px;
            max-width: 440px;
            width: 90%;
            text-align: center;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            animation: scaleIn 0.4s ease-out;
            position: relative;
        }
        .due-modal-close {
            position: absolute;
            top: 14px;
            right: 14px;
            background: none;
            border: none;
            color: #9CA3AF;
            font-size: 1.3rem;
            cursor: pointer;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s, color 0.2s;
        }
        .due-modal-close:hover {
            background: #F3F4F6;
            color: #374151;
        }
        .due-modal-icon {
            width: 72px;
            height: 72px;
            background: linear-gradient(135deg, #F97316, #EF4444);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 1.8rem;
            color: white;
            animation: bellRing 1s ease-in-out 0.5s;
            box-shadow: 0 8px 25px rgba(249, 115, 22, 0.35);
        }
        .due-modal-count {
            font-size: 3rem;
            font-weight: 800;
            background: linear-gradient(135deg, #F97316, #EF4444);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.1;
            margin-bottom: 6px;
        }
        .due-modal-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: #1F2937;
            margin-bottom: 8px;
        }
        .due-modal-desc {
            font-size: 0.9rem;
            color: #6B7280;
            margin-bottom: 28px;
            line-height: 1.5;
        }
        .due-modal-actions {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .due-modal-btn-primary {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: linear-gradient(135deg, #F97316, #EF4444);
            color: white;
            border: none;
            padding: 14px 24px;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 4px 15px rgba(249, 115, 22, 0.35);
        }
        .due-modal-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(249, 115, 22, 0.5);
            color: white;
        }
        .due-modal-btn-secondary {
            background: none;
            border: 1px solid #E5E7EB;
            padding: 12px 24px;
            border-radius: 12px;
            font-size: 0.9rem;
            font-weight: 600;
            color: #6B7280;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
        }
        .due-modal-btn-secondary:hover {
            background: #F9FAFB;
            color: #374151;
        }
        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @@keyframes scaleIn {
            from { opacity: 0; transform: scale(0.85); }
            to { opacity: 1; transform: scale(1); }
        }
        @@keyframes bellRing {
            0%, 100% { transform: rotate(0); }
            20% { transform: rotate(15deg); }
            40% { transform: rotate(-15deg); }
            60% { transform: rotate(10deg); }
            80% { transform: rotate(-10deg); }
        }
    </style>
}

@if (dueToday > 0)
{
    <div class="due-modal-overlay" id="dueModal">
        <div class="due-modal-card">
            <button class="due-modal-close" onclick="document.getElementById('dueModal').remove()">
                <i class="fas fa-times"></i>
            </button>
            <div class="due-modal-icon">
                <i class="fas fa-bell"></i>
            </div>
            <div class="due-modal-count">@dueToday</div>
            <div class="due-modal-title">từ đến hạn ôn tập!</div>
            <div class="due-modal-desc">
                Bạn có <strong>@dueToday từ vựng</strong> trong bộ <strong>@Model.SetName</strong> cần được ôn tập.<br>
                Hãy ôn ngay để ghi nhớ lâu hơn nhé! 🧠
            </div>
            <div class="due-modal-actions">
                <a href="@Url.Action("Study", "Vocabulary", new { setId = Model.SetId, mode = "review" })" class="due-modal-btn-primary">
                    <i class="fas fa-play"></i> Ôn tập ngay
                </a>
                <button class="due-modal-btn-secondary" onclick="document.getElementById('dueModal').remove()">
                    Để sau
                </button>
            </div>
        </div>
    </div>
}

<div class="set-detail-modern">
    <!-- Breadcrumb -->
    <nav class="breadcrumb-nav">
        <a href="@Url.Action("Index", "Vocabulary")">
            <i class="fas fa-home"></i> Trang chủ
        </a>
        <i class="fas fa-chevron-right separator"></i>
        <a href="@Url.Action("FolderDetail", "Vocabulary", new { folderId = Model.Folder?.FolderId })">@(Model.Folder?.FolderName ?? "Từ vựng")</a>
        <i class="fas fa-chevron-right separator"></i>
        <span>@Model.SetName</span>
    </nav>

    <!-- Hero Section -->
    <div class="set-hero">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="set-badge">
                <i class="fas fa-layer-group"></i>
                <span>@totalCards từ vựng</span>
            </div>
            <h1 class="set-title">@Model.SetName</h1>
            <div class="set-tags">
                @foreach (var tag in tags)
                {
                    <span class="tag">@tag</span>
                }
            </div>

            <!-- Study Stats -->
            <div class="study-stats">
                <div class="stat-group">
                    <div class="stat-item">
                        <span class="stat-value">@learnedCards</span>
                        <span class="stat-label">Đã học</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-value">@remainingCards</span>
                        <span class="stat-label">Còn lại</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-value">@accuracy%</span>
                        <span class="stat-label">Độ chính xác</span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="hero-actions">
                <a href="@Url.Action("Study", "Vocabulary", new { setId = Model.SetId })" class="btn-study">
                    <i class="fas fa-play"></i>
                    <span>@(learnedCards > 0 ? "Tiếp tục học" : "Bắt đầu học")</span>
                </a>
                @if (dueToday > 0)
                {
                    <a href="@Url.Action("Study", "Vocabulary", new { setId = Model.SetId, mode = "review" })" class="btn-study" style="background: linear-gradient(135deg, #EF4444 0%, #F59E0B 100%);">
                        <i class="fas fa-clock"></i>
                        <span>Ôn tập @dueToday từ đến hạn</span>
                    </a>
                }
                <button class="btn-bookmark">
                    <i class="far fa-bookmark"></i>
                </button>
                <button class="btn-share">
                    <i class="fas fa-share-alt"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Quick Stats Cards -->
    <div class="quick-stats">
        <div class="stat-card new">
            <div class="stat-icon">
                <i class="fas fa-star"></i>
            </div>
            <div class="stat-detail">
                <span class="stat-number">@newCards</span>
                <span class="stat-label">Từ mới</span>
            </div>
        </div>
        <div class="stat-card reviewing">
            <div class="stat-icon">
                <i class="fas fa-sync-alt"></i>
            </div>
            <div class="stat-detail">
                <span class="stat-number">@reviewingCards</span>
                <span class="stat-label">Đang ôn</span>
            </div>
        </div>
        <div class="stat-card mastered">
            <div class="stat-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-detail">
                <span class="stat-number">@masteredCards</span>
                <span class="stat-label">Thành thạo</span>
            </div>
        </div>
        <div class="stat-card due">
            <div class="stat-icon">
                <i class="fas fa-clock"></i>
            </div>
            <div class="stat-detail">
                <span class="stat-number">@dueToday</span>
                <span class="stat-label">Đến hạn</span>
            </div>
        </div>
    </div>

    <!-- Study Progress Section -->
    <div class="study-progress-section">
        <div class="section-header">
            <h2>Tiến độ học tập</h2>
            <div class="progress-summary">
                <span class="completed">@learnedCards hoàn thành</span>
                <span class="total">/ @totalCards từ</span>
            </div>
        </div>

        <div class="progress-visual">
            <div class="progress-circle" data-progress="@accuracy">
                <div class="progress-circle-inner">
                    <span class="percentage">@accuracy%</span>
                    <span class="label">Hoàn thành</span>
                </div>
            </div>
            <div class="progress-bars">
                <div class="progress-bar-item">
                    <div class="bar-label">
                        <span><i class="fas fa-circle" style="color: #4facfe"></i> Mới</span>
                        <span>@newCards từ</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width: @((newCards * 100) / (totalCards > 0 ? totalCards : 1))%"></div>
                    </div>
                </div>
                <div class="progress-bar-item">
                    <div class="bar-label">
                        <span><i class="fas fa-circle" style="color: #fbbf24"></i> Đang học</span>
                        <span>@reviewingCards từ</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width: @((reviewingCards * 100) / (totalCards > 0 ? totalCards : 1))%; background: #fbbf24"></div>
                    </div>
                </div>
                <div class="progress-bar-item">
                    <div class="bar-label">
                        <span><i class="fas fa-circle" style="color: #43e97b"></i> Thành thạo</span>
                        <span>@masteredCards từ</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width: @((masteredCards * 100) / (totalCards > 0 ? totalCards : 1))%; background: #43e97b"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Topics Preview Section -->
    @if (topics.Any())
    {
        <div class="topics-preview-section">
            <div class="section-header">
                <h2>
                    <i class="fas fa-tags"></i>
                    Danh sách chủ đề
                </h2>
                <a href="@Url.Action("Topics", "Vocabulary", new { setId = Model.SetId })" class="view-all-link">
                    <span>Xem tất cả @topicsCount chủ đề</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <div class="topics-grid">
                @foreach (var topic in topics.Take(4))
                {
                    <a href="@Url.Action("TopicDetail", "Vocabulary", new { setId = Model.SetId, topic = topic.TopicName })"
                       class="topic-preview-card">
                        <div class="topic-preview-header">
                            <div class="topic-icon">
                                <i class="fas fa-folder"></i>
                            </div>
                            <span class="topic-preview-name">@topic.TopicName</span>
                        </div>

                        <div class="topic-preview-stats">
                            <span class="topic-count">
                                <strong>@topic.LearnedCards</strong>/@topic.TotalCards
                            </span>
                            <span class="topic-percent">@topic.Progress%</span>
                        </div>

                        <div class="progress-bar-mini">
                            <div class="progress-fill-mini" style="width: @topic.Progress%"></div>
                        </div>
                    </a>
                }
            </div>

            @if (topics.Count > 4)
            {
                <div class="view-all-container">
                    <a href="@Url.Action("Topics", "Vocabulary", new { setId = Model.SetId })" class="btn-view-all">
                        <span>Xem tất cả @topicsCount chủ đề</span>
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            }
        </div>
    }

    <!-- Related Sets -->
    @if (Model.Folder?.Sets != null && Model.Folder.Sets.Count > 1)
    {
        <div class="related-section">
            <h2>Bộ từ cùng danh mục</h2>
            <div class="related-grid">
                @foreach (var relatedSet in Model.Folder.Sets.Where(s => s.SetId != Model.SetId).Take(3))
                {
                    var relatedTags = (relatedSet.Description ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries)
                    .Where(t => t.StartsWith("#")).ToList();

                    <div class="related-card">
                        <div class="related-header">
                            <span class="related-icon">📚</span>
                        </div>
                        <div class="related-body">
                            <h3>@relatedSet.SetName</h3>
                            <div class="related-meta">
                                <span><i class="fas fa-layer-group"></i> @(relatedSet.Cards?.Count ?? 0) từ</span>
                                @if (relatedTags.Any())
                                {
                                    <span class="related-tag">@relatedTags.First()</span>
                                }
                            </div>
                            <a href="@Url.Action("Detail", "Vocabulary", new { setId = relatedSet.SetId })" class="related-link">
                                Xem chi tiết <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Animate progress circle
        const circle = document.querySelector('.progress-circle');
        if (circle) {
            const progress = circle.dataset.progress;
            const radius = 15.9155;
            const circumference = 2 * Math.PI * radius;
            const offset = circumference - (progress / 100) * circumference;

            const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            svg.setAttribute('viewBox', '0 0 36 36');
            svg.classList.add('progress-svg');

            const bgCircle = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            bgCircle.setAttribute('d', 'M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831');
            bgCircle.classList.add('progress-bg');

            const fillCircle = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            fillCircle.setAttribute('d', 'M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831');
            fillCircle.classList.add('progress-fill');
            fillCircle.setAttribute('stroke-dasharray', circumference);
            fillCircle.setAttribute('stroke-dashoffset', offset);

            svg.appendChild(bgCircle);
            svg.appendChild(fillCircle);
            circle.prepend(svg);
        }
    </script>
}