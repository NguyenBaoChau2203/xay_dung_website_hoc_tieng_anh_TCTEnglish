@model TCTVocabulary.Models.Set
@{
    ViewData["Title"] = "Học từ vựng";

    var setId = Model.SetId;
    var set = Model;
    var cards = Model.Cards?.ToList() ?? new List<TCTVocabulary.Models.Card>();
    var totalCards = cards.Count;
    var currentIndex = ViewBag.CurrentIndex ?? 1;

    TCTVocabulary.Models.Card currentCard = null;
    if (cards != null && cards.Count > 0 && currentIndex <= cards.Count)
    {
        currentCard = cards[currentIndex - 1];
    }

    // Tính toán thống kê
    var learnedCount = cards.Count(c => c.LearningProgresses?.Any(lp => lp.Status == "Mastered") == true);
    var progress = totalCards > 0 ? (learnedCount * 100) / totalCards : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/vocabulary-system.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        /* Modern Study Page - Navy & White Theme */
        :root {
            --navy-dark: #0A2647;
            --navy-medium: #1B3A5C;
            --navy-light: #2C4E71;
            --navy-mist: #E8F0FE;
            --white: #FFFFFF;
            --off-white: #F8FAFC;
            --gray-light: #E2E8F0;
            --gray: #94A3B8;
            --gray-dark: #475569;
            --success: #10B981;
            --warning: #F59E0B;
            --danger: #EF4444;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, var(--off-white) 0%, var(--white) 100%);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            transition: background-color 0.3s, color 0.3s;
        }

            body.dark-mode {
                background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
                --white: #1e1e2f;
                --off-white: #2a2a3a;
                --gray-light: #3a3a4a;
                --gray: #a0a0b0;
                --gray-dark: #c0c0d0;
                --navy-dark: #88a4d0;
                --navy-mist: #2a3a5a;
            }

        .study-advanced {
            max-width: 1000px;
            margin: 0 auto;
            padding: 1.5rem;
        }

        /* Header */
        .study-header-modern {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--white);
            border-radius: 20px;
            padding: 0.75rem 1.25rem;
            border: 1px solid var(--gray-light);
            box-shadow: 0 4px 12px rgba(10, 38, 71, 0.04);
            margin-bottom: 1.5rem;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .back-btn {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--navy-mist);
            color: var(--navy-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.2s;
        }

            .back-btn:hover {
                background: var(--navy-dark);
                color: var(--white);
            }

        .set-info-compact h2 {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--navy-dark);
        }

        .set-info-compact .set-category {
            font-size: 0.75rem;
            color: var(--gray);
        }

        .header-stats-modern {
            display: flex;
            gap: 1.5rem;
        }

        .stat-item-compact {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.875rem;
            color: var(--gray-dark);
        }

            .stat-item-compact i {
                color: var(--navy-dark);
            }

        .header-right {
            display: flex;
            gap: 0.5rem;
        }

        .icon-btn {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--white);
            border: 1px solid var(--gray-light);
            color: var(--navy-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }

            .icon-btn:hover {
                background: var(--navy-mist);
                border-color: var(--navy-dark);
            }

        /* Mode Toggle - vẫn giữ để chuyển đổi */
        .mode-toggle {
            display: flex;
            background: var(--white);
            border: 1px solid var(--gray-light);
            border-radius: 40px;
            padding: 0.25rem;
        }

        .mode-btn {
            padding: 0.5rem 1.25rem;
            border-radius: 30px;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--gray);
            cursor: pointer;
            transition: all 0.2s;
            border: none;
            background: transparent;
        }

            .mode-btn.active {
                background: var(--navy-dark);
                color: var(--white);
            }

        /* Progress Timeline */
        .progress-timeline {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-bottom: 2rem;
            padding: 0 1rem;
        }

        .timeline-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--gray-light);
            cursor: pointer;
            position: relative;
            transition: all 0.2s;
        }

            .timeline-dot.completed {
                background: var(--navy-dark);
            }

            .timeline-dot.active {
                width: 16px;
                height: 16px;
                background: var(--navy-dark);
                box-shadow: 0 0 0 3px var(--navy-mist);
            }

            .timeline-dot:hover .dot-tooltip {
                opacity: 1;
                transform: translateY(-20px);
            }

        .dot-tooltip {
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            background: var(--navy-dark);
            color: white;
            font-size: 0.7rem;
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
            white-space: nowrap;
            opacity: 0;
            transition: all 0.2s;
            pointer-events: none;
        }

        /* Study Area */
        .study-area {
            background: var(--white);
            border-radius: 32px;
            border: 1px solid var(--gray-light);
            padding: 2rem;
            box-shadow: 0 8px 24px rgba(10, 38, 71, 0.04);
            margin-bottom: 1.5rem;
        }

        /* Flashcard Mode */
        .flashcard-3d {
            background: transparent;
            perspective: 1500px;
            margin-bottom: 2rem;
        }

        .flashcard-inner {
            position: relative;
            width: 100%;
            min-height: 400px;
            transition: transform 0.6s;
            transform-style: preserve-3d;
        }

        .flashcard-3d.flipped .flashcard-inner {
            transform: rotateY(180deg);
        }

        .flashcard-front, .flashcard-back {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            background: linear-gradient(145deg, var(--white), var(--off-white));
            border-radius: 28px;
            border: 1px solid var(--gray-light);
            padding: 2rem;
            display: flex;
            flex-direction: column;
            box-shadow: 0 10px 30px rgba(10, 38, 71, 0.08);
        }

        .flashcard-back {
            transform: rotateY(180deg);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .card-number {
            font-size: 0.85rem;
            color: var(--gray);
            background: var(--navy-mist);
            padding: 0.25rem 0.75rem;
            border-radius: 100px;
        }

        .card-actions {
            display: flex;
            gap: 0.5rem;
        }

        .card-action {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid var(--gray-light);
            background: var(--white);
            color: var(--navy-dark);
            cursor: pointer;
            transition: all 0.2s;
        }

            .card-action:hover {
                background: var(--navy-mist);
                border-color: var(--navy-dark);
            }

        .word-display {
            text-align: center;
            margin-bottom: 1.5rem;
        }

            .word-display h1 {
                font-size: 3rem;
                font-weight: 700;
                color: var(--navy-dark);
                margin-bottom: 0.5rem;
            }

        .word-phonetic {
            font-size: 1rem;
            color: var(--gray);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .play-sound {
            background: none;
            border: none;
            color: var(--navy-dark);
            cursor: pointer;
            font-size: 1.2rem;
        }

        .word-info {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
            margin-bottom: 2rem;
        }

        .pos-tag, .frequency-tag {
            padding: 0.25rem 0.75rem;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .pos-tag {
            background: var(--navy-mist);
            color: var(--navy-dark);
        }

        .frequency-tag {
            background: #FEF3C7;
            color: var(--warning);
        }

        .word-examples {
            background: var(--off-white);
            border-radius: 16px;
            padding: 1rem;
            margin-bottom: 1.5rem;
        }

        .example-item {
            display: flex;
            gap: 0.5rem;
            color: var(--gray-dark);
        }

            .example-item i {
                color: var(--navy-dark);
                font-size: 0.9rem;
            }

        .card-footer {
            margin-top: auto;
            text-align: center;
        }

        .flip-hint {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--gray);
            cursor: pointer;
            font-size: 0.9rem;
        }

            .flip-hint:hover {
                color: var(--navy-dark);
            }

        /* Writing Mode */
        .writing-mode {
            min-height: 400px;
            display: flex;
            flex-direction: column;
        }

        .definition-section {
            background: var(--off-white);
            border-radius: 24px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            position: relative;
        }

        .word-image {
            max-width: 100%;
            max-height: 150px;
            border-radius: 16px;
            margin-top: 1rem;
            object-fit: cover;
            border: 1px solid var(--gray-light);
        }

        .def-english, .def-vietnamese {
            margin-bottom: 1rem;
        }

            .def-english h4, .def-vietnamese h4 {
                font-size: 0.8rem;
                text-transform: uppercase;
                color: var(--gray);
                margin-bottom: 0.5rem;
            }

            .def-english p {
                font-size: 1.1rem;
                color: var(--navy-dark);
                font-weight: 500;
            }

            .def-vietnamese p {
                font-size: 1rem;
                color: var(--gray-dark);
            }

        .example-box {
            background: var(--white);
            border-left: 3px solid var(--navy-dark);
            padding: 1rem;
            border-radius: 12px;
            margin-top: 1rem;
        }

            .example-box .example-en {
                font-style: italic;
                margin-bottom: 0.25rem;
            }

            .example-box .example-vi {
                color: var(--gray);
                font-size: 0.9rem;
            }

        .input-section {
            margin-bottom: 2rem;
        }

        .input-label {
            font-size: 0.9rem;
            color: var(--gray);
            margin-bottom: 0.5rem;
        }

        .answer-input {
            width: 100%;
            padding: 1rem;
            border: 2px solid var(--gray-light);
            border-radius: 16px;
            font-size: 1.1rem;
            transition: all 0.2s;
        }

            .answer-input:focus {
                outline: none;
                border-color: var(--navy-dark);
            }

        .action-buttons-writing {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .btn-secondary {
            flex: 1;
            padding: 0.875rem;
            border-radius: 14px;
            border: 1px solid var(--navy-dark);
            background: var(--white);
            color: var(--navy-dark);
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

            .btn-secondary:hover {
                background: var(--navy-mist);
            }

        .btn-primary {
            flex: 1;
            padding: 0.875rem;
            border-radius: 14px;
            border: none;
            background: var(--navy-dark);
            color: var(--white);
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

            .btn-primary:hover {
                background: var(--navy-medium);
            }

        /* Mastery Buttons (dùng chung cho cả 2 mode) */
        .mastery-section {
            margin-top: 1.5rem;
            border-top: 1px solid var(--gray-light);
            padding-top: 1.5rem;
        }

        .mastery-title {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--navy-dark);
            font-weight: 500;
            margin-bottom: 1rem;
        }

        .mastery-buttons {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.75rem;
        }

        .mastery-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 1rem 0.5rem;
            border-radius: 16px;
            border: 1px solid var(--gray-light);
            background: var(--white);
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

            .mastery-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(10, 38, 71, 0.08);
            }

            .mastery-btn i {
                font-size: 1.5rem;
                margin-bottom: 0.5rem;
            }

        .btn-content {
            text-align: center;
        }

        .btn-label {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--navy-dark);
        }

        .btn-desc {
            font-size: 0.7rem;
            color: var(--gray);
        }

        .btn-shortcut {
            position: absolute;
            top: 0.5rem;
            right: 0.5rem;
            font-size: 0.6rem;
            background: var(--navy-mist);
            color: var(--navy-dark);
            padding: 0.15rem 0.4rem;
            border-radius: 4px;
        }

        .mastery-btn.hard i {
            color: var(--danger);
        }

        .mastery-btn.good i {
            color: var(--warning);
        }

        .mastery-btn.easy i {
            color: var(--success);
        }

        .mastery-btn.perfect i {
            color: var(--navy-dark);
        }

        /* Đáp án hiển thị khi bấm Không biết */
        .answer-reveal {
            background: var(--navy-mist);
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            text-align: center;
        }

            .answer-reveal .correct-word {
                font-size: 2rem;
                font-weight: 700;
                color: var(--navy-dark);
                margin-bottom: 0.5rem;
            }

            .answer-reveal .correct-phonetic {
                color: var(--gray);
            }

        /* Completion Screen */
        .completion-screen-advanced {
            text-align: center;
            padding: 2rem;
        }

        .completion-animation i {
            font-size: 4rem;
            color: var(--navy-dark);
            margin-bottom: 1rem;
        }

        .completion-stats-detailed {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin: 2rem 0;
        }

        .completion-stat-card {
            background: var(--off-white);
            border-radius: 16px;
            padding: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

            .completion-stat-card i {
                font-size: 1.5rem;
                color: var(--navy-dark);
            }

            .completion-stat-card .stat-value {
                font-size: 1.25rem;
                font-weight: 700;
                color: var(--navy-dark);
            }

        .completion-actions-advanced {
            display: flex;
            gap: 1rem;
            justify-content: center;
        }

        .btn-study-again, .btn-view-details {
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
        }

        .btn-study-again {
            background: var(--navy-dark);
            color: var(--white);
        }

        .btn-view-details {
            background: var(--white);
            color: var(--navy-dark);
            border: 1px solid var(--navy-dark);
        }

        /* Settings Panel nâng cấp */
        .settings-panel {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: var(--white);
            padding: 2rem;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            z-index: 1000;
            width: 90%;
            max-width: 400px;
        }

        .settings-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

            .settings-header h3 {
                font-size: 1.25rem;
                color: var(--navy-dark);
            }

            .settings-header button {
                background: none;
                border: none;
                font-size: 1.5rem;
                cursor: pointer;
                color: var(--gray);
            }

        .settings-body {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .setting-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

            .setting-group label {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                color: var(--navy-dark);
                font-weight: 500;
            }

            .setting-group input[type="range"] {
                width: 100%;
            }

            .setting-group select {
                padding: 0.5rem;
                border-radius: 8px;
                border: 1px solid var(--gray-light);
            }

        /* Responsive */
        @@media (max-width: 768px) {
            .study-header-modern {
                flex-wrap: wrap;
                gap: 1rem;
            }

            .header-stats-modern {
                order: 3;
                width: 100%;
                justify-content: center;
            }

            .mastery-buttons {
                grid-template-columns: repeat(2, 1fr);
            }

            .action-buttons-writing {
                flex-direction: column;
            }
        }

        /* Toast Notification */
        .toast-notification {
            position: fixed;
            top: 1.5rem;
            left: 50%;
            transform: translateX(-50%) translateY(-100px);
            padding: 1rem 2rem;
            border-radius: 16px;
            font-weight: 600;
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            z-index: 9999;
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            pointer-events: none;
        }

        .toast-notification.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }

        .toast-notification.success {
            background: linear-gradient(135deg, #10B981, #059669);
            color: white;
        }

        .toast-notification.error {
            background: linear-gradient(135deg, #EF4444, #DC2626);
            color: white;
        }

        .toast-notification i {
            font-size: 1.3rem;
        }

        /* Answer result inline */
        .answer-result {
            border-radius: 16px;
            padding: 1rem 1.5rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            animation: slideDown 0.3s ease;
        }

        .answer-result.correct {
            background: linear-gradient(135deg, #D1FAE5, #ECFDF5);
            border: 1px solid #6EE7B7;
            color: #065F46;
        }

        .answer-result.wrong {
            background: linear-gradient(135deg, #FEE2E2, #FEF2F2);
            border: 1px solid #FCA5A5;
            color: #991B1B;
        }

        .answer-result i {
            font-size: 1.5rem;
        }

        .answer-result .result-text {
            flex: 1;
        }

        .answer-result .result-title {
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 0.15rem;
        }

        .answer-result .result-desc {
            font-size: 0.85rem;
            opacity: 0.8;
        }

        @@keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%, 60% { transform: translateX(-6px); }
            40%, 80% { transform: translateX(6px); }
        }

        .shake {
            animation: shake 0.4s ease;
        }

        /* Session Progress Bar */
        .session-progress-bar {
            background: var(--white);
            border-radius: 16px;
            padding: 0.75rem 1.25rem;
            margin-bottom: 1rem;
            border: 1px solid var(--gray-light);
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .session-progress-bar .progress-info {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--navy-dark);
            white-space: nowrap;
            min-width: 70px;
        }

        .session-progress-bar .progress-track {
            flex: 1;
            height: 10px;
            background: var(--gray-light);
            border-radius: 100px;
            overflow: hidden;
        }

        .session-progress-bar .progress-fill {
            height: 100%;
            border-radius: 100px;
            transition: width 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background: linear-gradient(135deg, #EF4444, #F59E0B, #10B981);
            background-size: 200% 100%;
        }

        .session-progress-bar .progress-percent {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--navy-dark);
            min-width: 42px;
            text-align: right;
        }

        /* Shuffle Button */
        .shuffle-btn {
            background: none;
            border: 1.5px solid var(--gray-light);
            border-radius: 10px;
            padding: 0.5rem;
            cursor: pointer;
            color: var(--gray);
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
        }

        .shuffle-btn.active {
            color: var(--navy-dark);
            border-color: var(--navy-dark);
            background: var(--navy-mist);
        }

        .shuffle-btn:hover {
            border-color: var(--navy-dark);
            color: var(--navy-dark);
        }

        /* Keyboard hint */
        .keyboard-hint {
            text-align: center;
            padding: 0.4rem;
            font-size: 0.7rem;
            color: var(--gray);
        }

        .keyboard-hint kbd {
            background: var(--off-white);
            border: 1px solid var(--gray-light);
            border-radius: 4px;
            padding: 0.1rem 0.35rem;
            font-family: monospace;
            font-size: 0.7rem;
        }

        /* Completion Screen Upgrade */
        .completion-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(10, 38, 71, 0.85);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            animation: fadeInOverlay 0.3s ease;
        }

        @@keyframes fadeInOverlay {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .completion-card {
            background: var(--white);
            border-radius: 24px;
            padding: 2.5rem;
            max-width: 480px;
            width: 90%;
            text-align: center;
            animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        @@keyframes popIn {
            from { opacity: 0; transform: scale(0.8); }
            to { opacity: 1; transform: scale(1); }
        }

        .completion-trophy {
            font-size: 4rem;
            margin-bottom: 1rem;
            animation: bounce 1s ease infinite;
        }

        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .completion-card h2 {
            font-size: 1.75rem;
            color: var(--navy-dark);
            margin-bottom: 0.5rem;
        }

        .completion-card p {
            color: var(--gray);
            margin-bottom: 1.5rem;
        }

        .completion-stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

        .comp-stat {
            background: var(--off-white);
            border-radius: 14px;
            padding: 1rem 0.5rem;
        }

        .comp-stat .comp-stat-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--navy-dark);
            display: block;
        }

        .comp-stat .comp-stat-label {
            font-size: 0.7rem;
            color: var(--gray);
            text-transform: uppercase;
        }

        .comp-stat.correct .comp-stat-value { color: #10B981; }
        .comp-stat.wrong .comp-stat-value { color: #EF4444; }
        .comp-stat.time .comp-stat-value { color: #3B82F6; }

        .completion-buttons {
            display: flex;
            gap: 0.75rem;
            justify-content: center;
        }

        .comp-btn {
            padding: 0.75rem 1.5rem;
            border-radius: 14px;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
        }

        .comp-btn.primary {
            background: var(--navy-dark);
            color: white;
        }

        .comp-btn.primary:hover {
            background: var(--navy-medium);
            transform: translateY(-2px);
        }

        .comp-btn.secondary {
            background: var(--off-white);
            color: var(--navy-dark);
            border: 1px solid var(--gray-light);
        }

        .comp-btn.secondary:hover {
            background: var(--navy-mist);
            transform: translateY(-2px);
        }

        /* Confetti */
        .confetti {
            position: fixed;
            width: 10px;
            height: 10px;
            top: -10px;
            z-index: 10000;
            border-radius: 2px;
            pointer-events: none;
        }
    </style>
}

<div class="study-advanced">
    <!-- Header -->
    <div class="study-header-modern">
        <div class="header-left">
            <a href="@Url.Action("Detail", "Vocabulary", new { setId = setId })" class="back-btn">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div class="set-info-compact">
                <h2>@(set?.SetName ?? "3000 từ vựng Oxford")</h2>
                <span class="set-category">@(set?.Folder?.FolderName ?? "Animal")</span>
            </div>
        </div>

        <div class="header-stats-modern">
            <div class="stat-item-compact">
                <i class="fas fa-layer-group"></i>
                <span>@totalCards từ</span>
            </div>
            <div class="stat-item-compact">
                <i class="fas fa-star" style="color: #fbbf24;"></i>
                <span>@progress%</span>
            </div>
        </div>

        <div class="header-right">
            <!-- Shuffle Toggle -->
            <button class="shuffle-btn" id="shuffleBtn" onclick="toggleShuffle()" title="Trộn thẻ ngẫu nhiên">
                <i class="fas fa-random"></i>
            </button>
            <!-- Mode Toggle -->
            <div class="mode-toggle">
                <button class="mode-btn" id="modeWriting" onclick="setMode('writing')">Writing</button>
                <button class="mode-btn" id="modeFlashcard" onclick="setMode('flashcard')">Flashcard</button>
            </div>
            <button class="icon-btn" onclick="toggleSettings()">
                <i class="fas fa-cog"></i>
            </button>
        </div>
    </div>

    @if (totalCards > 0 && currentCard != null)
    {
        <!-- Session Progress Bar -->
        <div class="session-progress-bar">
            <span class="progress-info" id="progressInfo">@currentIndex / @totalCards</span>
            <div class="progress-track">
                <div class="progress-fill" id="progressFill" style="width: @((currentIndex * 100) / Math.Max(totalCards, 1))%; background-position: @(100 - (currentIndex * 100) / Math.Max(totalCards, 1))% 0;"></div>
            </div>
            <span class="progress-percent" id="progressPercent">@((currentIndex * 100) / Math.Max(totalCards, 1))%</span>
        </div>

        <!-- Progress Timeline -->
        <div class="progress-timeline">
            @for (int i = 1; i <= totalCards; i++)
            {
                <div class="timeline-dot @(i < currentIndex ? "completed" : "") @(i == currentIndex ? "active" : "")"
                     onclick="jumpToCard(@i)">
                    <span class="dot-tooltip">Thẻ @i</span>
                </div>
            }
        </div>

        <!-- Study Area -->
        <div class="study-area">
            <!-- Flashcard Mode -->
            <div id="flashcardMode" style="display: none;">
                <div class="flashcard-3d" id="flashcard3d">
                    <div class="flashcard-inner">
                        <!-- Mặt trước -->
                        <div class="flashcard-front">
                            <div class="card-header">
                                <span class="card-number">#@currentIndex</span>
                                <div class="card-actions">
                                    <button class="card-action" onclick="markAsImportant()">
                                        <i class="far fa-star"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="word-display">
                                <h1>@currentCard.Term</h1>
                                @if (!string.IsNullOrEmpty(currentCard.Phonetic))
                                {
                                    <div class="word-phonetic">
                                        <span>@currentCard.Phonetic</span>
                                        <button class="play-sound" onclick="playPronunciation('@currentCard.Term')">
                                            <i class="fas fa-volume-up"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="word-phonetic">
                                        <button class="play-sound" onclick="playPronunciation('@currentCard.Term')">
                                            <i class="fas fa-volume-up"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                            <div class="word-info">
                                <span class="pos-tag">noun</span>
                                <span class="frequency-tag">🔥 Phổ biến</span>
                            </div>
                            @if (!string.IsNullOrEmpty(currentCard.Example))
                            {
                                <div class="word-examples">
                                    <div class="example-item">
                                        <i class="fas fa-quote-left"></i>
                                        <p>@currentCard.Example</p>
                                    </div>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(currentCard.ImageUrl))
                            {
                                <img src="@currentCard.ImageUrl" alt="@currentCard.Term" class="word-image" style="max-height: 120px; margin: 0 auto;" />
                            }
                            <div class="card-footer">
                                <div class="flip-hint" onclick="flipCard3D()">
                                    <i class="fas fa-sync-alt"></i>
                                    <span>Nhấn để xem định nghĩa</span>
                                </div>
                            </div>
                        </div>
                        <!-- Mặt sau -->
                        <div class="flashcard-back">
                            <div class="card-header">
                                <span class="card-number">Định nghĩa</span>
                                <button class="card-action" onclick="flipCard3D()">
                                    <i class="fas fa-undo-alt"></i>
                                </button>
                            </div>
                            <div class="word-display">
                                <h1>@currentCard.Term</h1>
                            </div>
                            <div class="definition-main" style="margin-bottom: 1.5rem;">
                                <p style="font-size: 1.2rem; color: var(--navy-dark);">@currentCard.Definition</p>
                            </div>
                            @if (!string.IsNullOrEmpty(currentCard.Example))
                            {
                                <div class="word-examples">
                                    <div class="example-item">
                                        <i class="fas fa-quote-left"></i>
                                        <p>@currentCard.Example</p>
                                    </div>
                                    @if (!string.IsNullOrEmpty(currentCard.ExampleTranslation))
                                    {
                                        <p style="color: var(--gray); margin-top: 0.5rem;">→ @currentCard.ExampleTranslation</p>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(currentCard.ImageUrl))
                            {
                                <img src="@currentCard.ImageUrl" alt="@currentCard.Term" class="word-image" style="max-height: 120px; margin: 0 auto;" />
                            }
                        </div>
                    </div>
                </div>

                <!-- Mastery Buttons (cho flashcard, sẽ hiện sau khi lật) -->
                <div class="mastery-section" id="masterySectionFlashcard" style="display: none;">
                    <div class="mastery-title">
                        <i class="fas fa-chart-line"></i>
                        <span>Bạn nhớ từ này thế nào?</span>
                    </div>
                    @await Html.PartialAsync("_MasteryButtons")
                </div>
            </div>

            <!-- Writing Mode (hiển thị mặc định) -->
            <div id="writingMode" style="display: block;">
                <div class="writing-mode">
                    <!-- Định nghĩa và ví dụ -->
                    <div class="definition-section">
                        <div class="def-english">
                            <h4>Định nghĩa Tiếng Anh:</h4>
                            <p>The child of your uncle or aunt. A relative in the same generation.</p>
                        </div>
                        <div class="def-vietnamese">
                            <h4>Định nghĩa:</h4>
                            <p>@currentCard.Definition</p>
                        </div>
                        @if (!string.IsNullOrEmpty(currentCard.Example))
                        {
                            <div class="example-box">
                                <div class="example-en">@currentCard.Example</div>
                                @if (!string.IsNullOrEmpty(currentCard.ExampleTranslation))
                                {
                                    <div class="example-vi">@currentCard.ExampleTranslation</div>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(currentCard.ImageUrl))
                        {
                            <img src="@currentCard.ImageUrl" alt="@currentCard.Term" class="word-image" />
                        }
                    </div>

                    <!-- Input và actions -->
                    <div class="input-section">
                        <div class="input-label">Nhập từ tiếng Anh...</div>
                        <input type="text" id="answerInput" class="answer-input" placeholder="Gõ câu trả lời của bạn..." autocomplete="off">
                    </div>

                    <div class="action-buttons-writing">
                        <button class="btn-secondary" onclick="handleDontKnow()">
                            <i class="fas fa-question-circle"></i> Không Biết
                        </button>
                        <button class="btn-primary" onclick="checkAnswer()">
                            <i class="fas fa-check-circle"></i> Kiểm tra Đáp án
                        </button>
                    </div>

                    <!-- Kết quả kiểm tra đáp án -->
                    <div id="answerResultBox" style="display: none;"></div>

                    <!-- Khu vực hiển thị đáp án -->
                    <div id="answerReveal" style="display: none;" class="answer-reveal">
                        <div class="correct-word">@currentCard.Term</div>
                        @if (!string.IsNullOrEmpty(currentCard.Phonetic))
                        {
                            <div class="correct-phonetic">@currentCard.Phonetic</div>
                        }
                    </div>

                    <!-- Mastery Buttons (cho writing, hiện khi bấm Không Biết) -->
                    <div class="mastery-section" id="masterySectionWriting" style="display: none;">
                        <div class="mastery-title">
                            <i class="fas fa-chart-line"></i>
                            <span>Bạn nhớ từ này thế nào?</span>
                        </div>
                        @await Html.PartialAsync("_MasteryButtons")
                    </div>
                </div>
            </div>
        </div>

        <!-- ĐÃ XÓA nút Previous/Next -->
    }
    else
    {
        <div class="empty-state-advanced">
            <div class="empty-icon-wrapper">
                <i class="fas fa-book-open"></i>
            </div>
            <h3>Bộ từ vựng trống</h3>
            <p>Hãy thêm từ vựng đầu tiên để bắt đầu học nhé!</p>
            <div class="empty-actions">
                <a href="@Url.Action("Create", "Card", new { setId = setId })" class="btn-primary">
                    <i class="fas fa-plus"></i> Thêm từ vựng
                </a>
                <a href="@Url.Action("Detail", "Vocabulary", new { setId = setId })" class="btn-secondary">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
            </div>
        </div>
    }

    <!-- Settings Panel nâng cấp -->
    <div class="settings-panel" id="settingsPanel" style="display: none;">
        <div class="settings-header">
            <h3>Cài đặt học tập</h3>
            <button onclick="toggleSettings()">&times;</button>
        </div>
        <div class="settings-body">
            <div class="setting-group">
                <label>
                    <input type="checkbox" id="autoPlayAudio" checked> Tự động phát âm
                </label>
            </div>
            <div class="setting-group">
                <label>
                    <input type="checkbox" id="showExamples" checked> Hiển thị ví dụ
                </label>
            </div>
            <div class="setting-group">
                <label>
                    <input type="checkbox" id="darkMode"> Chế độ tối
                </label>
            </div>
            <div class="setting-group">
                <label for="speechRate">Tốc độ phát âm: <span id="rateValue">0.9</span></label>
                <input type="range" id="speechRate" min="0.5" max="2" step="0.1" value="0.9">
            </div>
            <div class="setting-group">
                <label for="fontSize">Cỡ chữ:</label>
                <select id="fontSize">
                    <option value="small">Nhỏ</option>
                    <option value="medium" selected>Vừa</option>
                    <option value="large">Lớn</option>
                </select>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // State
        let isFlipped = false;
        let currentIndex = @currentIndex;
        let totalCards = @totalCards;
        let currentMode = 'writing'; // Mặc định là writing
        let autoPlayAudio = true;
        let speechRate = 0.9;
        let answerRevealed = false;

        // Elements
        const flashcardMode = document.getElementById('flashcardMode');
        const writingMode = document.getElementById('writingMode');
        const modeWritingBtn = document.getElementById('modeWriting');
        const modeFlashcardBtn = document.getElementById('modeFlashcard');
        const masterySectionFlashcard = document.getElementById('masterySectionFlashcard');
        const masterySectionWriting = document.getElementById('masterySectionWriting');
        const answerRevealDiv = document.getElementById('answerReveal');
        const answerInput = document.getElementById('answerInput');
        const settingsPanel = document.getElementById('settingsPanel');
        const autoPlayCheckbox = document.getElementById('autoPlayAudio');
        const showExamplesCheckbox = document.getElementById('showExamples');
        const darkModeCheckbox = document.getElementById('darkMode');
        const speechRateInput = document.getElementById('speechRate');
        const rateValueSpan = document.getElementById('rateValue');
        const fontSizeSelect = document.getElementById('fontSize');

        // Khởi tạo
        document.addEventListener('DOMContentLoaded', function() {
            // Mặc định hiển thị writing
            setMode('writing');

            // Settings listeners
            autoPlayCheckbox?.addEventListener('change', function(e) {
                autoPlayAudio = e.target.checked;
            });

            speechRateInput?.addEventListener('input', function(e) {
                speechRate = parseFloat(e.target.value);
                rateValueSpan.textContent = speechRate.toFixed(1);
            });

            darkModeCheckbox?.addEventListener('change', function(e) {
                if (e.target.checked) {
                    document.body.classList.add('dark-mode');
                } else {
                    document.body.classList.remove('dark-mode');
                }
            });

            fontSizeSelect?.addEventListener('change', function(e) {
                const size = e.target.value;
                document.documentElement.style.fontSize =
                    size === 'small' ? '14px' : (size === 'medium' ? '16px' : '18px');
            });

            // Tự động phát âm nếu được bật
            if (autoPlayAudio && currentMode === 'writing') {
                setTimeout(() => {
                    playPronunciation('@(currentCard?.Term ?? "")');
                }, 500);
            }
        });

        // Chuyển đổi chế độ
        function setMode(mode) {
            currentMode = mode;
            if (mode === 'flashcard') {
                flashcardMode.style.display = 'block';
                writingMode.style.display = 'none';
                modeFlashcardBtn.classList.add('active');
                modeWritingBtn.classList.remove('active');
                // Ẩn mastery section của flashcard ban đầu
                masterySectionFlashcard.style.display = 'none';
                isFlipped = false;
                document.getElementById('flashcard3d')?.classList.remove('flipped');
            } else {
                flashcardMode.style.display = 'none';
                writingMode.style.display = 'block';
                modeWritingBtn.classList.add('active');
                modeFlashcardBtn.classList.remove('active');
                // Ẩn mastery section và answer reveal
                masterySectionWriting.style.display = 'none';
                answerRevealDiv.style.display = 'none';
                answerRevealed = false;
                if (answerInput) answerInput.value = '';
                // Tự động phát âm nếu được bật
                if (autoPlayAudio) {
                    playPronunciation('@(currentCard?.Term ?? "")');
                }
            }
        }

        // Flashcard flip
        function flipCard3D() {
            const card = document.getElementById('flashcard3d');
            if (card) {
                isFlipped = !isFlipped;
                card.classList.toggle('flipped', isFlipped);
                if (isFlipped) {
                    masterySectionFlashcard.style.display = 'block';
                } else {
                    masterySectionFlashcard.style.display = 'none';
                }
            }
        }

        // Writing: Xử lý nút "Không Biết"
        function handleDontKnow() {
            answerRevealDiv.style.display = 'block';
            masterySectionWriting.style.display = 'block';
            answerRevealed = true;
        }

        // Writing: Kiểm tra đáp án
        function checkAnswer() {
            const userAnswer = answerInput ? answerInput.value.trim().toLowerCase() : '';
            const correctAnswer = '@(currentCard?.Term ?? "")'.toLowerCase();
            const resultBox = document.getElementById('answerResultBox');

            if (!userAnswer) {
                // Rung input nếu trống
                answerInput.classList.add('shake');
                setTimeout(() => answerInput.classList.remove('shake'), 400);
                return;
            }

            if (userAnswer === correctAnswer) {
                // Hiện kết quả đúng
                resultBox.innerHTML = `
                    <div class="answer-result correct">
                        <i class="fas fa-check-circle"></i>
                        <div class="result-text">
                            <div class="result-title">🎉 Chính xác!</div>
                            <div class="result-desc">Bạn đã trả lời đúng. Hãy đánh giá mức độ nhớ bên dưới.</div>
                        </div>
                    </div>`;
                resultBox.style.display = 'block';

                // Hiện đáp án + mastery buttons để người dùng tự đánh giá
                answerRevealDiv.style.display = 'block';
                masterySectionWriting.style.display = 'block';

                // Disable input và buttons
                if (answerInput) answerInput.disabled = true;
                document.querySelectorAll('.action-buttons-writing button').forEach(b => b.disabled = true);

                // Hiện toast
                showToast('Chính xác! Tuyệt vời! 🎉', 'success');
            } else {
                // Hiện kết quả sai
                resultBox.innerHTML = `
                    <div class="answer-result wrong">
                        <i class="fas fa-times-circle"></i>
                        <div class="result-text">
                            <div class="result-title">Chưa đúng!</div>
                            <div class="result-desc">Hãy thử lại hoặc bấm "Không Biết" để xem đáp án.</div>
                        </div>
                    </div>`;
                resultBox.style.display = 'block';

                // Rung input
                answerInput.classList.add('shake');
                setTimeout(() => answerInput.classList.remove('shake'), 400);

                // Hiện toast
                showToast('Chưa đúng, thử lại nhé!', 'error');
            }
        }

        // Toast notification
        function showToast(message, type) {
            // Tạo toast element
            let toast = document.getElementById('toastNotification');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'toastNotification';
                toast.className = 'toast-notification';
                document.body.appendChild(toast);
            }

            const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
            toast.innerHTML = `<i class="fas ${icon}"></i><span>${message}</span>`;
            toast.className = `toast-notification ${type}`;

            // Show
            requestAnimationFrame(() => {
                toast.classList.add('show');
            });

            // Auto hide sau 2.5 giây
            setTimeout(() => {
                toast.classList.remove('show');
            }, 2500);
        }

        // Ghi nhận mức độ thành thạo (dùng chung)
        async function recordMastery(level) {
            console.log('Mastery level:', level);

            // Animation
            const btn = event?.currentTarget;
            if (btn) {
                btn.classList.add('pulse');
                setTimeout(() => btn.classList.remove('pulse'), 300);
            }

            // Gọi API để ghi nhận
            try {
                await fetch('/api/LearningApi/record', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        cardId: @(currentCard?.CardId ?? 0),
                        masteryLevel: level,
                        timestamp: new Date().toISOString()
                    })
                });
            } catch (err) {
                console.error('Error recording mastery:', err);
            }

            // Chuyển thẻ tiếp theo
            nextCard();
        }

        // Navigation (chỉ gọi khi hoàn thành)
        function nextCard() {
            if (currentIndex < totalCards) {
                currentIndex++;
                navigateToCard(currentIndex);
            } else if (currentIndex === totalCards) {
                showCompletionScreen();
            }
        }

        function jumpToCard(index) {
            if (index >= 1 && index <= totalCards) {
                // Cho phép nhảy đến thẻ bất kỳ (từ timeline)
                navigateToCard(index);
            }
        }

        function navigateToCard(index) {
            const setId = '@setId';
            const topic = @Html.Raw(Json.Serialize(ViewBag.TopicName ?? ""));
            const isReview = @Html.Raw(Json.Serialize((bool)(ViewBag.IsReview ?? false)));
            let url = '@Url.Action("Study", "Vocabulary")?setId=' + setId + '&index=' + index;
            if (topic) url += '&topic=' + encodeURIComponent(topic);
            if (isReview) url += '&mode=review';
            window.location.href = url;
        }

        // Pronunciation
        function playPronunciation(text) {
            if (!text || !('speechSynthesis' in window)) return;
            window.speechSynthesis.cancel();
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'en-US';
            utterance.rate = speechRate;
            window.speechSynthesis.speak(utterance);
        }

        // Settings
        function toggleSettings() {
            const panel = document.getElementById('settingsPanel');
            panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
        }

        // Mark important
        function markAsImportant() {
            const btn = event.currentTarget;
            btn.innerHTML = '<i class="fas fa-star" style="color: #fbbf24;"></i>';
            fetch('/api/LearningApi/important', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cardId: @(currentCard?.CardId ?? 0) })
            }).catch(err => console.error(err));
        }

        // ============ SESSION STATS (sessionStorage) ============
        const SESSION_KEY = 'studySession_@setId';

        function getSessionStats() {
            const raw = sessionStorage.getItem(SESSION_KEY);
            if (raw) {
                const data = JSON.parse(raw);
                // Reset nếu đã quá 2 giờ
                if (Date.now() - data.startTime > 7200000) {
                    return createNewSession();
                }
                return data;
            }
            return createNewSession();
        }

        function createNewSession() {
            const data = { startTime: Date.now(), correct: 0, wrong: 0, cardsStudied: 0 };
            sessionStorage.setItem(SESSION_KEY, JSON.stringify(data));
            return data;
        }

        function updateSessionStats(isCorrect) {
            const stats = getSessionStats();
            stats.cardsStudied++;
            if (isCorrect) stats.correct++;
            else stats.wrong++;
            sessionStorage.setItem(SESSION_KEY, JSON.stringify(stats));
        }

        // Track trong recordMastery
        const originalRecordMastery = recordMastery;
        recordMastery = async function(level) {
            // Track stats
            const isCorrect = level !== 'hard';
            updateSessionStats(isCorrect);
            // Gọi function gốc
            await originalRecordMastery(level);
        };

        // ============ COMPLETION SCREEN ============
        function showCompletionScreen() {
            const stats = getSessionStats();
            const elapsed = Math.round((Date.now() - stats.startTime) / 60000); // phút
            const totalStudied = stats.cardsStudied || totalCards;
            const accuracy = totalStudied > 0 ? Math.round((stats.correct / totalStudied) * 100) : 0;

            // Tạo confetti
            launchConfetti();

            // Tạo overlay
            const overlay = document.createElement('div');
            overlay.className = 'completion-overlay';
            overlay.innerHTML = `
                <div class="completion-card">
                    <div class="completion-trophy">🏆</div>
                    <h2>Hoàn thành xuất sắc!</h2>
                    <p>Bạn đã học hết ${totalCards} thẻ trong bộ từ vựng này</p>
                    <div class="completion-stats-grid">
                        <div class="comp-stat correct">
                            <span class="comp-stat-value">${stats.correct}</span>
                            <span class="comp-stat-label">Đúng</span>
                        </div>
                        <div class="comp-stat wrong">
                            <span class="comp-stat-value">${stats.wrong}</span>
                            <span class="comp-stat-label">Cần ôn</span>
                        </div>
                        <div class="comp-stat time">
                            <span class="comp-stat-value">${elapsed < 1 ? '<1' : elapsed}</span>
                            <span class="comp-stat-label">Phút</span>
                        </div>
                    </div>
                    <div style="margin-bottom:1.5rem;">
                        <div style="font-size:0.85rem;color:var(--gray);margin-bottom:0.5rem;">Độ chính xác</div>
                        <div style="background:var(--gray-light);border-radius:100px;height:12px;overflow:hidden;">
                            <div style="height:100%;border-radius:100px;background:linear-gradient(135deg,#10B981,#059669);width:${accuracy}%;transition:width 1s;"></div>
                        </div>
                        <div style="font-size:1.1rem;font-weight:700;color:var(--navy-dark);margin-top:0.4rem;">${accuracy}%</div>
                    </div>
                    <div class="completion-buttons">
                        <a href="@Url.Action("Study", "Vocabulary", new { setId = setId, index = 1 })" class="comp-btn primary">
                            <i class="fas fa-redo-alt"></i> Học lại
                        </a>
                        <a href="@Url.Action("Detail", "Vocabulary", new { setId = setId })" class="comp-btn secondary">
                            <i class="fas fa-chart-bar"></i> Xem chi tiết
                        </a>
                    </div>
                </div>`;
            document.body.appendChild(overlay);

            // Clear session
            sessionStorage.removeItem(SESSION_KEY);
        }

        // ============ CONFETTI ============
        function launchConfetti() {
            const colors = ['#EF4444', '#F59E0B', '#10B981', '#3B82F6', '#8B5CF6', '#EC4899'];
            for (let i = 0; i < 50; i++) {
                const confetti = document.createElement('div');
                confetti.className = 'confetti';
                confetti.style.left = Math.random() * 100 + 'vw';
                confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
                confetti.style.width = (Math.random() * 8 + 5) + 'px';
                confetti.style.height = (Math.random() * 8 + 5) + 'px';
                confetti.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
                confetti.style.transform = `rotate(${Math.random() * 360}deg)`;

                const duration = Math.random() * 2 + 2;
                const delay = Math.random() * 1;
                confetti.style.animation = `confettiFall ${duration}s ease ${delay}s forwards`;
                document.body.appendChild(confetti);

                setTimeout(() => confetti.remove(), (duration + delay) * 1000 + 100);
            }
        }

        // Confetti animation (added via JS)
        const confettiStyle = document.createElement('style');
        const direction = Math.random() > 0.5 ? '' : '-';
        confettiStyle.textContent = '@@keyframes confettiFall { 0% { top: -10px; opacity: 1; transform: translateX(0) rotate(0deg); } 100% { top: 110vh; opacity: 0; transform: translateX(' + direction + '100px) rotate(720deg); } }';
        document.head.appendChild(confettiStyle);

        // ============ SHUFFLE ============
        let isShuffled = sessionStorage.getItem('shuffleMode_@setId') === 'true';

        function toggleShuffle() {
            isShuffled = !isShuffled;
            sessionStorage.setItem('shuffleMode_@setId', isShuffled);
            const btn = document.getElementById('shuffleBtn');
            btn.classList.toggle('active', isShuffled);

            if (isShuffled) {
                showToast('🔀 Đã bật trộn ngẫu nhiên', 'success');
            } else {
                showToast('Đã tắt trộn ngẫu nhiên', 'error');
            }
        }

        // Khởi tạo shuffle state
        if (isShuffled) {
            document.getElementById('shuffleBtn')?.classList.add('active');
        }

        // Override navigateToCard nếu shuffle
        const originalNavigateToCard = navigateToCard;
        navigateToCard = function(index) {
            if (isShuffled && totalCards > 1) {
                // Chọn index ngẫu nhiên khác với current
                let randomIndex;
                do {
                    randomIndex = Math.floor(Math.random() * totalCards) + 1;
                } while (randomIndex === currentIndex && totalCards > 1);
                originalNavigateToCard(randomIndex);
            } else {
                originalNavigateToCard(index);
            }
        };

        // ============ KEYBOARD SHORTCUTS (Enhanced) ============
        document.addEventListener('keydown', function(e) {
            // Nếu đang focus input thì chỉ xử lý Enter
            const isInputFocused = document.activeElement === answerInput;

            if (currentMode === 'flashcard') {
                switch(e.key) {
                    case ' ': e.preventDefault(); flipCard3D(); break;
                    case '1': if (isFlipped) recordMastery('hard'); break;
                    case '2': if (isFlipped) recordMastery('good'); break;
                    case '3': if (isFlipped) recordMastery('easy'); break;
                    case '4': if (isFlipped) recordMastery('perfect'); break;
                }
            } else {
                // Writing mode
                if (e.key === 'Enter' && isInputFocused) {
                    e.preventDefault();
                    checkAnswer();
                    return;
                }

                // Phím tắt mastery khi đã hiện (không focus input)
                const masteryVisible = masterySectionWriting && masterySectionWriting.style.display !== 'none';
                if (masteryVisible && !isInputFocused) {
                    switch(e.key) {
                        case '1': recordMastery('hard'); break;
                        case '2': recordMastery('good'); break;
                        case '3': recordMastery('easy'); break;
                        case '4': recordMastery('perfect'); break;
                    }
                }

                // ? hoặc / → Không Biết
                if ((e.key === '?' || e.key === '/') && !isInputFocused) {
                    e.preventDefault();
                    handleDontKnow();
                }
            }
        });
    </script>
}