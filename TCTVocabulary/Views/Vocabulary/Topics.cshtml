@model TCTVocabulary.Models.Set
@using System.Linq
@using System.Collections.Generic
@{
    ViewData["Title"] = Model.SetName + " - Danh sách chủ đề";

    // Kiểm tra Model.Cards có null không
    var cards = Model.Cards ?? new List<TCTVocabulary.Models.Card>();

    // Các trạng thái đã học
    var learnedStatuses = new[] { "Mastered", "Learned" };

    // Nhóm các thẻ theo Topic
    var topics = cards
        .GroupBy(c => string.IsNullOrEmpty(c.Topic) ? "Chưa phân loại" : c.Topic)
        .Select(g =>
        {
            var learnedCount = g.Count(c => c.LearningProgresses != null
                && c.LearningProgresses.Any(lp => learnedStatuses.Contains(lp.Status)));
            var totalCount = g.Count();

            return new
            {
                TopicName = g.Key,
                Cards = g.ToList(),
                TotalCards = totalCount,
                LearnedCards = learnedCount,
                Progress = totalCount > 0 ? (learnedCount * 100) / totalCount : 0
            };
        })
        .OrderBy(t => t.TopicName)
        .ToList();

    var totalCards = cards.Count;
    var totalLearned = cards.Count(c => c.LearningProgresses != null
        && c.LearningProgresses.Any(lp => learnedStatuses.Contains(lp.Status)));
    var overallProgress = totalCards > 0 ? (totalLearned * 100) / totalCards : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/vocabulary-system.css" />
    <style>
        /* Topics page styles */
        .topics-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        /* Header */
        .topics-header {
            margin-bottom: 2rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: #64748b;
            text-decoration: none;
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
            transition: color 0.2s;
        }

            .back-link:hover {
                color: #0EA5E9;
            }

        .set-title-large {
            font-size: 2rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 0.5rem;
        }

        .set-description {
            color: #64748b;
            font-size: 1rem;
            margin-bottom: 1.5rem;
        }

        /* Progress overview */
        .progress-overview {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 4px 6px -2px rgba(0,0,0,0.05);
            border: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            gap: 2rem;
        }

        .overall-progress-circle {
            width: 100px;
            height: 100px;
            position: relative;
        }

            .overall-progress-circle svg {
                width: 100%;
                height: 100%;
                transform: rotate(-90deg);
            }

            .overall-progress-circle circle {
                fill: none;
                stroke-width: 8;
            }

        .circle-bg {
            stroke: #e2e8f0;
        }

        .circle-fill {
            stroke: #0EA5E9;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.5s;
        }

        .progress-number {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 1.5rem;
            font-weight: 700;
            color: #0EA5E9;
        }

        .overall-stats {
            flex: 1;
            display: flex;
            gap: 2rem;
        }

        .stat-block {
            display: flex;
            flex-direction: column;
        }

            .stat-block .value {
                font-size: 1.75rem;
                font-weight: 700;
                color: #0f172a;
                line-height: 1.2;
            }

            .stat-block .label {
                font-size: 0.9rem;
                color: #64748b;
            }

        /* Topics list */
        .topics-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .topic-item {
            background: white;
            border-radius: 16px;
            padding: 1.25rem;
            border: 1px solid #e2e8f0;
            transition: all 0.2s;
            cursor: pointer;
            text-decoration: none;
            display: block;
            color: inherit;
        }

            .topic-item:hover {
                border-color: #0EA5E9;
                box-shadow: 0 4px 12px rgba(14, 165, 233, 0.1);
                transform: translateY(-2px);
            }

        .topic-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .topic-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #F0F9FF 0%, #E0F2FE 100%);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0EA5E9;
            font-size: 1.5rem;
        }

        .topic-name {
            flex: 1;
            font-size: 1.2rem;
            font-weight: 600;
            color: #0f172a;
        }

        .topic-stats {
            display: flex;
            align-items: center;
            gap: 2rem;
        }

        .topic-count {
            color: #64748b;
            font-size: 0.95rem;
        }

            .topic-count strong {
                color: #0f172a;
                font-weight: 600;
            }

        .topic-progress {
            display: flex;
            align-items: center;
            gap: 1rem;
            min-width: 200px;
        }

        .progress-bar-container {
            flex: 1;
            height: 8px;
            background: #e2e8f0;
            border-radius: 100px;
            overflow: hidden;
        }

        .progress-bar-fill {
            height: 100%;
            background: #0EA5E9;
            border-radius: 100px;
            transition: width 0.3s;
        }

        .progress-percent {
            font-size: 0.9rem;
            font-weight: 600;
            color: #0EA5E9;
            min-width: 45px;
            text-align: right;
        }

        .topic-arrow {
            color: #94a3b8;
            font-size: 0.9rem;
            margin-left: 0.5rem;
        }

        /* Empty state */
        .empty-topics {
            text-align: center;
            padding: 4rem 2rem;
            background: white;
            border-radius: 24px;
            border: 1px dashed #cbd5e1;
        }

        .empty-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        .empty-topics h3 {
            font-size: 1.3rem;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 0.5rem;
        }

        .empty-topics p {
            color: #64748b;
            margin-bottom: 1.5rem;
        }

        .btn-add-topic {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #0EA5E9;
            color: white;
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
        }

            .btn-add-topic:hover {
                background: #0284C7;
                transform: translateY(-2px);
            }

        /* Responsive */
        @@media (max-width: 640px) {
            .progress-overview {
                flex-direction: column;
                text-align: center;
                gap: 1rem;
            }

            .overall-stats {
                justify-content: center;
            }

            .topic-header {
                flex-wrap: wrap;
            }

            .topic-stats {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.5rem;
                width: 100%;
            }

            .topic-progress {
                width: 100%;
            }
        }
    </style>
}

<div class="topics-container">
    <!-- Back link -->
    <a href="@Url.Action("Detail", "Vocabulary", new { setId = Model.SetId })" class="back-link">
        <i class="fas fa-arrow-left"></i>
        <span>Quay lại chi tiết bộ từ</span>
    </a>

    <!-- Header -->
    <div class="topics-header">
        <h1 class="set-title-large">@Model.SetName</h1>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="set-description">@Model.Description</div>
        }
    </div>

    <!-- Progress overview -->
    <div class="progress-overview">
        <div class="overall-progress-circle">
            <svg viewBox="0 0 100 100">
                <circle class="circle-bg" cx="50" cy="50" r="40"></circle>
                <circle class="circle-fill" cx="50" cy="50" r="40"
                        stroke-dasharray="251.2"
                        stroke-dashoffset="@(251.2 - (251.2 * overallProgress / 100))"></circle>
            </svg>
            <div class="progress-number">@overallProgress%</div>
        </div>

        <div class="overall-stats">
            <div class="stat-block">
                <span class="value">@totalCards</span>
                <span class="label">Tổng số thẻ</span>
            </div>
            <div class="stat-block">
                <span class="value">@topics.Count</span>
                <span class="label">Chủ đề</span>
            </div>
            <div class="stat-block">
                <span class="value">@totalLearned</span>
                <span class="label">Đã học</span>
            </div>
        </div>
    </div>

    <!-- Topics list -->
    @if (topics.Any())
    {
        <div class="topics-list">
            @foreach (var topic in topics)
            {
                <a href="@Url.Action("TopicDetail", "Vocabulary", new { setId = Model.SetId, topic = topic.TopicName })"
                   class="topic-item">
                    <div class="topic-header">
                        <div class="topic-icon">
                            <i class="fas fa-folder"></i>
                        </div>
                        <div class="topic-name">@topic.TopicName</div>

                        <div class="topic-stats">
                            <div class="topic-count">
                                <strong>@topic.LearnedCards</strong>/@topic.TotalCards thẻ
                            </div>

                            <div class="topic-progress">
                                <div class="progress-bar-container">
                                    <div class="progress-bar-fill" style="width: @topic.Progress%"></div>
                                </div>
                                <span class="progress-percent">
                                    @(topic.Progress > 0 ? topic.Progress + "%" : "—")
                                </span>
                            </div>

                            <i class="fas fa-chevron-right topic-arrow"></i>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="empty-topics">
            <div class="empty-icon">📚</div>
            <h3>Chưa có chủ đề nào</h3>
            <p>Bộ từ vựng này chưa được phân loại theo chủ đề.</p>
        </div>
    }
</div>