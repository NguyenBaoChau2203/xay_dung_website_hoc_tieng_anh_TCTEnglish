@model TCTVocabulary.ViewModel.SpeakingIndexViewModel
@{
    ViewData["Title"] = "Learn English with Videos — TCT";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int totalVideos = Model.VideosByLevel.Sum(kv => kv.Value.Count);
    // CEFR level display info
    var levelMeta = new Dictionary<string, (string Label, string Color, string Icon)>
    {
        ["A1"] = ("Beginner", "#10b981", "fas fa-seedling"),
        ["A2"] = ("Elementary", "#06b6d4", "fas fa-leaf"),
        ["B1"] = ("Intermediate", "#f59e0b", "fas fa-fire"),
        ["B2"] = ("Upper-Intermediate", "#ef4444", "fas fa-bolt")
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/speaking.css" asp-append-version="true" />
}

<div class="vi-page">

    @* ── PAGE HEADER ──────────────────────────────────────────── *@
    <header class="vi-header">
        <div class="vi-header-text">
            <h1 class="vi-title">Learn English with Videos</h1>
            <p class="vi-subtitle">Shadow real speakers. Build your accent and fluency.</p>
        </div>

        <div class="vi-search-box">
            <i class="fas fa-search vi-search-icon"></i>
            <input id="vi-search"
                   type="text"
                   class="vi-search-input"
                   placeholder="Search videos…"
                   autocomplete="off" />
        </div>
    </header>

    @* ── STATS ROW ────────────────────────────────────────────── *@
    <div class="vi-meta-row">
        <span class="vi-meta-chip"><i class="fas fa-film"></i> <span id="vi-video-count">@totalVideos videos</span></span>
        <span class="vi-meta-chip"><i class="fas fa-layer-group"></i> @Model.VideosByLevel.Count levels</span>
        <span class="vi-meta-chip"><i class="fas fa-tags"></i> @Model.Topics.Count topics</span>
        <span class="vi-meta-chip vi-chip-green"><i class="fas fa-infinity"></i> Free forever</span>
    </div>

    @* ── TOPIC FILTER PILLS ──────────────────────────────────── *@
    @if (Model.Topics.Any())
    {
        <section class="vi-filter-section">
            <div class="vi-filter-header">
                <i class="fas fa-filter"></i>
                <span>Filter by Topic</span>
            </div>
            <div class="vi-filter-pills">
                <button class="topic-filter-btn active" data-topic="all">
                    <i class="fas fa-globe"></i> All Topics
                </button>
                @foreach (var topic in Model.Topics)
                {
                    <button class="topic-filter-btn" data-topic="@topic">
                        @topic
                    </button>
                }
            </div>
        </section>
    }

    @* ── LEVEL SECTIONS ──────────────────────────────────────── *@
    @if (!Model.VideosByLevel.Any())
    {
        <div class="vi-empty">
            <i class="fas fa-satellite-dish"></i>
            <h3>No content yet</h3>
            <p>Videos are coming soon. Check back later!</p>
        </div>
    }
    else
    {
        foreach (var kvp in Model.VideosByLevel)
        {
            var level = kvp.Key;
            var videos = kvp.Value;
            var meta = levelMeta.ContainsKey(level) ? levelMeta[level] : (Label: "Level " + level, Color: "#6b7280", Icon: "fas fa-book");

            <section class="vi-level-section" data-level="@level">

                @* Level section header *@
                <div class="vi-level-head">
                    <div class="vi-level-info">
                        <span class="vi-level-icon" style="background: @meta.Item2;">
                            <i class="@meta.Item3"></i>
                        </span>
                        <div>
                            <h2 class="vi-level-name">
                                Level @level
                                <span class="vi-level-subtitle">— @meta.Item1</span>
                            </h2>
                        </div>
                    </div>
                    <div class="vi-level-actions">
                        <span class="vi-level-count">@videos.Count video@(videos.Count != 1 ? "s" : "")</span>
                    </div>
                </div>

                @* Video grid / slider track *@
                <div class="vi-video-track-wrapper">
                    <div class="vi-video-track" id="track-@level">
                        @foreach (var item in videos)
                        {
                            var thumb = string.IsNullOrEmpty(item.ThumbnailUrl)
                                ? $"https://img.youtube.com/vi/{item.YoutubeId}/hqdefault.jpg"
                                : item.ThumbnailUrl;

                            <div class="vi-video-col"
                                 data-title="@item.Title.ToLower()"
                                 data-topic="@item.Topic"
                                 data-level="@item.Level">
                                <a href="@Url.Action("Practice", "Speaking", new { id = item.Id })"
                                   class="video-card-link">
                                    <article class="video-card">

                                        @* ── Thumbnail ── *@
                                        <div class="vc-thumb">
                                            <img src="@thumb"
                                                 alt="@item.Title"
                                                 class="vc-img"
                                                 loading="lazy" />

                                            @* Dark overlay + play button *@
                                            <div class="vc-overlay">
                                                <div class="vc-play"><i class="fas fa-play"></i></div>
                                            </div>

                                            @* Level badge bottom-left *@
                                            <span class="vc-badge vc-badge-@level.ToLower()">@level</span>

                                            @* Duration chip bottom-right *@
                                            @if (!string.IsNullOrEmpty(item.Duration))
                                            {
                                                <span class="vc-duration">
                                                    <i class="far fa-clock"></i> @item.Duration
                                                </span>
                                            }
                                        </div>

                                        @* ── Card body ── *@
                                        <div class="vc-body">
                                            <h3 class="vc-title">@item.Title</h3>
                                            <div class="vc-meta">
                                                @if (!string.IsNullOrEmpty(item.Topic))
                                                {
                                                    <span class="vc-meta-item vc-topic-chip">
                                                        <i class="fas fa-tag"></i> @item.Topic
                                                    </span>
                                                }
                                                @if (item.SentenceCount > 0)
                                                {
                                                    <span class="vc-meta-item">
                                                        <i class="fas fa-align-left"></i>
                                                        @item.SentenceCount sentences
                                                    </span>
                                                }
                                                <span class="vc-meta-item vc-start">
                                                    <i class="fas fa-headphones"></i> Practice
                                                </span>
                                            </div>
                                        </div>

                                    </article>
                                </a>
                            </div>
                        }
                    </div>
                </div>

                @* Numbered Pagination Container *@
                <div class="numbered-pagination-container" data-level="@level"></div>

            </section>
        }
    }

</div>

@section Scripts {
    <script src="~/js/speaking.js" asp-append-version="true"></script>
}
