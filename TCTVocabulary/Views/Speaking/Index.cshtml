@model IEnumerable<TCTVocabulary.ViewModel.SpeakingVideoViewModel>
@{
    ViewData["Title"] = "Speaking";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/speaking.css" />
    <style>
        .speaking-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
        }
    </style>
}

<div class="container mt-4">
    <div class="speaking-header">
        <h1 class="fw-bold fs-2"><i class="fas fa-microphone-alt text-primary me-2"></i> Speaking Library</h1>
    </div>
    
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var video in Model)
        {
            <div class="col">
                <div class="card h-100 speaking-card">
                    <img src="@video.ThumbnailUrl" class="card-img-top" alt="@video.Title">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold text-dark">@video.Title</h5>
                        <div class="mb-3 mt-2">
                            <span class="badge bg-primary me-1">@video.Level</span>
                            <span class="badge bg-secondary"><i class="fas fa-list-ul me-1"></i> @video.SentenceCount sentences</span>
                        </div>
                        <a asp-controller="Speaking" asp-action="Practice" asp-route-id="@video.Id" class="btn btn-primary mt-auto w-100 fw-bold">Start Practice</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
