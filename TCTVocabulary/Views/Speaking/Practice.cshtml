@model TCTVocabulary.ViewModel.SpeakingPracticeViewModel
@{
    ViewData["Title"] = "Practice - " + Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/speaking.css" />
}

<div class="container-fluid mt-4 speaking-practice-container">
    <div class="row h-100">
        <!-- Left Column: Video Player -->
        <div class="col-lg-7 d-flex flex-column mb-4 mb-lg-0">
            <div class="d-flex align-items-center mb-3">
                <a asp-controller="Speaking" asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
                <h3 class="mb-0 fw-bold fs-4 text-dark text-truncate">@Model.Title</h3>
            </div>
            
            <div class="video-wrapper mb-3">
                <div id="youtube-player"></div>
            </div>
            
            <div class="video-controls text-center p-3 rounded shadow-sm d-flex justify-content-center align-items-center gap-3">
                <button id="btn-play-pause" class="btn btn-primary btn-lg rounded-circle" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-play" id="icon-play-pause"></i>
                </button>
                <button id="btn-replay" class="btn btn-outline-secondary btn-lg rounded-circle" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;" title="Replay Current Sentence">
                    <i class="fas fa-redo"></i>
                </button>
            </div>
        </div>

        <!-- Right Column: Transcript/Shadowing List -->
        <div class="col-lg-5 h-100 d-flex flex-column">
            <h4 class="mb-3 fw-bold fs-4 text-dark"><i class="fas fa-align-left text-primary me-2"></i> Transcript</h4>
            <div class="transcript-container flex-grow-1 overflow-auto pe-2">
                @for (int i = 0; i < Model.Sentences.Count; i++)
                {
                    var sentence = Model.Sentences[i];
                    <div class="sentence-item p-3 mb-2 bg-white border rounded shadow-sm" 
                         data-start="@sentence.StartTime" 
                         data-end="@sentence.EndTime">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="fw-bold text-muted me-2 mt-1">@(i + 1)</span>
                            <div class="flex-grow-1">
                                <p class="english-text mb-1 fw-bold fs-5">@sentence.Text</p>
                                <p class="vietnamese-text mb-0">@sentence.VietnameseMeaning</p>
                            </div>
                            <div class="text-nowrap ms-2 d-flex flex-column gap-2">
                                <button class="btn btn-sm btn-outline-primary btn-listen" title="Listen" data-start="@sentence.StartTime" data-end="@sentence.EndTime">
                                    <i class="fas fa-volume-up"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger btn-record" title="Record (Coming soon)">
                                    <i class="fas fa-microphone"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        var youtubeVideoId = '@Model.YoutubeId';
    </script>
    <script src="~/js/speaking.js"></script>
}
