@model TCTVocabulary.ViewModel.SpeakingPracticeViewModel
@{
    ViewData["Title"] = "Practice — " + Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/speaking.css" asp-append-version="true" />
}

@* ── TOAST NOTIFICATION ────────────────────────────────────────── *@
<div id="spk-toast" class="spk-toast" role="alert" aria-live="assertive"></div>

@* ── MAIN PRACTICE LAYOUT ──────────────────────────────────────── *@
<div class="prac-shell">

    @* ══ LEFT PANEL — Video + Controls ══ *@
    <div class="prac-left">

        @* Back link + title bar *@
        <div class="prac-topbar">
            <a asp-controller="Speaking" asp-action="Index" class="prac-back-btn" title="Back to playlists">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h1 class="prac-video-title">@Model.Title</h1>
        </div>

        @* YouTube IFrame placeholder *@
        <div class="prac-player-wrap">
            <div id="youtube-player"></div>
        </div>

        @* Progress bar *@
        <div class="prac-progress-bar">
            <div class="prac-progress-fill" id="prac-progress-fill"></div>
        </div>
        <div class="prac-progress-labels">
            <span id="prac-current-time">0:00</span>
            <span id="prac-total-time">0:00</span>
        </div>

        @* Control row *@
        <div class="prac-controls">

            @* Prev sentence *@
            <button class="prac-ctrl-btn" id="btn-prev-sentence" title="Previous sentence">
                <i class="fas fa-step-backward"></i>
            </button>

            @* Play / Pause *@
            <button class="prac-ctrl-btn prac-play-btn" id="btn-play-pause" title="Play / Pause">
                <i class="fas fa-play" id="icon-play-pause"></i>
            </button>

            @* Next sentence *@
            <button class="prac-ctrl-btn" id="btn-next-sentence" title="Next sentence">
                <i class="fas fa-step-forward"></i>
            </button>

            @* Repeat / Loop current sentence *@
            <button class="prac-ctrl-btn" id="btn-repeat" title="Repeat current sentence">
                <i class="fas fa-redo"></i>
            </button>

            @* Slow motion toggle *@
            <button class="prac-ctrl-btn prac-speed-btn" id="btn-slow" title="Slow Motion 0.75×">
                <span class="speed-label">0.75×</span>
            </button>

        </div>

        @* Sentence counter *@
        <div class="prac-counter">
            <span id="prac-sent-idx">—</span>
            <span> / @Model.Sentences.Count sentences</span>
            <span class="prac-mode-chip" id="prac-mode-chip"></span>
        </div>
    </div>

    @* ══ RIGHT PANEL — Transcript list ══ *@
    <div class="prac-right" id="prac-right">

        @* Panel header *@
        <div class="prac-transcript-header">
            <div class="prac-transcript-title">
                <i class="fas fa-scroll"></i>
                <span>Transcript</span>
                <span class="prac-sent-total-badge">@Model.Sentences.Count</span>
            </div>
            <button class="prac-toggle-vi-all" id="btn-toggle-vi-all" title="Show / hide all translations">
                <i class="fas fa-language"></i> VI
            </button>
        </div>

        @* Sentence list *@
        <div class="prac-sentence-list" id="prac-sentence-list">

            @if (!Model.Sentences.Any())
            {
                <div class="prac-no-sentences">
                    <i class="fas fa-comment-slash"></i>
                    <p>No transcript available for this video yet.</p>
                </div>
            }
            else
            {
                @for (int i = 0; i < Model.Sentences.Count; i++)
                {
                    var s = Model.Sentences[i];
                    <div class="prac-sentence"
                         data-index="@i"
                         data-start="@s.StartTime.ToString("F3", System.Globalization.CultureInfo.InvariantCulture)"
                         data-end="@s.EndTime.ToString("F3", System.Globalization.CultureInfo.InvariantCulture)"
                         data-text="@s.Text">

                        @* Sentence number bubble *@
                        <div class="prac-sent-num">@(i + 1)</div>

                        @* Text block *@
                        <div class="prac-sent-body">
                            <p class="prac-sent-en" id="sent-en-@i">@s.Text</p>
                            <p class="prac-sent-vi" id="sent-vi-@i">@s.VietnameseMeaning</p>

                            @* Accuracy bar — shown after recording *@
                            <div class="prac-accuracy-bar" id="acc-bar-@i" style="display:none">
                                <div class="prac-accuracy-fill" id="acc-fill-@i"></div>
                                <span class="prac-accuracy-pct" id="acc-pct-@i">0%</span>
                            </div>
                        </div>

                        @* Action buttons *@
                        <div class="prac-sent-actions">
                            @* Toggle Vietnamese *@
                            <button class="prac-icon-btn prac-vi-toggle"
                                    data-index="@i"
                                    title="Toggle translation">
                                <i class="fas fa-language"></i>
                            </button>

                            @* Listen — seek + play *@
                            <button class="prac-icon-btn prac-listen-btn"
                                    data-start="@s.StartTime.ToString("F3", System.Globalization.CultureInfo.InvariantCulture)"
                                    title="Listen to this sentence">
                                <i class="fas fa-volume-up"></i>
                            </button>

                            @* Record — Web Speech API *@
                            <button class="prac-icon-btn prac-mic-btn"
                                    data-index="@i"
                                    title="Record & compare">
                                <i class="fas fa-microphone"></i>
                            </button>
                        </div>

                    </div>
                }
            }
        </div>
    </div>

</div>

@section Scripts {
    @* Pass data to JS before loading the module *@
    <script>
        window.SPK_VIDEO_ID  = '@Model.YoutubeId';
        window.SPK_SENTENCES = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                Model.Sentences.Select(s => new {
                    id    = s.Id,
                    start = s.StartTime,
                    end   = s.EndTime,
                    text  = s.Text,
                    vi    = s.VietnameseMeaning
                })
            )
        );
    </script>
    <script src="~/js/speaking.js" asp-append-version="true"></script>
}
