@model TCTVocabulary.Models.ViewModels.FolderDetailViewModel

@{
    ViewData["Title"] = Model.Folder.FolderName;
}

<div class="folder-detail">

    <div class="folder-header">
        <div class="folder-header-left">
            <div class="folder-icon">
                <i class="fas fa-folder"></i>
            </div>
            <h1>@Model.Folder.FolderName</h1>
        </div>

        <button class="folder-menu-btn">
            <i class="fas fa-ellipsis-h"></i>
        </button>
    </div>
    <div class="folder-tabs">
        <button class="tab active">All</button>
        <button class="tab">Sets</button>
        <button class="tab">Flashcards</button>
    </div>

    @if (!Model.Sets.Any())
    {

        <div class="folder-empty">
            <div class="empty-illustration">
                <i class="fas fa-layer-group"></i>
            </div>

            <h3>Let’s start building your folder</h3>
            <p>Add sets or flashcards to organize your study materials.</p>

            <button class="btn-primary">
                Add study materials
            </button>
        </div>
    }
    else
    {

        <div class="set-list">

            @foreach (var set in Model.Sets)
            {
                <div class="set-item">
                    <div class="set-icon">
                        <i class="fas fa-clone"></i>
                    </div>

                    <div class="set-info">
                        <h4 class="set-name">@set.SetName</h4>
                        <span class="set-meta">
                            @(set.Cards.Any() ? $"{set.Cards.Count} cards" : "No cards yet")
                        </span>
                    </div>
                </div>
            }

        </div>
    }

</div>

<style>
    .folder-detail {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px;
    }

    /* HEADER */
    .folder-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .folder-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .folder-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: #eef2ff;
        color: #4255ff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
    }

    .folder-header h1 {
        font-size: 28px;
        font-weight: 800;
    }

    .folder-menu-btn {
        border: none;
        background: #f3f4f6;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 18px;
    }

        .folder-menu-btn:hover {
            background: #e5e7eb;
        }

    /* TABS */
    .folder-tabs {
        display: flex;
        gap: 12px;
        margin-bottom: 36px;
    }

    .tab {
        padding: 8px 16px;
        border-radius: 999px;
        border: 1px solid #e5e7eb;
        background: #fff;
        cursor: pointer;
        font-weight: 600;
    }

        .tab.active {
            background: #eef2ff;
            color: #4255ff;
            border-color: #c7d2fe;
        }

    /* EMPTY */
    .folder-empty {
        background: #f9fafb;
        border-radius: 20px;
        padding: 64px 24px;
        text-align: center;
    }

    .empty-illustration {
        font-size: 48px;
        color: #6366f1;
        margin-bottom: 20px;
    }

    .folder-empty h3 {
        font-size: 20px;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .folder-empty p {
        color: #6b7280;
        margin-bottom: 24px;
    }

    .btn-primary {
        background: #4255ff;
        color: #fff;
        border: none;
        padding: 12px 22px;
        border-radius: 999px;
        font-weight: 700;
        cursor: pointer;
    }

        .btn-primary:hover {
            background: #2f3fe0;
        }

    /* SET LIST */
    .set-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 16px;
    }

    .set-item {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 18px;
        display: flex;
        align-items: center;
        gap: 16px;
        cursor: pointer;
        transition: box-shadow 0.2s ease;
    }

        .set-item:hover {
            box-shadow: 0 6px 18px rgba(0,0,0,0.06);
        }

    .set-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: #eef2ff;
        color: #4255ff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .set-name {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .set-meta {
        font-size: 13px;
        color: #6b7280;
    }
</style>