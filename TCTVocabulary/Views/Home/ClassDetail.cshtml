        }

        .chat-input-bar button {
            background: #4255ff;
            color: white;
            border: none;
            padding: 0 16px;
            border-radius: 10px;
            cursor: pointer;
        }
    /* Members */
    .member-list {
        list-style: none;
        padding: 0;
    }

        .member-list li {
            padding: 10px;
            border-bottom: 1px solid #eee;
            display: flex;
            gap: 10px;
            align-items: center;
        }

    /* Empty */
    .empty-text {
        color: #9ca3af;
    }

    .chat-message {
        display: flex;
        margin-bottom: 8px;
    }

        .chat-message.mine {
            justify-content: flex-end;
        }

        .chat-message.other {
