<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const classId = @Model.Class.ClassId;
        const currentUserId = @int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier).Value);

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/classChatHub")
            .build();

        // 📥 Nhận message realtime
        connection.on("ReceiveMessage", function (msg) {
            const box = document.getElementById("chatMessages");
            const isMine = msg.userId === currentUserId;

            box.insertAdjacentHTML("beforeend", `
                <div class="chat-message ${isMine ? 'mine' : 'other'}">
                    <div class="chat-bubble">
                        ${!isMine ? `<div class="chat-name">${msg.fullName}</div>` : ''}
                        <div class="chat-content">${msg.content}</div>
                    </div>
                </div>
            `);

            box.scrollTop = box.scrollHeight;
        });

        // 🔌 Kết nối hub
        connection.start().then(() => {
            connection.invoke("JoinClass", classId);
        });

        // 📤 Gửi tin nhắn
        function sendMessage() {
            const input = document.getElementById("chatInput");
            if (!input.value.trim()) return;

            fetch('/Home/SendClassMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `classId=${classId}&content=${encodeURIComponent(input.value)}`
            });

            connection.invoke("SendMessage", classId, input.value);
            input.value = '';
        }
    </script>
}
