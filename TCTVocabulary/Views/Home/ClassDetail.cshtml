    }

    .chat-message.other .chat-bubble {
        background: #f1f1f1;
        color: #222;
        border-bottom-left-radius: 4px;
    }

    .chat-name {
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 4px;
    }

    /* ================= FOLDER TAB ================= */

    /* ===== FOLDER LIST ===== */
    .folder-grid {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-top: 16px;
    }

    /* Folder row */
    .class-folder-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-radius: 14px;
        background: #ffffff;
        border: 1px solid #e4e8ff;
        box-shadow: 0 4px 10px rgba(79, 108, 255, 0.05);
        transition: all 0.25s ease;
    }

        .class-folder-row:hover {
            background: #f6f8ff;
            border-color: #4f6cff;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(79, 108, 255, 0.12);
        }

    /* Left */
    .folder-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

        .folder-left i {
            font-size: 24px;
            color: #4f6cff;
        }

    .folder-name {
        font-size: 16px;
        font-weight: 600;
        color: #1f2937;
    }

    /* Right */
    .folder-right {
        font-size: 13px;
        color: #6b7280;
        white-space: nowrap;
    }
    /* ===== MODAL OVERLAY ===== */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(4px);
    }

        .modal-overlay.active {
