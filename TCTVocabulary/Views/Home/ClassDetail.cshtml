        }

    /* ===== MODAL CONTAINER ===== */
    .modal-container {
        width: 520px;
        max-height: 80vh;
        overflow-y: auto;
        background: #ffffff;
        border-radius: 18px;
        padding: 22px 26px;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.25);
        animation: modalFadeUp 0.25s ease;
    }

    /* ===== MODAL HEADER ===== */
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
    }

        .modal-header h3 {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
        }

    .close-btn {
        background: #f3f4f6;
        border: none;
        border-radius: 8px;
        font-size: 22px;
        width: 36px;
        height: 36px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .close-btn:hover {
            background: #e5e7eb;
        }

    /* ===== MODAL SECTION ===== */
    .modal-section {
        margin-bottom: 20px;
    }

        .modal-section h4 {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 12px;
            color: #374151;
        }

    /* ===== MODAL FOLDER LIST ===== */
    .modal-folder-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .modal-folder-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-radius: 12px;
        background: #f5f7ff;
        border: 1px solid transparent;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .modal-folder-item i {
            color: #4f6cff;
            font-size: 18px;
        }

        .modal-folder-item span {
            font-weight: 500;
            color: #1f2937;
        }

        .modal-folder-item:hover {
            background: #eef1ff;
            border-color: #4f6cff;
            transform: translateX(4px);
        }
    /* ===== FOLDER HEADER ===== */
    .folder-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 18px;
    }

        .folder-header h3 {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
        }

    /* Add folder button (header) */
    .btn-add-folder {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: 10px;
        background: #4f6cff;
        color: #ffffff;
        border: none;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .btn-add-folder i {
            font-size: 14px;
        }

        .btn-add-folder:hover {
            background: #3f5be0;
            transform: translateY(-1px);
        }

    /* ===== EMPTY STATE ===== */
    .empty-box {
        margin-top: 40px;
        padding: 40px 20px;
        border-radius: 16px;
        background: #f6f8ff;
        border: 2px dashed #c7d2fe;
        text-align: center;
    }

        .empty-box i {
            font-size: 42px;
            color: #4f6cff;
            margin-bottom: 12px;
        }

        .empty-box p {
            font-size: 15px;
            font-weight: 500;
            color: #4b5563;
            margin-bottom: 18px;
        }

    /* Primary button (empty state) */
    .btn-primary {
        padding: 12px 20px;
        border-radius: 12px;
        background: #4f6cff;
        color: #ffffff;
        border: none;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .btn-primary:hover {
            background: #3f5be0;
            transform: translateY(-1px);
        }
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const classId = @Model.Class.ClassId;
        const currentUserId = @int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier).Value);

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/classChatHub")
            .build();

        // 📥 Nhận message realtime
        connection.on("ReceiveMessage", function (msg) {
            const box = document.getElementById("chatMessages");
            const isMine = msg.userId === currentUserId;

            box.insertAdjacentHTML("beforeend", `
                <div class="chat-message ${isMine ? 'mine' : 'other'}">
                    <div class="chat-bubble">
                        ${!isMine ? `<div class="chat-name">${msg.fullName}</div>` : ''}
                        <div class="chat-content">${msg.content}</div>
                    </div>
                </div>
            `);

            box.scrollTop = box.scrollHeight;
        });

        // 🔌 Kết nối hub
        connection.start().then(() => {
            connection.invoke("JoinClass", classId);
        });

        // 📤 Gửi tin nhắn
        function sendMessage() {
            const input = document.getElementById("chatInput");
            if (!input.value.trim()) return;

            fetch('/Home/SendClassMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `classId=${classId}&content=${encodeURIComponent(input.value)}`
            });

            connection.invoke("SendMessage", classId, input.value);
            input.value = '';
        }
    </script>
}
