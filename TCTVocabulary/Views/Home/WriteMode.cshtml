@model TCTVocabulary.Models.ViewModels.StudyViewModel
@{
    ViewData["Title"] = "Write Mode: " + Model.Set.SetName;
}

<div class="write-mode-container">
    <!-- Header với thanh tiến độ và nút quay lại -->
    <div class="write-header">
        <a asp-action="Study" asp-route-id="@Model.Set.SetId" class="btn-back" title="Quay lại">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div class="header-content">
            <h2 class="set-name">@Model.Set.SetName</h2>
            <div class="progress-wrapper">
                <div class="progress-bar-bg">
                    <div class="progress-fill" id="progressFill" style="width: 0%;"></div>
                </div>
                <span class="progress-count" id="progressCount">0/@Model.Cards.Count</span>
            </div>
        </div>
    </div>

    <!-- Card câu hỏi (hiển thị trong lúc học) -->
    <div class="question-card" id="questionCard">
        <div class="term-wrapper" id="termWrapper">
            <span class="term" id="termDisplay">@Model.Cards[0].Term</span>
            <button class="btn-speak" id="speakTermBtn" title="Phát âm từ">
                <i class="fas fa-volume-up"></i>
            </button>
        </div>

        <!-- Khu vực nhập liệu -->
        <div class="input-area">
            <input type="text" id="answerInput" class="answer-input" placeholder="Nhập nghĩa của từ..." autofocus>
            <div class="action-buttons">
                <button class="btn-skip" id="skipBtn">Bỏ qua</button>
                <button class="btn-check" id="checkBtn">Kiểm tra</button>
            </div>
        </div>

        <!-- Khu vực phản hồi -->
        <div class="feedback-area" id="feedback"></div>
    </div>

    <!-- Bảng thống kê kết quả (ẩn ban đầu) -->
    <div class="stats-dashboard" id="statsDashboard" style="display: none;">
        <div class="stats-header">
            <h2 class="stats-title">📊 Kết quả học tập</h2>
            <p class="stats-subtitle">Bạn đã hoàn thành bài viết</p>
        </div>

        <!-- Thông tin tổng quan -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-label">Đúng</span>
                    <span class="stat-value" id="statCorrect">0</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: linear-gradient(135deg, #f093fb, #f5576c);">
                    <i class="fas fa-times-circle"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-label">Sai</span>
                    <span class="stat-value" id="statIncorrect">0</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: linear-gradient(135deg, #4facfe, #00f2fe);">
                    <i class="fas fa-forward"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-label">Bỏ qua</span>
                    <span class="stat-value" id="statSkipped">0</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: linear-gradient(135deg, #fa709a, #fee140);">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-label">Thời gian</span>
                    <span class="stat-value" id="statTime">0s</span>
                </div>
            </div>
        </div>

        <!-- Độ chính xác và chi tiết -->
        <div class="stats-details">
            <div class="chart-card">
                <h3 class="chart-title">Độ chính xác</h3>
                <div class="pie-chart" id="pieChart" style="--percentage: 0; --color: #4caf50;">
                    <div class="pie-inner">
                        <span class="pie-value" id="pieValue">0%</span>
                    </div>
                </div>
            </div>
            <div class="table-card">
                <h3 class="table-title">Chi tiết theo từ</h3>
                <div style="max-height: 200px; overflow-y: auto;">
                    <table class="stats-table" id="resultTable">
                        <thead>
                            <tr>
                                <th>Từ</th>
                                <th>Kết quả</th>
                            </tr>
                        </thead>
                        <tbody id="resultTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Hai nút hành động -->
        <div style="text-align: center; margin-top: 20px; display: flex; gap: 10px; justify-content: center;">
            <a asp-action="Study" asp-route-id="@Model.Set.SetId"
               style="display: inline-flex; align-items: center; padding: 8px 20px; background: #f1f5f9; color: #475569; border-radius: 30px; text-decoration: none; font-weight: 600; font-size: 0.85rem; transition: all 0.2s;">
                <i class="fas fa-arrow-left" style="margin-right: 6px;"></i> Quay lại
            </a>

            <button id="retryMistakesBtn"
                    style="padding: 8px 20px; background: #3b82f6; color: white; border-radius: 30px; border: none; font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 10px rgba(59, 130, 246, 0.2);">
                <i class="fas fa-redo" style="margin-right: 6px;"></i> Học lại từ sai
            </button>
        </div>
    </div>
</div>

<style>
    /* ========== Write Mode Styles ========== */
    .write-mode-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .write-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        background: white;
        padding: 15px 25px;
        border-radius: 60px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .btn-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f1f5f9;
        border-radius: 50%;
        color: #334155;
        transition: all 0.2s;
        text-decoration: none;
    }

        .btn-back:hover {
            background: #e2e8f0;
            transform: scale(1.05);
        }

    .header-content {
        flex: 1;
    }

    .set-name {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 0 0 8px 0;
        color: #0f172a;
    }

    .progress-wrapper {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .progress-bar-bg {
        flex: 1;
        height: 8px;
        background: #e2e8f0;
        border-radius: 20px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #3b82f6, #8b5cf6);
        border-radius: 20px;
        transition: width 0.3s ease;
    }

    .progress-count {
        font-size: 0.9rem;
        font-weight: 500;
        color: #64748b;
        min-width: 50px;
    }

    .question-card {
        background: white;
        padding: 40px;
        border-radius: 40px;
        box-shadow: 0 20px 35px -10px rgba(0,0,0,0.1);
        text-align: center;
        transition: transform 0.2s;
    }

    .term-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
        margin-bottom: 40px;
    }

    .term {
        font-size: 3rem;
        font-weight: 700;
        color: #0f172a;
        line-height: 1.3;
        display: inline-block;
        padding: 10px 30px;
        background: linear-gradient(145deg, #ffffff, #f8fafc);
        border-radius: 60px;
        box-shadow: 0 10px 20px -5px rgba(0,0,0,0.1);
        word-break: break-word;
    }

    .btn-speak {
        background: none;
        border: none;
        font-size: 2.5rem;
        color: #3b82f6;
        cursor: pointer;
        transition: transform 0.2s, color 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: #f1f5f9;
        color: #3b82f6;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

        .btn-speak:hover {
            transform: scale(1.1);
            background: #e2e8f0;
            color: #2563eb;
        }

        .btn-speak i {
            font-size: 1.8rem;
        }

    .input-area {
        max-width: 500px;
        margin: 0 auto;
    }

    .answer-input {
        width: 100%;
        padding: 16px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 50px;
        font-size: 1.1rem;
        outline: none;
        transition: all 0.3s;
        background: white;
    }

        .answer-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59,130,246,0.1);
        }

        .answer-input.correct {
            border-color: #22c55e;
            background: #f0fdf4;
        }

        .answer-input.incorrect {
            border-color: #ef4444;
            background: #fef2f2;
        }

    .action-buttons {
        display: flex;
        gap: 15px;
        margin-top: 20px;
        justify-content: center;
    }

    .btn-skip, .btn-check {
        padding: 12px 30px;
        border: none;
        border-radius: 40px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-skip {
        background: #f1f5f9;
        color: #475569;
    }

        .btn-skip:hover {
            background: #e2e8f0;
            transform: translateY(-2px);
        }

    .btn-check {
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        color: white;
        box-shadow: 0 10px 15px -5px rgba(59,130,246,0.3);
    }

        .btn-check:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 20px -5px rgba(59,130,246,0.4);
        }

        .btn-check:disabled, .btn-skip:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

    .feedback-area {
        margin-top: 25px;
        min-height: 60px;
    }

    .feedback {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: 40px;
        font-weight: 500;
        animation: slideIn 0.3s;
        flex-wrap: wrap;
        justify-content: center;
    }

        .feedback.correct {
            background: #dcfce7;
            color: #166534;
        }

        .feedback.incorrect {
            background: #fee2e2;
            color: #991b1b;
        }

        .feedback.warning {
            background: #fef9c3;
            color: #854d0e;
        }

        .feedback.success {
            background: #dbeafe;
            color: #1e40af;
        }

        .feedback i {
            font-size: 1.2rem;
        }

    .btn-speak-feedback {
        background: none;
        border: none;
        font-size: 1.2rem;
        color: currentColor;
        cursor: pointer;
        margin-left: 8px;
        padding: 4px 8px;
        border-radius: 20px;
        background: rgba(255,255,255,0.3);
        transition: background 0.2s;
    }

        .btn-speak-feedback:hover {
            background: rgba(255,255,255,0.5);
        }

    /* ========== Stats Dashboard Styles ========== */
    .stats-dashboard {
        background: white;
        border-radius: 40px;
        padding: 40px;
        box-shadow: 0 20px 35px -10px rgba(0,0,0,0.1);
        margin-top: 20px;
    }

    .stats-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .stats-title {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
        background: linear-gradient(135deg, #1e293b, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .stats-subtitle {
        font-size: 1rem;
        color: #64748b;
        margin-top: 5px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: #f8fafc;
        border-radius: 28px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.02);
        transition: transform 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-3px);
        }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
        box-shadow: 0 8px 12px rgba(0,0,0,0.1);
    }

    .stat-content {
        flex: 1;
    }

    .stat-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 500;
        color: #64748b;
        margin-bottom: 4px;
    }

    .stat-value {
        display: block;
        font-size: 1.8rem;
        font-weight: 700;
        color: #0f172a;
        line-height: 1.2;
    }

    .stats-details {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 25px;
    }

    .chart-card, .table-card {
        background: #f8fafc;
        border-radius: 28px;
        padding: 25px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.02);
    }

    .chart-title, .table-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #0f172a;
        margin: 0 0 20px 0;
    }

    .pie-chart {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: conic-gradient(var(--color) 0% var(--percentage), #e2e8f0 var(--percentage) 100%);
        margin: 0 auto 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-shadow: 0 10px 20px -5px rgba(0,0,0,0.2);
    }

    .pie-inner {
        width: 100px;
        height: 100px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 700;
        color: #0f172a;
        box-shadow: inset 0 2px 5px rgba(0,0,0,0.05);
    }

    .stats-table {
        width: 100%;
        border-collapse: collapse;
    }

        .stats-table th {
            text-align: left;
            padding: 10px 0;
            font-size: 0.85rem;
            font-weight: 600;
            color: #64748b;
            border-bottom: 2px solid #e2e8f0;
        }

        .stats-table td {
            padding: 10px 0;
            border-bottom: 1px solid #e2e8f0;
            color: #1e293b;
            font-weight: 500;
        }

        .stats-table tr:last-child td {
            border-bottom: none;
        }

    .result-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .result-correct {
        background: #dcfce7;
        color: #166534;
    }

    .result-incorrect {
        background: #fee2e2;
        color: #991b1b;
    }

    .result-skipped {
        background: #fff3cd;
        color: #856404;
    }

    #retryMistakesBtn:hover {
        background: #ea580c !important;
        transform: translateY(-2px);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 700px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .stats-details {
            grid-template-columns: 1fr;
        }

        .write-header {
            flex-direction: column;
            align-items: flex-start;
            border-radius: 30px;
        }
    }
</style>

@section Scripts {
    <script>
        // Dữ liệu gốc từ server
        const originalCards = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Cards.Select(c => new { term = c.Term, def = c.Definition })));

        // Biến hiện tại (sẽ thay đổi khi học lại từ sai)
        let currentCards = [...originalCards];
        let currentIndex = 0;
        let isAnswered = false;
        let timeoutId = null;

        // Thống kê phiên hiện tại
        let sessionResults = [];
        let correctCount = 0;
        let incorrectCount = 0;
        let skippedCount = 0;
        let startTime = Date.now();

        // DOM elements
        const termDisplay = document.getElementById('termDisplay');
        const answerInput = document.getElementById('answerInput');
        const feedbackDiv = document.getElementById('feedback');
        const progressFill = document.getElementById('progressFill');
        const progressCount = document.getElementById('progressCount');
        const checkBtn = document.getElementById('checkBtn');
        const skipBtn = document.getElementById('skipBtn');
        const termWrapper = document.getElementById('termWrapper');
        const questionCard = document.getElementById('questionCard');
        const statsDashboard = document.getElementById('statsDashboard');
        const speakTermBtn = document.getElementById('speakTermBtn');
        const retryMistakesBtn = document.getElementById('retryMistakesBtn');

        // Hàm phát âm (text-to-speech)
        function speak(text) {
            if (window.speechSynthesis) {
                window.speechSynthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'en-US';
                utterance.rate = 0.9;
                window.speechSynthesis.speak(utterance);
            }
        }

        // ===== ÂM THANH ĐẸP HƠN CHO ĐÚNG/SAI =====
        // Hàm phát âm thanh đúng (vui tai)
        function playCorrectSound() {
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                if (audioCtx.state === 'suspended') audioCtx.resume();
                const now = audioCtx.currentTime;

                // Hai oscillator tạo hợp âm đơn giản
                const osc1 = audioCtx.createOscillator();
                const osc2 = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();

                osc1.type = 'sine';
                osc2.type = 'sine';
                osc1.frequency.value = 523.25; // C5
                osc2.frequency.value = 659.25; // E5

                osc1.connect(gainNode);
                osc2.connect(gainNode);
                gainNode.connect(audioCtx.destination);

                // Đường bao: lên nhanh, xuống nhẹ
                gainNode.gain.setValueAtTime(0, now);
                gainNode.gain.linearRampToValueAtTime(0.2, now + 0.01);
                gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.3);

                osc1.start(now);
                osc2.start(now);
                osc1.stop(now + 0.3);
                osc2.stop(now + 0.3);
            } catch (e) { console.log("Audio not supported"); }
        }

        // Hàm phát âm thanh sai (êm dị hơn)
        function playIncorrectSound() {
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                if (audioCtx.state === 'suspended') audioCtx.resume();
                const now = audioCtx.currentTime;

                const osc = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();

                osc.type = 'triangle'; // sóng tam giác nghe mềm
                osc.frequency.value = 220; // A3

                osc.connect(gainNode);
                gainNode.connect(audioCtx.destination);

                gainNode.gain.setValueAtTime(0, now);
                gainNode.gain.linearRampToValueAtTime(0.15, now + 0.02);
                gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.5);

                osc.start(now);
                osc.stop(now + 0.5);
            } catch (e) { console.log("Audio not supported"); }
        }
        // ===== KẾT THÚC PHẦN ÂM THANH =====

        speakTermBtn.addEventListener('click', () => speak(termDisplay.innerText));

        function updateProgress() {
            const percent = (currentIndex / currentCards.length) * 100;
            progressFill.style.width = percent + '%';
            progressCount.innerText = currentIndex + '/' + currentCards.length;
        }

        function loadCurrentQuestion() {
            if (currentIndex >= currentCards.length) {
                finishStudy();
                return;
            }
            const currentCard = currentCards[currentIndex];
            termDisplay.innerText = currentCard.term;
            answerInput.value = '';
            answerInput.disabled = false;
            answerInput.classList.remove('correct', 'incorrect');
            feedbackDiv.innerHTML = '';
            checkBtn.style.display = 'inline-block';
            skipBtn.innerText = 'Bỏ qua';
            isAnswered = false;
            answerInput.focus();
            updateProgress();

            termWrapper.style.animation = 'fadeIn 0.3s';
            setTimeout(() => termWrapper.style.animation = '', 300);
        }

        function showFeedback(isCorrect, correctAnswer = '') {
            const currentCard = currentCards[currentIndex];

            if (isCorrect) {
                playCorrectSound(); // <-- phát âm thanh đúng
                feedbackDiv.innerHTML = '<div class="feedback correct"><i class="fas fa-check-circle"></i> Chính xác!</div>';
                answerInput.classList.add('correct');
                answerInput.classList.remove('incorrect');
                correctCount++;
                sessionResults[currentIndex] = { term: currentCard.term, result: 'correct' };
                timeoutId = setTimeout(() => {
                    currentIndex++;
                    loadCurrentQuestion();
                }, 1000);
            } else {
                playIncorrectSound(); // <-- phát âm thanh sai
                feedbackDiv.innerHTML = `
                    <div class="feedback incorrect">
                        <i class="fas fa-times-circle"></i> Sai rồi! Đáp án:
                        <strong>${correctAnswer}</strong>
                        <button class="btn-speak-feedback" onclick="speak('${correctAnswer.replace(/'/g, "\\'")}')">
                            <i class="fas fa-volume-up"></i>
                        </button>
                    </div>`;
                answerInput.classList.add('incorrect');
                answerInput.classList.remove('correct');
                answerInput.disabled = true;
                checkBtn.style.display = 'none';
                skipBtn.innerText = 'Tiếp tục';
                incorrectCount++;
                sessionResults[currentIndex] = { term: currentCard.term, result: 'incorrect' };
                timeoutId = setTimeout(() => {
                    currentIndex++;
                    loadCurrentQuestion();
                }, 2000);
            }
            isAnswered = true;
        }

        function checkAnswer() {
            if (isAnswered) return;

            const userAnswer = answerInput.value.trim().toLowerCase();
            const correctAnswer = currentCards[currentIndex].def.trim().toLowerCase();

            if (userAnswer === '') {
                feedbackDiv.innerHTML = '<div class="feedback warning"><i class="fas fa-exclamation-triangle"></i> Vui lòng nhập câu trả lời.</div>';
                return;
            }

            if (userAnswer === correctAnswer) {
                showFeedback(true);
            } else {
                showFeedback(false, currentCards[currentIndex].def);
            }
        }

        function skipCard() {
            if (skipBtn.innerText === 'Bỏ qua') {
                if (isAnswered) return;

                const currentCard = currentCards[currentIndex];

                skippedCount++;
                sessionResults[currentIndex] = { term: currentCard.term, result: 'skipped' };
                feedbackDiv.innerHTML = `
                    <div class="feedback warning">
                        <i class="fas fa-forward"></i> Đã bỏ qua. Đáp án:
                        <strong>${currentCard.def}</strong>
                        <button class="btn-speak-feedback" onclick="speak('${currentCard.def.replace(/'/g, "\\'")}')">
                            <i class="fas fa-volume-up"></i>
                        </button>
                    </div>`;
                answerInput.classList.add('incorrect');
                answerInput.disabled = true;
                checkBtn.style.display = 'none';
                skipBtn.innerText = 'Tiếp tục';
                isAnswered = true;
                timeoutId = setTimeout(() => {
                    currentIndex++;
                    loadCurrentQuestion();
                }, 1500);
            } else {
                // Bấm "Tiếp tục" sau khi sai/bỏ qua
                if (timeoutId) {
                    clearTimeout(timeoutId);
                    timeoutId = null;
                }
                currentIndex++;
                loadCurrentQuestion();
            }
        }

        function finishStudy() {
            questionCard.style.display = 'none';
            statsDashboard.style.display = 'block';

            // Tính toán từ sessionResults
            const totalCorrect = sessionResults.filter(r => r && r.result === 'correct').length;
            const totalIncorrect = sessionResults.filter(r => r && r.result === 'incorrect').length;
            const totalSkipped = sessionResults.filter(r => r && r.result === 'skipped').length;

            document.getElementById('statCorrect').innerText = totalCorrect;
            document.getElementById('statIncorrect').innerText = totalIncorrect;
            document.getElementById('statSkipped').innerText = totalSkipped;

            const totalTime = Math.floor((Date.now() - startTime) / 1000);
            document.getElementById('statTime').innerText = totalTime + 's';

            const totalAnswered = totalCorrect + totalIncorrect + totalSkipped;
            const accuracy = totalAnswered > 0 ? Math.round((totalCorrect / totalAnswered) * 100) : 0;
            document.getElementById('pieValue').innerText = accuracy + '%';
            document.getElementById('pieChart').style.setProperty('--percentage', accuracy);

            // Tạo bảng chi tiết từ sessionResults
            const tbody = document.getElementById('resultTableBody');
            tbody.innerHTML = '';
            sessionResults.forEach(item => {
                if (!item) return;
                const row = document.createElement('tr');
                let badgeClass = '', resultText = '';
                if (item.result === 'correct') {
                    badgeClass = 'result-correct';
                    resultText = 'Đúng';
                } else if (item.result === 'incorrect') {
                    badgeClass = 'result-incorrect';
                    resultText = 'Sai';
                } else {
                    badgeClass = 'result-skipped';
                    resultText = 'Bỏ qua';
                }
                row.innerHTML = `<td>${item.term}</td><td><span class="result-badge ${badgeClass}">${resultText}</span></td>`;
                tbody.appendChild(row);
            });

            // Kiểm tra nếu có từ sai để hiển thị nút
            const mistakeCount = totalIncorrect + totalSkipped;
            retryMistakesBtn.style.display = mistakeCount > 0 ? 'inline-block' : 'none';
        }

        function restartWithMistakes() {
            // Lọc các từ sai từ sessionResults của phiên vừa kết thúc
            const mistakeIndices = sessionResults.reduce((acc, item, index) => {
                if (item && item.result !== 'correct') acc.push(index);
                return acc;
            }, []);

            if (mistakeIndices.length === 0) return;

            // Tạo currentCards mới từ originalCards dựa trên indices
            currentCards = mistakeIndices.map(i => originalCards[i]);
            currentIndex = 0;

            // Reset thống kê phiên mới
            sessionResults = [];
            correctCount = 0;
            incorrectCount = 0;
            skippedCount = 0;
            startTime = Date.now(); // đặt lại thời gian

            // Ẩn stats, hiện questionCard
            statsDashboard.style.display = 'none';
            questionCard.style.display = 'block';

            loadCurrentQuestion();
        }

        // Sự kiện
        answerInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                checkAnswer();
            }
        });

        checkBtn.addEventListener('click', checkAnswer);
        skipBtn.addEventListener('click', skipCard);
        retryMistakesBtn.addEventListener('click', restartWithMistakes);

        // Khởi động
        loadCurrentQuestion();
    </script>
}