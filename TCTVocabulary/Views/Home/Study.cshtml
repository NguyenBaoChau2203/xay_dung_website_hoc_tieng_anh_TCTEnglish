@model TCTVocabulary.Models.ViewModels.StudyViewModel
@{
    ViewData["Title"] = "Học: " + (Model?.Set?.SetName ?? "Học phần");
}
<div class="study-wrapper">
    <!-- NAV -->
    <div class="study-nav">
        <div class="nav-left">
            <a asp-action="FolderDetail"
               asp-route-id="@(Model?.Set?.FolderId ?? 0)"
               class="btn-exit" title="Thoát">
                <i class="fas fa-times"></i>
            </a>
        </div>
        <div class="nav-center">
            <h3 class="set-title">@(Model?.Set?.SetName ?? "Học phần")</h3>
            <div class="progress-wrapper">
                <div class="study-mode-wrapper">
                    <select id="studyMode" class="study-mode-select">
                        <option value="all">📚 Học từ</option>
                        <option value="matching">🧠 Matching Mode</option>
                        <option value="write">✍ Write Mode</option>
                        <option value="quiz">🎮 Quiz Mode</option>
                    </select>
                </div>
                <div class="progress-bar-container">
                    <div class="progress-fill" id="progress-fill"></div>
                </div>
                <div class="progress-stats">
                    <span id="current-index">1</span> /
                    <strong>@(Model?.Cards?.Count ?? 0)</strong>
                </div>
            </div>
        </div>
        <div class="nav-right">
            <button id="darkToggle">🌙</button>
            <button class="tool-btn" id="fullscreenBtn" title="Toàn màn hình">
                <i class="fas fa-expand"></i>
            </button>
        </div>
    </div>

    <!-- THỐNG KÊ 3 MỤC – CLICK ĐỂ XEM DANH SÁCH TỪ -->
    <div class="dashboard-stats">
        <div class="stat-card mastered" data-state="1">
            <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
            <div class="stat-info">
                <span class="stat-value" id="statKnown">0</span>
                <span class="stat-label">Đã thuộc</span>
            </div>
            <div class="stat-progress">
                <div class="stat-progress-inner" id="pb-known"></div>
            </div>
        </div>
        <div class="stat-card learning" data-state="-1">
            <div class="stat-icon"><i class="fas fa-clock"></i></div>
            <div class="stat-info">
                <span class="stat-value" id="statLearning">0</span>
                <span class="stat-label">Chưa thuộc</span>
            </div>
            <div class="stat-progress">
                <div class="stat-progress-inner" id="pb-learning"></div>
            </div>
        </div>
        <div class="stat-card remaining" data-state="0">
            <div class="stat-icon"><i class="fas fa-layer-group"></i></div>
            <div class="stat-info">
                <span class="stat-value" id="statUnknown">0</span>
                <span class="stat-label">Chưa học</span>
            </div>
            <div class="stat-progress">
                <div class="stat-progress-inner" id="pb-unknown"></div>
            </div>
        </div>
    </div>

    <!-- MODAL HIỂN THỊ DANH SÁCH TỪ THEO TRẠNG THÁI -->
    <div id="wordsModal" class="stats-modal" style="display:none;">
        <div class="stats-content">
            <button class="modal-close-btn" onclick="closeWordsModal()">×</button>
            <h2 id="modalTitle">Danh sách từ</h2>
            <div class="stats-words" id="wordsList"></div>
            <div class="modal-actions">
                <button onclick="closeWordsModal()" class="btn-secondary-modern">Đóng</button>
            </div>
        </div>
    </div>

    <!-- FLASHCARD -->
    <div class="flashcard-container">
        <div class="flashcard" id="flashcard">
            <div class="card-face card-front">
                <div class="card-tag">THUẬT NGỮ</div>
                <button class="btn-speak"
                        onpointerdown="event.stopPropagation()"
                        onpointerup="event.stopPropagation()"
                        onclick="speakText(event, 'front')">
                    <i class="fas fa-volume-up"></i>
                </button>
                <div class="card-text" id="front-text">
                    @(Model?.Cards?.Any() == true ? Model.Cards[0].Term : "Học phần trống")
                </div>
            </div>
            <div class="card-face card-back">
                <div class="card-tag">ĐỊNH NGHĨA</div>
                <button class="btn-speak"
                        onpointerdown="event.stopPropagation()"
                        onpointerup="event.stopPropagation()"
                        onclick="speakText(event, 'back')">
                    <i class="fas fa-volume-up"></i>
                </button>
                <div class="card-text" id="back-text">
                    @(Model?.Cards?.Any() == true ? Model.Cards[0].Definition : "Chưa có dữ liệu")
                </div>
            </div>
        </div>
    </div>

    <div class="learning-actions">
        <button class="btn-status btn-not-known" onclick="markCard(false)">
            <i class="fas fa-times"></i> Chưa thuộc
        </button>
        <button class="btn-status btn-known" onclick="markCard(true)">
            <i class="fas fa-check"></i> Đã thuộc
        </button>
    </div>

    <!-- CONTROLS -->
    <div class="study-controls">
        <div class="control-group arrows-only">
            <button class="btn-arrow" id="prevBtn" title="Thẻ trước">
                <i class="fas fa-chevron-left"></i>
            </button>
            <div class="flip-wrapper">
                <button class="btn-main-action" id="flipBtn" title="Lật thẻ">
                    <i class="fas fa-sync-alt"></i>
                </button>
                <div class="space-badge">
                    <kbd>SPACE</kbd>
                </div>
            </div>
            <button class="btn-arrow" id="nextBtn" title="Thẻ sau">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </div>

    <!-- DANH SÁCH TỪ (giữ nguyên) -->
    <div class="wordlist-wrapper">
        <div class="word-list-header">
            <h3>Danh sách từ trong học phần</h3>
            <a asp-action="EditSet" asp-route-id="@Model.Set.SetId" class="btn-edit-list">
                <i class="fas fa-pen"></i> <span>Chỉnh sửa</span>
            </a>
        </div>
        <div class="wordlist">
            @if (Model?.Cards?.Any() == true)
            {
                for (int i = 0; i < Model.Cards.Count; i++)
                {
                    <div class="word-item" data-index="@i" onclick="jumpToCard(@i)">
                        <div class="word-index">@(i + 1)</div>
                        <div class="word-content horizontal">
                            <div class="word-term">@Model.Cards[i].Term</div>
                            <div class="word-divider"></div>
                            <div class="word-definition">@Model.Cards[i].Definition</div>
                        </div>
                        <button class="word-speak-btn"
                                onclick="event.stopPropagation(); speakWord('@(Model.Cards[i].Term.Replace("'", "\\'"))')"
                                title="Phát âm">
                            <i class="fas fa-volume-up"></i>
                        </button>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">Chưa có từ vựng nào</p>
            }
        </div>
    </div>
</div>

@section Styles {
<style>
