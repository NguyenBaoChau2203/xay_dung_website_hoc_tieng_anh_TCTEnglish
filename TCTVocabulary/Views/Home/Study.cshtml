                transform: translateY(-4px) scale(1.05);
            }



            .btn-arrow:disabled {
                opacity: 0.35;
                cursor: not-allowed;
                box-shadow: none;
            }



        .flip-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }



        .btn-main-action {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            border: none;
            background: linear-gradient(135deg, #4255ff, #5b6cff);
            box-shadow: 0 12px 35px rgba(66,85,255,0.4);
            color: white;
            font-size: 1.6rem;
            cursor: pointer;
