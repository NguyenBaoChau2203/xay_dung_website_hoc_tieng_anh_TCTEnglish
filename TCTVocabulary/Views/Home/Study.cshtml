@model TCTVocabulary.Models.ViewModels.StudyViewModel
@{
    ViewData["Title"] = "Học: " + (Model?.Set?.SetName ?? "Học phần");
}

<div class="study-wrapper">
    <!-- NAV -->
    <div class="study-nav">
        <div class="nav-left">
            <a asp-action="FolderDetail"
               asp-route-id="@(Model?.Set?.FolderId ?? 0)"
               class="btn-exit" title="Thoát">
                <i class="fas fa-times"></i>
            </a>
        </div>

        <div class="nav-center">
            <h3 class="set-title">@(Model?.Set?.SetName ?? "Học phần")</h3>
            <div class="progress-wrapper">
                <div class="progress-bar-container">
                    <div class="progress-fill" id="progress-fill"></div>
                </div>
                <div class="progress-stats">
                    <span id="current-index">1</span> /
                    <strong>@(Model?.Cards?.Count ?? 0)</strong>
                </div>
            </div>
        </div>

        <div class="nav-right">
            <button class="tool-btn" id="speakingModeBtn" title="Chuyển sang Luyện nói" onclick="location.href='@Url.Action("Speaking", "Home", new { id = Model?.Set?.SetId })'">
                <i class="fas fa-microphone"></i>
            </button>
            <button class="tool-btn" id="fullscreenBtn" title="Toàn màn hình">
                <i class="fas fa-expand"></i>
            </button>
        </div>
        </div>
    </div>

    <!-- FLASHCARD -->
    <div class="flashcard-container">
        <div class="flashcard" id="flashcard">
            <div class="card-face card-front">
                <div class="card-tag">THUẬT NGỮ</div>
                <button class="btn-speak"
                        onpointerdown="event.stopPropagation()"
                        onpointerup="event.stopPropagation()"
                        onclick="event.stopPropagation(); speakText(event, 'front')">
                    <i class="fas fa-volume-up"></i>
                </button>

                <div class="card-text" id="front-text">
                    @(Model?.Cards?.Any() == true ? Model.Cards[0].Term : "Học phần trống")
                </div>
            </div>

            <div class="card-face card-back">
                <div class="card-tag">ĐỊNH NGHĨA</div>
                <button class="btn-speak"
                        onpointerdown="event.stopPropagation()"
                        onpointerup="event.stopPropagation()"
                        onclick="event.stopPropagation(); speakText(event, 'back')">
                    <i class="fas fa-volume-up"></i>
                </button>

                <div class="card-text" id="back-text">
                    @(Model?.Cards?.Any() == true ? Model.Cards[0].Definition : "Chưa có dữ liệu")
                </div>
            </div>
        </div>
    </div>
    <div class="learning-actions">
        <button class="btn-status btn-not-known" onclick="markCard(false)">
            <i class="fas fa-times"></i> Chưa thuộc
        </button>
        <button class="btn-status btn-known" onclick="markCard(true)">
            <i class="fas fa-check"></i> Đã thuộc
        </button>
    </div>
    <!-- CONTROLS -->
    <div class="study-controls">
        <div class="control-group arrows-only">

            <button class="btn-arrow" id="prevBtn" title="Thẻ trước">
                <i class="fas fa-chevron-left"></i>
            </button>

            <div class="flip-wrapper">
                <button class="btn-main-action" id="flipBtn" title="Lật thẻ">
                    <i class="fas fa-sync-alt"></i>
                </button>
                <div class="space-badge">
                    <kbd>SPACE</kbd>
                </div>
            </div>

            <button class="btn-arrow" id="nextBtn" title="Thẻ sau">
                <i class="fas fa-chevron-right"></i>
            </button>

        </div>



        <div class="keyboard-guide">
            <kbd>←</kbd> Trước &nbsp;  &nbsp;
            <kbd>→</kbd> Sau &nbsp;  &nbsp;
            <kbd>Space</kbd> Lật thẻ
        </div>
    </div>
    <!-- WORD LIST -->
    <div class="wordlist-wrapper">
        <div class="word-list-header">
            <h3>Danh sách từ trong học phần</h3>

            <a asp-action="EditSet"
               asp-route-id="@(Model?.Set?.SetId ?? 0)"
               class="btn-edit-list">
                <i class="fas fa-pen"></i>
                <span>Chỉnh sửa</span>
            </a>
        </div>


        <div class="wordlist">
            @if (Model?.Cards?.Any() == true)
            {
                for (int i = 0; i < Model.Cards.Count; i++)
                {
                    <div class="word-item"
                         onclick="jumpToCard(@i)">

                        <div class="word-index">@(i + 1)</div>

                        <div class="word-content horizontal">
                            <div class="word-term">@Model.Cards[i].Term</div>
                            <div class="word-divider"></div>
                            <div class="word-definition">@Model.Cards[i].Definition</div>
                        </div>

                        <!-- NÚT PHÁT ÂM -->
                        <button class="word-speak-btn"
                                onclick="event.stopPropagation(); speakWord('@Model.Cards[i].Term')"
                                title="Phát âm">
                            <i class="fas fa-volume-up"></i>
                        </button>
                    </div>

                }
            }
            else
            {
                <p class="text-muted">Chưa có từ vựng nào</p>
            }
        </div>
        <!-- MODAL THỐNG KÊ -->
        <div class="stats-modal" id="statsModal" style="display:none" onclick="closeStats()">
            <div class="stats-content" onclick="event.stopPropagation()">

                <h2>Hoàn thành 🎉</h2>

                <!-- THỐNG KÊ -->
                <div class="stats-grid">
                    <div onclick="showWordsByState(1)" style="cursor:pointer">
                        <span class="stat-count mastered" id="statKnown">0</span>
                        <div class="stat-label">Đã thuộc</div>
                    </div>

                    <div onclick="showWordsByState(-1)" style="cursor:pointer">
                        <span class="stat-count learning" id="statLearning">0</span>
                        <div class="stat-label">Chưa thuộc</div>
                    </div>
                </div>

                <!-- DANH SÁCH TỪ -->
                <div class="stats-wordlist" id="statsWordList" style="display:none">
                    <h4 id="statsListTitle"></h4>
                    <div class="stats-words" id="statsWords"></div>
                </div>

                <!-- ACTIONS -->
                <div class="stats-actions">
                    <a href="javascript:void(0)"
                       class="link-restart refined"
                       onclick="restartStudy()">
                        <i class="fas fa-redo"></i> Học lại
                    </a>

                    <a asp-action="FolderDetail"
                       asp-route-id="@(Model?.Set?.FolderId ?? 0)"
                       class="btn-exit-link refined">
                        Quay về thư mục
                    </a>
                </div>

            </div>
        </div>



    </div>


@section Styles {
<style>
:root {
    --primary: #4255ff;
    --primary-hover: #2e3ed1;
    --bg-body: #f6f7fb;
    --text-dark: #1a1d23;
    --text-muted: #94a3b8;
    --card-shadow: 0 8px 30px rgba(0,0,0,0.08);
}

body {
    background: var(--bg-body);
    font-family: Inter, system-ui, sans-serif;
}

.study-wrapper {
    max-width: 900px;
    margin: 20px auto;
    padding: 0 15px;
    min-height: 85vh;
}

/* NAV */
.study-nav {
    display: grid;
    grid-template-columns: 50px 1fr 50px;
    align-items: center;
    margin-bottom: 25px;
}

.btn-exit {
    font-size: 24px;
    color: var(--text-muted);
    text-decoration: none;
}
.btn-exit:hover { color: var(--text-dark); }

.set-title {
    text-align: center;
    font-size: 1.25rem;
    font-weight: 700;
}

.progress-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 15px;
}

.progress-bar-container {
    width: 240px;
    height: 8px;
    background: #e2e8f0;
    border-radius: 10px;
    overflow: hidden;
}
.progress-fill {
    height: 100%;
    width: 0%;
    background: var(--primary);
    transition: width .3s;
}

/* FLASHCARD */
.flashcard-container {
    perspective: 2000px;
    display: flex;
    justify-content: center;
    align-items: center;
    flex: 1;
}

.flashcard {
    width: 100%;
    max-width: 750px;
    height: 480px;
    position: relative;
    transform-style: preserve-3d;
    transition: transform .6s cubic-bezier(.34,1.56,.64,1), opacity .25s;
    cursor: pointer;
}

.flashcard.is-flipped {
    transform: rotateX(180deg);
}

.flashcard.slide-next {
    opacity: 0;
    transform: translateX(-40px);
}

.flashcard.slide-prev {
    opacity: 0;
    transform: translateX(40px);
}

.card-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    background: white;
    border-radius: 28px;
    box-shadow: var(--card-shadow);
    padding: 50px;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
}

.card-back {
    transform: rotateX(180deg);
    border: 2px solid var(--primary);
}

.card-tag {
    position: absolute;
    top: 30px;
    left: 40px;
    font-size: .7rem;
    font-weight: 800;
    color: var(--text-muted);
    letter-spacing: 2px;
}

.card-text {
    font-size: 2.2rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.3;
}

.card-footer-hint {
    position: absolute;
    bottom: 30px;
    font-size: .8rem;
    color: var(--text-muted);
}

/* CONTROLS */
.study-controls {
    margin-top: 30px;
    text-align: center;
}

.control-group {
    display: flex;
    justify-content: center;
    gap: 40px;
}

.btn-circle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: none;
    background: white;
    box-shadow: 0 4px 12px rgba(0,0,0,.1);
    cursor: pointer;
}

.btn-circle:hover {
    background: var(--primary);
    color: white;
}

.btn-main-action {
    padding: 12px 45px;
    border-radius: 14px;
    border: none;
    background: var(--primary);
    color: white;
    font-weight: 700;
    cursor: pointer;
}

.keyboard-guide {
    margin-top: 20px;
    color: var(--text-muted);
    font-size: .85rem;
}

kbd {
    background: #e2e8f0;
    padding: 3px 8px;
    border-radius: 5px;
    font-size: .75rem;
}
            /* ===== NAV BUTTONS ===== */
            .btn-nav {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 14px 26px;
                border-radius: 16px;
                border: none;
                background: white;
                font-weight: 700;
                font-size: 0.95rem;
                color: var(--text-dark);
                box-shadow: 0 6px 18px rgba(0,0,0,0.12);
                cursor: pointer;
                transition: all .25s ease;
            }

