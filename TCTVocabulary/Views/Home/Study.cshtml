        top: 12px;
        right: 20px;
        background: none;
        border: none;
        font-size: 2.2rem;
        color: #94a3b8;
        cursor: pointer;
        line-height: 1;
    }
    .modal-close-btn:hover { color: #334155; }
    #modalTitle {
        margin: 0 0 20px;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--text-dark);
    }
    .stats-words {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin: 16px 0 24px;
    }
    .word-stat-item {
        background: #f8fafc;
        border-radius: 12px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 16px;
        cursor: pointer;
        transition: all 0.2s;
    }
    .word-stat-item:hover {
        background: #f1f5f9;
        transform: translateY(-2px);
    }
    .word-stat-index {
        min-width: 32px;
        height: 32px;
        background: var(--primary);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
    }
    .word-stat-content {
        flex: 1;
    }
    .word-stat-term {
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 4px;
    }
    .word-stat-def {
        color: var(--text-muted);
        font-size: 0.95rem;
    }

        :root {
            --primary: #4255ff;
            --primary-hover: #2e3ed1;
            --bg-body: #f6f7fb;
            --text-dark: #1a1d23;
            --text-muted: #94a3b8;
            --card-shadow: 0 8px 30px rgba(0,0,0,0.08);
        }



        body {
            background: var(--bg-body);
            font-family: Inter, system-ui, sans-serif;
        }



        .study-wrapper {
            max-width: 900px;
            margin: 20px auto;
            padding: 0 15px;
            min-height: 85vh;
        }



        /* NAV (giữ nguyên) */

        .study-nav {
            display: grid;
            grid-template-columns: 50px 1fr 50px;
            align-items: center;
            margin-bottom: 25px;
        }



        .btn-exit {
            font-size: 24px;
            color: var(--text-muted);
            text-decoration: none;
        }

            .btn-exit:hover {
                color: var(--text-dark);
            }



        .set-title {
            text-align: center;
            font-size: 1.25rem;
            font-weight: 700;
        }



        .progress-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
        }



        .progress-bar-container {
            width: 240px;
            height: 8px;
            background: #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            width: 0%;
            background: var(--primary);
            transition: width .3s;
        }



        /* QUICK STATS */

        .quick-stats {
            display: flex;
            justify-content: space-around;
            background: white;
            border-radius: 60px;
            padding: 15px 20px;
            margin-bottom: 25px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .stat-box {
            text-align: center;
            cursor: pointer;
            padding: 5px 15px;
            border-radius: 40px;
            transition: background 0.2s;
        }

            .stat-box:hover {
                background: #f1f5f9;
            }

        .stat-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-muted);
        }

        .stat-number {
            display: block;
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text-dark);
            line-height: 1.2;
        }



        /* FLASHCARD (giữ nguyên) */

        .flashcard-container {
            perspective: 2000px;
            display: flex;
            justify-content: center;
            align-items: center;
            flex: 1;
        }



        .flashcard {
            width: 100%;
            max-width: 750px;
            height: 480px;
            position: relative;
            transform-style: preserve-3d;
            transition: transform .6s cubic-bezier(.34,1.56,.64,1), opacity .25s;
            cursor: pointer;
            touch-action: pan-y;
            user-select: none;
        }



            .flashcard.is-flipped {
                transform: rotateX(180deg);
            }



            .flashcard.slide-next {
                opacity: 0;
                transform: translateX(-40px);
            }



            .flashcard.slide-prev {
                opacity: 0;
                transform: translateX(40px);
            }



        .card-face {
            position: absolute;
            inset: 0;
            backface-visibility: hidden;
            background: white;
            border-radius: 28px;
            box-shadow: var(--card-shadow);
            padding: 50px;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }



        .card-back {
            transform: rotateX(180deg);
            border: 2px solid var(--primary);
        }



        .card-tag {
            position: absolute;
            top: 30px;
            left: 40px;
            font-size: .7rem;
            font-weight: 800;
            color: var(--text-muted);
            letter-spacing: 2px;
        }



        .card-text {
            font-size: 2.2rem;
            font-weight: 600;
            text-align: center;
            line-height: 1.3;
        }



        .btn-speak {
            position: absolute;
            top: 30px;
            right: 40px;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: 1px solid #e2e8f0;
            background: white;
            color: var(--primary);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
            z-index: 10;
        }



            .btn-speak:hover {
                background: var(--primary);
                color: white;
                transform: scale(1.1);
            }



            .btn-speak i {
                font-size: 1.2rem;
            }



        /* LEARNING ACTIONS */

        .learning-actions {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 25px;
        }



        .btn-status {
