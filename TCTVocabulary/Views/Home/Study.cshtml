            }



        /* WORD LIST (giữ nguyên) */

        .wordlist-wrapper {
            margin-top: 60px;
        }



        .word-list-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 40px 0 18px;
        }



