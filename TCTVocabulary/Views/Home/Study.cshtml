                    transform: translateY(-4px) scale(1.05);
                }

                .btn-arrow:disabled {
                    opacity: 0.35;
                    cursor: not-allowed;
                    box-shadow: none;
                }

            /* ===== MAIN FLIP BUTTON (CENTER) ===== */
            .btn-main-action {
                width: 120px;
                height: 120px;
                border-radius: 50%;
                padding: 0;
                background: linear-gradient(135deg, #4255ff, #5b6cff);
                box-shadow: 0 14px 40px rgba(66,85,255,0.45);
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
            }

                .btn-main-action i {
                    font-size: 1.6rem;
                }

                .btn-main-action small {
                    font-size: .65rem;
                    opacity: .85;
                    margin-top: 4px;
                }
/* ===== FLIP WRAPPER ===== */
