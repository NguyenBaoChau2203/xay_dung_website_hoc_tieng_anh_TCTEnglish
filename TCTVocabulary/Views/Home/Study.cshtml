    .stats-modal {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(6px);
    }
    .stats-content {
        background: white;
        padding: 28px 32px;
        border-radius: 20px;
        max-width: 620px;
        width: 92%;
        max-height: 82vh;
        overflow-y: auto;
        position: relative;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    }
    .modal-close-btn {
