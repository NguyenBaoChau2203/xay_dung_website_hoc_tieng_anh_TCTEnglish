                color: white;
            }



        /* CONTROLS (giữ nguyên) */

        .study-controls {
            margin-top: 30px;
            text-align: center;
        }



        .control-group {
            display: flex;
            justify-content: center;
            gap: 40px;
        }



        .btn-arrow {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            border: none;
            background: white;
            color: var(--text-dark);
            font-size: 1.4rem;
            box-shadow: 0 8px 20px rgba(0,0,0,0.18);
            cursor: pointer;
            transition: all .25s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }



            .btn-arrow:hover:not(:disabled) {
                background: var(--primary);
