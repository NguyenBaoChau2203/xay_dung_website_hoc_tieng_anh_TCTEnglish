            }

                .word-speak-btn i {
                    font-size: 1rem;
                }

                .word-speak-btn:hover {
                    background: #4255ff;
                    color: white;
                    transform: scale(1.1);
                }
            /* ===== STATS WORD ITEM LAYOUT ===== */
            .stats-word-main {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 12px;
            }

            /* TEXT */
            .stats-word-text strong {
                display: block;
                font-weight: 700;
                color: var(--text-dark);
            }

            .stats-word-text span {
                font-size: 0.85rem;
                color: var(--text-muted);
            }

            /* SPEAK BUTTON */
            .stats-speak-btn {
                width: 34px;
                height: 34px;
                border-radius: 50%;
                border: none;
                background: #eef2ff;
                color: #4255ff;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                transition: all 0.2s ease;
                flex-shrink: 0;
            }

                .stats-speak-btn i {
                    font-size: 0.9rem;
                }

                .stats-speak-btn:hover {
                    background: #4255ff;
                    color: white;
                    transform: scale(1.1);
                }
            /* ===== SWIPE EFFECT ===== */
            .flashcard.dragging {
                transition: none !important;
            }

            .flashcard.swipe-right {
                transform: translateX(120px) rotate(6deg);
                opacity: 0;
            }

            .flashcard.swipe-left {
                transform: translateX(-120px) rotate(-6deg);
                opacity: 0;
            }
            .flashcard {
    touch-action: pan-y; /* cho phép kéo ngang */
    user-select: none;   /* tránh bị bôi đen chữ */
    cursor: grab;
}

.flashcard.dragging {
    cursor: grabbing;
}

        </style>
}

@section Scripts {
<script>
const cards = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model?.Cards?.Select(c => new {
        term = c.Term ?? "",
        def = c.Definition ?? ""
    }) ?? Enumerable.Empty<object>()
));

let currentIndex = 0;

const card = document.getElementById('flashcard');
const frontText = document.getElementById('front-text');
const backText = document.getElementById('back-text');
const progressFill = document.getElementById('progress-fill');
const currIdx = document.getElementById('current-index');
const prevBtn = document.getElementById('prevBtn');
const nextBtn = document.getElementById('nextBtn');

function updateCard(direction = 'none') {
    if (direction !== 'none') {
        card.classList.add(direction === 'next' ? 'slide-next' : 'slide-prev');
    }

    setTimeout(() => {
        card.classList.remove('is-flipped');

        if (cards.length > 0) {
            frontText.innerText = cards[currentIndex].term;
            backText.innerText = cards[currentIndex].def;
            currIdx.innerText = currentIndex + 1;
            progressFill.style.width = ((currentIndex + 1) / cards.length * 100) + '%';
        }

        card.classList.remove('slide-next', 'slide-prev');
        prevBtn.disabled = currentIndex === 0;
        nextBtn.disabled = currentIndex === cards.length - 1;
    }, direction === 'none' ? 0 : 200);
}

// EVENTS
card.onclick = () => card.classList.toggle('is-flipped');
flipBtn.onclick = e => {
    e.stopPropagation();
    card.classList.toggle('is-flipped');
};

nextBtn.onclick = () => {
    if (currentIndex < cards.length - 1) {
        currentIndex++;
        updateCard('next');
    }
};

prevBtn.onclick = () => {
    if (currentIndex > 0) {
        currentIndex--;
        updateCard('prev');
    }
};

document.addEventListener('keydown', e => {
    if (e.code === 'Space') {
        e.preventDefault();
        card.classList.toggle('is-flipped');
    }
    if (e.code === 'ArrowRight') nextBtn.click();
    if (e.code === 'ArrowLeft') prevBtn.click();
});

// FULLSCREEN
fullscreenBtn.onclick = () => {
    document.fullscreenElement
        ? document.exitFullscreen()
        : document.documentElement.requestFullscreen();
};
            function jumpToCard(index) {
                if (index >= 0 && index < cards.length) {
                    currentIndex = index;
                    updateCard('none');

                // Scroll lên flashcard cho tiện học
                    document.querySelector('.flashcard-container')
                        .scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }
            // Âm  thanh

            function speakText(event, side) {
                // Ngăn chặn sự kiện lật thẻ khi bấm vào nút loa
                if (event) event.stopPropagation();

            const text = side === 'front'
                    ? document.getElementById('front-text').innerText
                    : document.getElementById('back-text').innerText;

            if (!text || text === "Học phần trống") return;

            // Hủy các giọng nói đang chờ (nếu có)
                window.speechSynthesis.cancel();

            const utterance = new SpeechSynthesisUtterance(text);

            // Tự động chọn ngôn ngữ:
                // Nếu là thuật ngữ (mặt trước) thường là Tiếng Anh
                if (side === 'front') {
                    utterance.lang = 'en-US';
                } else {
                    utterance.lang = 'vi-VN'; // Định nghĩa mặt sau thường là Tiếng Việt
                }

            utterance.rate = 0.9; // Tốc độ đọc vừa phải
                window.speechSynthesis.speak(utterance);
            }

        // (Tùy chọn) Thêm phím tắt chữ 'V' để phát âm
            document.addEventListener('keydown', e => {
                if (e.key.toLowerCase() === 'v') {
                    // Mặc định phát âm mặt đang hiển thị
                    const side = card.classList.contains('is-flipped') ? 'back' : 'front';
                    speakText(null, side);
                }
            });
                        function speakWord(text) {
                if (!text) return;

            // Hủy giọng đang đọc
                window.speechSynthesis.cancel();

            const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'en-US';
                utterance.rate = 0.9;

            window.speechSynthesis.speak(utterance);
            }

            // ===== CARD STATES =====
            // 0: chưa học | 1: đã thuộc | -1: chưa thuộc
            let cardStates = new Array(cards.length).fill(0);

        let knownCount = 0;
            let learningCount = 0;
            function markCard(isKnown) {
                // Nếu đã đánh dấu rồi thì không tính lại
                if (cardStates[currentIndex] !== 0) return;

            if (isKnown) {
                    cardStates[currentIndex] = 1;
                    knownCount++;
                } else {
                    cardStates[currentIndex] = -1;
                    learningCount++;
                }

            // Tự động sang thẻ tiếp
                if (currentIndex < cards.length - 1) {
                    currentIndex++;
                    updateCard('next');
                } else {
                    showStats();
                }
            }
            function showStats() {
                document.getElementById('statKnown').innerText = knownCount;
                document.getElementById('statLearning').innerText = learningCount;
                document.getElementById('statsModal').style.display = 'flex';
            }
            function restartStudy() {
                // Reset trạng thái
                currentIndex = 0;
                cardStates = new Array(cards.length).fill(0);
                knownCount = 0;
                learningCount = 0;

            // Ẩn modal
                document.getElementById('statsModal').style.display = 'none';

            // Reset progress
                progressFill.style.width = '0%';
                currIdx.innerText = 1;

            // Reset thẻ
                card.classList.remove('is-flipped');

            updateCard('none');

            // Scroll về flashcard
                document.querySelector('.flashcard-container')
                    .scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
                        function showWordsByState(state) {
    const listWrap = document.getElementById('statsWordList');
    const list = document.getElementById('statsWords');
    const title = document.getElementById('statsListTitle');

    list.innerHTML = '';
    listWrap.style.display = 'block';

    title.innerText = state === 1
        ? '📘 Từ đã thuộc'
        : '📕 Từ chưa thuộc';

    cards.forEach((card, index) => {
        if (cardStates[index] === state) {
            const item = document.createElement('div');
            item.className = 'stats-word-item';

            item.innerHTML = `
                <div class="stats-word-main">
                    <div class="stats-word-text">
                        <strong>${card.term}</strong>
                        <span>${card.def}</span>
                    </div>

                    <button class="stats-speak-btn"
                        onclick="speakWord('${card.term.replace(/'/g, "\\'")}')"
                        title="Phát âm">
                        <i class="fas fa-volume-up"></i>
                    </button>
                </div>
            `;

            list.appendChild(item);
        }
    });

    if (!list.innerHTML) {
        list.innerHTML = `<p class="text-muted">Không có từ nào</p>`;
    }
}
function speakWord(text) {
    if (!text) return;

    window.speechSynthesis.cancel();

    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    utterance.rate = 0.9;

    window.speechSynthesis.speak(utterance);
}
let pointerStartX = 0;
let pointerCurrentX = 0;
let isPointerDown = false;
const swipeThreshold = 90;

card.addEventListener('pointerdown', e => {
    pointerStartX = e.clientX;
    isPointerDown = true;
    card.setPointerCapture(e.pointerId);
    card.classList.add('dragging');
});

card.addEventListener('pointermove', e => {
    if (!isPointerDown) return;

    pointerCurrentX = e.clientX - pointerStartX;
    card.style.transform = `translateX(${pointerCurrentX}px) rotate(${pointerCurrentX / 14}deg)`;
});

card.addEventListener('pointerup', e => {
    card.releasePointerCapture(e.pointerId);
    finishSwipe();
});

card.addEventListener('pointercancel', finishSwipe);
card.addEventListener('pointerleave', finishSwipe);

function finishSwipe() {
    if (!isPointerDown) return;

    card.classList.remove('dragging');

    if (Math.abs(pointerCurrentX) > swipeThreshold) {
        if (pointerCurrentX > 0) {
            swipeKnown();
        } else {
            swipeNotKnown();
        }
    } else {
        card.style.transform = '';
    }

    pointerCurrentX = 0;
    isPointerDown = false;
}
function swipeKnown() {
    card.classList.add('swipe-right');
    setTimeout(() => {
        card.classList.remove('swipe-right');
        card.style.transform = '';
        markCard(true);
    }, 200);
}

function swipeNotKnown() {
    card.classList.add('swipe-left');
    setTimeout(() => {
        card.classList.remove('swipe-left');
        card.style.transform = '';
        markCard(false);
    }, 200);
}

            

// INIT
updateCard();
</script>
}
