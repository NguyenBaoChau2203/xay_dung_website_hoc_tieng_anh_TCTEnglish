@model TCTVocabulary.ViewModels.SecuritySettingsViewModel

@{
    ViewData["Title"] = "Cài đặt & Bảo mật";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <!-- Thông báo -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="text-center mb-4">
                <h3 class="fw-bold text-dark">Cài đặt tài khoản</h3>
                <p class="text-muted">Quản lý thông tin cá nhân và bảo mật của bạn</p>
            </div>

            <form asp-controller="Account" asp-action="ChangePassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Email Settings Card -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-bold text-dark d-flex align-items-center">
                            <i class="fas fa-envelope text-primary me-2"></i> Thông tin tài khoản
                        </h6>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-2">
                            <label asp-for="Email" class="form-label fw-medium text-dark">Địa chỉ email</label>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="form-text text-muted">
                            <i class="fas fa-info-circle me-1"></i> Email dùng để đăng nhập và khôi phục tài khoản.
                        </div>
                    </div>
                </div>

                <!-- Password Settings Card -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-bold text-dark d-flex align-items-center">
                            <i class="fas fa-shield-alt text-success me-2"></i> Bảo mật & Mật khẩu
                        </h6>
                    </div>
                    <div class="card-body p-4">
                        <div class="alert alert-light border small text-muted mb-4 d-flex align-items-center">
                            <i class="fas fa-lock-open me-2 text-warning"></i> Bỏ trống nếu bạn không muốn thay đổi mật khẩu
                        </div>

                        <div class="mb-4">
                            <label asp-for="CurrentPassword" class="form-label fw-medium text-dark">Mật khẩu hiện tại</label>
                            <div class="input-group">
                                <input asp-for="CurrentPassword" class="form-control" placeholder="Nhập mật khẩu hiện tại" />
                                <button class="btn btn-outline-secondary toggle-pwd" type="button" tabindex="-1">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="NewPassword" class="form-label fw-medium text-dark">Mật khẩu mới</label>
                                <div class="input-group">
                                    <input asp-for="NewPassword" class="form-control" placeholder="Mật khẩu mới" />
                                    <button class="btn btn-outline-secondary toggle-pwd" type="button" tabindex="-1">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ConfirmPassword" class="form-label fw-medium text-dark">Xác nhận mật khẩu</label>
                                <div class="input-group">
                                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Xác nhận" />
                                    <button class="btn btn-outline-secondary toggle-pwd" type="button" tabindex="-1">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Nút lưu -->
                <div class="d-flex justify-content-end mb-4">
                    <button type="submit" class="btn btn-primary px-4 py-2 fw-medium">
                        <i class="fas fa-save me-1"></i> Lưu cài đặt
                    </button>
                </div>
            </form>

            <!-- Danger Zone Card -->
            <div class="card border-danger mb-5 shadow-sm">
                <div class="card-header bg-white border-danger border-bottom py-3">
                    <h6 class="mb-0 fw-bold text-danger d-flex align-items-center">
                        <i class="fas fa-exclamation-triangle me-2"></i> Vùng nguy hiểm
                    </h6>
                </div>
                <div class="card-body p-4 d-flex flex-column flex-md-row align-items-md-center justify-content-between">
                    <div class="mb-3 mb-md-0 me-md-4">
                        <p class="mb-1 fw-bold text-dark">Xóa tài khoản vĩnh viễn</p>
                        <p class="mb-0 text-muted small">Mọi dữ liệu học tập (chuỗi ngày, từ vựng) sẽ bị xóa và không thể khôi phục.</p>
                    </div>
                    <div>
                        <button type="button" class="btn btn-outline-danger">
                            Xóa tài khoản
                        </button>
                    </div>
                </div>
            </div>

            <!-- Link quay lại Profile -->
            <div class="text-center pb-4">
                <a asp-action="Profile" class="text-decoration-none text-muted hover-primary">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại Hồ sơ
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        // Toggle Password Visibility
        document.querySelectorAll('.toggle-pwd').forEach(function(button) {
            button.addEventListener('click', function() {
                let input = this.closest('.input-group')?.querySelector('.form-control');
                if (!input) return;

                let icon = this.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.remove('fa-eye');
                    icon.classList.add('fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                }
            });
        });

        // Tự động ẩn thông báo sau 5 giây
        setTimeout(function () {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function (alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}