@model TCTVocabulary.ViewModels.UpdateProfileViewModel

@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <!-- Thông báo -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold text-dark">Hồ sơ của bạn</h3>
                        <p class="text-muted">Thay đổi ảnh đại diện và thông tin</p>
                    </div>

                    <form asp-controller="Account" asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="text-center mb-4">
                            <input asp-for="Avatar" type="file" id="Avatar" class="d-none" accept=".jpg,.jpeg,.png" onchange="previewImage(this);" />

                            @{
                                var avatarSrc = string.IsNullOrEmpty(Model.CurrentAvatarUrl) ? "/images/default-avatar.png" : Model.CurrentAvatarUrl;
                            }

                            <div class="position-relative d-inline-block" style="cursor: pointer;" onclick="document.getElementById('Avatar').click();">
                                <img id="avatarPreview" src="@avatarSrc" alt="Avatar" class="rounded-circle border" style="width: 150px; height: 150px; object-fit: cover;" />
                                <div class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle p-2 shadow-sm" style="transform: translate(-10%, -10%); width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-camera"></i>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.FullName))
                            {
                                <div class="mt-3 fs-5 fw-semibold text-dark">
                                    <i class="fas fa-user text-muted me-2"></i>@Model.FullName
                                </div>
                            }

                            <div class="form-text mt-2 text-muted">
                                Bấm vào ảnh để thay đổi (tối đa 2MB, .jpg/.png)
                            </div>
                            <span asp-validation-for="Avatar" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 text-start">
                            <label asp-for="FullName" class="form-label fw-medium text-dark">Họ và tên</label>
                            <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên..." />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary py-2 fw-medium">
                                <i class="fas fa-save me-1"></i> Cập nhật hồ sơ
                            </button>
                        </div>
                    </form>

                    <hr class="my-5 text-muted opacity-25" />

                    <div class="row g-3">
                        <div class="col-6">
                            <div class="border border-light rounded p-3 text-center bg-light">
                                <div class="fs-3 mb-1">🔥</div>
                                <div class="fw-bold fs-4 text-dark">5</div>
                                <div class="text-muted small">Ngày liên tiếp</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border border-light rounded p-3 text-center bg-light">
                                <div class="fs-3 mb-1">📚</div>
                                <div class="fw-bold fs-4 text-dark">120</div>
                                <div class="text-muted small">Từ đã ghi nhớ</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center pb-4">
                <a asp-action="Settings" class="text-decoration-none text-muted hover-primary">
                    <i class="fas fa-shield-alt me-1"></i> Bảo mật & Mật khẩu
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        setTimeout(function () {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function (alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}