{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Google": {
      "ClientId": "__SET_GOOGLE_CLIENT_ID__",
      "ClientSecret": "__SET_GOOGLE_CLIENT_SECRET__"
    },
    "Facebook": {
      "AppId": "__SET_FACEBOOK_APP_ID__",
      "AppSecret": "__SET_FACEBOOK_APP_SECRET__"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=__DB_SERVER__;Database=__DB_NAME__;User Id=__DB_USER__;Password=__DB_PASSWORD__;TrustServerCertificate=True;MultipleActiveResultSets=True;Max Pool Size=200;Connection Timeout=30;"
  },
  "SmtpSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "SenderEmail": "support.tctenglish@gmail.com",
    "SenderName": "TCT English",
    "Password": "__SET_SMTP_PASSWORD__"
  },
  "OpenAiApiKey": "your_openai_api_key_here"
}
