@model dynamic

@{
    ViewData["Title"] = "Đăng nhập / Đăng ký | TCT English";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Đăng nhập hoặc đăng ký tài khoản TCT English – nền tảng học tiếng Anh nội bộ dành cho nhân viên TCT." />
    <title>@ViewData["Title"]</title>

    <!-- Google Fonts: Be Vietnam Pro / Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Bootstrap 5 (for blocked-account modal) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1WR6zNn36Dg50z5cYkN7fIZFLog7kGr" crossorigin="anonymous" />

    <!-- TCT English Redesign Shared UI & Auth Styles -->
    <link href="~/css/tct-learning-ui.css" rel="stylesheet" />
    <link href="~/css/auth-stitch.css" rel="stylesheet" />
</head>
<body class="auth-page">

    <div class="auth-split-container">

        <!-- ============================================================
             LEFT COLUMN: Dark Gradient Hero
             ============================================================ -->
        <div class="auth-col-left">
            <!-- Dot-grid pattern overlay -->
            <div class="auth-decoration"></div>

            <!-- Floating glass shapes -->
            <div class="auth-floating-shapes">
                <div class="auth-shape auth-shape--1"></div>
                <div class="auth-shape auth-shape--2"></div>
                <div class="auth-shape auth-shape--3"></div>
                <div class="auth-shape auth-shape--4"></div>
                <div class="auth-shape auth-shape--5"></div>
            </div>

            <!-- Brand content -->
            <div class="auth-brand-content">
                <div class="auth-brand-logo">
                    <i class="fa-solid fa-graduation-cap"></i>
                </div>
                <div class="auth-brand-title">TCT ENGLISH</div>
                <div class="auth-brand-subtitle">
                    Học tiếng Anh thông minh — dành cho mọi người.<br />
                    Nâng tầm ngoại ngữ, mở rộng tương lai.
                </div>
            </div>

            <!-- Feature glass cards -->
            <div class="auth-features">
                <div class="auth-feature-card">
                    <div class="auth-feature-icon auth-feature-icon--vocab">
                        <i class="fa-solid fa-book-open"></i>
                    </div>
                    <span class="auth-feature-label">500+ Từ vựng</span>
                </div>
                <div class="auth-feature-card">
                    <div class="auth-feature-icon auth-feature-icon--speaking">
                        <i class="fa-solid fa-microphone"></i>
                    </div>
                    <span class="auth-feature-label">AI Speaking</span>
                </div>
                <div class="auth-feature-card">
                    <div class="auth-feature-icon auth-feature-icon--quiz">
                        <i class="fa-solid fa-bolt"></i>
                    </div>
                    <span class="auth-feature-label">Smart Quiz</span>
                </div>
            </div>
        </div>

        <!-- ============================================================
             RIGHT COLUMN: Auth Card Area
             ============================================================ -->
        <div class="auth-col-right">
            <button class="auth-close-btn" onclick="window.history.back()" aria-label="Quay lại" id="btn-close-auth">
                <i class="fa-solid fa-xmark"></i>
            </button>

            <div class="auth-card">

                <!-- TABS header -->
                <div class="auth-tabs">
                    <button class="auth-tab-btn active" onclick="switchTab('register')" id="tab-register">Đăng ký</button>
                    <button class="auth-tab-btn" onclick="switchTab('login')" id="tab-login">Đăng nhập</button>
                </div>

                <!-- Error Message Display -->
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="auth-error-msg">
                        <i class="fa-solid fa-circle-exclamation" style="margin-right: 6px;"></i>
                        @ViewBag.ErrorMessage
                    </div>
                }

                @if (TempData["SuccessMessage"] != null)
                {
                    <script>
                        document.addEventListener("DOMContentLoaded", function() {
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công!',
                                text: @Html.Raw(Json.Serialize(TempData["SuccessMessage"])),
                                confirmButtonColor: '#4255ff',
                                confirmButtonText: 'Đăng nhập ngay'
                            });
                        });
                    </script>
                }

                <!-- SOCIAL LOGIN (Shared) -->
                <div class="auth-social-btns">
                    <button class="auth-btn-social" type="button" id="btn-google" onclick="handleExternalLogin('@Url.Action("ExternalLogin", "Account", new { provider = "Google" })')">
                        <i class="fa-brands fa-google" style="color: #DB4437; font-size: 17px;"></i>
                        Google
                    </button>
                    <button class="auth-btn-social" type="button" id="btn-facebook" onclick="handleExternalLogin('@Url.Action("ExternalLogin", "Account", new { provider = "Facebook" })')">
                        <i class="fa-brands fa-facebook" style="color: #1877F2; font-size: 17px;"></i>
                        Facebook
                    </button>
                </div>

                <div class="auth-separator">hoặc bằng email</div>

                <!-- ==================== REGISTER FORM ==================== -->
                <form id="form-register" action="@Url.Action("Register", "Account")" method="post" onsubmit="handleRegister(event)">
                    @Html.AntiForgeryToken()

                    <div class="auth-form-group">
                        <label class="auth-form-label">Ngày sinh <span style="color: var(--tct-text-muted); font-weight: 400;">(không bắt buộc)</span></label>
                        <div style="display: flex; gap: 8px;">
                            <input type="text" class="auth-form-input" placeholder="Ngày" style="width: 30%">
                            <input type="text" class="auth-form-input" placeholder="Tháng" style="width: 30%">
                            <input type="text" class="auth-form-input" placeholder="Năm" style="width: 40%">
                        </div>
                    </div>

                    <div class="auth-form-group">
                        <label class="auth-form-label">Email</label>
                        <input type="email" name="email" class="auth-form-input" placeholder="nhapemail@example.com" required id="register-email">
                    </div>

                    <div class="auth-form-group">
                        <label class="auth-form-label">Tên hiển thị</label>
                        <input type="text" name="fullName" class="auth-form-input" placeholder="Nhập tên của bạn" required id="register-name">
                    </div>

                    <div class="auth-form-group">
                        <label class="auth-form-label">Mật khẩu</label>
                        <div class="auth-password-wrap">
                            <input type="password" name="password" class="auth-form-input" placeholder="Tối thiểu 6 ký tự" required id="register-password">
                            <button type="button" class="auth-toggle-password" onclick="togglePassword('register-password', this)" aria-label="Hiện/ẩn mật khẩu">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="auth-checkbox-wrap">
                        <input type="checkbox" id="terms">
                        <label for="terms" style="cursor: pointer">
                            Tôi chấp nhận <strong>Điều khoản dịch vụ</strong> và <strong>Chính sách quyền riêng tư</strong> của TCT English.
                        </label>
                    </div>

                    <button type="submit" class="auth-btn-submit" id="btn-register-submit">
                        <i class="fa-solid fa-user-plus" style="margin-right: 6px;"></i> Đăng ký
                    </button>

                    <div class="auth-form-footer">
                        Bạn đã có tài khoản? <button type="button" class="auth-link" onclick="switchTab('login')">Đăng nhập</button>
                    </div>
                </form>

                <!-- ==================== LOGIN FORM (Hidden by default) ==================== -->
                <form id="form-login" action="@Url.Action("Login", "Account")" method="post" onsubmit="handleLogin(event)" style="display: none;">
                    @Html.AntiForgeryToken()

                    <div class="auth-form-group">
                        <label class="auth-form-label">Email</label>
                        <input type="text" name="email" class="auth-form-input" placeholder="Nhập email của bạn" required id="login-email">
                    </div>

                    <div class="auth-form-group">
                        <label class="auth-form-label">Mật khẩu</label>
                        <div class="auth-password-wrap">
                            <input type="password" name="password" class="auth-form-input" placeholder="••••••••" required id="login-password">
                            <button type="button" class="auth-toggle-password" onclick="togglePassword('login-password', this)" aria-label="Hiện/ẩn mật khẩu">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        <a href="@Url.Action("ForgotPassword", "Account")" class="auth-forgot-pass">Quên mật khẩu?</a>
                    </div>

                    <!-- Blocked Account Alert (hidden by default) -->
                    <div id="blocked-alert" class="auth-blocked-alert" style="display:none;">
                        <div class="blocked-header">
                            <i class="fa-solid fa-lock"></i>
                            <strong>Tài khoản đã bị khóa</strong>
                        </div>
                        <p><strong>Lý do:</strong> <span id="blocked-reason"></span></p>
                        <p><strong>Mở khóa:</strong> <span id="blocked-expiry"></span></p>
                        <a href="@Url.Action("Contact", "Home", new { subject = "khieu-nai-khoa-tai-khoan" })" class="auth-btn-appeal">
                            <i class="fa-solid fa-paper-plane"></i> Gửi khiếu nại
                        </a>
                    </div>

                    <button type="submit" class="auth-btn-submit" id="btn-login-submit">
                        <i class="fa-solid fa-right-to-bracket" style="margin-right: 6px;"></i> Đăng nhập
                    </button>

                    <div class="auth-form-footer">
                        Mới sử dụng TCT English? <button type="button" class="auth-link" onclick="switchTab('register')">Tạo tài khoản</button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <!-- LOADER OVERLAY -->
    <div id="loader-overlay">
        <div class="loader-brand">TCT ENGLISH</div>

        <div class="loader-tip-card">
            <div class="loader-tip-icon"><i class="fa-solid fa-lightbulb"></i></div>
            <div class="loader-tip-title">MẸO GHI NHỚ:</div>
            <div class="loader-tip-content">
                Sử dụng hình ảnh và âm thanh để kích thích não bộ ghi nhớ.
            </div>
        </div>

        <div class="loading-bar-wrap">
            <div class="loading-fill" id="loading-fill"></div>
        </div>
    </div>

    <!-- SCRIPT -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Lấy giá trị từ Controller (login hoặc register)
            const activeTab = '@ViewData["ActiveTab"]';
            if (activeTab) {
                switchTab(activeTab);
            }

            // Check if redirected due to blocked social login
            @if (TempData["BlockedReason"] != null)
            {
                <text>
                switchTab('login');
                document.getElementById('blocked-reason').textContent = '@Html.Raw(TempData["BlockedReason"])';
                document.getElementById('blocked-expiry').textContent = '@Html.Raw(TempData["BlockedExpiry"])';
                document.getElementById('blocked-alert').style.display = 'block';
                </text>
            }
        });

        // Toggle password visibility
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        // Show loader overlay then redirect for external login (Google/Facebook)
        function handleExternalLogin(url) {
            const overlay = document.getElementById('loader-overlay');
            const bar = document.getElementById('loading-fill');

            // Reset progress bar
            bar.style.transition = 'none';
            bar.style.width = '0%';

            // Show overlay immediately
            overlay.classList.add('active');

            // Animate progress bar (indeterminate feel)
            setTimeout(() => {
                bar.style.transition = 'width 3s ease-out';
                bar.style.width = '80%';
            }, 50);

            // Redirect to external provider
            setTimeout(() => {
                window.location.href = url;
            }, 150);
        }

        function switchTab(tabName) {
            const btnReg = document.getElementById('tab-register');
            const btnLog = document.getElementById('tab-login');
            const formReg = document.getElementById('form-register');
            const formLog = document.getElementById('form-login');

            if (tabName === 'register') {
                btnReg.classList.add('active');
                btnLog.classList.remove('active');
                formReg.style.display = 'block';
                formLog.style.display = 'none';
            } else {
                btnLog.classList.add('active');
                btnReg.classList.remove('active');
                formLog.style.display = 'block';
                formReg.style.display = 'none';
            }
        }

        function handleRegister(e) {
            e.preventDefault();

            const terms = document.getElementById('terms');
            if (!terms.checked) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Điều khoản dịch vụ',
                    text: 'Vui lòng đồng ý với điều khoản dịch vụ để tiếp tục.',
                    confirmButtonColor: '#4255ff',
                    confirmButtonText: 'Đã hiểu'
                });
                return;
            }

            document.getElementById('form-register').submit();
        }

        function handleLogin(e) {
            e.preventDefault();

            const form = document.getElementById('form-login');
            const formData = new FormData(form);

            // Hide blocked alert on new attempt
            document.getElementById('blocked-alert').style.display = 'none';

            // AJAX Fetch
            fetch(form.action, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showLoaderAndRedirect();
                } else if (data.blocked) {
                    location.reload();
                } else {
                    showLoginError(data.message || "Đã có lỗi xảy ra");
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showLoginError("Lỗi kết nối server.");
            });
        }

        function showLoginError(msg) {
            let errorBox = document.getElementById('login-error-msg');
            if (!errorBox) {
                const form = document.getElementById('form-login');
                const btn = form.querySelector('.auth-btn-submit');
                errorBox = document.createElement('div');
                errorBox.id = 'login-error-msg';
                errorBox.className = 'auth-error-msg';
                form.insertBefore(errorBox, btn);
            }
            errorBox.innerHTML = '<i class="fa-solid fa-circle-exclamation" style="margin-right: 6px;"></i>' + msg;
            errorBox.style.display = 'block';
        }

        function runLoaderAndSubmit(formId) {
            const overlay = document.getElementById('loader-overlay');
            const bar = document.getElementById('loading-fill');
            const form = document.getElementById(formId);

            bar.style.transition = 'none';
            bar.style.width = '0%';
            overlay.classList.add('active');

            setTimeout(() => {
                bar.style.transition = 'width 1.5s linear';
                bar.style.width = '100%';
            }, 50);

            setTimeout(() => {
                form.submit();
            }, 1550);
        }

        function showLoaderAndRedirect() {
            const overlay = document.getElementById('loader-overlay');
            const bar = document.getElementById('loading-fill');
            
            const errorBox = document.getElementById('login-error-msg');
            if(errorBox) errorBox.style.display = 'none';

            bar.style.transition = 'none';
            bar.style.width = '0%';
            overlay.classList.add('active');

            setTimeout(() => {
                bar.style.transition = 'width 1.5s linear';
                bar.style.width = '100%';
            }, 50);

            setTimeout(() => {
                window.location.href = '@Url.Action("Index", "Home")';
            }, 1550);
        }

        function runDemoLogin() {
            const overlay = document.getElementById('loader-overlay');
            const bar = document.getElementById('loading-fill');

            bar.style.transition = 'none';
            bar.style.width = '0%';
            overlay.classList.add('active');

            setTimeout(() => {
                bar.style.transition = 'width 3s linear';
                bar.style.width = '100%';
            }, 50);

            setTimeout(() => {
                window.location.href = '@Url.Action("Index", "Home")';
            }, 3100);
        }
    </script>

    @if (TempData["IsBlocked"] is true)
    {
        <!-- ===== BLOCKED ACCOUNT MODAL (Bootstrap 5) ===== -->
        <div class="modal fade" id="blockedAccountModal" tabindex="-1" aria-labelledby="blockedAccountModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow" style="border-radius: 24px;">
                    <div class="modal-header border-bottom-0 pb-0">
                        <h5 class="modal-title fw-semibold text-danger" id="blockedAccountModalLabel">
                            <i class="fa-solid fa-lock me-2"></i>Tài khoản đã bị khóa
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-2"><strong>Lý do:</strong> @TempData["LockReason"]</p>
                        <p class="mb-3"><strong>Mở khóa:</strong> @TempData["LockExpiry"]</p>
                        <a href="@Url.Action("Contact", "Home", new { subject = "khieu-nai-khoa-tai-khoan" })"
                           class="auth-btn-appeal" style="text-decoration: none; display: inline-flex;">
                            <i class="fa-solid fa-paper-plane"></i> Gửi khiếu nại
                        </a>
                    </div>
                    <div class="modal-footer border-top-0 pt-0">
                        <button type="button" class="tct-btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var blockedModal = new bootstrap.Modal(document.getElementById('blockedAccountModal'));
                blockedModal.show();
            });
        </script>
    }

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
