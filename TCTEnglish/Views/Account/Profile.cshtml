@model TCTVocabulary.ViewModels.UpdateProfileViewModel

@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />
}

<div class="account-page bg-light min-vh-100 py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <!-- Alert Notifications -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-check-circle me-2"></i>
                            <div>@TempData["SuccessMessage"]</div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <div>@TempData["ErrorMessage"]</div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <!-- Main Profile Card -->
                <div class="card bg-white border-secondary-subtle rounded-3 shadow-sm overflow-hidden mb-4">
                    <div class="card-body p-4 p-md-5">
                        <div class="mb-5">
                            <h4 class="fw-semibold text-dark mb-1">Hồ sơ cá nhân</h4>
                            <p class="text-muted small mb-0">Quản lý thông tin định danh và ảnh đại diện của bạn.</p>
                        </div>

                        <form asp-controller="Account" asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

                            <div class="text-center mb-5">
                                <div class="position-relative d-inline-block">
                                    <input asp-for="Avatar" type="file" id="Avatar" class="d-none" accept=".jpg,.jpeg,.png" onchange="previewImage(this);" />
                                    
                                    @{
                                        var avatarSrc = string.IsNullOrEmpty(Model.CurrentAvatarUrl) ? "/images/default-avatar.png" : Model.CurrentAvatarUrl;
                                    }
                                    
                                    <div class="position-relative shadow-sm rounded-circle p-1 border border-secondary-subtle account-avatar-wrapper"
                                         id="avatarClickTarget">
                                        <img id="avatarPreview" src="@avatarSrc" alt="Avatar" 
                                             class="rounded-circle w-100 h-100 object-fit-cover" />

                                        <div class="position-absolute bottom-0 end-0 bg-white border border-secondary-subtle rounded-circle shadow-sm d-flex align-items-center justify-content-center account-avatar-camera">
                                            <i class="fas fa-camera text-primary small"></i>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="mt-3">
                                    <div class="fw-medium text-dark">@Model.FullName</div>
                                    <div class="text-muted small">Ảnh đại diện giúp mọi người nhận ra bạn</div>
                                </div>
                                <span asp-validation-for="Avatar" class="text-danger small mt-2 d-block"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="FullName" class="form-label small fw-medium text-secondary">Họ và tên</label>
                                <input asp-for="FullName" class="form-control border-secondary-subtle py-2 px-3" placeholder="Ví dụ: Nguyễn Văn A" />
                                <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="pt-2">
                                <button type="submit" class="btn btn-primary w-100 py-2 fw-medium shadow-sm border-0">
                                    <i class="fas fa-check me-2"></i> Lưu thay đổi
                                </button>
                            </div>
                        </form>

                        <div class="my-5 border-top border-light-subtle"></div>

                        <div class="row g-0 rounded-3 border border-secondary-subtle bg-light shadow-sm">
                            <div class="col-6 border-end border-secondary-subtle">
                                <div class="p-4 text-center">
                                    <div class="mb-1 text-warning"><i class="fas fa-fire fa-lg"></i></div>
                                    <div class="fw-bold fs-3 text-dark mb-0">@Model.StreakDays</div>
                                    <div class="text-muted small fw-medium">Ngày liên tiếp</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-4 text-center">
                                    <div class="mb-1 text-success"><i class="fas fa-book fa-lg"></i></div>
                                    <div class="fw-bold fs-3 text-dark mb-0">@Model.SavedWordsCount</div>
                                    <div class="text-muted small fw-medium">Từ đã lưu</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-center">
                    <a asp-action="Settings" class="btn btn-link text-decoration-none text-muted small fw-medium">
                        <i class="fas fa-shield-halved me-1"></i> Bảo mật tài khoản & Cài đặt nâng cao
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.getElementById('avatarClickTarget')?.addEventListener('click', function () {
            document.getElementById('Avatar').click();
        });

        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        setTimeout(function () {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function (alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}