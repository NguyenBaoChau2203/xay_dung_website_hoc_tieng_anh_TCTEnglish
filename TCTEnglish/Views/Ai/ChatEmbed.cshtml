@model TCTEnglish.ViewModels.AI.AiChatPageViewModel

@{
    Layout = null;
    ViewData["Title"] = "TCT AI";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TCT AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/ai-chat.css" asp-append-version="true" />
</head>
<body class="ai-chat-embed-body">
    <partial name="_ChatShell" model="Model" />

    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.6/dist/purify.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/ai-chat.js" asp-append-version="true"></script>
    <script>
        window.tctAiChat?.init({
            sendUrl: '@Url.Action("Send", "Ai")',
            observabilityUrl: '@Url.Action("Observability", "Ai")',
            hubUrl: '/classChatHub'
        });
    </script>
</body>
</html>
