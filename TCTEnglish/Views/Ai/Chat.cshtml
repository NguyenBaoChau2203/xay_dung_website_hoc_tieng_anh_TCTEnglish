@model TCTEnglish.ViewModels.AI.AiChatPageViewModel

@{
    ViewData["Title"] = "AI Chat";
    var chatPageUrl = Url.Action("Chat", "Ai") ?? "/AI/Chat";
}

<div class="ai-chat-page">
    <div class="ai-chat-layout" data-ai-chat-layout>
        <aside class="ai-chat-history"
               aria-label="Lịch sử hội thoại"
               data-ai-history-root
               data-ai-chat-base-url="@chatPageUrl">
            <div class="ai-chat-history-header">
                <h2 class="ai-chat-history-title">Đoạn chat gần đây</h2>
                <a class="btn btn-outline-primary btn-sm"
                   asp-controller="Ai"
                   asp-action="Chat"
                   data-ai-new-chat-link>
                    New chat
                </a>
            </div>

            <div class="ai-chat-history-empty @(Model.Conversations.Count == 0 ? string.Empty : "d-none")"
                 data-ai-history-empty>
                Bạn chưa có hội thoại nào.
            </div>

            <nav class="ai-chat-history-list @(Model.Conversations.Count == 0 ? "d-none" : string.Empty)"
                 aria-label="Danh sách hội thoại"
                 data-ai-history-list>
                @foreach (var conversation in Model.Conversations)
                {
                    var isActive = Model.ConversationId.HasValue && Model.ConversationId.Value == conversation.Id;
                    var updatedLabel = conversation.UpdatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm");

                    <div class="ai-chat-history-item-wrapper" data-ai-history-item-wrapper>
                        <a class="ai-chat-history-item @(isActive ? "active" : string.Empty)"
                           asp-controller="Ai"
                           asp-action="Chat"
                           asp-route-conversationId="@conversation.Id"
                           aria-current="@(isActive ? "page" : null)"
                           data-ai-history-item
                           data-conversation-id="@conversation.Id">
                            <span class="ai-chat-history-item-title">@conversation.Title</span>
                            <span class="ai-chat-history-item-time" data-timestamp="@conversation.UpdatedAtUtc.ToString("O")">@updatedLabel</span>
                        </a>
                        <button type="button" 
                                class="ai-chat-history-delete-btn" 
                                data-ai-history-delete="@conversation.Id"
                                aria-label="Xóa hội thoại">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>
                }
            </nav>
        </aside>

        <div class="ai-chat-surface" data-ai-chat-surface>
            <partial name="_ChatShell" model="Model" />
        </div>
    </div>
</div>

<div class="modal fade" id="deleteConversationModal" tabindex="-1" aria-labelledby="deleteConversationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteConversationModalLabel">Xóa đoạn chat</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa đoạn chat này không? Hành động này không thể hoàn tác.</p>
                <div id="deleteConversationError" class="alert alert-danger d-none mb-0"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteConversationBtn">Xóa đoạn chat</button>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="deleteSuccessToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                Đã xóa đoạn chat thành công.
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Đóng"></button>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/ai-chat.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.6/dist/purify.min.js"></script>
    <script src="~/js/ai-chat.js" asp-append-version="true"></script>
    <script>
        window.tctAiChat?.init({
            sendUrl: '@Url.Action("Send", "Ai")',
            observabilityUrl: '@Url.Action("Observability", "Ai")',
            deleteUrl: '@Url.Action("Delete", "Ai")',
            hubUrl: '/classChatHub'
        });
    </script>
}
