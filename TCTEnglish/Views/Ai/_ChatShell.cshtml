@model TCTEnglish.ViewModels.AI.AiChatPageViewModel

<div class="ai-chat-shell @(Model.IsEmbedded ? "ai-chat-shell-embedded" : "ai-chat-shell-page")"
     data-ai-chat-shell="@(Model.IsEmbedded ? "embedded" : "page")">
    @if (!Model.IsEmbedded)
    {
        <div class="ai-chat-shell-header">
            <div>
                <div class="ai-chat-shell-kicker">TCT AI</div>
                <h1 class="ai-chat-shell-title">Trợ lý học tiếng Anh</h1>
                <p class="ai-chat-shell-subtitle mb-0">
                    Hỏi về từ vựng, cách luyện tập, speaking và mẹo học phù hợp với lộ trình của bạn.
                </p>
            </div>

            <div class="ai-chat-shell-meta">
                <span class="ai-chat-shell-meta-label">Đoạn chat hiện tại</span>
                <span id="conversationMetaValue"
                      class="ai-chat-shell-meta-value"
                      title="@Model.CurrentConversationTitle">
                    @Model.CurrentConversationTitle
                </span>
                <span id="conversationMetaStatus" class="ai-chat-shell-meta-hint">@Model.CurrentConversationStatus</span>
            </div>
        </div>

        <div class="row g-2 ai-chat-metrics" id="aiObservabilityPanel">
            <div class="col-md-3">
                <div class="ai-chat-metric-card">
                    <div class="ai-chat-metric-label">Requests (7 ngày)</div>
                    <div id="aiMetricRequestCount" class="ai-chat-metric-value">-</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="ai-chat-metric-card">
                    <div class="ai-chat-metric-label">Error rate</div>
                    <div id="aiMetricErrorRate" class="ai-chat-metric-value">-</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="ai-chat-metric-card">
                    <div class="ai-chat-metric-label">Latency p50/p95</div>
                    <div id="aiMetricLatency" class="ai-chat-metric-value">-</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="ai-chat-metric-card">
                    <div class="ai-chat-metric-label">Token hôm nay</div>
                    <div id="aiMetricTokenToday" class="ai-chat-metric-value">-</div>
                </div>
            </div>
        </div>
    }

    <div class="ai-chat-window-wrapper" data-ai-chat-panel>
        <div id="chatWindow"
             class="ai-chat-window"
             data-ai-chat-scroll-region
             tabindex="0"
             role="log"
             aria-live="polite"
             aria-relevant="additions text"
             aria-label="Lịch sử tin nhắn AI">
            @if (Model.Messages.Count == 0)
            {
                <div class="ai-chat-empty-state" data-chat-empty-state>
                    Hãy bắt đầu cuộc trò chuyện với AI.
                </div>
            }
            else
            {
                @foreach (var message in Model.Messages)
                {
                    var isUser = string.Equals(message.Role, "user", System.StringComparison.OrdinalIgnoreCase);
                    var isAssistant = string.Equals(message.Role, "assistant", System.StringComparison.OrdinalIgnoreCase);
                    var isSystem = string.Equals(message.Role, "system", System.StringComparison.OrdinalIgnoreCase);
                    var messageClass = isUser
                        ? "ai-chat-message ai-chat-message-user"
                        : isSystem
                            ? "ai-chat-message ai-chat-message-system"
                            : "ai-chat-message ai-chat-message-assistant";
                    var bubbleClass = isUser
                        ? "ai-chat-bubble ai-chat-bubble-user"
                        : isSystem
                            ? "ai-chat-bubble ai-chat-bubble-system"
                            : "ai-chat-bubble ai-chat-bubble-assistant";

                    <div class="@messageClass" data-role="@message.Role">
                        <div class="@bubbleClass">
                            @if (isAssistant)
                            {
                                <div class="js-assistant-markdown">@message.Content</div>
                            }
                            else
                            {
                                @message.Content
                            }
                        </div>
                    </div>
                }
            }
        </div>
        <button type="button"
                id="scrollToBottomBtn"
                class="ai-scroll-bottom-btn"
                data-ai-scroll-bottom
                hidden
                aria-hidden="true"
                aria-label="Cuộn xuống cuối"
                aria-controls="chatWindow"
                title="Cuộn xuống cuối">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <polyline points="19 12 12 19 5 12"></polyline>
            </svg>
        </button>
    </div>

    <div class="ai-chat-composer-zone" data-ai-chat-composer>
        <form id="chatForm" class="ai-chat-form" data-state="idle">
            @Html.AntiForgeryToken()
            <input type="hidden" id="conversationIdInput" value="@(Model.ConversationId?.ToString() ?? string.Empty)" />

            <div class="ai-chat-composer">
                <label for="messageInput" class="visually-hidden">Nội dung tin nhắn chat</label>

                <div class="ai-chat-composer-main">
                    <input id="messageInput"
                           class="form-control ai-chat-input"
                           maxlength="1000"
                           placeholder="Nhập câu hỏi của bạn..."
                           autocomplete="off"
                           aria-describedby="typing chatStatus" />

                    <div class="ai-chat-composer-actions">
                        <button id="sendBtn" class="btn btn-primary ai-chat-send-btn" type="submit">Gửi</button>
                        <button id="stopBtn" class="btn btn-outline-secondary ai-chat-stop-btn d-none" type="button">Dừng</button>
                    </div>
                </div>
            </div>
        </form>

        <div id="typing" class="ai-chat-typing d-none" role="status" aria-live="polite" aria-atomic="true">AI đang trả lời...</div>
        <div id="chatStatus" class="alert alert-warning ai-chat-status d-none mb-0" role="status" aria-live="assertive" aria-atomic="true"></div>
    </div>
</div>
