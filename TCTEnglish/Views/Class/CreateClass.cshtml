@model TCTVocabulary.ViewModels.CreateClassViewModel

@{
    ViewData["Title"] = "Tạo lớp học mới";
}

<div class="create-class-container">

    <!-- Header -->
    <div class="page-header">
        <h1>Tạo lớp học</h1>
        <p>Thiết lập lớp học để mời mọi người cùng học tập</p>
    </div>

    <form class="create-class-form" method="post" enctype="multipart/form-data">

        <!-- Class Name -->
        <div class="form-group">
            <label>Tên lớp <span class="required">*</span></label>
            <input type="text"
                   name="ClassName"
                   placeholder="Ví dụ: TOEIC 600+, JLPT N3..."
                   required />
        </div>

        <!-- Avatar -->
        <div class="form-group">
            <label>Ảnh đại diện lớp</label>

            <div class="avatar-upload">
                <div class="avatar-preview">
                    <img id="avatarPreview"
                         src="/images/ClassDefault/class-default.png"
                         alt="Avatar" />
                </div>

                <!-- Hidden input -->
                <input type="file"
                       id="avatarInput"
                       name="Avatar"
                       accept="image/*"
                       hidden
                       onchange="previewAvatar(event)" />

                <!-- Custom button -->
                <div class="avatar-actions">
                    <button type="button"
                            class="btn-avatar"
                            onclick="document.getElementById('avatarInput').click()">
                        Chọn ảnh
                    </button>

                    <span class="avatar-hint">
                        JPG, PNG • tối đa 2MB
                    </span>
                </div>
            </div>
        </div>

        <!-- Password -->
        <div class="form-group">
            <label>
                <input type="checkbox" id="enablePassword" onchange="togglePassword()" />
                Đặt mật khẩu cho lớp
            </label>

            <input type="password"
                   id="classPassword"
                   name="Password"
                   placeholder="Nhập mật khẩu lớp"
                   disabled />
        </div>

        <!-- Description -->
        <div class="form-group">
            <label>Mô tả lớp</label>
            <textarea name="Description"
                      rows="4"
                      placeholder="Mô tả mục đích, nội dung học của lớp..."></textarea>
        </div>

        <!-- Actions -->
        <div class="form-actions">
            <a href="@Url.Action("Index", "Home")" class="btn-cancel">
                Hủy
            </a>

            <button type="submit" class="btn-submit">
                Tạo lớp
            </button>
        </div>

    </form>
</div>
<style>
    .create-class-container {
        max-width: 700px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .page-header h1 {
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .page-header p {
        color: #6b7280;
        margin-bottom: 32px;
    }

    /* Form */
    .create-class-form {
        background: #fff;
        border: 2px solid #edeff4;
        border-radius: 20px;
        padding: 32px;
    }

    .form-group {
        margin-bottom: 24px;
    }

        .form-group label {
            display: block;
            font-weight: 700;
            margin-bottom: 8px;
        }

    .required {
        color: #ef4444;
    }

    .form-group input[type="text"],
    .form-group input[type="password"],
    .form-group textarea {
        width: 100%;
        padding: 12px 16px;
        border-radius: 10px;
        border: 2px solid #edeff4;
        font-size: 15px;
    }

    .form-group textarea {
        resize: vertical;
    }

    /* Avatar */
    .avatar-upload {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .avatar-preview {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid #edeff4;
    }

        .avatar-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Actions */
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 16px;
        margin-top: 30px;
    }

    .btn-cancel {
        padding: 10px 20px;
        border-radius: 10px;
        background: #f3f4f6;
        font-weight: 700;
        text-decoration: none;
        color: #374151;
    }

    .btn-submit {
        padding: 10px 24px;
        border-radius: 10px;
        background: #4255ff;
        color: white;
        border: none;
        font-weight: 700;
        cursor: pointer;
    }

        .btn-submit:hover {
            background: #2f3fe0;
        }

    /* Avatar actions */
    .avatar-actions {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .btn-avatar {
        padding: 10px 18px;
        border-radius: 10px;
        border: 2px solid #edeff4;
        background: #f9fafb;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .btn-avatar:hover {
            background: #eef2ff;
            border-color: #4255ff;
            color: #4255ff;
        }

    .avatar-hint {
        font-size: 13px;
        color: #6b7280;
    }
</style>
<script>
        function previewAvatar(event) {
        const file = event.target.files[0];
        if (!file) return;

        if (!file.type.startsWith('image/')) {
            alert('Vui lòng chọn file ảnh');
            event.target.value = '';
            return;
        }

        if (file.size > 2 * 1024 * 1024) {
            alert('Ảnh tối đa 2MB');
            event.target.value = '';
            return;
        }

        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('avatarPreview').src = e.target.result;
        };
        reader.readAsDataURL(file);
    }
    function togglePassword() {
        const checkbox = document.getElementById("enablePassword");
        const passwordInput = document.getElementById("classPassword");

        if (checkbox.checked) {
            passwordInput.disabled = false;
            passwordInput.focus();
        } else {
            passwordInput.value = "";
            passwordInput.disabled = true;
        }
    }
</script>
