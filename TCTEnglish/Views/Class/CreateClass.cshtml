@model TCTVocabulary.ViewModels.CreateClassViewModel

@{
    ViewData["Title"] = "Tạo lớp học mới";
}

<div class="create-class-container">
    <div class="page-header">
        <h1>Tạo lớp học</h1>
        <p>Thiết lập lớp học để mời mọi người cùng học tập</p>
    </div>

    <form class="create-class-form" method="post" enctype="multipart/form-data">
        <!-- Class Name -->
        <div class="form-group">
            <label>Tên lớp <span class="required">*</span></label>
            <input type="text" name="ClassName" placeholder="Ví dụ: TOEIC 600+, JLPT N3..." required />
        </div>

        <!-- Avatar (Giữ nguyên logic của bạn) -->
        <div class="form-group">
            <label>Ảnh đại diện lớp</label>
            <div class="avatar-upload">
                <div class="avatar-preview">
                    <img id="avatarPreview" src="/images/ClassDefault/class-default.png" alt="Avatar" />
                </div>
                <input type="file" id="avatarInput" name="Avatar" accept="image/*" hidden onchange="previewAvatar(event)" />
                <div class="avatar-actions">
                    <button type="button" class="btn-avatar" onclick="document.getElementById('avatarInput').click()">Chọn ảnh</button>
                    <span class="avatar-hint">JPG, PNG • tối đa 2MB</span>
                </div>
            </div>
        </div>

        <!-- Password -->
        <div class="form-group">
            <label class="checkbox-container">
                <input type="checkbox" id="enablePassword" onchange="togglePassword()" />
                <span class="checkmark"></span>
                Đặt mật khẩu cho lớp
            </label>
            <input type="password" id="classPassword" name="Password" placeholder="Nhập mật khẩu lớp" disabled />
        </div>

        <!-- Cài đặt quyền hạn (PHẦN THÊM MỚI) -->
        <div class="form-group settings-section">
            <label>Quyền hạn & Riêng tư</label>
            
            <div class="settings-grid">
                <label class="setting-item">
                    <input type="checkbox" name="RequiresApproval" value="true" />
                    <div class="setting-info">
                        <span class="setting-title">Phê duyệt thành viên</span>
                        <span class="setting-desc">Người dùng cần được bạn chấp nhận mới có thể vào lớp</span>
                    </div>
                </label>

                <label class="setting-item">
                    <input type="checkbox" name="IsChatLocked" value="true" />
                    <div class="setting-info">
                        <span class="setting-title">Khóa chat lớp</span>
                        <span class="setting-desc">Chỉ trưởng nhóm và phó nhóm mới được gửi tin nhắn</span>
                    </div>
                </label>

                <label class="setting-item">
                    <input type="checkbox" name="AllowMemberToPost" value="true" />
                    <div class="setting-info">
                        <span class="setting-title">Cho phép thành viên đăng bài</span>
                        <span class="setting-desc">Thành viên thường có thể thêm Folder vào lớp học</span>
                    </div>
                </label>
            </div>
        </div>

        <!-- Description -->
        <div class="form-group">
            <label>Mô tả lớp</label>
            <textarea name="Description" rows="4" placeholder="Mô tả mục đích, nội dung học của lớp..."></textarea>
        </div>

        <div class="form-actions">
            <a href="@Url.Action("Index", "Home")" class="btn-cancel">Hủy</a>
            <button type="submit" class="btn-submit">Tạo lớp</button>
        </div>
    </form>
</div>

<style>
    * {
        box-sizing: border-box;
    }

    .create-class-container {
        max-width: 900px;
        margin: 30px auto;
        padding: 32px;
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 10px 35px rgba(0, 0, 0, 0.05);
    }

    .page-header {
        margin-bottom: 30px;
        border-bottom: 1px solid #eef1f5;
        padding-bottom: 20px;
    }

        .page-header h1 {
            font-size: 30px;
            font-weight: 800;
            color: #111827;
            margin-bottom: 8px;
        }

        .page-header p {
            font-size: 15px;
            color: #6b7280;
            margin: 0;
        }

    .create-class-form {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .form-group label {
            font-size: 15px;
            font-weight: 700;
            color: #1f2937;
        }

    .required {
        color: #ef4444;
    }

    input[type="text"],
    input[type="password"],
    textarea {
        width: 100%;
        padding: 14px 16px;
        border: 1.5px solid #dbe2ea;
        border-radius: 12px;
        font-size: 15px;
        background: #fff;
        transition: 0.25s ease;
        outline: none;
    }

        input[type="text"]:focus,
        input[type="password"]:focus,
        textarea:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.08);
        }

    textarea {
        resize: vertical;
        min-height: 120px;
    }

    /* Avatar Upload */
    .avatar-upload {
        display: flex;
        align-items: center;
        gap: 24px;
        padding: 20px;
        border: 1.5px dashed #dbe2ea;
        border-radius: 16px;
        background: #fafbfc;
    }

    .avatar-preview {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid #e5e7eb;
        flex-shrink: 0;
        background: white;
    }

        .avatar-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .avatar-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .btn-avatar {
        padding: 12px 20px;
        border: none;
        border-radius: 10px;
        background: #2563eb;
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: 0.25s;
    }

        .btn-avatar:hover {
            background: #1d4ed8;
        }

    .avatar-hint {
        font-size: 13px;
        color: #6b7280;
    }

    /* Password checkbox */
    .checkbox-container {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        font-weight: 600;
    }

        .checkbox-container input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

    #classPassword {
        margin-top: 10px;
    }

    /* Settings section */
    .settings-section {
        background: #f8fafc;
        padding: 24px;
        border-radius: 18px;
        border: 1px solid #e5e7eb;
    }

    .settings-grid {
        display: flex;
        flex-direction: column;
        gap: 18px;
        margin-top: 12px;
    }

    .setting-item {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 16px;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        background: white;
        transition: 0.25s ease;
        cursor: pointer;
    }

        .setting-item:hover {
            border-color: #2563eb;
            background: #f8fbff;
        }

        .setting-item input[type="checkbox"] {
            width: 18px;
            height: 18px;
            margin-top: 3px;
            cursor: pointer;
            flex-shrink: 0;
        }

    .setting-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .setting-title {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
    }

    .setting-desc {
        font-size: 13px;
        color: #6b7280;
        line-height: 1.5;
    }

    /* Buttons */
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 14px;
        margin-top: 10px;
        padding-top: 24px;
        border-top: 1px solid #eef1f5;
    }

    .btn-cancel,
    .btn-submit {
        padding: 13px 26px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 14px;
        text-decoration: none;
        cursor: pointer;
        transition: 0.25s;
    }

    .btn-cancel {
        background: #f3f4f6;
        color: #374151;
        border: 1px solid #d1d5db;
    }

        .btn-cancel:hover {
            background: #e5e7eb;
        }

    .btn-submit {
        border: none;
        background: #2563eb;
        color: white;
    }

        .btn-submit:hover {
            background: #1d4ed8;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .create-class-container {
            padding: 20px;
            margin: 20px 12px;
        }

        .avatar-upload {
            flex-direction: column;
            align-items: flex-start;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-cancel,
        .btn-submit {
            width: 100%;
            text-align: center;
        }
    }
</style>
<script>
        function previewAvatar(event) {
        const file = event.target.files[0];
        if (!file) return;

        if (!file.type.startsWith('image/')) {
            alert('Vui lòng chọn file ảnh');
            event.target.value = '';
            return;
        }

        if (file.size > 2 * 1024 * 1024) {
            alert('Ảnh tối đa 2MB');
            event.target.value = '';
            return;
        }

        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('avatarPreview').src = e.target.result;
        };
        reader.readAsDataURL(file);
    }
    function togglePassword() {
        const checkbox = document.getElementById("enablePassword");
        const passwordInput = document.getElementById("classPassword");

        if (checkbox.checked) {
            passwordInput.disabled = false;
            passwordInput.focus();
        } else {
            passwordInput.value = "";
            passwordInput.disabled = true;
        }
    }
</script>
