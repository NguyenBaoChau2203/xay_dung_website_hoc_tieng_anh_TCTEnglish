@model TCTVocabulary.ViewModels.ClassDetailViewModel
@{
    ViewData["Title"] = Model.Class.ClassName;
    var canViewContent = Model.CanViewPrivateContent;
    var classDescription = string.IsNullOrWhiteSpace(Model.Class.Description)
        ? "Chưa có mô tả cho lớp học này."
        : Model.Class.Description;
}

<div class="class-detail-container">
    @Html.AntiForgeryToken()

    <section class="class-hero">
        <div class="class-header">
            <img class="class-avatar"
                 src="@(string.IsNullOrEmpty(Model.Class.ImageUrl)
                     ? "/images/ClassDefault/class-default.png"
                     : Model.Class.ImageUrl)"
                 alt="@Model.Class.ClassName"
                 onerror="this.src='/images/ClassDefault/class-default.png'" />

            <div class="class-info">
                <div class="class-title-row">
                    <h1>@Model.Class.ClassName</h1>
                </div>

                <p class="class-desc">@Model.Members.Count thành viên</p>

            </div>

            <div class="class-actions">
                <button type="button"
                        class="more-btn"
                        onclick="openClassActionModal()"
                        aria-label="Quản lý lớp">
                    <i class="fas fa-ellipsis-h"></i>
                </button>
            </div>
        </div>
    </section>

    @if (!canViewContent)
    {
        <section class="join-required-panel">
            <div class="join-required-card">
                <h2>Hãy tham gia nhóm</h2>

                <p>
                    Bạn cần tham gia lớp học này để xem chat, folder và danh sách thành viên.
                </p>

                <button class="btn-primary"
                        type="button"
                        onclick="handleJoinClick(@Model.Class.ClassId, @(Model.Class.HasPassword.ToString().ToLower()))">
                    Tham gia nhóm
                </button>
            </div>
        </section>
    }
    else
    {
        <section class="class-main-panel">
            <div class="class-tabs" role="tablist" aria-label="Class detail tabs">
                <button class="tab-btn active" type="button" data-tab="chat" onclick="showTab('chat')">
                    <i class="fas fa-comments"></i>
                    <span>Chat</span>
                </button>

                <button class="tab-btn" type="button" data-tab="folders" onclick="showTab('folders')">
                    <i class="fas fa-folder"></i>
                    <span>Folder</span>
                </button>

                <button class="tab-btn" type="button" data-tab="members" onclick="showTab('members')">
                    <i class="fas fa-users"></i>
                    <span>Thành viên</span>
                </button>

                <button class="tab-btn" type="button" data-tab="about" onclick="showTab('about')">
                    <i class="fas fa-circle-info"></i>
                    <span>Giới thiệu</span>
                </button>
            </div>

            <div id="tab-chat" class="tab-content active">
                <div class="content-shell chat-shell">
                    <div id="chatMessages" class="chat-box">
                        @foreach (var msg in Model.Messages)
                        {
                            <div class="chat-message @(msg.IsMine ? "mine" : "other")">
                                <div class="chat-bubble">
                                    @if (!msg.IsMine)
                                    {
                                        <div class="chat-name">@msg.FullName</div>
                                    }

                                    <div class="chat-content">
                                        @if (msg.Content.StartsWith("/uploads/"))
                                        {
                                            <img src="@msg.Content"
                                                 class="chat-image"
                                                 alt="Chat image"
                                                 onclick="window.open(this.src)" />
                                        }
                                        else
                                        {
                                            @msg.Content
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (Model.Class.IsChatLocked && !Model.CanChatWhenLocked)
                    {
                        <div class="chat-locked-notice">
                            Chat đang bị khóa. Chỉ người quản lý lớp mới có thể nhắn tin.
                        </div>
                    }
                    else
                    {
                        <div class="chat-input-bar">
                            <label class="chat-icon" title="Tải ảnh">
                                <i class="fas fa-image"></i>
                                <input type="file"
                                       id="imageInput"
                                       accept="image/*"
                                       hidden />
                            </label>

                            <button type="button"
                                    class="chat-utility-btn"
                                    onclick="toggleEmoji()"
                                    title="Emoji">
                                <i class="far fa-smile"></i>
                            </button>

                            <div id="emojiPanel" class="emoji-picker">
                                <span class="emoji-item">😀</span>
                                <span class="emoji-item">😁</span>
                                <span class="emoji-item">😂</span>
                                <span class="emoji-item">🤣</span>
                                <span class="emoji-item">😍</span>
                                <span class="emoji-item">😎</span>
                                <span class="emoji-item">👍</span>
                                <span class="emoji-item">❤️</span>
                                <span class="emoji-item">🎉</span>
                                <span class="emoji-item">🔥</span>
                            </div>

                            <input id="chatInput"
                                   type="text"
                                   placeholder="Nhập tin nhắn..."
                                   onkeydown="if(event.key==='Enter') sendMessage()" />

                            <button type="button" class="chat-send-btn" onclick="sendMessage()">
                                Gửi
                            </button>
                        </div>
                    }
                </div>
            </div>

            <div id="tab-folders" class="tab-content">
                <div class="content-shell">
                    <div class="section-header">
                        <div>
                            <h3>Folder của lớp</h3>
                            <p>Quản lý các folder đang được chia sẻ trong lớp học.</p>
                        </div>

                        @if (Model.CanManageClass || Model.Class.AllowMemberToPost)
                        {
                            <button class="btn-primary btn-add-folder"
                                    type="button"
                                    onclick="openAddFolderModal()">
                                Thêm folder
                            </button>
                        }
                    </div>

                    @if (!Model.ClassFolders.Any())
                    {
                        <div class="empty-box">
                            <p>Chưa có folder nào trong lớp.</p>
                        </div>
                    }
                    else
                    {
                        <div class="folder-grid">
                            @foreach (var f in Model.ClassFolders)
                            {
                                <a asp-controller="Folder"
                                   asp-action="FolderDetail"
                                   asp-route-id="@f.FolderId"
                                   class="f-link">
                                    <article class="class-folder-row">
                                        <div class="folder-left">
                                            <div class="folder-name">@f.FolderName</div>
                                        </div>

                                        <div class="folder-right">
                                            <span>Thêm bởi <strong>@f.AddedByUserName</strong></span>

                                            @if (f.CanRemove)
                                            {
                                                <button type="button"
                                                        class="btn-delete-folder"
                                                        onclick="removeFolder(event, @f.FolderId)">
                                                    Xóa
                                                </button>
                                            }
                                        </div>
                                    </article>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>

            <div id="tab-members" class="tab-content">
                <div class="content-shell">
                    <div class="section-header">
                        <div>
                            <h3>Thành viên</h3>
                            <p>Theo dõi vai trò và xử lý những thao tác quản lý cần thiết.</p>
                        </div>
                    </div>

                    <div class="member-list">
                        @foreach (var member in Model.Members)
                        {
                            <article class="member-item">
                                <div class="member-info-left">
                                    <img class="member-avatar-circle"
                                         src="@(string.IsNullOrEmpty(member.AvatarUrl)
                                             ? "/images/default-avatar.png"
                                             : member.AvatarUrl)"
                                         alt="@member.FullName" />

                                    <div>
                                        <div class="member-name-text">@member.FullName</div>

                                        <div class="member-role-badge">
                                            @if (member.UserId == Model.Class.OwnerId)
                                            {
                                                <span class="role owner">Trưởng nhóm</span>
                                            }
                                            else if (member.Role == TCTVocabulary.Models.ClassRole.Assistant)
                                            {
                                                <span class="role assistant">Phó nhóm</span>
                                            }
                                            else
                                            {
                                                <span class="role member">Thành viên</span>
                                            }

                                            @if (member.IsMuted)
                                            {
                                                <span class="role muted">Đã mute</span>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="dropdown-member">
                                    <button class="three-dots-btn"
                                            type="button"
                                            onclick="toggleMemberDropdown(event, @member.UserId)"
                                            aria-label="Thao tác thành viên">
                                        <i class="fas fa-ellipsis-h"></i>
                                    </button>

                                    <div id="dropdown-@member.UserId" class="dropdown-content-member">
                                        @if (member.UserId != Model.CurrentUserId
                                             && member.UserId != Model.Class.OwnerId
                                             && (Model.IsOwner
                                                 || Model.IsAdmin
                                                 || (Model.IsAssistant && member.Role == TCTVocabulary.Models.ClassRole.Member)))
                                        {
                                            @if (Model.IsOwner)
                                            {
                                                @if (member.Role == TCTVocabulary.Models.ClassRole.Member)
                                                {
                                                    <button type="button"
                                                            class="dropdown-action-btn"
                                                            onclick="changeMemberRole(@member.UserId, 1)">
                                                        Đặt làm phó nhóm
                                                    </button>
                                                }
                                                else if (member.Role == TCTVocabulary.Models.ClassRole.Assistant)
                                                {
                                                    <button type="button"
                                                            class="dropdown-action-btn"
                                                            onclick="changeMemberRole(@member.UserId, 0)">
                                                        Hạ xuống thành viên
                                                    </button>
                                                }
                                            }

                                            @if (!member.IsMuted)
                                            {
                                                <button type="button"
                                                        class="dropdown-action-btn warning"
                                                        onclick="toggleMuteMember(@member.UserId, true)">
                                                    Mute thành viên
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="dropdown-action-btn success"
                                                        onclick="toggleMuteMember(@member.UserId, false)">
                                                    Bỏ mute
                                                </button>
                                            }

                                            <button type="button"
                                                    class="delete-member-btn"
                                                    onclick="kickMember(@member.UserId)">
                                                Xóa khỏi lớp
                                            </button>

                                            @if (Model.IsOwner || Model.IsAdmin)
                                            {
                                                <button type="button"
                                                        class="delete-member-btn"
                                                        onclick="blockMember(@member.UserId)">
                                                    Xóa và chặn
                                                </button>
                                            }
                                        }
                                        else
                                        {
                                            <span class="no-action">Không có hành động</span>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            </div>

            <div id="tab-about" class="tab-content">
                <div class="content-shell">
                    <div class="section-header">
                        <div>
                            <h3>Thông tin lớp học</h3>
                            <p>Tổng quan nhanh về lớp và các cấu hình hiện tại.</p>
                        </div>
                    </div>

                    <div class="about-card">
                        <p class="about-description">@classDescription</p>

                        <div class="about-stats">
                            <div class="about-stat">
                                <span class="about-stat-label">Số lượng thành viên</span>
                                <strong>@Model.Members.Count</strong>
                            </div>

                            <div class="about-stat">
                                <span class="about-stat-label">Quyền vào lớp</span>
                                <strong>@(Model.Class.RequiresApproval ? "Cần phê duyệt" : "Vào trực tiếp")</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }

    @if (canViewContent)
    {
        <div id="addFolderModal" class="modal-overlay">
            <div class="modal-container">
                <div class="modal-header">
                    <h3>Thêm folder vào lớp</h3>

                    <button type="button"
                            class="close-btn"
                            onclick="closeAddFolderModal()">
                        ×
                    </button>
                </div>

                <div class="modal-section">
                    <h4>Folder của bạn</h4>

                    @foreach (var f in Model.MyFolders)
                    {
                        <div class="modal-folder-item"
                             onclick="addFolder(@f.FolderId)">
                            @f.FolderName
                        </div>
                    }

                    <h4 class="modal-subtitle">Folder đã lưu</h4>

                    @foreach (var f in Model.SavedFolders)
                    {
                        <div class="modal-folder-item"
                             onclick="addFolder(@f.FolderId)">
                            @f.FolderName
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div id="classActionModal" class="modal-overlay">
        <div class="modal-container">
            <div class="modal-header">
                <h3>Quản lý lớp học</h3>

                <button type="button"
                        class="close-btn"
                        onclick="closeClassActionModal()">
                    ×
                </button>
            </div>

            <div class="modal-actions stacked-actions">
                @if (Model.CanManageClass)
                {
                    <button class="btn-primary"
                            type="button"
                            onclick="openEditClassModal()">
                        Sửa thông tin và cài đặt
                    </button>

                    <button class="btn-delete-folder"
                            type="button"
                            onclick="deleteClass()">
                        Giải tán lớp
                    </button>
                }

                @if (Model.CanManageClass && Model.Class.RequiresApproval)
                {
                    <button class="btn-secondary"
                            type="button"
                            onclick="openJoinRequestsModal()">
                        Yêu cầu gia nhập
                    </button>
                }
                else if (Model.CanJoinClass)
                {
                    <button class="btn-primary"
                            type="button"
                            onclick="handleJoinClick(@Model.Class.ClassId, @(Model.Class.HasPassword.ToString().ToLower()))">
                        Tham gia lớp
                    </button>
                }
                else if (Model.IsMember && !Model.IsOwner)
                {
                    <button class="btn-secondary"
                            type="button"
                            onclick="leaveClass()">
                        Thoát lớp
                    </button>
                }

                <button class="btn-secondary"
                        type="button"
                        onclick="closeClassActionModal()">
                    Đóng
                </button>
            </div>
        </div>
    </div>

    @if (Model.CanManageClass)
    {
        <div id="editClassModal" class="modal-overlay">
            <div class="modal-container">
                <div class="modal-header">
                    <h3>Chỉnh sửa lớp học</h3>

                    <button type="button"
                            class="close-btn"
                            onclick="closeEditClassModal()">
                        ×
                    </button>
                </div>

                <div class="modal-section">
                    <label for="editClassName">Tên lớp</label>
                    <input type="text"
                           id="editClassName"
                           value="@Model.Class.ClassName" />
                </div>

                <div class="modal-section">
                    <label for="editClassDescription">Mô tả</label>
                    <textarea id="editClassDescription"
                              rows="4">@Model.Class.Description</textarea>
                </div>

                <div class="modal-section checkbox-list">
                    <label>
                        <input type="checkbox"
                               id="editRequiresApproval"
                        @(Model.Class.RequiresApproval ? "checked" : "") />
                        Yêu cầu phê duyệt khi tham gia
                    </label>

                    <label>
                        <input type="checkbox"
                               id="editIsChatLocked"
                        @(Model.Class.IsChatLocked ? "checked" : "") />
                        Khóa chat lớp
                    </label>

                    <label>
                        <input type="checkbox"
                               id="editAllowMemberToPost"
                        @(Model.Class.AllowMemberToPost ? "checked" : "") />
                        Cho phép thành viên thêm folder
                    </label>
                </div>

                <div class="modal-actions">
                    <button class="btn-primary"
                            type="button"
                            onclick="saveClassInfo()">
                        Lưu thay đổi
                    </button>

                    <button class="btn-secondary"
                            type="button"
                            onclick="closeEditClassModal()">
                        Hủy
                    </button>
                </div>
            </div>
        </div>
    }

    @if (Model.CanJoinClass)
    {
        <div id="joinClassModal" class="modal-overlay">
            <div class="modal-container">
                <div class="modal-header">
                    <h3>Nhập mật khẩu lớp</h3>

                    <button type="button"
                            class="close-btn"
                            onclick="closeJoinClassModal()">
                        ×
                    </button>
                </div>

                <div class="modal-section">
                    <input type="password"
                           id="joinClassPassword"
                           placeholder="Nhập mật khẩu lớp..." />
                </div>

                <div class="modal-actions">
                    <button class="btn-primary"
                            type="button"
                            onclick="confirmJoinClass()">
                        Tham gia
                    </button>

                    <button class="btn-secondary"
                            type="button"
                            onclick="closeJoinClassModal()">
                        Hủy
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.CanManageClass && Model.Class.RequiresApproval)
{
    <div id="joinRequestsModal" class="modal-overlay">
        @Html.AntiForgeryToken()
        <div class="modal-container">
            <div class="modal-header">
                <h3>Yêu cầu gia nhập lớp</h3>

                <button type="button"
                        class="close-btn"
                        onclick="closeJoinRequestsModal()">
                    ×
                </button>
            </div>

            <div class="modal-section">
                @if (Model.JoinRequests != null && Model.JoinRequests.Any())
                {
                    @foreach (var request in Model.JoinRequests)
                    {
                        <div class="request-item">
                            <div class="request-left">
                                <div class="request-name">@request.FullName</div>

                                @if (!string.IsNullOrEmpty(request.RequestMessage))
                                {
                                    <div class="request-message">@request.RequestMessage</div>
                                }
                            </div>

                            <div class="request-actions">
                                <button class="btn-primary"
                                        type="button"
                                        onclick="approveJoinRequest(@request.RequestId)">
                                    Accept
                                </button>

                                <button class="btn-delete-folder"
                                        type="button"
                                        onclick="declineJoinRequest(@request.RequestId)">
                                    Decline
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-box">
                        <p>Không có yêu cầu đang chờ.</p>
                    </div>
                }
            </div>
        </div>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="~/css/Class-Detail.css" />
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const classId = @Model.Class.ClassId;
        const currentUserId = @Model.CurrentUserId;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const approveJoinRequestUrl = '@Url.Action("ApproveJoinRequest", "Class")';
        const declineJoinRequestUrl = '@Url.Action("DeclineJoinRequest", "Class")';
    </script>

    <script src="~/js/Class-Detail.js"></script>
}
