@model TCTVocabulary.ViewModel.SpeakingPracticeViewModel
@{
    ViewData["Title"] = "Luyện phát âm — " + Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
    int totalCount = Model.Sentences.Count;
    int practicedCount = Model.Sentences.Count(s => s.IsPracticed);
    int progressPct = totalCount > 0 ? (int)Math.Round((double)practicedCount / totalCount * 100) : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/speaking.css" asp-append-version="true" />
}

<div class="spk-page">
    @Html.AntiForgeryToken()

    <!-- ══════════ TOP NAV BAR ══════════ -->
    <div class="spk-topnav">
        <a asp-controller="Speaking" asp-action="Index" class="spk-back-btn" title="Quay lại">
            <i class="fas fa-arrow-left"></i>
        </a>

        <!-- Pill Menu -->
        <div class="spk-pill-menu">
            <button class="spk-pill-btn spk-pill-active" id="tab-pronunciation">
                <i class="fas fa-microphone"></i> Phát âm
            </button>
            <button class="spk-pill-btn" id="tab-dictation">
                <i class="fas fa-headphones"></i> Chép chính tả
            </button>
        </div>

        <div class="spk-topnav-right">
            <!-- intentionally empty – reserved for future actions -->
        </div>
    </div>

    <!-- ══════════ MAIN 2-COLUMN GRID ══════════ -->
    <div class="spk-main-row">

        <!-- ╔══════════════════════════════════╗
             ║  LEFT COLUMN — Video + Progress  ║
             ╚══════════════════════════════════╝ -->
        <div class="spk-left-col">

            <!-- Video Player (16:9) -->
            <div class="spk-video-frame">
                <iframe src="https://www.youtube.com/embed/@Model.YoutubeId?enablejsapi=1"
                        id="youtube-player"
                        title="@Model.Title"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen></iframe>
                <!-- Black overlay — hides subtitles while keeping audio (toggled by Ẩn video button) -->
                <div class="spk-vid-overlay d-none" id="video-overlay"></div>
            </div>

            <!-- Overall Progress Bar -->
            <div class="spk-progress-card">
                <div class="spk-progress-header">
                    <span class="spk-progress-label">
                        Đã hoàn thành
                        <strong id="prog-text">@practicedCount / @totalCount</strong>
                    </span>
                    <span class="spk-progress-pct" id="prog-pct">@progressPct%</span>
                </div>
                <div class="spk-progress-track">
                    <div class="spk-progress-fill"
                         id="prog-bar"
                         style="width: @progressPct%"
                         role="progressbar"
                         aria-valuenow="@progressPct"
                         aria-valuemin="0"
                         aria-valuemax="100"></div>
                </div>
            </div>

        </div>
        <!-- /LEFT COLUMN -->

        <!-- ╔══════════════════════════════════════════════════════╗
             ║  RIGHT COLUMN — Pronunciation Practice & Scoring    ║
             ╚══════════════════════════════════════════════════════╝ -->
        <div class="spk-right-col">

            <!-- ─── PRONUNCIATION TAB ─── -->
            <div id="pronunciation-content" class="spk-right-pane">

                <!-- Pane header -->
                <div class="spk-pane-header">
                    <span class="spk-pane-title">Luyện phát âm</span>
                    <span class="spk-pane-counter" id="sent-indicator">(Câu hỏi 1/@totalCount)</span>
                </div>

                <!-- 1. Sentence Slider / Pagination -->
                <div class="spk-slider-wrapper">
                    <button class="spk-slider-arrow" id="btn-slider-prev" aria-label="Cuộn trái">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <div class="spk-slider-track" id="sentence-scroll-container">
                        @for (int i = 0; i < Model.Sentences.Count; i++)
                        {
                            var s = Model.Sentences[i];
                            var activeClass = i == 0 ? "spk-sent-btn--active" : "";
                            var practicedClass = s.IsPracticed ? "spk-sent-btn--done" : "";
                            <button type="button"
                                    class="spk-sent-btn @activeClass @practicedClass"
                                    data-index="@i"
                                    data-start="@s.StartTime"
                                    data-end="@s.EndTime"
                                    title="Câu @(i + 1)">
                                <span>@(i + 1)</span>
                                @if (s.IsPracticed)
                                {
                                    <i class="fas fa-check spk-done-check"></i>
                                }
                            </button>
                        }
                    </div>
                    <button class="spk-slider-arrow" id="btn-slider-next" aria-label="Cuộn phải">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>

                <!-- 2. Transcript Card -->
                <div class="spk-transcript-card">
                    <div class="spk-transcript-label">CÂU HIỆN TẠI</div>
                    <button class="spk-hide-text-btn" id="btn-hide-text">Ẩn</button>
                    <div class="spk-transcript-text" id="current-transcript-en" style="min-height: 56px;">
                        Chọn một câu để bắt đầu luyện tập
                    </div>
                    <div class="spk-transcript-vi d-none" id="current-transcript-vi"></div>
                </div>

                <!-- 3. Action Buttons Row -->
                <div class="spk-action-row">
                    <!-- Prev -->
                    <div class="spk-action-col">
                        <button class="spk-btn spk-btn--nav" id="btn-prev" title="Câu trước (Shift+←)">
                            <i class="fas fa-chevron-left"></i>
                            <span>Trước</span>
                        </button>
                        <span class="spk-shortcut">Shift+←</span>
                    </div>

                    <!-- Center: Replay + Record -->
                    <div class="spk-action-col spk-action-col--center">
                        <div class="spk-center-btns">
                            <div class="spk-center-btn-wrap">
                                <button class="spk-btn spk-btn--replay" id="btn-replay" title="Phát lại (Space)">
                                    <i class="fas fa-volume-up"></i>
                                </button>
                                <span class="spk-shortcut">Space</span>
                            </div>
                            <div class="spk-center-btn-wrap">
                                <button class="spk-btn spk-btn--record" id="btn-record" title="Kiểm tra phát âm (Enter)">
                                    <i class="fas fa-microphone" id="record-icon"></i>
                                    <span id="record-label">Kiểm tra phát âm</span>
                                </button>
                                <span class="spk-shortcut">Enter</span>
                            </div>
                        </div>
                    </div>

                    <!-- Next -->
                    <div class="spk-action-col">
                        <button class="spk-btn spk-btn--nav spk-btn--nav-next" id="btn-next" title="Câu tiếp (Tab)">
                            <span>Tiếp</span>
                            <i class="fas fa-chevron-right"></i>
                        </button>
                        <span class="spk-shortcut">Tab / →</span>
                    </div>
                </div>

                <!-- 4. Score Panel (2×2 grid with circular mini-progress) -->
                <div class="spk-score-panel">
                    <div class="spk-score-grid">

                        <div class="spk-score-cell spk-score-cell--border-right spk-score-cell--border-bottom">
                            <div class="spk-score-content">
                                <div class="spk-score-ring-wrap">
                                    <svg class="spk-ring" viewBox="0 0 36 36" aria-hidden="true">
                                        <circle class="spk-ring-bg" cx="18" cy="18" r="15.9"/>
                                        <circle class="spk-ring-fill" id="ring-total" cx="18" cy="18" r="15.9"
                                                stroke-dasharray="0, 100"/>
                                    </svg>
                                    <span class="spk-score-val" id="score-total">0.0</span>
                                </div>
                                <div class="spk-score-info">
                                    <div class="spk-score-name">Điểm phát âm</div>
                                    <div class="spk-score-bar-track">
                                        <div class="spk-score-bar-fill" id="bar-total" style="width:0%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="spk-score-cell spk-score-cell--border-bottom">
                            <div class="spk-score-content">
                                <div class="spk-score-ring-wrap">
                                    <svg class="spk-ring" viewBox="0 0 36 36" aria-hidden="true">
                                        <circle class="spk-ring-bg" cx="18" cy="18" r="15.9"/>
                                        <circle class="spk-ring-fill spk-ring-fill--blue" id="ring-accuracy" cx="18" cy="18" r="15.9"
                                                stroke-dasharray="0, 100"/>
                                    </svg>
                                    <span class="spk-score-val" id="score-accuracy">0.0</span>
                                </div>
                                <div class="spk-score-info">
                                    <div class="spk-score-name">Độ chính xác</div>
                                    <div class="spk-score-bar-track">
                                        <div class="spk-score-bar-fill spk-score-bar-fill--blue" id="bar-accuracy" style="width:0%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="spk-score-cell spk-score-cell--border-right">
                            <div class="spk-score-content">
                                <div class="spk-score-ring-wrap">
                                    <svg class="spk-ring" viewBox="0 0 36 36" aria-hidden="true">
                                        <circle class="spk-ring-bg" cx="18" cy="18" r="15.9"/>
                                        <circle class="spk-ring-fill spk-ring-fill--amber" id="ring-fluency" cx="18" cy="18" r="15.9"
                                                stroke-dasharray="0, 100"/>
                                    </svg>
                                    <span class="spk-score-val" id="score-fluency">0.0</span>
                                </div>
                                <div class="spk-score-info">
                                    <div class="spk-score-name">Độ trôi chảy</div>
                                    <div class="spk-score-bar-track">
                                        <div class="spk-score-bar-fill spk-score-bar-fill--amber" id="bar-fluency" style="width:0%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="spk-score-cell">
                            <div class="spk-score-content">
                                <div class="spk-score-ring-wrap">
                                    <svg class="spk-ring" viewBox="0 0 36 36" aria-hidden="true">
                                        <circle class="spk-ring-bg" cx="18" cy="18" r="15.9"/>
                                        <circle class="spk-ring-fill spk-ring-fill--purple" id="ring-complete" cx="18" cy="18" r="15.9"
                                                stroke-dasharray="0, 100"/>
                                    </svg>
                                    <span class="spk-score-val" id="score-complete">0.0</span>
                                </div>
                                <div class="spk-score-info">
                                    <div class="spk-score-name">Độ hoàn thiện</div>
                                    <div class="spk-score-bar-track">
                                        <div class="spk-score-bar-fill spk-score-bar-fill--purple" id="bar-complete" style="width:0%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div><!-- /spk-score-grid -->
                </div><!-- /spk-score-panel -->

            </div><!-- /pronunciation-content -->

            <!-- ─── DICTATION TAB ─── -->
            <div id="dictation-content" class="spk-right-pane d-none">

                <!-- Pane header -->
                <div class="spk-pane-header">
                    <span class="spk-pane-title">Chép chính tả</span>
                    <span class="spk-pane-counter" id="dic-sent-indicator">(Câu hỏi 1/@totalCount)</span>
                </div>

                <!-- Ẩn video quick control -->
                <div class="spk-dic-quick-row">
                    <button class="spk-vid-ctrl-btn" id="btn-dic-hide-video">
                        <i class="fas fa-eye-slash"></i> Ẩn video
                    </button>
                </div>

                <!-- Sentence slider -->
                <div class="spk-slider-wrapper">
                    <button class="spk-slider-arrow" id="btn-dic-slider-prev" aria-label="Cuộn trái">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <div class="spk-slider-track" id="dic-sentence-scroll-container">
                        @for (int j = 0; j < Model.Sentences.Count; j++)
                        {
                            var dicSent = Model.Sentences[j];
                            var dicActive = j == 0 ? "spk-sent-btn--active" : "";
                            <button type="button"
                                    class="spk-sent-btn spk-sent-btn--wide @dicActive"
                                    data-dic-index="@j"
                                    data-start="@dicSent.StartTime"
                                    data-end="@dicSent.EndTime"
                                    title="Câu @(j + 1)">
                                Câu: @(j + 1)
                            </button>
                        }
                    </div>
                    <button class="spk-slider-arrow" id="btn-dic-slider-next" aria-label="Cuộn phải">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>

                <!-- Typing area -->
                <textarea class="spk-dic-input"
                          id="dic-input"
                          placeholder="Nhập những gì bạn nghe được..."
                          autocomplete="off"
                          autocorrect="off"
                          autocapitalize="off"
                          spellcheck="false"
                          rows="3"></textarea>

                <!-- Real-time masked feedback (JS will rebuild this dynamically) -->
                <div class="spk-dic-feedback" id="dic-feedback">
                    <!-- Mock spans for styling preview -->
                    <span class="spk-dic-word spk-dic-word--done">
                        <span class="char-correct">O</span><span class="char-correct">n</span><span class="char-correct">e</span>
                    </span>
                    <span class="spk-dic-word spk-dic-word--active">
                        <span class="char-correct">t</span><span class="char-correct">w</span><span class="char-untyped">*</span>
                    </span>
                    <span class="spk-dic-word">
                        <span class="char-untyped">*</span>
                    </span>
                    <span class="spk-dic-word">
                        <span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span>
                    </span>
                    <span class="spk-dic-word">
                        <span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span>
                    </span>
                    <span class="spk-dic-word">
                        <span class="char-untyped">*</span><span class="char-untyped">*</span>
                    </span>
                    <span class="spk-dic-word">
                        <span class="char-incorrect">t</span><span class="char-incorrect">r</span>
                    </span>
                    <span class="spk-dic-word">
                        <span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span>
                    </span>
                    <span class="spk-dic-word">
                        <span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span><span class="char-untyped">*</span>
                    </span>
                </div>

                <!-- Bottom action bar: [Hint] [Play/Pause] [Next] -->
                <div class="spk-dic-action-bar">
                    <button class="spk-dic-hint-btn" id="btn-dic-hint" title="Gợi ý (H)">
                        <i class="fas fa-lightbulb"></i>
                    </button>
                    <button class="spk-dic-play-btn" id="btn-dic-play" title="Phát / Dừng (Space)">
                        <i class="fas fa-play" id="dic-play-icon"></i>
                        <span id="dic-play-label">Phát lại</span>
                    </button>
                    <button class="spk-btn spk-btn--nav spk-btn--nav-next spk-dic-next-btn" id="btn-dic-next" title="Câu tiếp (Tab)">
                        <span>Tiếp</span>
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>

            </div>

        </div>
        <!-- /RIGHT COLUMN -->

    </div>
    <!-- /row -->

</div>
<!-- /spk-page -->

<!-- Toast -->
<div class="spk-toast" id="spk-toast"></div>

@section Scripts {
    <script>
        // ── Data bridge (Razor → JS) ──────────────────────────────
        window.SPK_VIDEO_ID  = '@Model.YoutubeId';
        window.SPK_SENTENCES = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                Model.Sentences.Select(s => new {
                    id                = s.Id,
                    start             = s.StartTime,
                    end               = s.EndTime,
                    text              = s.Text,
                    vi                = s.VietnameseMeaning,
                    totalScore        = s.TotalScore,
                    accuracyScore     = s.AccuracyScore,
                    fluencyScore      = s.FluencyScore,
                    completenessScore = s.CompletenessScore,
                    isPracticed       = s.IsPracticed
                })
            )
        );
    </script>
    <script src="~/js/speaking.js" asp-append-version="true"></script>
}
