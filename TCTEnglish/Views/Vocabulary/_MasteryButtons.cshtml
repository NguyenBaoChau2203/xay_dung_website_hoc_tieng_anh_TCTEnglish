@model dynamic
@* Mastery buttons - compact horizontal layout for single-viewport study page *@
<div class="mastery-buttons">
    <button class="mastery-btn hard" onclick="recordMastery('hard')">
        <i class="fas fa-frown"></i>
        <div class="btn-content">
            <span class="btn-label">Học lại</span>
            <span class="btn-desc">< 10 phút</span>
        </div>
        <span class="btn-shortcut">1</span>
    </button>

    <button class="mastery-btn good" onclick="recordMastery('good')">
        <i class="fas fa-meh"></i>
        <div class="btn-content">
            <span class="btn-label">Khó</span>
            <span class="btn-desc">1-12 giờ</span>
        </div>
        <span class="btn-shortcut">2</span>
    </button>

    <button class="mastery-btn easy" onclick="recordMastery('easy')">
        <i class="fas fa-smile"></i>
        <div class="btn-content">
            <span class="btn-label">Tốt</span>
            <span class="btn-desc">1-3 ngày</span>
        </div>
        <span class="btn-shortcut">3</span>
    </button>

    <button class="mastery-btn perfect" onclick="recordMastery('perfect')">
        <i class="fas fa-grin-stars"></i>
        <div class="btn-content">
            <span class="btn-label">Dễ</span>
            <span class="btn-desc">3-7 ngày</span>
        </div>
        <span class="btn-shortcut">4</span>
    </button>
</div>