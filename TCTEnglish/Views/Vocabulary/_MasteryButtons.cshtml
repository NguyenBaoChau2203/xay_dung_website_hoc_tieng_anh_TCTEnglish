<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<style>
    .mastery-buttons {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        margin: 20px 0;
        font-family: 'Segoe UI', Roboto, system-ui, -apple-system, sans-serif;
    }

    .mastery-btn {
        flex: 1 1 180px;
        min-width: 160px;
        border: none;
        border-radius: 24px;
        padding: 16px 12px 16px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        position: relative;
        border: 1px solid rgba(0, 0, 0, 0.03);
    }

        .mastery-btn i {
            font-size: 30px;
            width: 40px;
            text-align: center;
            filter: drop-shadow(0 2px 2px rgba(0,0,0,0.1));
        }

    .btn-content {
        flex: 1;
        text-align: left;
    }

    .btn-label {
        display: block;
        font-weight: 600;
        font-size: 1.1rem;
        line-height: 1.3;
        letter-spacing: -0.01em;
    }

    .btn-desc {
        display: block;
        font-size: 0.75rem;
        opacity: 0.75;
        font-weight: 500;
        margin-top: 2px;
    }

    .btn-shortcut {
        position: absolute;
        top: 10px;
        right: 12px;
        background: rgba(0, 0, 0, 0.08);
        width: 26px;
        height: 26px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 700;
        color: inherit;
        transition: background 0.2s;
    }

    /* Màu sắc theo từng mức độ */
    .mastery-btn.hard {
        background: #ffe9e9;
        color: #b33939;
    }

        .mastery-btn.hard:hover {
            background: #ffd6d6;
            box-shadow: 0 8px 16px rgba(179, 57, 57, 0.15);
            transform: translateY(-2px);
        }

            .mastery-btn.hard:hover .btn-shortcut {
                background: rgba(179, 57, 57, 0.15);
            }

    .mastery-btn.good {
        background: #fff0e0;
        color: #cc5f2c;
    }

        .mastery-btn.good:hover {
            background: #ffe4cc;
            box-shadow: 0 8px 16px rgba(204, 95, 44, 0.15);
            transform: translateY(-2px);
        }

            .mastery-btn.good:hover .btn-shortcut {
                background: rgba(204, 95, 44, 0.15);
            }

    .mastery-btn.easy {
        background: #e3f1e4;
        color: #2e7d32;
    }

        .mastery-btn.easy:hover {
            background: #d0e7d2;
            box-shadow: 0 8px 16px rgba(46, 125, 50, 0.15);
            transform: translateY(-2px);
        }

            .mastery-btn.easy:hover .btn-shortcut {
                background: rgba(46, 125, 50, 0.15);
            }

    .mastery-btn.perfect {
        background: #e1efff;
        color: #1e5f9e;
    }

        .mastery-btn.perfect:hover {
            background: #cde2fd;
            box-shadow: 0 8px 16px rgba(30, 95, 158, 0.15);
            transform: translateY(-2px);
        }

            .mastery-btn.perfect:hover .btn-shortcut {
                background: rgba(30, 95, 158, 0.15);
            }


</style>

<div class="mastery-buttons">
    <button class="mastery-btn hard" onclick="recordMastery('hard')">
        <i class="fas fa-frown"></i>
        <div class="btn-content">
            <span class="btn-label">Học lại</span>
            <span class="btn-desc">< 10 phút</span>
        </div>
        <span class="btn-shortcut">1</span>
    </button>

    <button class="mastery-btn good" onclick="recordMastery('good')">
        <i class="fas fa-meh"></i>
        <div class="btn-content">
            <span class="btn-label">Khó</span>
            <span class="btn-desc">1-12 giờ</span>
        </div>
        <span class="btn-shortcut">2</span>
    </button>

    <button class="mastery-btn easy" onclick="recordMastery('easy')">
        <i class="fas fa-smile"></i>
        <div class="btn-content">
            <span class="btn-label">Tốt</span>
            <span class="btn-desc">1-3 ngày</span>
        </div>
        <span class="btn-shortcut">3</span>
    </button>

    <button class="mastery-btn perfect" onclick="recordMastery('perfect')">
        <i class="fas fa-grin-stars"></i>
        <div class="btn-content">
            <span class="btn-label">Dễ</span>
            <span class="btn-desc">3-7 ngày</span>
        </div>
        <span class="btn-shortcut">4</span>
    </button>
</div>