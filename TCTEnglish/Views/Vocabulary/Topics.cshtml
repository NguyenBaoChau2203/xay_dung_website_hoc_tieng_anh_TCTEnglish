@model TCTVocabulary.ViewModels.VocabularyTopicsViewModel
@using System.Linq
@{
    ViewData["Title"] = Model.Set.SetName + " - Danh sách chủ đề";

    var topics = Model.Topics;
    var totalCards = Model.Stats.TotalCards;
    var totalLearned = Model.Stats.LearnedCards;
    var overallProgress = Model.Stats.Accuracy;
}

@section Styles {
    <link rel="stylesheet" href="~/css/vocabulary-system.css" />
    <style>
        /* Modern Topics Page - Navy & White Theme */
        :root {
            --navy-dark: #0A2647;
            --navy-medium: #1B3A5C;
            --navy-light: #2C4E71;
            --navy-mist: #E8F0FE;
            --white: #FFFFFF;
            --off-white: #F8FAFC;
            --gray-light: #E2E8F0;
            --gray: #94A3B8;
            --accent-blue: #2563EB;
            --success: #10B981;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, var(--off-white) 0%, var(--white) 100%);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
        }

        /* Container */
        .topics-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 2rem;
        }

        /* Back Link */
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.625rem;
            padding: 0.625rem 1.25rem;
            background: var(--white);
            color: var(--navy-dark);
            text-decoration: none;
            font-size: 0.9375rem;
            font-weight: 500;
            border-radius: 100px;
            border: 1px solid var(--gray-light);
            margin-bottom: 2rem;
            transition: all 0.2s ease;
            box-shadow: 0 2px 4px rgba(10, 38, 71, 0.02);
        }

            .back-link:hover {
                border-color: var(--navy-dark);
                background: var(--navy-dark);
                color: var(--white);
                transform: translateX(-4px);
                box-shadow: 0 4px 12px rgba(10, 38, 71, 0.1);
            }

            .back-link i {
                font-size: 0.875rem;
            }

        /* Header Section */
        .header-section {
            margin-bottom: 2.5rem;
        }

        .set-title {
            font-size: 2.25rem;
            font-weight: 700;
            color: var(--navy-dark);
            margin-bottom: 0.75rem;
            line-height: 1.2;
        }

        .set-description {
            color: var(--navy-light);
            font-size: 1rem;
            opacity: 0.9;
            max-width: 600px;
        }

        /* Progress Card */
        .progress-card {
            background: var(--white);
            border-radius: 28px;
            padding: 2rem;
            margin-bottom: 2.5rem;
            border: 1px solid var(--gray-light);
            box-shadow: 0 8px 24px rgba(10, 38, 71, 0.04);
            display: flex;
            align-items: center;
            gap: 2.5rem;
        }

        /* Circular Progress */
        .circular-progress {
            width: 120px;
            height: 120px;
            position: relative;
        }

            .circular-progress svg {
                width: 100%;
                height: 100%;
                transform: rotate(-90deg);
            }

        .progress-bg {
            stroke: var(--gray-light);
            stroke-width: 6;
            fill: none;
        }

        .progress-fill {
            stroke: var(--navy-dark);
            stroke-width: 6;
            fill: none;
            stroke-linecap: round;
            stroke-dasharray: 314.16;
            stroke-dashoffset: @(314.16 - (314.16 * overallProgress / 100));
            transition: stroke-dashoffset 0.5s ease;
        }

        .progress-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }

        .progress-percent {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--navy-dark);
            line-height: 1;
        }

        .progress-label {
            font-size: 0.75rem;
            color: var(--gray);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Stats Grid */
        .stats-grid {
            flex: 1;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }

        .stat-item {
            display: flex;
            flex-direction: column;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--navy-dark);
            line-height: 1.2;
        }

        .stat-label {
            font-size: 0.875rem;
            color: var(--gray);
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .stat-divider {
            width: 1px;
            height: 40px;
            background: var(--gray-light);
        }

        /* Section Title */
        .section-title {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

            .section-title h2 {
                font-size: 1.25rem;
                font-weight: 600;
                color: var(--navy-dark);
            }

        .topic-count-badge {
            background: var(--navy-mist);
            color: var(--navy-dark);
            padding: 0.25rem 0.75rem;
            border-radius: 100px;
            font-size: 0.875rem;
            font-weight: 500;
        }

        /* Topics List */
        .topics-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .topic-card {
            background: var(--white);
            border-radius: 20px;
            padding: 1.25rem;
            border: 1px solid var(--gray-light);
            text-decoration: none;
            color: inherit;
            transition: all 0.2s ease;
            display: block;
        }

            .topic-card:hover {
                border-color: var(--navy-dark);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(10, 38, 71, 0.08);
            }

        .topic-content {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .topic-icon {
            width: 56px;
            height: 56px;
            background: var(--navy-mist);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--navy-dark);
            font-size: 1.75rem;
            transition: all 0.2s ease;
        }

        .topic-card:hover .topic-icon {
            background: var(--navy-dark);
            color: var(--white);
        }

        .topic-info {
            flex: 1;
            min-width: 0;
        }

        .topic-name {
            font-size: 1.125rem;
            font-weight: 600;
            color: var(--navy-dark);
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .topic-meta {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            color: var(--gray);
            font-size: 0.875rem;
        }

            .topic-meta i {
                margin-right: 0.375rem;
                color: var(--navy-dark);
                opacity: 0.5;
            }

        .progress-indicator {
            display: flex;
            align-items: center;
            gap: 1rem;
            min-width: 220px;
        }

        .progress-track {
            flex: 1;
            height: 6px;
            background: var(--gray-light);
            border-radius: 100px;
            overflow: hidden;
        }

        .progress-track-fill {
            height: 100%;
            background: var(--navy-dark);
            border-radius: 100px;
            width: 0%;
            transition: width 0.3s ease;
        }

        .progress-stats {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.875rem;
        }

        .learned-count {
            font-weight: 600;
            color: var(--navy-dark);
        }

        .total-count {
            color: var(--gray);
        }

        .progress-value {
            font-weight: 600;
            color: var(--navy-dark);
            min-width: 45px;
            text-align: right;
        }

        .arrow-icon {
            color: var(--gray);
            font-size: 0.875rem;
            transition: all 0.2s ease;
        }

        .topic-card:hover .arrow-icon {
            color: var(--navy-dark);
            transform: translateX(4px);
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: var(--white);
            border-radius: 28px;
            border: 1px dashed var(--gray-light);
        }

        .empty-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        .empty-state h3 {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--navy-dark);
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            color: var(--gray);
            margin-bottom: 1.5rem;
        }

        .btn-add {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--navy-dark);
            color: var(--white);
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 500;
            border: none;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .btn-add:hover {
                background: var(--navy-medium);
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(10, 38, 71, 0.2);
            }

        /* Responsive */
        @@media (max-width: 768px) {
            .topics-container {
                padding: 1.5rem;
            }

            .progress-card {
                flex-direction: column;
                text-align: center;
                gap: 1.5rem;
                padding: 1.5rem;
            }

            .stats-grid {
                width: 100%;
            }

            .topic-content {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            .topic-meta {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.5rem;
            }

            .progress-indicator {
                width: 100%;
                min-width: 0;
            }
        }

        @@media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
                gap: 1rem;
                text-align: center;
            }

            .stat-divider {
                display: none;
            }

            .topic-name {
                flex-wrap: wrap;
            }
        }

        /* Animations */
        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .topic-card {
            animation: fadeIn 0.3s ease-out forwards;
        }
    </style>
}

<div class="topics-container">
    <!-- Back Link -->
    <a href="@Url.Action("Detail", "Vocabulary", new { setId = Model.Set.SetId })" class="back-link">
        <i class="fas fa-arrow-left"></i>
        <span>Quay lại</span>
    </a>

    <!-- Header -->
    <div class="header-section">
        <h1 class="set-title">@Model.Set.SetName</h1>
        @if (!string.IsNullOrEmpty(Model.Set.Description))
        {
            <p class="set-description">@Model.Set.Description</p>
        }
    </div>

    

    <!-- Topics Section -->
    <div class="section-title">
        <h2>Danh sách chủ đề</h2>
        <span class="topic-count-badge">@topics.Count chủ đề</span>
    </div>

    @if (topics.Any())
    {
        <div class="topics-list">
            @foreach (var topic in topics)
            {
                <a href="@Url.Action("TopicDetail", "Vocabulary", new { setId = Model.Set.SetId, topic = topic.TopicName })"
                   class="topic-card">
                    <div class="topic-content">
                        <div class="topic-icon">
                            <i class="fas fa-layer-group"></i>
                        </div>

                        <div class="topic-info">
                            <div class="topic-name">
                                <span>@topic.TopicName</span>
                            </div>

                            <div class="topic-meta">
                                <span>
                                    <i class="fas fa-book"></i>
                                    @topic.TotalCards thẻ
                                </span>
                                <span>
                                    <i class="fas fa-check-circle"></i>
                                    @topic.LearnedCards đã học
                                </span>
                            </div>
                        </div>

                        <div class="progress-indicator">
                            <div class="progress-track">
                                <div class="progress-track-fill" style="width: @topic.Progress%"></div>
                            </div>
                            <div class="progress-stats">
                                <span class="learned-count">@topic.LearnedCards</span>
                                <span class="total-count">/@topic.TotalCards</span>
                            </div>
                            <span class="progress-value">@(topic.Progress > 0 ? topic.Progress + "%" : "—")</span>
                            <i class="fas fa-chevron-right arrow-icon"></i>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">📚</div>
            <h3>Chưa có chủ đề nào</h3>
            <p>Bộ từ vựng này chưa được phân loại theo chủ đề.</p>
            <button class="btn-add" onclick="alert('Chức năng đang phát triển')">
                <i class="fas fa-plus"></i>
                <span>Thêm chủ đề mới</span>
            </button>
        </div>
    }
</div>