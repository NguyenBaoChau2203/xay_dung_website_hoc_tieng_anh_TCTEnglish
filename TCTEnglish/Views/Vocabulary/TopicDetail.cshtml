@model TCTVocabulary.ViewModels.VocabularyTopicDetailViewModel
@{
    var topicName = Model.Topic.TopicName;
    ViewData["Title"] = topicName;

    var totalCards = Model.Stats.TotalCards;
    var learnedCards = Model.Stats.LearnedCards;
    var progress = Model.Topic.Progress;
    var newCards = Model.Stats.NewCards;
    var reviewingCards = Model.Stats.ReviewingCards;
    var masteredCards = Model.Stats.MasteredCards;
}

@section Styles {
    <link rel="stylesheet" href="~/css/vocabulary-system.css" />
    <style>
        /* Compact Topic Detail - Navy & White Theme */
        :root {
            --navy-dark: #0A2647;
            --navy-medium: #1B3A5C;
            --navy-light: #2C4E71;
            --navy-mist: #E8F0FE;
            --white: #FFFFFF;
            --off-white: #F8FAFC;
            --gray-light: #E2E8F0;
            --gray: #94A3B8;
            --gray-dark: #475569;
            --success: #10B981;
            --warning: #F59E0B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, var(--off-white) 0%, var(--white) 100%);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
        }

        /* Container - Rộng hơn để hiển thị nhiều thẻ */
        .topic-detail {
            max-width: 1200px;
            margin: 0 auto;
            padding: 1.5rem;
        }

        /* Back Link - Nhỏ gọn */
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: var(--white);
            color: var(--navy-dark);
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
            border-radius: 100px;
            border: 1px solid var(--gray-light);
            margin-bottom: 1.5rem;
            transition: all 0.2s ease;
        }

            .back-link:hover {
                border-color: var(--navy-dark);
                background: var(--navy-dark);
                color: var(--white);
                transform: translateX(-4px);
            }

        /* Header - Nhỏ gọn */
        .topic-header {
            margin-bottom: 1.5rem;
        }

        .title-wrapper {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .title-main {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

            .title-main h1 {
                font-size: 1.75rem;
                font-weight: 700;
                color: var(--navy-dark);
                margin: 0;
            }

        .topic-meta-badge {
            background: var(--navy-mist);
            color: var(--navy-dark);
            padding: 0.25rem 0.75rem;
            border-radius: 100px;
            font-size: 0.8rem;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }

        /* Status Cards - Nhỏ gọn hơn */
        .status-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

        .status-card {
            background: var(--white);
            border-radius: 16px;
            padding: 1rem;
            border: 1px solid var(--gray-light);
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

            .status-card:hover {
                border-color: var(--navy-dark);
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(10, 38, 71, 0.06);
            }

        .status-icon {
            width: 36px;
            height: 36px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .status-card.new .status-icon {
            background: var(--navy-mist);
            color: var(--navy-dark);
        }

        .status-card.reviewing .status-icon {
            background: #FEF3C7;
            color: var(--warning);
        }

        .status-card.mastered .status-icon {
            background: #D1FAE5;
            color: var(--success);
        }

        .status-info {
            flex: 1;
        }

        .status-value {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--navy-dark);
            line-height: 1.2;
        }

        .status-label {
            font-size: 0.75rem;
            color: var(--gray);
        }

        /* Progress Action Card - Nhỏ gọn */
        .progress-action-card {
            background: var(--white);
            border-radius: 20px;
            padding: 1.25rem;
            border: 1px solid var(--gray-light);
            box-shadow: 0 4px 12px rgba(10, 38, 71, 0.04);
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        /* Circular Progress - Nhỏ hơn */
        .progress-circle {
            width: 80px;
            height: 80px;
            position: relative;
            flex-shrink: 0;
        }

            .progress-circle svg {
                width: 100%;
                height: 100%;
                transform: rotate(-90deg);
            }

        .circle-bg {
            stroke: var(--gray-light);
            stroke-width: 5;
            fill: none;
        }

        .circle-fill {
            stroke: var(--navy-dark);
            stroke-width: 5;
            fill: none;
            stroke-linecap: round;
            stroke-dasharray: 219.8;
            transition: stroke-dashoffset 0.5s ease;
        }

        .progress-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }

        .progress-percent {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--navy-dark);
            line-height: 1;
        }

        .progress-label {
            font-size: 0.6rem;
            color: var(--gray);
            text-transform: uppercase;
        }

        /* Progress Stats - Nhỏ gọn */
        .progress-stats {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .stat-block {
            display: flex;
            flex-direction: column;
        }

            .stat-block .value {
                font-size: 1.25rem;
                font-weight: 700;
                color: var(--navy-dark);
                line-height: 1.2;
            }

            .stat-block .label {
                font-size: 0.75rem;
                color: var(--gray);
            }

        /* Action Buttons - Nhỏ gọn */
        .action-buttons {
            display: flex;
            gap: 0.75rem;
            flex-shrink: 0;
        }

        .btn-primary, .btn-secondary {
            padding: 0.6rem 1.25rem;
            border-radius: 12px;
            font-size: 0.875rem;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .btn-primary {
            background: var(--navy-dark);
            color: var(--white);
            border: 1px solid transparent;
        }

            .btn-primary:hover {
                background: var(--navy-medium);
                transform: translateY(-2px);
                box-shadow: 0 4px 10px rgba(10, 38, 71, 0.2);
            }

        .btn-secondary {
            background: var(--white);
            color: var(--navy-dark);
            border: 1px solid var(--navy-dark);
        }

            .btn-secondary:hover {
                background: var(--navy-mist);
                transform: translateY(-2px);
            }

        /* Section Title - Nhỏ gọn */
        .section-title {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

            .section-title h2 {
                font-size: 1.1rem;
                font-weight: 600;
                color: var(--navy-dark);
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

                .section-title h2 i {
                    font-size: 0.9rem;
                    background: var(--navy-mist);
                    padding: 0.4rem;
                    border-radius: 10px;
                }

        .card-count {
            background: var(--navy-mist);
            color: var(--navy-dark);
            padding: 0.25rem 0.75rem;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 500;
        }

        /* Cards List - Grid layout để hiển thị nhiều thẻ */
        .cards-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 0.75rem;
        }

        /* Card Item - Nhỏ gọn */
        .card-item {
            background: var(--white);
            border-radius: 16px;
            padding: 1rem;
            border: 1px solid var(--gray-light);
            transition: all 0.2s ease;
            animation: fadeIn 0.3s ease-out forwards;
            display: flex;
            flex-direction: column;
        }

            .card-item:hover {
                border-color: var(--navy-dark);
                box-shadow: 0 4px 12px rgba(10, 38, 71, 0.06);
                transform: translateY(-2px);
            }

        /* Card Header - Nhỏ gọn */
        .card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .term-wrapper {
            flex: 1;
            min-width: 0; /* Tránh tràn chữ */
        }

        .term {
            font-size: 1rem;
            font-weight: 600;
            color: var(--navy-dark);
            display: block;
            margin-bottom: 0.15rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .phonetic {
            font-size: 0.7rem;
            color: var(--gray);
            font-family: 'Monaco', 'Menlo', monospace;
            display: inline-block;
            background: var(--off-white);
            padding: 0.15rem 0.5rem;
            border-radius: 100px;
            border: 1px solid var(--gray-light);
        }

        /* Status Badge - Nhỏ gọn */
        .status-badge {
            padding: 0.2rem 0.6rem;
            border-radius: 100px;
            font-size: 0.6rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            white-space: nowrap;
            flex-shrink: 0;
        }

            .status-badge.new {
                background: var(--navy-mist);
                color: var(--navy-dark);
            }

            .status-badge.reviewing {
                background: #FEF3C7;
                color: var(--warning);
            }

            .status-badge.mastered {
                background: #D1FAE5;
                color: var(--success);
            }

        /* Card Content - Nhỏ gọn */
        .card-content {
            font-size: 0.85rem;
        }

        .definition {
            color: var(--gray-dark);
            margin-bottom: 0.5rem;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .example {
            font-size: 0.8rem;
            color: var(--gray);
            font-style: italic;
            padding: 0.4rem 0.6rem;
            background: var(--off-white);
            border-radius: 8px;
            margin-bottom: 0.3rem;
            border-left: 2px solid var(--navy-dark);
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .example-translation {
            font-size: 0.75rem;
            color: var(--gray);
            padding-left: 0.6rem;
            margin-bottom: 0.3rem;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

            .example-translation i {
                font-size: 0.6rem;
                margin-right: 0.3rem;
                color: var(--navy-dark);
            }

        .card-image {
            max-width: 100%;
            max-height: 60px;
            border-radius: 8px;
            margin-top: 0.5rem;
            object-fit: cover;
            border: 1px solid var(--gray-light);
        }

        /* Empty State - Nhỏ gọn */
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            background: var(--white);
            border-radius: 20px;
            border: 1px dashed var(--gray-light);
            grid-column: 1 / -1;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 0.5rem;
            opacity: 0.5;
        }

        .empty-state h3 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--navy-dark);
            margin-bottom: 0.25rem;
        }

        .empty-state p {
            font-size: 0.85rem;
            color: var(--gray);
            margin-bottom: 1rem;
        }

        /* Animations */
        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .topic-detail {
                padding: 1rem;
            }

            .progress-action-card {
                flex-direction: column;
                text-align: center;
                gap: 1rem;
                padding: 1rem;
            }

            .progress-stats {
                width: 100%;
                justify-content: center;
            }

            .action-buttons {
                width: 100%;
                flex-direction: column;
            }

            .btn-primary, .btn-secondary {
                width: 100%;
                justify-content: center;
            }

            .cards-list {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 480px) {
            .status-grid {
                grid-template-columns: 1fr;
            }

            .progress-stats {
                flex-direction: column;
                gap: 0.5rem;
            }

            .title-wrapper {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
}

<div class="topic-detail">
    <!-- Back Link -->
    <a href="@Url.Action("Detail", "Vocabulary", new { setId = Model.Set.SetId })" class="back-link">
        <i class="fas fa-arrow-left"></i>
        <span>Quay lại</span>
    </a>

    <!-- Header -->
    <div class="topic-header">
        <div class="title-wrapper">
            <div class="title-main">
                <h1>@topicName</h1>
                <span class="topic-meta-badge">
                    <i class="fas fa-book"></i>
                    @totalCards thẻ
                </span>
            </div>
        </div>
    </div>

    <!-- Status Cards - Dạng ngang, nhỏ gọn -->
    <div class="status-grid">
        <div class="status-card new">
            <div class="status-icon">
                <i class="fas fa-plus-circle"></i>
            </div>
            <div class="status-info">
                <div class="status-value">@newCards</div>
                <div class="status-label">Từ mới</div>
            </div>
        </div>
        <div class="status-card reviewing">
            <div class="status-icon">
                <i class="fas fa-sync-alt"></i>
            </div>
            <div class="status-info">
                <div class="status-value">@reviewingCards</div>
                <div class="status-label">Đang ôn</div>
            </div>
        </div>
        <div class="status-card mastered">
            <div class="status-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="status-info">
                <div class="status-value">@masteredCards</div>
                <div class="status-label">Thành thạo</div>
            </div>
        </div>
    </div>

    <!-- Progress & Actions - Nhỏ gọn -->
    <div class="progress-action-card">
        <div class="progress-circle">
            <svg viewBox="0 0 90 90">
                <circle class="circle-bg" cx="45" cy="45" r="35" stroke-width="5"></circle>
                <circle class="circle-fill" cx="45" cy="45" r="35" stroke-width="5"
                        stroke-dashoffset="@(219.8 - (219.8 * progress / 100))"></circle>
            </svg>
            <div class="progress-text">
                <div class="progress-percent">@progress%</div>
                <div class="progress-label">Tiến độ</div>
            </div>
        </div>

        <div class="progress-stats">
            <div class="stat-block">
                <span class="value">@learnedCards</span>
                <span class="label">Đã học</span>
            </div>
            <div class="stat-block">
                <span class="value">@(totalCards - learnedCards)</span>
                <span class="label">Chưa học</span>
            </div>
        </div>

        <div class="action-buttons">
            <a href="@Url.Action("Study", "Vocabulary", new { setId = Model.Set.SetId, topic = topicName })" class="btn-primary">
                <i class="fas fa-play"></i>
                <span>Học</span>
            </a>
        </div>
    </div>

    <!-- Cards List Section -->
    <div class="section-title">
        <h2>
            <i class="fas fa-layer-group"></i>
            Danh sách từ vựng
        </h2>
        <span class="card-count">@totalCards thẻ</span>
    </div>

    @if (Model.Cards.Any())
    {
        <div class="cards-list">
            @foreach (var card in Model.Cards)
            {

                <div class="card-item">
                    <div class="card-header">
                        <div class="term-wrapper">
                            <span class="term">@card.Term</span>
                            @if (!string.IsNullOrEmpty(card.Phonetic))
                            {
                                <span class="phonetic">@card.Phonetic</span>
                            }
                        </div>
                        <span class="status-badge @card.StatusClass">
                            @card.StatusText
                        </span>
                    </div>

                    <div class="card-content">
                        <div class="definition">@card.Definition</div>

                        @if (!string.IsNullOrEmpty(card.Example))
                        {
                            <div class="example">"@card.Example"</div>
                            @if (!string.IsNullOrEmpty(card.ExampleTranslation))
                            {
                                <div class="example-translation">
                                    <i class="fas fa-arrow-right"></i>
                                    @card.ExampleTranslation
                                </div>
                            }
                        }

                        @if (!string.IsNullOrEmpty(card.ImageUrl))
                        {
                            <img src="@card.ImageUrl" alt="@card.Term" class="card-image" />
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">📭</div>
            <h3>Chưa có thẻ từ vựng</h3>
            <p>Chủ đề này hiện chưa có thẻ từ vựng nào.</p>
            <button class="btn-primary" onclick="alert('Chức năng đang phát triển')">
                <i class="fas fa-plus"></i>
                <span>Thêm từ mới</span>
            </button>
        </div>
    }
</div>