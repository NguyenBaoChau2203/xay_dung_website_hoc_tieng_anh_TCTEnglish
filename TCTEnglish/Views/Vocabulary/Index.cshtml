    @section Scripts {
    <script>
        // Store original sets data
        let originalFolders = @Html.Raw(Json.Serialize(Model.Select(f => new {
            f.FolderName,
            Sets = f.Sets.Select(s => new {
                s.SetId,
                s.SetName,
                CardsCount = s.Cards.Count,
                Description = s.Description,
                Tags = (s.Description ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries).Where(t => t.StartsWith("#")).ToList()
            })
        })));

        let currentFilters = {
            search: '',
            tag: 'all',
            sort: 'name-asc',
            progress: 'all'
        };

        function applyFilters() {
            // Update search filter
            currentFilters.search = document.getElementById('searchFilter').value.toLowerCase();
            
            // Update sort filter
            currentFilters.sort = document.getElementById('sortFilter').value;
            
            // Update progress filter
            currentFilters.progress = document.getElementById('progressFilter').value;
            
            filterAndDisplaySets();
            updateActiveFiltersDisplay();
        }

        function filterByTag(tag) {
            currentFilters.tag = tag;
            
            // Update active state of tag buttons
            document.querySelectorAll('.tag-filter-btn').forEach(btn => {
                if (btn.dataset.tag === tag) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
            
            filterAndDisplaySets();
            updateActiveFiltersDisplay();
        }

        function filterAndDisplaySets() {
            let filteredFolders = originalFolders.map(folder => {
                let filteredSets = folder.sets.filter(set => {
                    // Search filter
                    if (currentFilters.search && !set.setName.toLowerCase().includes(currentFilters.search)) {
                        return false;
                    }
                    
                    // Tag filter
                    if (currentFilters.tag !== 'all' && !set.tags.includes(currentFilters.tag)) {
                        return false;
                    }
                    
                    // Progress filter (you'll need to implement actual progress checking)
                    if (currentFilters.progress !== 'all') {
                        // This is a placeholder - you need to implement actual progress tracking
                        // For now, we'll just return true
                        return true;
                    }
                    
                    return true;
                });

                // Apply sorting
                filteredSets = sortSets(filteredSets, currentFilters.sort);
                
                return {
                    folderName: folder.folderName,
                    sets: filteredSets
                };
            });

            // Remove folders with no sets
            filteredFolders = filteredFolders.filter(f => f.sets.length > 0);
            
            renderFilteredSets(filteredFolders);
        }

        function sortSets(sets, sortType) {
            return [...sets].sort((a, b) => {
                switch(sortType) {
                    case 'name-asc':
                        return a.setName.localeCompare(b.setName);
                    case 'name-desc':
                        return b.setName.localeCompare(a.setName);
                    case 'cards-desc':
                        return b.cardsCount - a.cardsCount;
                    case 'cards-asc':
                        return a.cardsCount - b.cardsCount;
                    case 'newest':
                        // Assuming you have a CreatedDate field
                        return (b.createdDate || 0) - (a.createdDate || 0);
                    default:
                        return 0;
                }
            });
        }

        function renderFilteredSets(filteredFolders) {
            const categoriesSection = document.querySelector('.categories-section');
            if (!categoriesSection) return;
            
            // Get the section header and keep it
            const sectionHeader = categoriesSection.querySelector('.section-header');
            
            // Clear everything except the section header
            categoriesSection.innerHTML = '';
            categoriesSection.appendChild(sectionHeader);
            
            if (filteredFolders.length === 0) {
                // Show no results message
                categoriesSection.innerHTML += `
                    <div class="no-results">
                        <i class="fas fa-search fa-3x" style="color: var(--neutral-300); margin-bottom: 1rem;"></i>
                        <h3 style="color: var(--neutral-600); margin-bottom: 0.5rem;">Không tìm thấy bộ từ nào</h3>
                        <p style="color: var(--neutral-500);">Thử điều chỉnh bộ lọc của bạn</p>
                    </div>
                `;
            } else {
                // Render filtered folders
                filteredFolders.forEach(folder => {
                    const folderHtml = createFolderHtml(folder);
                    categoriesSection.innerHTML += folderHtml;
                });
            }
        }

        function createFolderHtml(folder) {
            let setsHtml = '';
            folder.sets.forEach(set => {
                setsHtml += `
                    <div class="set-card">
                        <div class="card-header">
                            <div class="card-tags">
                                ${set.tags.slice(0, 2).map(tag => `<span class="tag">${tag}</span>`).join('')}
                            </div>
                            <div class="card-title">${set.setName}</div>
                        </div>
                        <div class="card-body">
                            <div class="card-meta">
                                <span class="meta-item">
                                    <i class="fas fa-layer-group"></i>
                                    ${set.cardsCount} từ
                                </span>
                                <span class="rating">
                                    <i class="fas fa-star"></i>
                                    4.8
                                </span>
                            </div>
                        </div>
                        <div class="card-footer">
                            <span class="learners">
                                <i class="fas fa-users"></i>
                                1.2k học viên
                            </span>
                            <a href="/Vocabulary/Detail?setId=${set.setId}" class="explore-link">
                                Khám phá
                                <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                `;
            });

            return `
                <div class="folder-group">
                    <div class="folder-header">
                        <div class="folder-title">
                            <h3>${folder.folderName}</h3>
                            <span class="folder-count">${folder.sets.length} bộ</span>
                        </div>
                        <a href="#" class="view-all">
                            Xem thêm
                            <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                    <div class="sets-grid">
                        ${setsHtml}
                    </div>
                </div>
            `;
        }

        function updateActiveFiltersDisplay() {
            const activeFiltersDiv = document.getElementById('activeFilters');
            const filterTagsDiv = document.getElementById('filterTags');
            const clearBtn = document.querySelector('.clear-filters-btn');
            
            let activeFilters = [];
            
            if (currentFilters.search) {
                activeFilters.push({
                    type: 'search',
                    label: `Tìm: "${currentFilters.search}"`
                });
            }
            
            if (currentFilters.tag !== 'all') {
                activeFilters.push({
                    type: 'tag',
                    label: currentFilters.tag
                });
            }
            
            if (currentFilters.progress !== 'all') {
                const progressLabels = {
                    'not-started': 'Chưa bắt đầu',
                    'in-progress': 'Đang học',
                    'mastered': 'Đã thành thạo'
                };
                activeFilters.push({
                    type: 'progress',
                    label: progressLabels[currentFilters.progress]
                });
            }
            
            if (activeFilters.length > 0) {
                activeFiltersDiv.style.display = 'flex';
                clearBtn.style.display = 'inline-flex';
                
                filterTagsDiv.innerHTML = activeFilters.map(filter => `
                    <span class="filter-tag">
                        ${filter.label}
                        <i class="fas fa-times" onclick="removeFilter('${filter.type}')"></i>
                    </span>
                `).join('');
            } else {
                activeFiltersDiv.style.display = 'none';
                clearBtn.style.display = 'none';
            }
        }

        function removeFilter(filterType) {
            switch(filterType) {
                case 'search':
                    currentFilters.search = '';
                    document.getElementById('searchFilter').value = '';
                    break;
                case 'tag':
                    currentFilters.tag = 'all';
                    filterByTag('all');
                    return;
                case 'progress':
                    currentFilters.progress = 'all';
                    document.getElementById('progressFilter').value = 'all';
                    break;
            }
            filterAndDisplaySets();
            updateActiveFiltersDisplay();
        }

        function clearAllFilters() {
            currentFilters = {
                search: '',
                tag: 'all',
                sort: 'name-asc',
                progress: 'all'
            };
            
            // Reset all inputs
            document.getElementById('searchFilter').value = '';
            document.getElementById('sortFilter').value = 'name-asc';
            document.getElementById('progressFilter').value = 'all';
            
            // Reset tag buttons
            document.querySelectorAll('.tag-filter-btn').forEach(btn => {
                if (btn.dataset.tag === 'all') {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
            
            filterAndDisplaySets();
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            // Store original folders data for filtering
            // Note: You'll need to pass the actual data from server
            console.log('Filter system initialized');
        });
    </script>
}