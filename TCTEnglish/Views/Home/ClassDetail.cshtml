@model TCTVocabulary.ViewModel.ClassDetailViewModel
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Class.ClassName;
    var currentUserId = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!);
    bool CanViewContent = Model.IsOwner || Model.IsMember;

}

<div class="class-detail-container">
@Html.AntiForgeryToken()
    <!-- ===== HEADER ===== -->
    <div class="class-header">
        <img class="class-avatar"
             src="@(string.IsNullOrEmpty(Model.Class.ImageUrl)
                                ? "/images/class-default.png"
                                : Model.Class.ImageUrl)" />

        <div class="class-info">
            <h1>@Model.Class.ClassName</h1>
            <p>
                @(string.IsNullOrEmpty(Model.Class.Description)
                                ? "Chưa có mô tả cho lớp học này."
                                : Model.Class.Description)
            </p>
        </div>

        <div class="class-actions">
            <button class="more-btn" onclick="openClassActionModal()">⋯</button>
        </div>
    </div>
    <!-- ===== NỘI DUNG CHÍNH ===== -->
@if (!CanViewContent)
{
    <!-- ===== JOIN REQUIRED ===== -->
    <div class="join-required-panel">
        <div class="join-required-card">
            <div class="lock-icon">🔒</div>
            <h2>Hãy tham gia nhóm</h2>
            <p>Bạn cần tham gia lớp học này để xem nội dung chat, thư mục và thành viên.</p>

            <button class="btn-primary"
                    onclick="handleJoinClick(@Model.Class.ClassId, @(Model.Class.HasPassword.ToString().ToLower()))">
                ➕ Tham gia nhóm
            </button>
        </div>
    </div>
}
else
{
    <!-- ===== TABS ===== -->
    <div class="class-tabs">
        <button class="tab-btn active" onclick="showTab('chat')">
            <i class="fas fa-comments"></i> Chat
        </button>
        <button class="tab-btn" onclick="showTab('folders')">
            <i class="fas fa-folder"></i> Folder
        </button>
        <button class="tab-btn" onclick="showTab('members')">
            <i class="fas fa-user-group"></i> Thành viên
        </button>
        <button class="tab-btn" onclick="showTab('about')">
            <i class="fas fa-circle-info"></i> Giới thiệu
        </button>
    </div>

    <!-- ===== CHAT ===== -->
    <div id="tab-chat" class="tab-content active">
            <div id="chatMessages" class="chat-box">
                @foreach (var msg in Model.Messages)
                {
                    <div class="chat-message @(msg.IsMine ? "mine" : "other")">
                        <div class="chat-bubble">
                            @if (!msg.IsMine)
                            {
                                <div class="chat-name">@msg.FullName</div>
                            }
                            <div class="chat-content">
                                @if (msg.Content.StartsWith("/uploads/"))
                                {
                                    <img src="@msg.Content" class="chat-image" onclick="window.open(this.src)" />
                                }
                                else
                                {
                                    @msg.Content
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="chat-input-bar">

                <!-- nút upload ảnh -->
                <label type="button" class="chat-icon">
                    📷
                    <input type="file" id="imageInput" accept="image/*" hidden>
                </label>

                <!-- emoji -->
                <button type="button" onclick="toggleEmoji()">😊</button>

                <input id="chatInput"
                       placeholder="Nhập tin nhắn..."
                       onkeydown="if(event.key==='Enter') sendMessage()" />

                <button onclick="sendMessage()">
                    <i class="fas fa-paper-plane"></i>
                </button>

            </div>

            <!-- emoji panel -->
            <div id="emojiPanel" class="emoji-picker" style="display:none">
                <span class="emoji-item">😀</span> <span class="emoji-item">😁</span>
                <span class="emoji-item">😂</span> <span class="emoji-item">🤣</span>
                <span class="emoji-item">😍</span> <span class="emoji-item">😎</span>
                <span class="emoji-item">👍</span> <span class="emoji-item">❤️</span>
                <span class="emoji-item">🎉</span> <span class="emoji-item">🔥</span>
            </div>
    </div>

    <!-- ===== FOLDERS ===== -->
    <div id="tab-folders" class="tab-content">
        <div class="folder-header">
            <h3>Folder của lớp</h3>
            <button class="btn-add-folder" onclick="openAddFolderModal()">
                <i class="fas fa-plus"></i> Thêm folder
            </button>
        </div>

        @if (!Model.ClassFolders.Any())
        {
            <div class="empty-box">
                <i class="fas fa-folder-open"></i>
                <p>Chưa có folder nào trong lớp</p>
            </div>
        }
        else
        {
            <div class="folder-grid">
                @foreach (var f in Model.ClassFolders)
                {
                    <a asp-action="FolderDetail"
                       asp-controller="Home"
                       asp-route-id="@f.FolderId"
                       class="f-link">

                        <div class="class-folder-row">
                            <div class="folder-left">
                                <i class="fas fa-folder"></i>
                                <span class="folder-name">@f.Folder.FolderName</span>
                            </div>
                            <div class="folder-right">
                                Thêm bởi <strong>@f.AddedByUser.FullName</strong>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    <!-- ===== MEMBERS ===== -->
    <div id="tab-members" class="tab-content">
        <ul class="member-list">
            @foreach (var u in Model.Members)
            {
                <li>
                    <i class="fas fa-user"></i>
                    @u.FullName
                </li>
            }
        </ul>
    </div>

    <!-- ===== ABOUT ===== -->
    <div id="tab-about" class="tab-content">
        <h3>Thông tin lớp học</h3>
        <p>@Model.Class.Description</p>
    </div>
}
<!-- ===== ADD FOLDER MODAL ===== -->
<div id="addFolderModal" class="modal-overlay">
    <div class="modal-container">
        <div class="modal-header">
            <h3>Thêm folder vào lớp</h3>
            <button class="close-btn" onclick="closeAddFolderModal()">×</button>
        </div>

        <div class="modal-section">
            <h4>Folder của tôi</h4>
            @foreach (var f in Model.MyFolders)
            {
                <div class="modal-folder-item" onclick="addFolder(@f.FolderId)">
                    <i class="fas fa-folder"></i> @f.FolderName
                </div>
            }
        </div>

        <div class="modal-section">
            <h4>Folder đã lưu</h4>
            @foreach (var f in Model.SavedFolders)
            {
                <div class="modal-folder-item" onclick="addFolder(@f.FolderId)">
                    <i class="fas fa-bookmark"></i> @f.FolderName
                </div>
            }
        </div>
    </div>
</div>

<!-- ===== CLASS ACTION MODAL ===== -->
<div id="classActionModal" class="modal-overlay">
    <div class="modal-container">

        @if (Model.IsOwner)
        {
            <button class="modal-item" onclick="openEditClassModal()">Sửa tên / mô tả</button>
            <button class="modal-item danger" onclick="deleteClass()">Giải tán lớp</button>
        }
        else
        {
            @if (!Model.IsMember)
            {
                <button class="modal-item"
                        onclick="handleJoinClick(@Model.Class.ClassId, @(Model.Class.HasPassword.ToString().ToLower()))">
                    ➕ Tham gia lớp
                </button>
            }
            else
            {
                <button class="modal-item danger" onclick="leaveClass()">Thoát lớp</button>
            }
        }

        <button class="modal-item cancel" onclick="closeClassActionModal()">Hủy</button>
    </div>
</div>
<!-- ===== EDIT CLASS MODAL ===== -->
<div id="editClassModal" class="modal-overlay">
    <div class="modal-container">

        <div class="modal-header">
            <h3>Chỉnh sửa lớp học</h3>
            <button class="close-btn" onclick="closeEditClassModal()">×</button>
        </div>

        <div class="modal-section">
            <label>Tên lớp</label>
            <input type="text"
                   id="editClassName"
                   value="@Model.Class.ClassName"
                   placeholder="Nhập tên lớp" />
        </div>

        <div class="modal-section">
            <label>Mô tả</label>
            <textarea id="editClassDescription"
                      rows="4"
                      placeholder="Nhập mô tả lớp">@Model.Class.Description</textarea>
        </div>

        <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:20px">
            <button class="btn-outline" onclick="closeEditClassModal()">Hủy</button>
            <button class="btn-primary" onclick="saveClassInfo()">Lưu thay đổi</button>
        </div>
    </div>
</div>
<!-- ===== JOIN PASSWORD MODAL ===== -->
<div id="joinClassModal" class="modal-overlay">
    <div class="modal-container">
        <h3>Nhập mật khẩu lớp</h3>
        <input type="password" id="joinClassPassword" placeholder="Mật khẩu lớp" />

        <div style="margin-top:20px;display:flex;justify-content:flex-end;gap:10px">
            <button class="btn-outline" onclick="closeJoinClassModal()">Hủy</button>
            <button class="btn-primary" onclick="confirmJoinClass()">Tham gia</button>
        </div>
    </div>
</div>

<script>
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
    let pendingClassId = null;

    function showTab(tab) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        document.querySelector(`[onclick="showTab('${tab}')"]`).classList.add('active');
        document.getElementById(`tab-${tab}`).classList.add('active');
    }

    function openAddFolderModal() {
        document.getElementById('addFolderModal').classList.add('active');
    }

    function closeAddFolderModal() {
        document.getElementById('addFolderModal').classList.remove('active');
    }

           function addFolder(folderId) {
            fetch('/Home/AddFolderToClass', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `classId=@Model.Class.ClassId&folderId=${folderId}`
            }).then(() => location.reload());
        }

    function openClassActionModal() {
        document.getElementById('classActionModal').classList.add('active');
    }

    function closeClassActionModal() {
        document.getElementById('classActionModal').classList.remove('active');
    }

    function handleJoinClick(classId, hasPassword) {
        closeClassActionModal();
        if (hasPassword) {
            pendingClassId = classId;
            document.getElementById('joinClassModal').classList.add('active');
        } else {
            joinClass(classId, '');
        }
    }

    function closeJoinClassModal() {
        document.getElementById('joinClassModal').classList.remove('active');
        pendingClassId = null;
    }

    function confirmJoinClass() {
        const pw = document.getElementById('joinClassPassword').value;
        joinClass(pendingClassId, pw);
    }

           function joinClass(classId, password) {
            fetch('/Home/JoinClass', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `classId=${classId}&password=${encodeURIComponent(password)}`
            }).then(() => location.reload());
        }

           function leaveClass() {
            if (!confirm('Bạn chắc chắn muốn rời lớp?')) return;

            fetch('/Home/LeaveClass', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `classId=@Model.Class.ClassId`
            })
            .then(() => window.location.href = '/Home/Class');
        }
</script>
<script>
    /* ===== EDIT CLASS ===== */
    function openEditClassModal() {
        closeClassActionModal();
        document.getElementById('editClassModal').classList.add('active');
    }

    function closeEditClassModal() {
        document.getElementById('editClassModal').classList.remove('active');
    }

            function saveClassInfo() {

            const name = document.getElementById('editClassName').value.trim();
            const desc = document.getElementById('editClassDescription').value.trim();

            if (!name) {
                alert("Tên lớp không được để trống");
                return;
            }

            fetch('/Home/EditClass', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body:
                    `classId=@Model.Class.ClassId` +
                    `&className=${encodeURIComponent(name)}` +
                    `&description=${encodeURIComponent(desc)}`
            })
            .then(res => {
                if (!res.ok) throw new Error();
                location.reload();
            })
            .catch(() => alert("Không thể cập nhật lớp"));
        }

    /* ===== DELETE CLASS ===== */
            function deleteClass() {

            if (!confirm("Bạn có chắc muốn GIẢI TÁN lớp này? Tất cả thành viên sẽ bị xoá.")) return;

            fetch('/Home/DeleteClass', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `classId=@Model.Class.ClassId`
            })
            .then(() => window.location.href = '/Home/Class')
            .catch(() => alert("Không thể xoá lớp"));
        }
</script>
