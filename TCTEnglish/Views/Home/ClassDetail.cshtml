            display: flex;
            gap: 8px;
            margin-top: 12px;
            align-items: center;
        }

            /* Style cho nút Icon (Ảnh & Emoji) */
            .chat-icon,
            .chat-input-bar button[onclick="toggleEmoji()"] {
                width: 42px;
                height: 42px;
                display: flex;
                align-items: center;
                justify-content: center;
                background: #f3f4f6;
                border-radius: 10px;
                border: none;
                cursor: pointer;
                font-size: 18px;
                transition: all 0.2s ease;
                padding: 0;
                margin: 0;
            }

                .chat-icon:hover,
                .chat-input-bar button[onclick="toggleEmoji()"]:hover {
                    background: #e5e7eb;
                    transform: scale(1.05);
                }

            .chat-input-bar input {
                flex: 1;
                padding: 11px 14px;
                border-radius: 10px;
                border: 1px solid #e5e7eb;
                outline: none;
                transition: border 0.2s;
            }

                .chat-input-bar input:focus {
                    border-color: #4255ff;
                }

            /* Nút Gửi (Primary) */
            .chat-input-bar button:not([onclick="toggleEmoji()"]) {
                background: #4255ff;
                color: white;
                height: 42px;
                padding: 0 18px;
                border-radius: 10px;
                border: none;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.2s ease;
            }

                .chat-input-bar button:not([onclick="toggleEmoji()"]):hover {
                    background: #3344cc;
                    box-shadow: 0 4px 12px rgba(66, 85, 255, 0.2);
                }

        /* Members */
        .member-list {
            list-style: none;
