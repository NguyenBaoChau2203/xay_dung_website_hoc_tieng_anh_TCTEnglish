<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

        <script>
    const classId = @Model.Class.ClassId;
    const currentUserId = @currentUserId;

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/classChatHub")
        .build();

    // 1. Hàm cuộn xuống đáy khung chat
    function scrollToBottom() {
        const box = document.getElementById("chatMessages");
        if (box) {
            box.scrollTop = box.scrollHeight;
        }
    }

    // 2. Hàm chung để render tin nhắn vào box
    function appendMessage(msg, type = 'text') {
        const box = document.getElementById("chatMessages");
        const isMine = msg.userId === currentUserId;

        // Thêm onload="scrollToBottom()" cho ảnh để cuộn đúng sau khi ảnh tải xong
        let contentHtml = type === 'image'
            ? `<img src="${msg.imageUrl}" class="chat-image" onload="scrollToBottom()" onclick="window.open(this.src)"/>`
            : msg.content;

        box.insertAdjacentHTML("beforeend", `
            <div class="chat-message ${isMine ? 'mine' : 'other'}">
                <div class="chat-bubble">
                    ${(!isMine && type === 'text') ? `<div class="chat-name">${msg.fullName}</div>` : ''}
                    <div class="chat-content">${contentHtml}</div>
                </div>
            </div>
        `);
        
        scrollToBottom();
    }

    // --- SIGNALR EVENTS ---
    connection.on("ReceiveMessage", msg => appendMessage(msg, 'text'));
    connection.on("ReceiveImage", msg => appendMessage(msg, 'image'));

    connection.start()
        .then(() => {
            connection.invoke("JoinClass", classId);
            // Cuộn xuống sau khi kết nối thành công (đã render tin nhắn cũ từ server)
            scrollToBottom();
        })
        .catch(err => console.error(err.toString()));

    // --- XỬ LÝ KHI VỪA LOAD TRANG ---
    document.addEventListener("DOMContentLoaded", scrollToBottom);

    // --- XỬ LÝ EMOJI ---
    function toggleEmoji() {
        const panel = document.getElementById("emojiPanel");
        panel.style.display = panel.style.display === "none" ? "grid" : "none";
    }

    document.querySelectorAll(".emoji-item").forEach(item => {
        item.addEventListener("click", function() {
            const input = document.getElementById("chatInput");
            input.value += this.innerText;
            input.focus();
        });
    });

    // --- XỬ LÝ UPLOAD ẢNH ---
    document.getElementById("imageInput").addEventListener("change", async function () {
        const file = this.files[0];
        if (!file) return;

        const formData = new FormData();
        formData.append("image", file);
        formData.append("classId", classId);

        try {
            const res = await fetch("/Chat/UploadImage", { method: "POST", body: formData });
            if (res.ok) {
                const data = await res.json();
                connection.invoke("SendImageMessage", classId, data.imageUrl);
            }
        } catch (err) {
            console.error("Lỗi upload:", err);
        }
        this.value = ""; // Reset input file
    });

    // --- GỬI TIN NHẮN CHỮ ---
    function sendMessage() {
        const input = document.getElementById("chatInput");
        const text = input.value.trim();
        if (!text) return;
        connection.invoke("SendMessage", classId, text);
        input.value = '';
    }

    // Gửi bằng phím Enter
    document.getElementById("chatInput").addEventListener("keypress", function(e) {
        if (e.key === "Enter") {
            sendMessage();
        }
    });
</script>
}
