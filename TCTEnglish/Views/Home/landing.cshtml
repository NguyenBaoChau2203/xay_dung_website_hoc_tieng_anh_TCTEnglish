@{
Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TCT English — Nền tảng học tiếng Anh toàn diện</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/ai-chat-launcher.css" asp-append-version="true">

    <style>
        :root {
            --brand: #4255ff;
            --brand-dark: #3040d4;
            --brand-light: #eef0ff;
            --accent: #ff6b35;
            --accent-light: #fff4ef;
            --dark: #0f1729;
            --dark-muted: #3a4260;
            --text: #1e2a45;
            --text-muted: #64748b;
            --surface: #f8fafc;
            --white: #ffffff;
            --teal: #10b981;
            --teal-light: #ecfdf5;
            --coral: #f43f5e;
            --amber: #f59e0b;
            --purple: #8b5cf6;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Be Vietnam Pro', system-ui, sans-serif;
            color: var(--text);
            background: var(--white);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        .serif { font-family: 'Playfair Display', Georgia, serif; }

        /* ═══════════════════════ NAVBAR ═══════════════════════ */
        .nav-main {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(0,0,0,0.06);
            transition: all 0.3s;
        }
        .nav-main.scrolled { box-shadow: 0 4px 30px rgba(0,0,0,0.06); }
        .nav-inner {
            max-width: 1200px; margin: auto;
            padding: 14px 24px;
            display: flex; align-items: center; justify-content: space-between;
        }
        .nav-logo {
            font-weight: 900; font-size: 28px; color: var(--brand);
            text-decoration: none; letter-spacing: -1px;
        }
        .nav-logo span { color: var(--accent); }
        .nav-links { display: flex; align-items: center; gap: 32px; }
        .nav-links a {
            font-size: 15px; font-weight: 600; color: var(--text);
            text-decoration: none; transition: color 0.2s;
        }
        .nav-links a:hover { color: var(--brand); }
        .nav-actions { display: flex; align-items: center; gap: 12px; }
        .btn-ghost {
            padding: 10px 20px; font-weight: 700; font-size: 14px;
            color: var(--text); background: transparent; border: none;
            border-radius: 10px; cursor: pointer; text-decoration: none;
            transition: all 0.2s;
        }
        .btn-ghost:hover { background: var(--surface); color: var(--brand); }
        .btn-primary-brand {
            padding: 10px 24px; font-weight: 700; font-size: 14px;
            color: var(--white); background: var(--brand); border: none;
            border-radius: 10px; cursor: pointer; text-decoration: none;
            transition: all 0.25s;
        }
        .btn-primary-brand:hover {
            background: var(--brand-dark); color: var(--white);
            transform: translateY(-2px); box-shadow: 0 8px 24px rgba(66,85,255,0.25);
        }

        /* ═══════════════════════ HERO ═══════════════════════ */
        .hero {
            min-height: 100vh; padding: 140px 24px 80px;
            display: flex; align-items: center;
            background:
                radial-gradient(ellipse at 20% 50%, rgba(66,85,255,0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(255,107,53,0.04) 0%, transparent 50%),
                var(--white);
        }
        .hero-inner {
            max-width: 1200px; margin: auto; width: 100%;
            display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;
        }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 6px 16px; border-radius: 100px;
            background: var(--brand-light); color: var(--brand);
            font-size: 13px; font-weight: 700; margin-bottom: 24px;
        }
        .hero-badge i { font-size: 11px; }
        .hero h1 {
            font-size: 56px; font-weight: 900; line-height: 1.08;
            letter-spacing: -2px; margin-bottom: 24px;
        }
        .hero h1 .highlight {
            background: linear-gradient(135deg, var(--brand), var(--purple));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero-desc {
            font-size: 18px; line-height: 1.7; color: var(--text-muted);
            margin-bottom: 36px; max-width: 480px;
        }
        .hero-cta { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
        .btn-hero {
            padding: 16px 36px; font-weight: 800; font-size: 16px;
            border-radius: 14px; border: none; cursor: pointer;
            text-decoration: none; transition: all 0.3s;
        }
        .btn-hero-fill {
            background: var(--brand); color: var(--white);
            box-shadow: 0 4px 20px rgba(66,85,255,0.2);
        }
        .btn-hero-fill:hover {
            background: var(--brand-dark); color: var(--white);
            transform: translateY(-3px); box-shadow: 0 12px 32px rgba(66,85,255,0.3);
        }
        .btn-hero-outline {
            background: var(--white); color: var(--text);
            border: 2px solid rgba(0,0,0,0.1);
        }
        .btn-hero-outline:hover {
            border-color: var(--brand); color: var(--brand);
            transform: translateY(-2px);
        }

        .hero-visual {
            position: relative; display: flex;
            justify-content: center; align-items: center;
        }
        .hero-mockup {
            width: 100%; max-width: 520px;
            background: var(--white); border-radius: 24px;
            border: 1px solid rgba(0,0,0,0.08);
            box-shadow: 0 24px 80px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.04);
            overflow: hidden;
        }
        .mockup-header {
            padding: 16px 20px; background: var(--surface);
            border-bottom: 1px solid rgba(0,0,0,0.06);
            display: flex; align-items: center; gap: 8px;
        }
        .mockup-dot { width: 10px; height: 10px; border-radius: 50%; }
        .mockup-body { padding: 24px; }
        .mockup-card {
            background: var(--white); border: 1px solid rgba(0,0,0,0.06);
            border-radius: 16px; padding: 20px; margin-bottom: 12px;
            transition: all 0.3s;
        }
        .mockup-card:hover { border-color: var(--brand); transform: translateX(4px); }
        .mockup-card-term {
            font-size: 20px; font-weight: 800; margin-bottom: 4px;
        }
        .mockup-card-def { color: var(--text-muted); font-size: 14px; }
        .mockup-card-phonetic {
            font-size: 12px; color: var(--brand); font-weight: 600;
            margin-top: 4px;
        }
        .float-badge {
            position: absolute; padding: 10px 16px;
            background: var(--white); border-radius: 14px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
            font-size: 13px; font-weight: 700;
            display: flex; align-items: center; gap: 8px;
            animation: floatBadge 3s ease-in-out infinite;
        }
        .float-badge-1 { top: 10%; right: -20px; animation-delay: 0s; }
        .float-badge-2 { bottom: 20%; left: -20px; animation-delay: 1.5s; }

        

        /* ═══════════════════════ FEATURES GRID ═══════════════════════ */
        .section { padding: 100px 24px; }
        .section-inner { max-width: 1200px; margin: auto; }
        .section-label {
            font-size: 13px; font-weight: 800; text-transform: uppercase;
            letter-spacing: 2px; color: var(--brand); margin-bottom: 16px;
        }
        .section-title {
            font-size: 40px; font-weight: 900; line-height: 1.15;
            letter-spacing: -1px; margin-bottom: 16px;
        }
        .section-desc {
            font-size: 17px; color: var(--text-muted); line-height: 1.7;
            max-width: 560px; margin-bottom: 48px;
        }

        .features-grid {
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
        }
        .feature-card {
            background: var(--white); border: 1px solid rgba(0,0,0,0.06);
            border-radius: 20px; padding: 32px 28px;
            transition: all 0.35s; cursor: default; position: relative;
            overflow: hidden;
        }
        .feature-card::before {
            content: ''; position: absolute; top: 0; left: 0;
            width: 100%; height: 4px;
            background: linear-gradient(90deg, var(--brand), var(--purple));
            opacity: 0; transition: opacity 0.3s;
        }
        .feature-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 48px rgba(0,0,0,0.06);
            border-color: transparent;
        }
        .feature-card:hover::before { opacity: 1; }
        .feature-icon {
            width: 52px; height: 52px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; margin-bottom: 20px;
        }
        .feature-card h3 { font-size: 18px; font-weight: 800; margin-bottom: 8px; }
        .feature-card p { font-size: 14px; color: var(--text-muted); line-height: 1.6; }

        .fi-vocab { background: var(--brand-light); color: var(--brand); }
        .fi-speaking { background: var(--accent-light); color: var(--accent); }
        .fi-writing { background: var(--teal-light); color: var(--teal); }
        .fi-listening { background: #fef3c7; color: var(--amber); }
        .fi-reading { background: #fce7f3; color: var(--coral); }
        .fi-ai { background: #f3e8ff; color: var(--purple); }

        /* ═══════════════════════ STUDY MODES ═══════════════════════ */
        .modes-section { background: var(--dark); color: var(--white); }
        .modes-section .section-label { color: var(--accent); }
        .modes-section .section-title { color: var(--white); }
        .modes-section .section-desc { color: rgba(255,255,255,0.6); }

        .modes-grid {
            display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
        }
        .mode-card {
            border-radius: 20px; padding: 32px 24px;
            text-align: center; transition: all 0.35s; cursor: default;
            border: 1px solid rgba(255,255,255,0.06);
        }
        .mode-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 48px rgba(0,0,0,0.3);
        }
        .mode-card i { font-size: 36px; margin-bottom: 16px; display: block; }
        .mode-card h4 { font-size: 17px; font-weight: 800; margin-bottom: 6px; }
        .mode-card p { font-size: 13px; opacity: 0.75; }

        .mc-flash { background: linear-gradient(135deg, #4255ff, #6366f1); }
        .mc-quiz { background: linear-gradient(135deg, #f59e0b, #f97316); color: var(--dark); }
        .mc-write { background: linear-gradient(135deg, #10b981, #14b8a6); }
        .mc-match { background: linear-gradient(135deg, #f43f5e, #ec4899); }

        /* ═══════════════════════ AI SECTION ═══════════════════════ */
        .ai-section { background: var(--surface); }
        .ai-grid {
            display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;
        }
        .ai-chat-mockup {
            background: var(--white); border-radius: 20px;
            border: 1px solid rgba(0,0,0,0.08);
            box-shadow: 0 16px 48px rgba(0,0,0,0.06);
            overflow: hidden;
        }
        .ai-chat-header {
            padding: 16px 20px; background: var(--brand); color: var(--white);
            display: flex; align-items: center; gap: 12px;
        }
        .ai-chat-header i { font-size: 20px; }
        .ai-chat-header span { font-weight: 700; font-size: 15px; }
        .ai-chat-body { padding: 20px; }
        .ai-bubble {
            padding: 12px 16px; border-radius: 14px; margin-bottom: 12px;
            font-size: 14px; line-height: 1.5; max-width: 85%;
        }
        .ai-bubble-user {
            background: var(--brand); color: var(--white);
            margin-left: auto; border-bottom-right-radius: 4px;
        }
        .ai-bubble-bot {
            background: var(--surface); color: var(--text);
            border-bottom-left-radius: 4px;
        }

        .ai-features-list { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; }
        .ai-feature-item {
            display: flex; align-items: flex-start; gap: 14px;
            padding: 16px; border-radius: 14px;
            background: var(--white); border: 1px solid rgba(0,0,0,0.06);
            transition: all 0.3s;
        }
        .ai-feature-item:hover {
            border-color: var(--brand);
            box-shadow: 0 4px 16px rgba(66,85,255,0.08);
        }
        .ai-feature-icon {
            width: 40px; height: 40px; border-radius: 10px;
            background: var(--brand-light); color: var(--brand);
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; flex-shrink: 0;
        }
        .ai-feature-item h4 { font-size: 15px; font-weight: 700; margin-bottom: 2px; }
        .ai-feature-item p { font-size: 13px; color: var(--text-muted); margin: 0; }

        /* ═══════════════════════ GOALS & STREAKS ═══════════════════════ */
        .goals-grid {
            display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
        }
        .goal-card {
            text-align: center; padding: 32px 20px;
            background: var(--white); border: 1px solid rgba(0,0,0,0.06);
            border-radius: 20px; transition: all 0.3s;
        }
        .goal-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 36px rgba(0,0,0,0.06);
        }
        .goal-icon {
            font-size: 36px; margin-bottom: 12px; display: block;
        }
        .goal-card h4 { font-size: 16px; font-weight: 800; margin-bottom: 6px; }
        .goal-card p { font-size: 13px; color: var(--text-muted); }

        /* ═══════════════════════ CTA ═══════════════════════ */
        .cta-section {
            background: linear-gradient(135deg, var(--brand), var(--purple));
            text-align: center; padding: 100px 24px;
        }
        .cta-section h2 {
            font-size: 44px; font-weight: 900; color: var(--white);
            letter-spacing: -1px; margin-bottom: 16px;
        }
        .cta-section p {
            font-size: 18px; color: rgba(255,255,255,0.8);
            margin-bottom: 36px; max-width: 500px; margin-inline: auto;
        }
        .btn-cta {
            padding: 18px 48px; font-weight: 800; font-size: 17px;
            border-radius: 14px; border: none; cursor: pointer;
            background: var(--white); color: var(--brand);
            text-decoration: none; transition: all 0.3s; display: inline-block;
        }
        .btn-cta:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 16px 40px rgba(0,0,0,0.2);
            color: var(--brand);
        }

        /* ═══════════════════════ FOOTER ═══════════════════════ */
        .footer {
            background: var(--dark); color: rgba(255,255,255,0.6);
            padding: 64px 24px 32px;
        }
        .footer-inner {
            max-width: 1200px; margin: auto;
            display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px;
        }
        .footer-brand { font-size: 24px; font-weight: 900; color: var(--white); margin-bottom: 12px; }
        .footer-desc { font-size: 14px; line-height: 1.7; }
        .footer h5 {
            color: var(--white); font-size: 14px; font-weight: 800;
            text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px;
        }
        .footer ul { list-style: none; padding: 0; }
        .footer ul li { margin-bottom: 10px; }
        .footer ul a {
            color: rgba(255,255,255,0.6); text-decoration: none;
            font-size: 14px; transition: color 0.2s;
        }
        .footer ul a:hover { color: var(--white); }
        .footer-bottom {
            max-width: 1200px; margin: auto;
            padding-top: 32px; margin-top: 48px;
            border-top: 1px solid rgba(255,255,255,0.08);
            display: flex; justify-content: space-between; align-items: center;
            font-size: 13px;
        }
        .footer-social a {
            color: rgba(255,255,255,0.5); margin-left: 16px;
            font-size: 18px; transition: color 0.2s;
        }
        .footer-social a:hover { color: var(--white); }

        /* ═══════════════════════ ANIMATIONS ═══════════════════════ */
        .reveal {
            opacity: 0; transform: translateY(32px);
            transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal.visible { opacity: 1; transform: none; }

        /* ═══════════════════════ RESPONSIVE ═══════════════════════ */
        @@media (max-width: 992px) {
            .hero-inner { grid-template-columns: 1fr; text-align: center; }
            .hero h1 { font-size: 40px; }
            .hero-desc { margin-inline: auto; }
            .hero-cta { justify-content: center; }
            .hero-visual { margin-top: 40px; }
            .float-badge { display: none; }
            .features-grid { grid-template-columns: repeat(2, 1fr); }
            .modes-grid { grid-template-columns: repeat(2, 1fr); }
            .ai-grid { grid-template-columns: 1fr; }
            .goals-grid { grid-template-columns: repeat(2, 1fr); }
            .footer-inner { grid-template-columns: 1fr 1fr; }
            .nav-links { display: none; }
        }
        @@media (max-width: 576px) {
            .hero h1 { font-size: 32px; }
            .section-title { font-size: 28px; }
            .features-grid, .modes-grid, .goals-grid { grid-template-columns: 1fr; }
            .footer-inner { grid-template-columns: 1fr; }
            .cta-section h2 { font-size: 30px; }
        }
    </style>
</head>
<body>

    <!-- ═══════════════════════ NAVBAR ═══════════════════════ -->
    <nav class="nav-main" id="navbar">
        <div class="nav-inner">
            <a href="/" class="nav-logo">TCT<span>.</span></a>
            <div class="nav-links">
                <a href="#features">Tính năng</a>
                <a href="#study-modes">Chế độ học</a>
                <a href="#ai-assistant">AI Chatbot</a>
                <a href="/Home/Contact">Liên hệ</a>
            </div>
            <div class="nav-actions">
                <a href="/Account/Login" class="btn-ghost">Đăng nhập</a>
                <a href="/Account/Login" class="btn-primary-brand">Bắt đầu miễn phí</a>
            </div>
        </div>
    </nav>

    <!-- ═══════════════════════ HERO ═══════════════════════ -->
    <section class="hero">
        <div class="hero-inner">
            <div>
                <div class="hero-badge">
                    <i class="fas fa-bolt"></i> Tích hợp Gemini AI
                </div>
                <h1>
                    Chinh phục<br>
                    tiếng Anh với<br>
                    <span class="highlight">TCT English</span>
                </h1>
                <p class="hero-desc">
                    Nền tảng học tiếng Anh toàn diện dành cho nhân viên công ty TCT —
                    từ vựng, nghe, nói, đọc, viết cùng trợ lý AI thông minh.
                </p>
                <div class="hero-cta">
                    <a href="/Account/Login" class="btn-hero btn-hero-fill">
                        Học ngay miễn phí <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                    <a href="#features" class="btn-hero btn-hero-outline">
                        Khám phá tính năng
                    </a>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-mockup">
                    <div class="mockup-header">
                        <div class="mockup-dot" style="background:#ff5f56;"></div>
                        <div class="mockup-dot" style="background:#ffbd2e;"></div>
                        <div class="mockup-dot" style="background:#27c93f;"></div>
                    </div>
                    <div class="mockup-body">
                        <div class="mockup-card">
                            <div class="mockup-card-term">Accomplish</div>
                            <div class="mockup-card-def">Hoàn thành, đạt được</div>
                            <div class="mockup-card-phonetic">/əˈkɑːm.plɪʃ/</div>
                        </div>
                        <div class="mockup-card">
                            <div class="mockup-card-term">Negotiate</div>
                            <div class="mockup-card-def">Đàm phán, thương lượng</div>
                            <div class="mockup-card-phonetic">/nɪˈɡoʊ.ʃi.eɪt/</div>
                        </div>
                        <div class="mockup-card">
                            <div class="mockup-card-term">Collaborate</div>
                            <div class="mockup-card-def">Cộng tác, hợp tác</div>
                            <div class="mockup-card-phonetic">/kəˈlæb.ə.reɪt/</div>
                        </div>
                    </div>
                </div>
                <div class="float-badge float-badge-1">
                    <span style="font-size:20px;">🔥</span> Streak 15 ngày
                </div>
                <div class="float-badge float-badge-2">
                    <i class="fas fa-check-circle" style="color:var(--teal);"></i> 120 từ đã thuộc
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════ FEATURES ═══════════════════════ -->
    <section class="section" id="features" style="background: var(--surface);">
        <div class="section-inner">
            <div class="reveal">
                <div class="section-label">Tính năng</div>
                <div class="section-title">6 kỹ năng, một nền tảng</div>
                <div class="section-desc">
                    Phát triển toàn diện tiếng Anh chuyên ngành — từ vựng, phát âm, viết luận,
                    nghe hiểu, đọc hiểu và trò chuyện cùng AI.
                </div>
            </div>
            <div class="features-grid">
                <div class="feature-card reveal">
                    <div class="feature-icon fi-vocab"><i class="fas fa-layer-group"></i></div>
                    <h3>Từ vựng Flashcard</h3>
                    <p>Hệ thống flashcard thông minh với hình ảnh, phiên âm IPA, ví dụ minh họa và thuật toán lặp lại ngắt quãng.</p>
                </div>
                <div class="feature-card reveal">
                    <div class="feature-icon fi-speaking"><i class="fas fa-microphone-alt"></i></div>
