@using System.Text.Json
@model TCTVocabulary.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var userName   = Model.FullName ?? User.Identity?.Name ?? "Bạn";
    var initials   = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
    var xpCurrent  = Model.CardCount * 5 + Model.Streak * 20;
    var xpNext     = Math.Max(xpCurrent + 500, 1000);
    var xpPct      = Math.Min((int)((double)xpCurrent / xpNext * 100), 100);
    int litDays    = Math.Min(Model.Streak % 7 == 0 && Model.Streak > 0 ? 7 : Model.Streak % 7, 7);
    string[] dayNames = { "T2","T3","T4","T5","T6","T7","CN" };
    // Xác định hôm nay là index nào trong tuần (0=T2 ... 6=CN)
    int todayDow    = (int)DateTime.Now.DayOfWeek; // Sun=0,Mon=1,...
    int todayInWeek = todayDow == 0 ? 6 : todayDow - 1;
    int streakStart = Math.Max(0, todayInWeek - litDays + 1);
    var totalProgress = Math.Max(Model.MasteredCount + Model.LearningCount + Model.NewCount, 1);
    var masteredPct = (int)Math.Round(Model.MasteredCount * 100d / totalProgress);
    var learningPct = (int)Math.Round(Model.LearningCount * 100d / totalProgress);
    var newPct = Math.Max(0, 100 - masteredPct - learningPct);
    var featureTimeJson = JsonSerializer.Serialize(Model.FeatureTimeBreakdown);
    // Time-based greeting
    var nowHour = DateTime.Now.Hour;
    var greetingText = nowHour < 12 ? "Chào buổi sáng ☀️"
                     : nowHour < 18 ? "Chào buổi chiều 🌤️"
                     : "Chào buổi tối 🌙";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />
<script src="https://cdn.jsdelivr.net/npm/apexcharts" defer></script>

@Html.AntiForgeryToken()

<!-- ════════════════════════════════════
     GREETING
═══════════════════════════════════════ -->
<div class="db-greeting">
    <div>
        <p class="db-greeting__sub">@greetingText</p>
        <h1 class="db-greeting__title">
            Xin chào, <span class="db-greeting__name">@userName</span>!
        </h1>
    </div>

</div>

<!-- ════════════════════════════════════
     ROW 1 : XP | Streak | Memory
═══════════════════════════════════════ -->
<div class="row g-3 mb-3">

    <!-- XP / Level (col-7) -->
    <div class="col-12 col-lg-7">
        <div class="db-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="db-label">Level Progress</span>
                <span class="db-pill">Lv Explorer</span>
            </div>

            <div class="d-flex justify-content-between align-items-baseline mb-2">
                <span class="db-xp-current">@xpCurrent <span class="db-xp-unit">XP</span></span>
                <span class="db-xp-max">@xpNext XP</span>
            </div>
            <div class="db-xp-track mb-1">
                <div class="db-xp-fill" style="width:@xpPct%"></div>
            </div>
            <p class="db-xp-hint mb-3">@(xpNext - xpCurrent) XP đến level tiếp theo</p>

            <div class="row g-2">
                <div class="col-4">
                    <div class="db-mini-stat db-mini-stat--blue text-center">
                        <span class="db-mini-stat__val">@Model.CardCount</span>
                        <span class="db-mini-stat__lbl">Cards</span>
                    </div>
                </div>
                <div class="col-4">
                    <div class="db-mini-stat db-mini-stat--green text-center">
                        <span class="db-mini-stat__val">@Model.SetCount</span>
                        <span class="db-mini-stat__lbl">Sets</span>
                    </div>
                </div>
                <div class="col-4">
                    <div class="db-mini-stat db-mini-stat--yellow text-center">
                        <span class="db-mini-stat__val">@Model.FolderCount</span>
                        <span class="db-mini-stat__lbl">Folders</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Streak (col-2) -->
    <div class="col-6 col-lg-2">
        <div class="db-card h-100 d-flex flex-column align-items-center justify-content-center text-center gap-1 py-3">
            <span class="db-flame">🔥</span>
            <p class="db-streak-num">@Model.Streak</p>
            <p class="db-streak-label">Day Streak</p>
            <div class="db-week-dots mt-2">
                @for (int i = 0; i < 7; i++)
                {
                    <span class="db-day-dot @(i >= streakStart && i <= todayInWeek ? "db-day-dot--on" : "") @(i == todayInWeek ? "db-day-dot--today" : "")">@dayNames[i]</span>
                }
            </div>
        </div>
    </div>

    <!-- Memory Strength (col-3) -->
    <div class="col-6 col-lg-3">
        <div class="db-card h-100 d-flex flex-column">
            <span class="db-label mb-1">Memory Strength</span>
            <div id="dbRadialChart" style="flex:1;min-height:160px;">
                <div class="db-chart-skeleton"></div>
            </div>
            <div class="row g-1 text-center" style="font-size:12px;">
                <div class="col-4">
                    <span class="db-dot db-dot--green"></span>
                    <span class="text-muted">Mastered</span><br>
                    <strong>@Model.MasteredCount</strong>
                </div>
                <div class="col-4">
                    <span class="db-dot db-dot--yellow"></span>
                    <span class="text-muted">Learning</span><br>
                    <strong>@Model.LearningCount</strong>
                </div>
                <div class="col-4">
                    <span class="db-dot db-dot--blue"></span>
                    <span class="text-muted">New</span><br>
                    <strong>@Model.NewCount</strong>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════
     ROW 2 : CTA | Quick Access
═══════════════════════════════════════ -->
<div class="row g-3 mb-3">

    <!-- CTA Study Now (col-4) -->
    <div class="col-12 col-md-5 col-lg-4">
        <div class="db-card db-card--cta h-100 d-flex flex-column justify-content-between">
            <div class="db-cta-deco db-cta-deco--top"></div>
            <div class="db-cta-deco db-cta-deco--bot"></div>
            <a asp-controller="Goals" asp-action="Index" style="position:relative;z-index:1;text-decoration:none;color:inherit;">
                <span class="db-cta-tag">Mục tiêu hôm nay</span>
                <h2 class="db-cta-title">Mục tiêu: <strong>@Model.Goal từ</strong><br><span style="font-size:16px;opacity:0.9">cần ôn mỗi ngày</span></h2>
                <p class="db-cta-sub">Hãy bắt đầu ngay để không gián đoạn streak!</p>
            </a>
            @if (Model.TodayFolders.Any())
            {
                <a asp-controller="Folder" asp-action="FolderDetail"
                   asp-route-id="@Model.TodayFolders.First().FolderId"
                   class="db-cta-btn">
                    <i class="fa-solid fa-bolt"></i> Học ngay!
                </a>
            }
            else
            {
                <a asp-controller="Folder" asp-action="Index" class="db-cta-btn">
                    <i class="fa-solid fa-plus"></i> Tạo folder mới
                </a>
            }
        </div>
    </div>

    <!-- Quick Access (col-8) -->
    <div class="col-12 col-md-7 col-lg-8">
        <div class="db-card h-100">
            <span class="db-label d-block mb-3">Truy cập nhanh</span>
            <div class="row g-2">
                <div class="col-4">
                    <a asp-controller="Vocabulary" asp-action="Index" class="db-quick-item db-quick-item--blue">
                        <i class="fa-solid fa-clone"></i><span>Flashcards</span>
                    </a>
                </div>
                <div class="col-4">
                    <a asp-controller="Speaking" asp-action="Index" class="db-quick-item db-quick-item--yellow">
                        <i class="fa-solid fa-microphone"></i><span>Speaking</span>
                    </a>
                </div>
                <div class="col-4">
                    <a asp-controller="Study" asp-action="Reading" class="db-quick-item db-quick-item--purple">
                        <i class="fa-solid fa-book-open"></i><span>Reading</span>
                    </a>
                </div>
                <div class="col-4">
                    <a asp-controller="Study" asp-action="Listening" class="db-quick-item db-quick-item--blue">
                        <i class="fa-solid fa-headphones"></i><span>Listening</span>
                    </a>
                </div>
                <div class="col-4">
                    <a asp-controller="Study" asp-action="Writing" class="db-quick-item db-quick-item--yellow">
                        <i class="fa-solid fa-pen-nib"></i><span>Writing</span>
                    </a>
                </div>
                <div class="col-4">
                    <a asp-controller="Vocabulary" asp-action="Index" class="db-quick-item db-quick-item--purple">
                        <i class="fa-solid fa-language"></i><span>Vocabulary</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════
     ROW 3 : Heatmap | Today Folders
═══════════════════════════════════════ -->
<div class="row g-3 mb-3">

    <!-- Thời gian học theo tính năng (col-8) -->
    <div class="col-12 col-lg-8">
        <div class="db-card">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="db-label">Thời gian học trong tuần</span>
                <span class="db-label-sub text-muted" style="font-size:.75rem;">phút</span>
            </div>
            <div id="dbTimeChart">
                <div class="db-chart-skeleton" style="height:160px;"></div>
            </div>
        </div>
    </div>

    <!-- Today Folders (col-4) -->
    <div class="col-12 col-lg-4">
        <div class="db-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="db-label">Học gì hôm nay</span>
                <a asp-controller="Folder" asp-action="Index" class="db-link-sm">Xem tất cả →</a>
            </div>

            @if (Model.TodayFolders.Any())
            {
                <div class="d-flex flex-column gap-2">
                    @foreach (var folder in Model.TodayFolders.Take(4))
                    {
                        <a asp-controller="Folder" asp-action="FolderDetail"
                           asp-route-id="@folder.FolderId"
                           class="db-folder-item">
                            <div class="db-folder-icon">
                                <i class="fa-solid fa-folder-open"></i>
                            </div>
                            <div class="db-folder-info">
                                <span class="db-folder-name">@folder.FolderName</span>
                                <span class="db-folder-meta">@folder.SetCount sets · @folder.CreatorName</span>
                            </div>
                            <i class="fa-solid fa-chevron-right db-folder-arrow"></i>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="db-empty">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <p class="mb-2">Bạn chưa có folder nào</p>
                    <a asp-controller="Folder" asp-action="Index" class="db-cta-btn db-cta-btn--sm">
                        Tạo folder đầu tiên
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- ════════════════════════════════════
     ROW 4 : Continue Reading | Daily Challenge
═══════════════════════════════════════ -->
<div class="row g-3 mb-3">

    @if (Model.RecentInProcessReading != null)
    {
        <div class="col-12 col-lg-6">
            <div class="db-card db-card--continue h-100">
                <span class="db-continue-badge">
                    <i class="fa-solid fa-clock-rotate-left"></i> Đang học dở
                </span>
                <h3 class="db-continue-title">@Model.RecentInProcessReading.Title</h3>
                <p class="db-continue-meta">
                    <i class="fa-solid fa-tag"></i> @Model.RecentInProcessReading.Topic
                    &nbsp;·&nbsp;
                    <i class="fa-solid fa-layer-group"></i> Level @Model.RecentInProcessReading.Level
                </p>
                <a asp-controller="Study" asp-action="Reading"
                   class="db-continue-btn">
                    Tiếp tục học <i class="fa-solid fa-play ms-1"></i>
                </a>
            </div>
        </div>
        <div class="col-12 col-lg-6">
            <div class="db-card db-card--challenge h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="db-label">
                        <i class="fa-solid fa-bolt" style="color:#4255ff"></i> Daily Challenge
                    </span>
                </div>
                <div id="daily-challenge-content">
                    <partial name="_DailyChallenge" model="Model.DailyChallenge" />
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="db-card db-card--challenge">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="db-label">
                        <i class="fa-solid fa-bolt" style="color:#4255ff"></i> Daily Challenge
                    </span>
                </div>
                <div id="daily-challenge-content">
                    <partial name="_DailyChallenge" model="Model.DailyChallenge" />
                </div>
            </div>
        </div>
    }
</div>

<!-- ════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════ -->
<script>
document.addEventListener("DOMContentLoaded", function () {

    // ── Daily Challenge ───────────────────────────────────────────
    const container = document.getElementById("daily-challenge-content");
    if (container) {
        container.addEventListener("click", function (e) {
            const btn = e.target.closest(".answer-btn");
            if (!btn || btn.classList.contains("correct") || btn.classList.contains("wrong")) return;

            const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            fetch("/Home/CheckAnswer", {
                method: "POST",
                headers: {
                    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                    "RequestVerificationToken": csrfToken ?? ""
                },
                body: new URLSearchParams({
                    selectedCardId: btn.dataset.id,
                    challengeToken: btn.dataset.token ?? ""
                }).toString()
            })
            .then(r => r.json())
            .then(data => {
                const correctId = String(data.correctCardId ?? "");
                btn.classList.add(data.correct === true ? "correct" : "wrong");
                if (data.correct !== true)
                    container.querySelector(`.answer-btn[data-id="${correctId}"]`)?.classList.add("correct");
                setTimeout(refreshChallenge, 1200);
            })
            .catch(err => console.error("Lỗi:", err));
        });

        function refreshChallenge() {
            container.style.opacity = "0.5";
            fetch("/Home/RefreshDailyChallenge")
                .then(r => r.text())
                .then(html => { container.innerHTML = html; container.style.opacity = "1"; })
                .catch(() => { container.style.opacity = "1"; });
        }
    }

    // ── Radial Bar ────────────────────────────────────────────────
    if (document.querySelector("#dbRadialChart") && typeof ApexCharts !== "undefined") {
        const radialEl = document.querySelector("#dbRadialChart");
        const radialChart = new ApexCharts(radialEl, {
            series: [@masteredPct, @learningPct, @newPct],
            chart:  { type: "radialBar", height: 180, background: "transparent" },
            theme:  { mode: "light" },
            plotOptions: {
                radialBar: {
                    hollow: { size: "28%" },
                    track:  { background: "#f1f5f9", margin: 4 },
                    dataLabels: {
                        name:  { fontSize: "10px", color: "#64748b" },
                        value: { fontSize: "13px", fontWeight: 700, color: "#1e293b" }
                    }
                }
            },
            colors: ["#10b981", "#f59e0b", "#4255ff"],
            labels: ["Mastered", "Learning", "New"],
            legend: { show: false }
        });
        radialEl.querySelector(".db-chart-skeleton")?.remove();
        radialChart.render();
    }

    // ── Stacked Bar: Thời gian học theo tính năng ────────────────────
    if (document.querySelector("#dbTimeChart") && typeof ApexCharts !== "undefined") {
        const ftRaw = @Html.Raw(featureTimeJson);

        // Tính Thứ 2 của tuần hiện tại
        const now = new Date();
        const dow = now.getDay(); // 0=CN, 1=T2, ..., 6=T7
        const daysToMonday = dow === 0 ? -6 : 1 - dow;
        const monday = new Date(now);
        monday.setDate(now.getDate() + daysToMonday);

        // Xây dựng 7 ngày T2→CN với ngày đúng, ghép data từ backend theo DayLabel
        const dayNames = ["T2", "T3", "T4", "T5", "T6", "T7", "CN"];
        const backendMap = {};
        ftRaw.forEach(d => { backendMap[d.DayLabel] = d; });

        const ftData = dayNames.map((label, i) => {
            const date = new Date(monday);
            date.setDate(monday.getDate() + i);
            const dd = String(date.getDate()).padStart(2, "0");
            const mm = String(date.getMonth() + 1).padStart(2, "0");
            const bd = backendMap[label] || {};
            return {
                DayLabel: label,
                FullDate: `${dd}/${mm}`,
                IsToday: date.toDateString() === now.toDateString(),
                FlashcardMinutes: bd.FlashcardMinutes ?? 0,
                QuizMinutes:      bd.QuizMinutes      ?? 0,
                SpeakingMinutes:  bd.SpeakingMinutes  ?? 0,
                ReadingMinutes:   bd.ReadingMinutes   ?? 0,
                ListeningMinutes: bd.ListeningMinutes ?? 0,
                WritingMinutes:   bd.WritingMinutes   ?? 0,
                GrammarMinutes:   bd.GrammarMinutes   ?? 0,
            };
        });

        const labels = ftData.map(d => d.DayLabel);

        // Màu sắc cho từng tính năng
        const features = [
            { key: "FlashcardMinutes", name: "Flashcard",  color: "#4255ff" },
            { key: "QuizMinutes",      name: "Quiz",        color: "#f97316" },
            { key: "SpeakingMinutes",  name: "Speaking",    color: "#10b981" },
            { key: "ReadingMinutes",   name: "Reading",     color: "#6366f1" },
            { key: "ListeningMinutes", name: "Listening",   color: "#f59e0b" },
            { key: "WritingMinutes",   name: "Writing",     color: "#ec4899" },
            { key: "GrammarMinutes",   name: "Grammar",     color: "#14b8a6" },
        ];

        const timeEl = document.querySelector("#dbTimeChart");
        const timeChart = new ApexCharts(timeEl, {
            series: features.map(f => ({
                name: f.name,
                data: ftData.map(d => d[f.key] ?? 0)
            })),
            chart: {
                type: "bar", stacked: true, height: 160,
                background: "transparent", toolbar: { show: false },
                animations: { enabled: true, speed: 500 }
            },
            colors: features.map(f => f.color),
            plotOptions: {
                bar: { borderRadius: 3, columnWidth: "55%" }
            },
            dataLabels: { enabled: false },
            xaxis: {
                categories: labels,
                labels: { style: { colors: "#94a3b8", fontSize: "11px" } },
                axisBorder: { show: false },
                axisTicks:  { show: false }
            },
            yaxis: {
                labels: {
                    style: { colors: "#94a3b8", fontSize: "11px" },
                    formatter: v => v > 0 ? v + "p" : ""
                },
                min: 0
            },
            grid: { borderColor: "#f1f5f9", strokeDashArray: 4, padding: { left: 0 } },
            legend: {
                show: true, position: "top", horizontalAlign: "right",
                fontSize: "11px", offsetY: -8,
                markers: { width: 8, height: 8, radius: 2 }
            },
            tooltip: {
                shared: true,
                intersect: false,
                theme: "light",
                y: { formatter: v => v + " phút" },
                x: {
                    formatter: (val, { dataPointIndex }) => {
                        const d = ftData[dataPointIndex];
                        return `${d.DayLabel} (${d.FullDate})${d.IsToday ? " — Hôm nay" : ""}`;
                    }
                }
            }
        });
        timeEl.querySelector(".db-chart-skeleton")?.remove();
        timeChart.render();
    }
});
</script>


