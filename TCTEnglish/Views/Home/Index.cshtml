@model TCTVocabulary.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}


<link rel="stylesheet" href="~/css/Dashboard.css" />
@Html.AntiForgeryToken()
<div class="dashboard">
    <div class="hero-section">

        <!-- ================= WELCOME CARD ================= -->
        <section class="welcome-card">
            <div class="welcome-content">
                <h1 class="welcome-title">
                    Welcome back, @User.Identity?.Name
                    <i class="fa-solid fa-hand-wave"></i>
                </h1>

                <p class="welcome-subtitle">
                    Học từ vựng hiệu quả mỗi ngày
                </p>

                <!-- ===== STATS (HORIZONTAL) ===== -->
                <div class="welcome-stats">

                    <div class="stat-item">
                        <span class="stat-icon">
                            <i class="fa-solid fa-fire"></i>
                        </span>
                        <div class="stat-info">
                            <span class="stat-value">@Model.Streak</span>
                            <span class="stat-label">Streak</span>
                        </div>
                    </div>

                    <div class="stat-item">
                        <span class="stat-icon">
                            <i class="fa-solid fa-bullseye"></i>
                        </span>
                        <div class="stat-info">
                            <span class="stat-value">@Model.Goal</span>
                            <span class="stat-label">Goal</span>
                        </div>
                    </div>

                    <div class="stat-item">
                        <span class="stat-icon">
                            <i class="fa-solid fa-folder"></i>
                        </span>
                        <div class="stat-info">
                            <span class="stat-value">@Model.FolderCount</span>
                            <span class="stat-label">Folders</span>
                        </div>
                    </div>

                    <div class="stat-item">
                        <span class="stat-icon">
                            <i class="fa-solid fa-brain"></i>
                        </span>
                        <div class="stat-info">
                            <span class="stat-value">@Model.CardCount</span>
                            <span class="stat-label">Cards</span>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- ===== FEATURES ===== -->
        <div class="features">
            <h3>Top Features</h3>

            <div class="feature-list">
                <a asp-controller="Study" asp-action="Grammar" class="feature">
                    <i class="fa-solid fa-spell-check"></i>
                    Grammar
                </a>

                <a asp-controller="Study" asp-action="Listening" class="feature">
                    <i class="fa-solid fa-headphones"></i>
                    Listening
                </a>

                <a asp-controller="Study" asp-action="Reading" class="feature">
                    <i class="fa-solid fa-book-open"></i>
                    Reading
                </a>

                <a asp-controller="Study" asp-action="Writing" class="feature">
                    <i class="fa-solid fa-pen-nib"></i>
                    Writing
                </a>

                <a asp-controller="Speaking" asp-action="Index" class="feature speaking">
                    <i class="fa-solid fa-microphone"></i>
                    Speaking
                </a>
            </div>
        </div>
        @if (Model.RecentInProcessReading != null)
        {
            <div class="continue-learning mb-4">
                <div class="card border-primary shadow-sm" style="border-left: 5px solid var(--primary-blue);">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <span class="badge bg-warning text-dark mb-1">
                                <i class="fa-solid fa-clock-rotate-left"></i> Đang học dở
                            </span>
                            <h4 class="mb-1">@Model.RecentInProcessReading.Title</h4>
                            <p class="text-muted mb-0 small">
                                <i class="fa-solid fa-tag"></i> @Model.RecentInProcessReading.Topic •
                                <i class="fa-solid fa-layer-group"></i> Level @Model.RecentInProcessReading.Level
                            </p>
                        </div>
                        <div>
                            <a asp-controller="Reading" asp-action="Study" asp-route-id="@Model.RecentInProcessReading.Id"
                                   class="btn btn-primary rounded-pill px-4">
                                Tiếp tục học <i class="fa-solid fa-play ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
        <!-- ===== TODAY LEARNING ===== -->
        <div class="today-learning">
            <h3>
                <i class="fa-solid fa-graduation-cap"></i>
                Học gì hôm nay
            </h3>

            @if (Model.TodayFolders.Any())
            {
                <div class="today-folder-list">
                    @foreach (var folder in Model.TodayFolders)
                    {
                        <div class="today-folder-card">
                            <h4>
                                <i class="fa-solid fa-folder-open"></i>
                                @folder.FolderName
                            </h4>

                                <p>
                                <i class="fa-solid fa-layer-group"></i>
                                @folder.SetCount set •
                                <i class="fa-solid fa-user"></i>
                                @folder.CreatorName
                            </p>

                            <a asp-action="FolderDetail"
                               asp-controller="Folder"
                               asp-route-id="@folder.FolderId" class="learn-btn">
                                Xem & học
                                <i class="fa-solid fa-arrow-right"></i>
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="empty-text">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    Bạn chưa có folder nào
                </p>
            }
        </div>

        <!-- ===== DAILY CHALLENGE ===== -->
        <div class="challenge">
            <h3>
                <i class="fa-solid fa-bolt"></i>
                Daily Challenge
            </h3>

            <partial name="_DailyChallenge" model="Model.DailyChallenge" />
        </div>

    </div>
</div>
<script>
    document.querySelectorAll(".answer-btn").forEach(btn => {
        btn.addEventListener("click", function () {

            if (this.classList.contains("correct") || this.classList.contains("wrong"))
                return;

            const selected = this.dataset.id;
            const challengeToken = this.dataset.token;
            const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            const payload = new URLSearchParams({
                selectedCardId: selected,
                challengeToken: challengeToken ?? ""
            });

            fetch("/Home/CheckAnswer", {
                method: "POST",
                headers: {
                    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                    "RequestVerificationToken": antiForgeryToken ?? ""
                },
                body: payload.toString()
            })
                .then(async response => {
                    if (!response.ok) {
                        throw new Error(`CheckAnswer failed: ${response.status}`);
                    }

                    return await response.json();
                })
                .then(data => {
                    const correctCardId = String(data.correctCardId ?? "");
                    if (data.correct === true) {
                        this.classList.add("correct");
                    } else {
                        this.classList.add("wrong");
                        document.querySelector(`.answer-btn[data-id="${correctCardId}"]`)?.classList.add("correct");
                    }

                    setTimeout(() => {
                        location.reload();
                    }, 800);
                })
                .catch(error => {
                    console.error(error);
                });
        });
    });
</script>
