@{
    ViewData["Title"] = "Liên hệ";
}

@section Styles {
<style>
    /* ===== CONTACT PAGE ===== */
    .contact-hero {
        background: linear-gradient(135deg, #4255ff 0%, #7c3aed 100%);
        border-radius: 16px;
        padding: 48px 40px;
        color: #fff;
        margin-bottom: 32px;
        position: relative;
        overflow: hidden;
    }

    .contact-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        background: rgba(255,255,255,0.08);
        border-radius: 50%;
    }

    .contact-hero::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 300px;
        height: 300px;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
    }

    .contact-hero h1 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 8px;
        position: relative;
        z-index: 1;
    }

    .contact-hero p {
        font-size: 1rem;
        opacity: 0.9;
        position: relative;
        z-index: 1;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 32px;
        align-items: start;
    }

    @@media (max-width: 768px) {
        .contact-grid {
            grid-template-columns: 1fr;
        }
    }

    /* --- INFO CARDS --- */
    .info-section {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .info-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: box-shadow 0.2s, border-color 0.2s;
    }

    .info-card:hover {
        border-color: #c7d2fe;
        box-shadow: 0 4px 16px rgba(66,85,255,0.08);
    }

    .info-card .icon-box {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .icon-box.blue   { background: #e0e7ff; color: #4255ff; }
    .icon-box.green  { background: #d1fae5; color: #059669; }
    .icon-box.purple { background: #ede9fe; color: #7c3aed; }
    .icon-box.orange { background: #ffedd5; color: #ea580c; }

    .info-card .info-text h5 {
        font-size: 14px;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .info-card .info-text p {
        font-size: 15px;
        font-weight: 600;
        color: #1f2937;
        margin: 0;
    }

    /* --- FORM CARD --- */
    .form-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 32px;
    }

    .form-card h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 4px;
    }

    .form-card .form-subtitle {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 24px;
    }

    .form-card .form-label {
        font-weight: 600;
        font-size: 13px;
        color: #374151;
        margin-bottom: 6px;
    }

    .form-card .form-control {
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 14px;
        transition: border-color 0.2s;
    }

    .form-card .form-control:focus {
        border-color: #4255ff;
        box-shadow: 0 0 0 3px rgba(66,85,255,0.1);
    }

    .form-card textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .btn-send {
        background: #4255ff;
        color: #fff;
        font-weight: 700;
        font-size: 15px;
        border: none;
        border-radius: 10px;
        padding: 12px 32px;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-send:hover {
        background: #3345d6;
        color: #fff;
    }

    .btn-send:active {
        transform: scale(0.98);
    }

    /* --- FAQ --- */
    .faq-section {
        margin-top: 48px;
    }

    .faq-section h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 20px;
    }

    .faq-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    @@media (max-width: 768px) {
        .faq-grid {
            grid-template-columns: 1fr;
        }
    }

    .faq-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 20px 24px;
        transition: border-color 0.2s;
    }

    .faq-item:hover {
        border-color: #c7d2fe;
    }

    .faq-item h5 {
        font-size: 14px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 6px;
    }

    .faq-item p {
        font-size: 13px;
        color: #6b7280;
        margin: 0;
        line-height: 1.6;
    }
</style>
}

<!-- ===== HERO ===== -->
<div class="contact-hero">
    <h1><i class="fa-solid fa-headset me-2"></i> Liên hệ với chúng tôi</h1>
    <p>Bạn có câu hỏi, góp ý hoặc cần hỗ trợ? Đội ngũ TCT English luôn sẵn sàng giúp đỡ bạn.</p>
</div>

<!-- ===== GRID: INFO + FORM ===== -->
<div class="contact-grid">

    <!-- LEFT: Info Cards -->
    <div class="info-section">
        <div class="info-card">
            <div class="icon-box blue">
                <i class="fa-solid fa-envelope"></i>
            </div>
            <div class="info-text">
                <h5>Email</h5>
                <p>support.tctenglish@gmail.com</p>
            </div>
        </div>

        <div class="info-card">
            <div class="icon-box green">
                <i class="fa-solid fa-phone"></i>
            </div>
            <div class="info-text">
                <h5>Điện thoại</h5>
                <p>+84 123 456 789</p>
            </div>
        </div>

        <div class="info-card">
            <div class="icon-box purple">
                <i class="fa-solid fa-location-dot"></i>
            </div>
            <div class="info-text">
                <h5>Địa chỉ</h5>
                <p>Hà Nội, Việt Nam</p>
            </div>
        </div>

        <div class="info-card">
            <div class="icon-box orange">
                <i class="fa-solid fa-clock"></i>
            </div>
            <div class="info-text">
                <h5>Giờ làm việc</h5>
                <p>Thứ 2 – Thứ 6, 8:00 – 17:30</p>
            </div>
        </div>
    </div>

    <!-- RIGHT: Contact Form -->
    <div class="form-card">
        <h3>Gửi tin nhắn</h3>
        <p class="form-subtitle">Chúng tôi sẽ phản hồi trong vòng 24 giờ làm việc.</p>

        <form id="contactForm">
            <div class="mb-3">
                <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="contactName" placeholder="Nhập họ tên..." required />
            </div>

            <div class="mb-3">
                <label class="form-label">Email <span class="text-danger">*</span></label>
                <input type="email" class="form-control" id="contactEmail" placeholder="example@email.com" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Chủ đề</label>
                <select class="form-control" id="contactSubject">
                    <option value="general">Câu hỏi chung</option>
                    <option value="khieu-nai-khoa-tai-khoan">Khiếu nại khóa tài khoản</option>
                    <option value="bug">Báo lỗi / Bug</option>
                    <option value="feedback">Góp ý cải tiến</option>
                    <option value="other">Khác</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Nội dung <span class="text-danger">*</span></label>
                <textarea class="form-control" id="contactMessage" placeholder="Mô tả chi tiết vấn đề của bạn..." required></textarea>
            </div>

            <button type="submit" class="btn-send">
                <i class="fa-solid fa-paper-plane"></i> Gửi tin nhắn
            </button>
        </form>
    </div>
</div>

<!-- ===== FAQ ===== -->
<div class="faq-section">
    <h3><i class="fa-solid fa-circle-question me-2" style="color:#4255ff;"></i> Câu hỏi thường gặp</h3>
    <div class="faq-grid">
        <div class="faq-item">
            <h5>Tài khoản bị khóa thì phải làm gì?</h5>
            <p>Bạn hãy gửi tin nhắn với chủ đề "Khiếu nại khóa tài khoản" kèm theo email đăng ký. Đội ngũ admin sẽ xem xét và phản hồi sớm nhất.</p>
        </div>
        <div class="faq-item">
            <h5>Làm sao để đổi mật khẩu?</h5>
            <p>Vào Cài đặt tài khoản → Đổi mật khẩu, hoặc sử dụng chức năng "Quên mật khẩu" ở trang đăng nhập.</p>
        </div>
        <div class="faq-item">
            <h5>TCT English có miễn phí không?</h5>
            <p>Có! Tất cả tính năng cơ bản đều miễn phí cho nhân viên công ty TCT.</p>
        </div>
        <div class="faq-item">
            <h5>Tôi muốn góp ý/báo lỗi?</h5>
            <p>Bạn có thể gửi qua form trên hoặc email trực tiếp cho chúng tôi. Mọi ý kiến đều được ghi nhận!</p>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Auto-select subject from query string
    document.addEventListener('DOMContentLoaded', function () {
        const params = new URLSearchParams(window.location.search);
        const subject = params.get('subject');
        if (subject) {
            const select = document.getElementById('contactSubject');
            const option = select.querySelector('option[value="' + subject + '"]');
            if (option) {
                select.value = subject;
            }
        }
    });

    // Form submit → SweetAlert (no backend processing for now)
    document.getElementById('contactForm').addEventListener('submit', function (e) {
        e.preventDefault();

        const name = document.getElementById('contactName').value.trim();
        const email = document.getElementById('contactEmail').value.trim();
        const message = document.getElementById('contactMessage').value.trim();

        if (!name || !email || !message) {
            Swal.fire({
                icon: 'warning',
                title: 'Thiếu thông tin',
                text: 'Vui lòng điền đầy đủ các trường bắt buộc.',
                confirmButtonColor: '#4255ff'
            });
            return;
        }

        Swal.fire({
            icon: 'success',
            title: 'Đã gửi thành công!',
            html: 'Cảm ơn bạn đã liên hệ.<br>Chúng tôi sẽ phản hồi qua email <strong>' + email + '</strong> trong thời gian sớm nhất.',
            confirmButtonColor: '#4255ff',
            confirmButtonText: 'Đã hiểu'
        });

        this.reset();
    });
</script>
}
