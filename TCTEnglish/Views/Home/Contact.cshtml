@model TCTVocabulary.ViewModel.ContactFormViewModel

@{
    ViewData["Title"] = "Liên hệ";
    var subjectOptions = TCTVocabulary.ViewModel.ContactFormViewModel.SubjectOptions;
}

@section Styles {
<style>
    .contact-hero {
        background: linear-gradient(135deg, #4255ff 0%, #7c3aed 100%);
        border-radius: 16px;
        padding: 48px 40px;
        color: #fff;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
    }

    .contact-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        background: rgba(255,255,255,0.08);
        border-radius: 50%;
    }

    .contact-hero::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 300px;
        height: 300px;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
    }

    .contact-hero h1,
    .contact-hero p {
        position: relative;
        z-index: 1;
    }

    .contact-hero h1 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .contact-hero p {
        font-size: 1rem;
        opacity: 0.92;
    }

    .contact-alert {
        margin-bottom: 16px;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 32px;
        align-items: start;
    }

    @@media (max-width: 768px) {
        .contact-grid {
            grid-template-columns: 1fr;
        }
    }

    .info-section {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .info-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: box-shadow 0.2s, border-color 0.2s;
    }

    .info-card:hover {
        border-color: #c7d2fe;
        box-shadow: 0 4px 16px rgba(66,85,255,0.08);
    }

    .info-card .icon-box {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .icon-box.blue { background: #e0e7ff; color: #4255ff; }
    .icon-box.green { background: #d1fae5; color: #059669; }
    .icon-box.purple { background: #ede9fe; color: #7c3aed; }
    .icon-box.orange { background: #ffedd5; color: #ea580c; }

    .info-card .info-text h5 {
        font-size: 14px;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .info-card .info-text p {
        font-size: 15px;
        font-weight: 600;
        color: #1f2937;
        margin: 0;
    }

    .form-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 32px;
    }

    .form-card h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 4px;
    }

    .form-card .form-subtitle {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 24px;
    }

    .form-card .form-label {
        font-weight: 600;
        font-size: 13px;
        color: #374151;
        margin-bottom: 6px;
    }

    .form-card .form-control {
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 14px;
        transition: border-color 0.2s;
    }

    .form-card .form-control:focus {
        border-color: #4255ff;
        box-shadow: 0 0 0 3px rgba(66,85,255,0.1);
    }

    .form-card textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .field-validation-error {
        display: block;
        margin-top: 6px;
        font-size: 12px;
    }

    .validation-summary-valid {
        display: none;
    }

    .btn-send {
        background: #4255ff;
        color: #fff;
        font-weight: 700;
        font-size: 15px;
        border: none;
        border-radius: 10px;
        padding: 12px 32px;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-send:hover {
        background: #3345d6;
        color: #fff;
    }

    .btn-send:active {
        transform: scale(0.98);
    }

    .faq-section {
        margin-top: 48px;
    }

    .faq-section h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 20px;
    }

    .faq-icon {
        color: #4255ff;
    }

    .faq-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    @@media (max-width: 768px) {
        .faq-grid {
            grid-template-columns: 1fr;
        }
    }

    .faq-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 20px 24px;
        transition: border-color 0.2s;
    }

    .faq-item:hover {
        border-color: #c7d2fe;
    }

    .faq-item h5 {
        font-size: 14px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 6px;
    }

    .faq-item p {
        font-size: 13px;
        color: #6b7280;
        margin: 0;
        line-height: 1.6;
    }
</style>
}

<div class="contact-hero">
    <h1><i class="fa-solid fa-headset me-2"></i> Liên hệ với chúng tôi</h1>
    <p>Bạn có câu hỏi, góp ý hoặc cần hỗ trợ? Đội ngũ TCT English luôn sẵn sàng giúp đỡ bạn.</p>
</div>

@if (TempData["ContactSuccessMessage"] is string successMessage)
{
    <div class="alert alert-success contact-alert" role="alert">
        @successMessage
    </div>
}

@if (TempData["ContactErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger contact-alert" role="alert">
        @errorMessage
    </div>
}

<div class="contact-grid">
    <div class="info-section">
        <div class="info-card">
            <div class="icon-box blue">
                <i class="fa-solid fa-envelope"></i>
            </div>
            <div class="info-text">
                <h5>Email</h5>
                <p>support.tctenglish@gmail.com</p>
            </div>
        </div>

        <div class="info-card">
            <div class="icon-box green">
                <i class="fa-solid fa-phone"></i>
            </div>
            <div class="info-text">
                <h5>Điện thoại</h5>
                <p>+84 123 456 789</p>
            </div>
        </div>

        <div class="info-card">
            <div class="icon-box purple">
                <i class="fa-solid fa-location-dot"></i>
            </div>
            <div class="info-text">
                <h5>Địa chỉ</h5>
                <p>Hà Nội, Việt Nam</p>
            </div>
        </div>

        <div class="info-card">
            <div class="icon-box orange">
                <i class="fa-solid fa-clock"></i>
            </div>
            <div class="info-text">
                <h5>Giờ làm việc</h5>
                <p>Thứ 2 - Thứ 6, 8:00 - 17:30</p>
            </div>
        </div>
    </div>

    <div class="form-card">
        <h3>Gửi tin nhắn</h3>
        <p class="form-subtitle">Chúng tôi sẽ phản hồi trong vòng 24 giờ làm việc.</p>

        <form asp-action="Contact" asp-controller="Home" method="post" id="contactForm" novalidate>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="Nhập họ tên..." autocomplete="name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                <input asp-for="Email" class="form-control" placeholder="example@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Subject" class="form-label">Chủ đề</label>
                <select asp-for="Subject" class="form-control">
                    @foreach (var item in subjectOptions)
                    {
                        <option value="@item.Key">@item.Value</option>
                    }
                </select>
                <span asp-validation-for="Subject" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Message" class="form-label">Nội dung <span class="text-danger">*</span></label>
                <textarea asp-for="Message" class="form-control" placeholder="Mô tả chi tiết vấn đề của bạn..."></textarea>
                <span asp-validation-for="Message" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-send">
                <i class="fa-solid fa-paper-plane"></i> Gửi tin nhắn
            </button>
        </form>
    </div>
</div>

<div class="faq-section">
    <h3><i class="fa-solid fa-circle-question me-2 faq-icon"></i> Câu hỏi thường gặp</h3>
    <div class="faq-grid">
        <div class="faq-item">
            <h5>Tài khoản bị khóa thì phải làm gì?</h5>
            <p>Hãy gửi tin nhắn với chủ đề "Khiếu nại khóa tài khoản" kèm theo email đăng ký. Đội ngũ admin sẽ xem xét và phản hồi sớm nhất.</p>
        </div>
        <div class="faq-item">
            <h5>Làm sao để đổi mật khẩu?</h5>
            <p>Vào Cài đặt tài khoản -> Đổi mật khẩu, hoặc dùng chức năng "Quên mật khẩu" ở trang đăng nhập.</p>
        </div>
        <div class="faq-item">
            <h5>TCT English có miễn phí không?</h5>
            <p>Có. Tất cả tính năng cơ bản đều miễn phí cho nhân viên công ty TCT.</p>
        </div>
        <div class="faq-item">
            <h5>Tôi muốn góp ý/báo lỗi?</h5>
            <p>Bạn có thể gửi qua form trên hoặc email trực tiếp cho chúng tôi. Mọi ý kiến đều được ghi nhận.</p>
        </div>
    </div>
</div>

