@model TCTVocabulary.ViewModel.ContactFormViewModel

@{
    ViewData["Title"] = "Liên hệ";
    var subjectOptions = TCTVocabulary.ViewModel.ContactFormViewModel.SubjectOptions;
}

@section Styles {
    <link rel="stylesheet" href="~/css/contact.css" asp-append-version="true" />
}

<div class="contact-hero">
    <h1><i class="fa-solid fa-headset me-2"></i> Liên hệ với chúng tôi</h1>
    <p>Bạn có câu hỏi, góp ý hoặc cần hỗ trợ? Đội ngũ TCT English luôn sẵn sàng giúp đỡ bạn.</p>
</div>

@if (TempData["ContactSuccessMessage"] is string successMessage)
{
    <div class="alert alert-success contact-alert" role="alert">
        @successMessage
    </div>
}

@if (TempData["ContactErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger contact-alert" role="alert">
        @errorMessage
    </div>
}

<div class="contact-grid">
    <div class="info-section">
        <div class="info-card">
            <div class="icon-box blue">
                <i class="fa-solid fa-envelope"></i>
            </div>
            <div class="info-text">
                <h5>Email</h5>
                <p>support.tctenglish@gmail.com</p>
            </div>
        </div>

        <div class="info-card">
            <div class="icon-box green">
                <i class="fa-solid fa-phone"></i>
            </div>
            <div class="info-text">
                <h5>Điện thoại</h5>
                <p>+84 123 456 789</p>
            </div>
        </div>

        <div class="info-card">
            <div class="icon-box purple">
                <i class="fa-solid fa-location-dot"></i>
            </div>
            <div class="info-text">
                <h5>Địa chỉ</h5>
                <p>Hà Nội, Việt Nam</p>
            </div>
        </div>

        <div class="info-card">
            <div class="icon-box orange">
                <i class="fa-solid fa-clock"></i>
            </div>
            <div class="info-text">
                <h5>Giờ làm việc</h5>
                <p>Thứ 2 - Thứ 6, 8:00 - 17:30</p>
            </div>
        </div>
    </div>

    <div class="form-card">
        <h3>Gửi tin nhắn</h3>
        <p class="form-subtitle">Chúng tôi sẽ phản hồi trong vòng 24 giờ làm việc.</p>

        <form asp-action="Contact" asp-controller="Home" method="post" id="contactForm" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="Nhập họ tên..." autocomplete="name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                <input asp-for="Email" class="form-control" placeholder="example@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Subject" class="form-label">Chủ đề</label>
                <select asp-for="Subject" class="form-control">
                    @foreach (var item in subjectOptions)
                    {
                        <option value="@item.Key">@item.Value</option>
                    }
                </select>
                <span asp-validation-for="Subject" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Message" class="form-label">Nội dung <span class="text-danger">*</span></label>
                <textarea asp-for="Message" class="form-control" placeholder="Mô tả chi tiết vấn đề của bạn..."></textarea>
                <span asp-validation-for="Message" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-send" id="contactSubmitBtn" aria-live="polite">
                <span class="btn-send-default">
                    <i class="fa-solid fa-paper-plane"></i>
                    Gửi tin nhắn
                </span>
                <span class="btn-send-loading" aria-hidden="true">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    Đang gửi...
                </span>
            </button>
        </form>
    </div>
</div>

<div class="faq-section">
    <h3><i class="fa-solid fa-circle-question me-2 faq-icon"></i> Câu hỏi thường gặp</h3>
    <div class="faq-grid">
        <div class="faq-item">
            <h5>Tài khoản bị khóa thì phải làm gì?</h5>
            <p>Hãy gửi tin nhắn với chủ đề "Khiếu nại khóa tài khoản" kèm theo email đăng ký. Đội ngũ admin sẽ xem xét và phản hồi sớm nhất.</p>
        </div>
        <div class="faq-item">
            <h5>Làm sao để đổi mật khẩu?</h5>
            <p>Vào Cài đặt tài khoản -> Đổi mật khẩu, hoặc dùng chức năng "Quên mật khẩu" ở trang đăng nhập.</p>
        </div>
        <div class="faq-item">
            <h5>TCT English có miễn phí không?</h5>
            <p>Có. Tất cả tính năng cơ bản đều miễn phí cho nhân viên công ty TCT.</p>
        </div>
        <div class="faq-item">
            <h5>Tôi muốn góp ý/báo lỗi?</h5>
            <p>Bạn có thể gửi qua form trên hoặc email trực tiếp cho chúng tôi. Mọi ý kiến đều được ghi nhận.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/contact.js" asp-append-version="true"></script>
}
