@{
    ViewData["Title"] = "Mục tiêu học tập";
}

@section Styles {
    <link rel="stylesheet" href="~/css/goals.css" />
}

<div class="container-fluid goals-container">
    <!-- Header -->
    <div class="row align-items-center mb-4">
        <div class="col-6">
            <h2 class="section-title">Mục tiêu của tôi</h2>
        </div>
        <div class="col-6 text-end">
            <button class="btn btn-outline-primary btn-edit-goals">
                <i class="fas fa-pencil-alt me-2"></i>Chỉnh sửa mục tiêu
            </button>
        </div>
    </div>

    <!-- Row 1: Overview (Streak & Daily Progress) -->
    <div class="row mb-4">
        <!-- Streak Card -->
        <div class="col-md-6 mb-3 mb-md-0">
            <div class="card h-100 shadow-sm border-0 goal-card">
                <div class="card-body d-flex align-items-center">
                    <div class="fire-icon-wrapper me-4">
                        <i class="fas fa-fire fire-icon"></i>
                    </div>
                    <div>
                        <h1 class="display-4 fw-bold mb-0">12 Ngày</h1>
                        <p class="text-muted mb-0">Bạn đang cháy hết mình! 🔥</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Daily Progress Card -->
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0 goal-card">
                <div class="card-body d-flex flex-column justify-content-center align-items-center">
                    <div class="circular-progress position-relative">
                        <svg viewBox="0 0 36 36" class="circular-chart">
                            <path class="circle-bg"
                                  d="M18 2.0845
                                     a 15.9155 15.9155 0 0 1 0 31.831
                                     a 15.9155 15.9155 0 0 1 0 -31.831" />
                            <path class="circle"
                                  stroke-dasharray="60, 100"
                                  d="M18 2.0845
                                     a 15.9155 15.9155 0 0 1 0 31.831
                                     a 15.9155 15.9155 0 0 1 0 -31.831" />
                        </svg>
                        <div class="percentage-label">
                            <span class="fs-4 fw-bold">30/50</span>
                            <span class="d-block text-muted small">XP</span>
                        </div>
                    </div>
                    <p class="mt-3 mb-0 fw-bold">Mục tiêu ngày</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2: Activity Chart -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 goal-card">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-4">Hoạt động tuần này</h5>
                    <div class="chart-container">
                        <div class="chart-bar" style="--height: 40%;" data-day="Mon"></div>
                        <div class="chart-bar" style="--height: 70%;" data-day="Tue"></div>
                        <div class="chart-bar" style="--height: 55%;" data-day="Wed"></div>
                        <div class="chart-bar active" style="--height: 85%;" data-day="Thu"></div>
                        <div class="chart-bar" style="--height: 30%;" data-day="Fri"></div>
                        <div class="chart-bar" style="--height: 10%;" data-day="Sat"></div>
                        <div class="chart-bar" style="--height: 60%;" data-day="Sun"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 3: Achievements -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0 goal-card">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-4">Huy hiệu</h5>
                    <div class="achievements-list d-flex gap-4 overflow-auto pb-3">
                        <!-- Unlocked Badge -->
                        <div class="badge-item text-center">
                            <div class="badge-icon unlocked mb-2">
                                <i class="fas fa-rocket"></i>
                            </div>
                            <span class="badge-name">Khởi đầu</span>
                        </div>
                        <!-- Unlocked Badge -->
                        <div class="badge-item text-center">
                            <div class="badge-icon unlocked mb-2">
                                <i class="fas fa-book-open"></i>
                            </div>
                            <span class="badge-name">Mọt sách</span>
                        </div>
                        <!-- Unlocked Badge -->
                        <div class="badge-item text-center">
                            <div class="badge-icon unlocked mb-2">
                                <i class="fas fa-bolt"></i>
                            </div>
                            <span class="badge-name">Cao thủ</span>
                        </div>
                        <!-- Locked Badge -->
                        <div class="badge-item text-center">
                            <div class="badge-icon locked mb-2">
                                <i class="fas fa-lock"></i>
                            </div>
                            <span class="badge-name">Tương lai</span>
                        </div>
                        <!-- Locked Badge -->
                        <div class="badge-item text-center">
                            <div class="badge-icon locked mb-2">
                                <i class="fas fa-lock"></i>
                            </div>
                            <span class="badge-name">Bí ẩn</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
