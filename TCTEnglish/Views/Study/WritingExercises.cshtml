@using System
@using System.Linq
@model TCTEnglish.ViewModels.WritingExerciseListViewModel
@{
    ViewData["Title"] = "Bài tập viết";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var hasMyExercises = Model.MyExercises.Any();
    var createFromAiUrl = Url.Action("CreateWritingExerciseFromAi", "Study") ?? string.Empty;
    var practiceUrl = Url.Action("WritingPractice", "Study") ?? string.Empty;
}

@section Styles {
    <link rel="stylesheet" href="~/css/writing-exercises.css" asp-append-version="true" />
}

<div class="writing-exercises-page">
    <div class="writing-exercises-shell">

        @* ── Breadcrumbs ──────────────────────────────────── *@
        <nav class="writing-breadcrumb" aria-label="Điều hướng trang">
            <a href="/Home">Trang chủ</a>
            <i class="fas fa-chevron-right" style="font-size: 0.6rem;"></i>
            <a asp-controller="Study" asp-action="Writing" asp-route-level="@Model.SelectedLevelKey">Viết</a>
            <i class="fas fa-chevron-right" style="font-size: 0.6rem;"></i>
            <span style="color:var(--we-primary); font-weight:700;">@Model.SelectedContentTypeTitle</span>
        </nav>

        @* ── Flash Messages ───────────────────────────────── *@
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="writing-alert writing-alert--success" role="alert">
                <i class="fas fa-check-circle"></i>
                @successMessage
            </div>
        }

        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="writing-alert writing-alert--error" role="alert">
                <i class="fas fa-exclamation-circle"></i>
                <span>@Html.Raw(errorMessage)</span>
            </div>
        }

        @* ── Page Header ──────────────────────────────────── *@
        <div class="writing-exercises-head">
            <div>
                <h1 class="writing-exercises-title">Danh sách bài tập viết</h1>
                <div class="writing-exercises-meta">
                    <span class="writing-level-chip">
                        <i class="fas fa-layer-group"></i>
                        @Model.SelectedLevelTitle
                    </span>
                    <span class="writing-exercises-count">
                        @Model.TotalCount bài tập khả dụng
                    </span>
                </div>
            </div>
        </div>

        @* ── Filter Bar ───────────────────────────────────── *@
        <section class="writing-filter-bar">
            <div class="writing-filter-search">
                <i class="fas fa-search filter-search-icon"></i>
                <input type="text"
                       placeholder="Tìm kiếm trên trang hiện tại..."
                       readonly
                       title="Tìm kiếm không khả dụng ở dạng tĩnh"
                       style="opacity:0.6; cursor:not-allowed;" />
            </div>

            <form method="get"
                  asp-controller="Study"
                  asp-action="WritingExercises"
                  class="writing-filters-group"
                  data-writing-filter-form>
                <input type="hidden" name="level" value="@Model.SelectedLevelKey" />
                <input type="hidden" name="contentType" value="@Model.SelectedContentTypeKey" />
                <input type="hidden" name="page" value="1" />

                <select name="topic" class="writing-select" data-filter-select>
                    @foreach (var option in Model.TopicOptions)
                    {
                        <option value="@option.Value" selected="@(string.Equals(option.Value, Model.SelectedTopic, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                            @option.Label
                        </option>
                    }
                </select>

                @if (Model.ShowProgressMetadata)
                {
                    <select name="status" class="writing-select" data-filter-select>
                        @foreach (var option in Model.StatusOptions)
                        {
                            <option value="@option.Value" selected="@(string.Equals(option.Value, Model.SelectedStatus, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                @option.Label
                            </option>
                        }
                    </select>
                }
            </form>
        </section>

        @* ── My Exercises (Authenticated) ─────────────────── *@
        @if (Model.IsAuthenticatedUser)
        {
            <div class="mb-8">
                <h2 class="writing-section-title">Bài viết của tôi</h2>

                @if (Model.CanCreateFromAi)
                {
                    <div class="writing-create-panel">
                        <div class="writing-create-grid">
                            <div class="writing-create-copy">
                                <h3>Tạo bài viết bằng AI</h3>
                                <p>Dán một bài tiếng Việt hoặc tiếng Anh hoàn chỉnh. Hệ thống sẽ tách câu, dịch song ngữ và đưa bài mới vào luồng luyện tập.</p>
                                <span class="writing-card-chip writing-card-chip--default" style="display:inline-block; margin-top:1rem; background:#f0fdfa; color:#0f766e;">
                                    <i class="fas fa-sparkles"></i> 5 bài AI mỗi ngày
                                </span>
                            </div>

                            <form class="writing-create-form"
                                  data-writing-create-form
                                  data-create-url="@createFromAiUrl"
                                  data-practice-url="@practiceUrl">
                                @Html.AntiForgeryToken()
                                <textarea id="writingSourceText"
                                          name="sourceText"
                                          class="writing-create-textarea"
                                          rows="4"
                                          maxlength="4000"
                                          required
                                          placeholder="Dán bài viết của bạn ở đây..."></textarea>
                                <div style="display:flex; justify-content:space-between; align-items:center;">
                                    <span style="font-size:0.75rem; color:var(--we-on-surface-variant);">Tối đa 4000 ký tự</span>
                                    <button type="submit" class="writing-btn writing-btn--primary" data-writing-create-submit>
                                        <span data-writing-create-submit-text>Tạo bài bằng AI</span>
                                    </button>
                                </div>
                                <p class="writing-create-message" data-writing-create-message hidden></p>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="writing-create-panel" style="padding:1.5rem;">
                        <h3 style="font-size:1.125rem; font-weight:700; margin-bottom:0.5rem; color:var(--we-on-surface);">Tính năng tạo bài bằng AI</h3>
                        <p style="font-size:0.875rem; color:var(--we-on-surface-variant); margin:0;">
                            Bạn cần nâng cấp Premium để mở khóa tính năng tạo bài cá nhân bằng AI.
                        </p>
                    </div>
                }

                @if (hasMyExercises)
                {
                    @if (Model.IsMyExercisesLocked)
                    {
                        <div class="writing-lock-banner" role="status">
                            <i class="fas fa-lock" aria-hidden="true"></i>
                            <div>
                                <strong>Đã khóa do gói hiện tại</strong>
                                <p>Bạn vẫn nhìn thấy tiêu đề bài cũ nhưng không thể luyện tập hay xóa cho đến khi nâng cấp lại.</p>
                            </div>
                        </div>
                    }

                    <div class="writing-exercise-grid">
                        @foreach (var exercise in Model.MyExercises)
                        {
                            var isLocked = exercise.IsLocked;
                            <article class="writing-exercise-card writing-exercise-card--private @(isLocked ? "is-locked" : "")"
                                     style="@(isLocked ? "border-left-color: #d97706; background: #fffbeb;" : "")">
                                <div class="writing-exercise-top">
                                    <span class="writing-card-chip writing-card-chip--default">@exercise.Topic</span>
                                    <span class="writing-card-duration">
                                        <i class="far fa-file-alt"></i> @exercise.SentenceCount câu
                                    </span>
                                </div>
                                <div>
                                    <h3 class="writing-exercise-title">@exercise.Title</h3>
                                    <p class="writing-exercise-preview">@exercise.PreviewText</p>
                                </div>
                                <div class="writing-exercise-bottom">
                                    <div class="writing-status-group">
                                        @if (isLocked)
                                        {
                                            <span class="writing-status-text writing-status-badge" style="color:#b45309;">
                                                <i class="fas fa-lock"></i> Đã khóa
                                            </span>
                                        }
                                        else if (Model.ShowProgressMetadata)
                                        {
                                            var statusColor = string.IsNullOrWhiteSpace(exercise.StatusKey) ? "" :
                                                              (exercise.StatusKey == "completed" ? "writing-status-text--completed" : "writing-status-text--active");
                                            var icon = exercise.StatusKey == "completed" ? "fa-check-circle" :
                                                       (string.IsNullOrWhiteSpace(exercise.StatusKey) ? "fa-circle" : "fa-clock");
                                            <span class="writing-status-text writing-status-badge @statusColor">
                                                <i class="fas @icon"></i> @exercise.StatusLabel
                                            </span>
                                            @if (exercise.AttemptCount > 0)
                                            {
                                                <span class="writing-attempt-badge">@exercise.AttemptCount lần</span>
                                            }
                                        }
                                    </div>
                                    <div style="display:flex; gap:0.5rem; align-items:center;">
                                        @if (!isLocked && exercise.CanDelete)
                                        {
                                            <form method="post" asp-controller="Study" asp-action="DeleteOwnedWritingExercise" class="writing-delete-form" data-writing-delete-form>
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="exerciseId" value="@exercise.Id" />
                                                <input type="hidden" name="level" value="@Model.SelectedLevelKey" />
                                                <input type="hidden" name="contentType" value="@Model.SelectedContentTypeKey" />
                                                <input type="hidden" name="topic" value="@Model.SelectedTopic" />
                                                <input type="hidden" name="status" value="@Model.SelectedStatus" />
                                                <input type="hidden" name="page" value="@Model.CurrentPage" />
                                                <button type="submit" class="writing-btn--icon" title="Xóa bài">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        }

                                        @if (isLocked)
                                        {
                                            <span class="writing-btn writing-btn--muted" style="opacity:0.5; cursor:not-allowed;">
                                                @(string.IsNullOrWhiteSpace(exercise.StartActionLabel) ? "Khóa" : exercise.StartActionLabel)
                                            </span>
                                        }
                                        else
                                        {
                                            <a asp-controller="Study"
                                               asp-action="WritingPractice"
                                               asp-route-level="@Model.SelectedLevelKey"
                                               asp-route-contentType="@Model.SelectedContentTypeKey"
                                               asp-route-topic="@Model.SelectedTopic"
                                               asp-route-status="@Model.SelectedStatus"
                                               asp-route-page="@Model.CurrentPage"
                                               asp-route-exerciseId="@exercise.Id"
                                               class="writing-btn writing-btn--outline">
                                                @(string.IsNullOrWhiteSpace(exercise.StartActionLabel) ? "Bắt đầu" : exercise.StartActionLabel)
                                            </a>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
            </div>
        }

        @* ── System Catalog ───────────────────────────────── *@
        <h2 class="writing-section-title">Catalog hệ thống</h2>

        @if (!Model.Exercises.Any())
        {
            <div class="writing-empty-state">
                <i class="fas fa-search empty-icon"></i>
                <h2>Không tìm thấy bài tập</h2>
                <p>Hãy thử đổi chủ đề hoặc trạng thái để xem thêm bài luyện viết.</p>
            </div>
        }
        else
        {
            <div class="writing-exercise-grid">
                @foreach (var exercise in Model.Exercises)
                {
                    var isStartedOrCompleted = !string.IsNullOrWhiteSpace(exercise.StatusKey) && exercise.StatusKey != "not-started";
                    var chipClass = exercise.Topic switch {
                        "Cơ bản" => "writing-card-chip--basic",
                        "Trung cấp" => "writing-card-chip--intermediate",
                        "Nâng cao" => "writing-card-chip--advanced",
                        _ => "writing-card-chip--default"
                    };
                    <article class="writing-exercise-card @(isStartedOrCompleted ? "writing-exercise-card--active" : "")">
                        <div class="writing-exercise-top">
                            <span class="writing-card-chip @chipClass">@exercise.Topic</span>
                            <span class="writing-card-duration">
                                <i class="far fa-file-alt"></i> @exercise.SentenceCount câu
                            </span>
                        </div>
                        <div>
                            <h3 class="writing-exercise-title">@exercise.Title</h3>
                            <p class="writing-exercise-preview">@exercise.PreviewText</p>
                        </div>
                        <div class="writing-exercise-bottom">
                            <div class="writing-status-group">
                                @if (Model.ShowProgressMetadata)
                                {
                                    var statusColor = string.IsNullOrWhiteSpace(exercise.StatusKey) ? "" :
                                                      (exercise.StatusKey == "completed" ? "writing-status-text--completed" : "writing-status-text--active");
                                    var icon = exercise.StatusKey == "completed" ? "fa-check-circle" :
                                               (string.IsNullOrWhiteSpace(exercise.StatusKey) ? "fa-circle" : "fa-clock");
                                    <span class="writing-status-text writing-status-badge @statusColor">
                                        <i class="fas @icon"></i> @exercise.StatusLabel
                                    </span>
                                    @if (exercise.AttemptCount > 0)
                                    {
                                        <span class="writing-attempt-badge">@exercise.AttemptCount lần</span>
                                    }
                                }
                            </div>
                            <a asp-controller="Study"
                               asp-action="WritingPractice"
                               asp-route-level="@Model.SelectedLevelKey"
                               asp-route-contentType="@Model.SelectedContentTypeKey"
                               asp-route-topic="@Model.SelectedTopic"
                               asp-route-status="@Model.SelectedStatus"
                               asp-route-page="@Model.CurrentPage"
                               asp-route-exerciseId="@exercise.Id"
                               class="writing-btn @(isStartedOrCompleted ? "writing-btn--primary" : "writing-btn--outline")">
                                @(string.IsNullOrWhiteSpace(exercise.StartActionLabel) ? "Bắt đầu" : exercise.StartActionLabel)
                            </a>
                        </div>
                    </article>
                }
            </div>

            @* Pagination *@
            <div class="writing-pagination-wrap">
                <p class="writing-pagination-info">
                    Hiển thị <strong>@Model.StartItemNumber-@Model.EndItemNumber</strong> / <strong>@Model.TotalCount</strong>
                </p>

                @if (Model.TotalPages > 1)
                {
                    <nav class="writing-pagination-nav" aria-label="Phân trang">
                        @if (Model.CurrentPage > 1)
                        {
                            <a asp-controller="Study" asp-action="WritingExercises"
                               asp-route-level="@Model.SelectedLevelKey"
                               asp-route-contentType="@Model.SelectedContentTypeKey"
                               asp-route-topic="@Model.SelectedTopic"
                               asp-route-status="@Model.SelectedStatus"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               class="writing-page-link" aria-label="Trang trước">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        }

                        @foreach (var pageNumber in Model.PageNumbers)
                        {
                            if (pageNumber.HasValue)
                            {
                                <a asp-controller="Study" asp-action="WritingExercises"
                                   asp-route-level="@Model.SelectedLevelKey"
                                   asp-route-contentType="@Model.SelectedContentTypeKey"
                                   asp-route-topic="@Model.SelectedTopic"
                                   asp-route-status="@Model.SelectedStatus"
                                   asp-route-page="@pageNumber.Value"
                                   class="writing-page-link @(pageNumber.Value == Model.CurrentPage ? "is-active" : "")"
                                   aria-current="@(pageNumber.Value == Model.CurrentPage ? "page" : null)">
                                    @pageNumber.Value
                                </a>
                            }
                            else
                            {
                                <span class="writing-page-ellipsis">...</span>
                            }
                        }

                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <a asp-controller="Study" asp-action="WritingExercises"
                               asp-route-level="@Model.SelectedLevelKey"
                               asp-route-contentType="@Model.SelectedContentTypeKey"
                               asp-route-topic="@Model.SelectedTopic"
                               asp-route-status="@Model.SelectedStatus"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               class="writing-page-link" aria-label="Trang tiếp">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        }
                    </nav>
                }
            </div>
        }

    </div>
</div>

@section Scripts {
    <script src="~/js/writing-exercises.js" asp-append-version="true"></script>
}
