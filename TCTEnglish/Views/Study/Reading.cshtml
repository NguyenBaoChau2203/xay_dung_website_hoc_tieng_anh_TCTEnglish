@model IEnumerable<TCTEnglish.ViewModels.ReadingListViewModel>

<link rel="stylesheet" href="~/css/Reading.css" />

<div class="reading-page-wrapper container mt-4">
    <h2 class="mb-4">Reading Practice</h2>

    <div class="reading-toolbar mb-4">
        <div class="row g-3">
            <div class="col-md-4">
                <input type="text" id="readingSearch" class="form-control" placeholder="Tìm kiếm tiêu đề bài đọc...">
            </div>
            <div class="col-md-8 d-flex flex-wrap gap-2">
                <button class="btn btn-outline-primary filter-btn active" data-filter="all">Tất cả</button>
                <button class="btn btn-outline-secondary filter-btn" data-filter="A1">A1</button>
                <button class="btn btn-outline-secondary filter-btn" data-filter="A2">A2</button>
                <button class="btn btn-outline-secondary filter-btn" data-filter="B1">B1</button>
                <button class="btn btn-outline-secondary filter-btn" data-filter="B2">B2</button>
                <button class="btn btn-outline-secondary filter-btn" data-filter="C1">C1</button>
                
                <div class="ms-md-auto d-flex gap-2">
                    <button class="btn btn-info text-white filter-status" data-status="inprogress">Đang làm</button>
                    <button class="btn btn-success filter-status" data-status="completed">Đã xong</button>
                </div>
            </div>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">Chưa có dữ liệu bài đọc.</div>
    }
    else
    {
        <div class="reading-grid" id="readingGrid">
            @foreach (var item in Model)
            {
                <div class="reading-item"
                     data-title="@item.Title.ToLower()"
                     data-level="@item.Level"
                     data-completed="@item.IsCompleted.ToString().ToLower()"
                     data-inprogress="@item.IsInProgress.ToString().ToLower()">
                    
                    <a asp-controller="Reading" asp-action="Study" asp-route-id="@item.Id" class="reading-card">
                        <div class="reading-thumb-container">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="reading-thumb" alt="@item.Title" />
                            }
                            else
                            {
                                <div class="thumb-placeholder">Reading</div>
                            }
                            <span class="level-badge">@item.Level</span>
                        </div>

                        <div class="reading-card-body">
                            <h5 class="reading-title">@item.Title</h5>
                            <div class="reading-status-tags">
                                @if (item.IsCompleted)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else if (item.IsInProgress)
                                {
                                    <span class="badge bg-warning text-dark">In progress</span>
                                }
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
        <div id="noResults" class="alert alert-warning d-none">Không tìm thấy bài đọc phù hợp.</div>
    }
</div>

@section Scripts {
    <script src="~/js/Reading.js"></script>
}