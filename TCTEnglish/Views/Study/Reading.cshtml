@model IEnumerable<TCTEnglish.ViewModels.ReadingListViewModel>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="~/css/Reading.css" asp-append-version="true" />

<div class="reading-index-page">
    <div class="container">
        <!-- Hero Section -->
        <header class="reading-hero">
            <h1>Luyện Kỹ Năng Đọc</h1>
            <p>Khám phá kho tàng bài đọc đa dạng cấp độ, giúp bạn cải thiện vốn từ vựng và tư duy ngôn ngữ mỗi ngày.</p>
        </header>

        <!-- Toolbar & Search -->
        <div class="reading-toolbar-wrap mb-5">
            <div class="row align-items-center g-4">
                <div class="col-lg-4">
                    <div class="search-group">
                        <i class="bi bi-search"></i>
                        <input type="text" id="readingSearch" class="form-control search-input" placeholder="Tìm tiêu đề bài đọc...">
                    </div>
                </div>
                <div class="col-lg-8">
                    <div class="d-flex flex-wrap justify-content-lg-end align-items-center gap-3">
                        <div class="filter-chips">
                            <button class="filter-chip active" data-filter="all">Tất cả</button>
                            <button class="filter-chip" data-filter="A1">A1</button>
                            <button class="filter-chip" data-filter="A2">A2</button>
                            <button class="filter-chip" data-filter="B1">B1</button>
                            <button class="filter-chip" data-filter="B2">B2</button>
                            <button class="filter-chip" data-filter="C1">C1</button>
                        </div>
                        <div class="vr d-none d-md-block mx-2"></div>
                        <div class="status-group">
                            <button class="btn status-btn" data-status="inprogress" title="Đang làm">
                                <i class="bi bi-clock-history"></i>
                            </button>
                            <button class="btn status-btn" data-status="completed" title="Đã xong">
                                <i class="bi bi-check-circle-fill"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Content Groups -->
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <img src="/img/empty-reading.svg" alt="Empty" style="width: 200px; opacity: 0.5;" />
                <h4 class="mt-4 text-muted">Chưa có bài đọc nào được xuất bản.</h4>
            </div>
        }
        else
        {
            var levels = new[] { "A1", "A2", "B1", "B2", "C1", "C2" };
            
            <div class="reading-groups-container" id="readingGrid">
                @foreach (var lvl in levels)
                {
                    var itemsInLevel = Model.Where(x => x.Level == lvl).ToList();
                    if (itemsInLevel.Any())
                    {
                        <section class="level-group" data-group-level="@lvl">
                            <div class="level-group-header">
                                <div class="level-title-wrap">
                                    <div class="level-badge-large lvl-@lvl-bg">@lvl</div>
                                    <div class="level-group-info">
                                        <h3>Các bài đọc @lvl</h3>
                                        <p>Nâng cao kỹ năng đọc hiểu trình độ @lvl</p>
                                    </div>
                                </div>
                                <div class="scroll-hint d-none d-md-block text-muted small">
                                    <i class="bi bi-arrow-left-right me-1"></i> Cuộn sang ngang để xem thêm
                                </div>
                            </div>

                            <div class="scroll-container-outer">
                                <div class="scroll-container">
                                    @foreach (var item in itemsInLevel)
                                    {
                                        <div class="reading-item-container"
                                             data-title="@item.Title.ToLower()"
                                             data-level="@item.Level"
                                             data-completed="@item.IsCompleted.ToString().ToLower()"
                                             data-inprogress="@item.IsInProgress.ToString().ToLower()">
                                            
                                            <a asp-controller="Reading" asp-action="Study" asp-route-id="@item.Id" class="reading-card-item">
                                                <div class="card-thumb-wrap">
                                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                    {
                                                        <img src="@item.ImageUrl" class="card-img" alt="@item.Title" loading="lazy" />
                                                    }
                                                    else
                                                    {
                                                        <div class="thumb-placeholder-new">
                                                            <i class="bi bi-journal-text"></i>
                                                            <span class="fw-bold small text-uppercase">Reading</span>
                                                        </div>
                                                    }
                                                    <span class="level-tag lvl-@item.Level">@item.Level</span>
                                                </div>

                                                <div class="card-content">
                                                    <h5 class="card-title">@item.Title</h5>
                                                    
                                                    <div class="card-footer p-0 bg-transparent border-0">
                                                        <div class="status-indicator">
                                                            @if (item.IsCompleted)
                                                            {
                                                                <span class="status-completed">
                                                                    <i class="bi bi-check-circle-fill"></i> Hoàn thành
                                                                </span>
                                                            }
                                                            else if (item.IsInProgress)
                                                            {
                                                                <span class="status-inprogress">
                                                                    <i class="bi bi-play-circle-fill"></i> Đang học
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted small">
                                                                    <i class="bi bi-circle"></i> Chưa học
                                                                </span>
                                                            }
                                                        </div>
                                                        
                                                        <span class="start-btn">
                                                            Học <i class="bi bi-arrow-right"></i>
                                                        </span>
                                                    </div>
                                                </div>
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </section>
                    }
                }
            </div>
            
            <div id="noResults" class="text-center py-5 d-none">
                <i class="bi bi-search-heart display-1 text-muted opacity-25"></i>
                <h4 class="mt-4 text-muted">Không tìm thấy bài đọc phù hợp.</h4>
                <button class="btn btn-link" onclick="resetFilters()">Xóa bộ lọc</button>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/Reading.js" asp-append-version="true"></script>
}