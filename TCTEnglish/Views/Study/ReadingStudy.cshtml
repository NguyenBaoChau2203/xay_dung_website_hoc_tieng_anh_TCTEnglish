@model TCTEnglish.ViewModels.ReadingStudyViewModel

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="~/css/reading-study.css" />

<div class="reading-toolbar shadow-sm">
    <div class="container-fluid d-flex align-items-center justify-content-between">
        <a href="/Home/Reading" class="btn btn-light border btn-sm hover-elevate">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm px-4 d-flex align-items-center gap-2" id="toggleTranslation">
                <i class="bi bi-translate"></i>
                <span>Dịch toàn bài</span>
            </button>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <button class="btn btn-outline-success btn-sm px-4 d-flex align-items-center gap-2" id="btnMyTranslation">
                    <i class="bi bi-pencil-square"></i>
                    <span>Bản dịch của tôi</span>
                </button>
            }
        </div>
    </div>
</div>

<div class="container-fluid py-4">
    <div class="reading-grid">
        
        <div class="passage-container">
            <div class="card border-0 shadow-sm p-4">
                <h2 class="passage-title mb-4" id="passageTitle">@Model.Title</h2>

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="text-center mb-4">
                        <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" style="max-height: 350px;" />
                    </div>
                }

                <div class="passage-content" id="passageContent">
                    @{
                        var paragraphs = Model.Content?.Split("\n");
                    }
                    @foreach (var p in paragraphs)
                    {
                        <div class="paragraph-block">
                            <p class="passage-text">@p</p>
                            <p class="translation d-none text-muted"></p>
                        </div>
                    }
                </div>
            </div>

            @* ─── Khu vực Bản dịch nổi bật ─── *@
            <div class="card border-0 shadow-sm p-4 mt-4" id="communityTranslationsCard">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-star-fill text-warning me-2"></i>Những bản dịch nổi bật
                    </h5>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button class="btn btn-sm btn-outline-primary rounded-circle p-0 d-flex align-items-center justify-content-center"
                                style="width:32px;height:32px;" id="btnAddTranslation" title="Thêm bản dịch">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    }
                </div>
                <div id="translationsList">
                    <div class="text-center text-muted py-3">
                        <span class="spinner-border spinner-border-sm"></span> Đang tải...
                    </div>
                </div>
            </div>
        </div>

        <div class="question-container">
            <div class="card border-0 shadow-sm sticky-card">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h6 class="fw-bold text-uppercase text-secondary small">Danh sách câu hỏi</h6>
                    <div class="question-nav d-flex flex-wrap gap-2 mt-3" id="questionNav">
                        @for (int i = 0; i < Model.Questions.Count; i++)
                        {
                            <button type="button" class="btn btn-outline-secondary nav-btn"
                                    onclick="showQuestion(@i)" id="nav-btn-@i">
                                @(i + 1)
                            </button>
                        }
                    </div>
                </div>

                <div class="card-body p-4">
                    <div id="quizStatus" class="alert d-none mb-3"></div>

                    <form id="readingForm">
                        <input type="hidden" name="passageId" value="@Model.Id" />

                        <div class="question-display-area">
                            @for (int i = 0; i < Model.Questions.Count; i++)
                            {
                                var q = Model.Questions[i];
                                <div class="question-panel @(i == 0 ? "" : "d-none")" id="q-panel-@i" data-q-id="@q.Id">
                                    <h6 class="mb-3 fw-bold">Câu @(i + 1): @q.QuestionText</h6>
                                    
                                    <div class="options-list">
                                        @foreach (var opt in q.Options)
                                        {
                                            <div class="option-item mb-2">
                                                <input class="btn-check" type="radio"
                                                       name="answers[@q.Id]" value="@opt.Id"
                                                       id="opt_@opt.Id" required onchange="markNavDone(@i)">
                                                <label class="btn btn-outline-light text-start w-100 py-2 px-3 option-label" for="opt_@opt.Id">
                                                    @opt.OptionText
                                                </label>
                                            </div>
                                        }
                                    </div>
                                    <div class="result-feedback mt-3 d-none"></div>
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                            <div class="btn-group">
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="prevQuestion()" id="btnPrev">Trước</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="nextQuestion()" id="btnNext">Sau</button>
                            </div>
                            <button type="submit" id="btnSubmit" class="btn btn-sm btn-success px-4 fw-bold">Nộp bài</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

<div id="wordPopup" class="word-popup d-none shadow-lg"></div>

@* ─── Modal AI Feedback ─── *@
<div class="modal fade" id="aiFeedbackModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-robot me-2"></i>Kết quả chấm AI
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="aiScoreDisplay" class="text-center mb-3">
                    <div class="ai-score-circle mx-auto mb-2">
                        <span id="aiScoreValue">--</span>
                    </div>
                    <div id="aiApprovalBadge"></div>
                </div>
                <div id="aiFeedbackText" class="bg-light rounded p-3 mb-3"></div>
                <div id="aiActions" class="d-flex gap-2 justify-content-center"></div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="passageId" value="@Model.Id" />
@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/time-tracker.js" data-feature="Reading" defer></script>
    <script src="~/js/reading-study.js"></script>
    <script src="~/js/reading-translation.js"></script>
}