
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TCTEnglish</title>

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/layout.css" />

    <script src="~/js/layout.js"></script>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <partial name="_Loader" />
    <!-- ================= HEADER ================= -->
    <header class="header">
        <div class="header-left">
            <i class="fas fa-bars menu-icon"></i>
            <a asp-controller="Home" asp-action="Index" class="logo">TCT</a>
        </div>

        <form asp-controller="Home"
              asp-action="Search"
              method="get"
              class="search-box">

            <i class="fas fa-search"></i>

            <input type="text"
                   name="q"
                   value="@Context.Request.Query["q"]"
                   placeholder="Search for folders, classes, users"
                   autocomplete="off" />
        </form>

        <div class="header-right">
            <button class="btn-circle">
                <i class="fas fa-plus"></i>
            </button>

            <button class="btn-upgrade">
                Upgrade: free 7-day trial
            </button>

            <button class="btn-notification">
                <i class="fas fa-bell"></i>
                <span class="notification-badge">3</span>
            </button>

            @if (User.Identity!.IsAuthenticated)
            {
                var avatarUrl = User.Claims.FirstOrDefault(c => c.Type == "AvatarUrl")?.Value;
                var avatarStyle = !string.IsNullOrEmpty(avatarUrl)
                    ? $"background-image: url('{avatarUrl}'); background-size: cover; background-position: center; background-color: transparent;"
                    : "";

                <div class="user-menu-container">
                    <div class="user-profile" id="userProfileBtn">
                        <div class="avatar" style="@avatarStyle"></div>
                        <span class="user-name-display">@User.Identity.Name</span>
                        <i class="fas fa-chevron-down" style="font-size: 12px; color: #6b7280;"></i>
                    </div>

                    <div class="user-dropdown" id="userDropdown">
                        <div class="dropdown-header">
                            <div class="avatar small" style="@avatarStyle"></div>
                            <div class="user-info-text">
                                <div class="name">@User.Identity.Name</div>
                                <div class="email">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value</div>
                            </div>
                        </div>
                        <hr />
                        <a asp-controller="Account" asp-action="Profile" class="dropdown-item">
                            <i class="fas fa-user"></i> Hồ sơ của tôi
                        </a>
                        <a asp-controller="Account" asp-action="Settings" class="dropdown-item">
                            <i class="fas fa-cog"></i> Cài đặt
                        </a>
                        <a href="#" class="dropdown-item">
                            <i class="fas fa-layer-group"></i> Chủ đề đã học
                        </a>
                        <hr />
                        <a asp-controller="Account" asp-action="Logout" class="dropdown-item logout">
                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            }
            else
            {
                 <a asp-controller="Account" asp-action="Login" class="btn-upgrade" style="background: #e0e7ff; color: #4255ff; margin-left: 10px;">Đăng nhập</a>
            }
        </div>
    </header>

    <div class="layout">
        <!-- ================= SIDEBAR ================= -->
        <aside class="sidebar">
            <nav>
                <div class="nav-dropdown" id="coursesDropdown">
                    <div class="nav-dropdown-item" id="coursesDropdownBtn">
                        <div class="nav-dropdown-title">
                            <i class="fas fa-book-open"></i>
                            <span>Courses</span>
                        </div>
                        <i class="fas fa-chevron-down dropdown-arrow"></i>
                    </div>
                    
                    <div class="nav-dropdown-menu" id="coursesDropdownMenu">
                        <a class="nav-sub-item" asp-controller="Home" asp-action="Grammar">
                            <span>Grammar</span>
                        </a>
                        <a class="nav-sub-item" asp-controller="Home" asp-action="Listening">
                            <span>Listening</span>
                        </a>
                        <a class="nav-sub-item" asp-controller="Home" asp-action="Reading">
                            <span>Reading</span>
                        </a>
                        <a class="nav-sub-item" asp-controller="Home" asp-action="Writing">
                            <span>Writing <i class="fas fa-fire" style="color:#f97316; font-size:14px; margin-left:6px;"></i></span>
                        </a>
                        <a class="nav-sub-item" asp-controller="Speaking" asp-action="Index">
                            <span>Speaking</span>
                        </a>
                    </div>
                </div>

                <hr style="margin: 10px 0;" />

                <a class="nav-item">
                    <i class="fas fa-layer-group"></i>
                    <span>Your library</span>
                </a>

            
                <a class="nav-item" asp-controller="Goals" asp-action="Index">
                    <i class="fas fa-bullseye"></i>
                    <span>Goals</span>
                </a>

                <a class="nav-item " asp-controller="Ranking" asp-action="Index">
                    <i class="fas fa-trophy"></i>
                    <span>Ranking</span>
                </a>

                <a class="nav-item" asp-controller="Vocabulary" asp-action="Index">
                    <i class="fas fa-book"></i>
                    <span>Vocabulary</span>
                </a>



                <div class="nav-dropdown" id="classDropdown">

                    <div class="nav-dropdown-item" id="classDropdownBtn">
                        <div class="nav-dropdown-title">
                            <i class="fas fa-chalkboard-teacher"></i>
                            <span>Classes</span>
                        </div>
                        <i class="fas fa-chevron-down dropdown-arrow"></i>
                    </div>

                    <div class="nav-dropdown-menu" id="classDropdownMenu">

                        <a class="nav-sub-item"
                           asp-controller="Home"
                           asp-action="CreateClass">

                            <span class="icon-circle small">
                                <i class="fas fa-plus"></i>
                            </span>
                            New class
                        </a>

                        <a class="nav-sub-item"
                           asp-controller="Home"
                           asp-action="Class">

                            <i class="fas fa-users"></i>
                            My classes

                        </a>

                    </div>
                </div>

                <div class="nav-dropdown" id="folderDropdown">

                    <div class="nav-dropdown-item" id="folderDropdownBtn">
                        <div class="nav-dropdown-title">
                            <i class="fas fa-folder"></i>
                            <span>Folders</span>
                        </div>
                        <i class="fas fa-chevron-down dropdown-arrow"></i>
                    </div>

                    <div class="nav-dropdown-menu" id="folderDropdownMenu">

                        <button class="nav-sub-item" id="newFolderBtn">
                            <span class="icon-circle small">
                                <i class="fas fa-plus"></i>
                            </span>
                            New folder
                        </button>

                        <a class="nav-sub-item" asp-controller="Home" asp-action="Folder">
                            <i class="fas fa-folder-open"></i>
                            My folders
                        </a>

                    </div>
                </div>

                <a class="nav-item" asp-controller="Home" asp-action="Contact">
                    <i class="fas fa-envelope"></i>
                    <span>Liên hệ</span>
                </a>

                @if (User.IsInRole("Admin"))
                {
                <hr style="margin: 10px 0;" />
                <a class="nav-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="fas fa-shield-alt"></i>
                    <span>Admin Panel</span>
                </a>
                }
            </nav>

            <hr />


            <div class="sidebar-footer">
                Tận dụng Flashcards để ghi nhớ kiến thức nhanh hơn 3 lần.
            </div>
        </aside>

        <!-- ================= MAIN ================= -->
        <main class="main">
            @RenderBody()
        </main>
    </div>
    <footer class="tct-footer">

        <div class="footer-container">

            <!-- BRAND -->
            <div class="footer-brand">

                <h3>TCT Vocabulary</h3>

                <p>
                    Hệ thống học từ vựng thông minh sử dụng
                    phương pháp lặp lại ngắt quãng (SRS)
                </p>

                <div class="footer-contact">

                    <div class="contact-item">
                        <i class="fas fa-location-dot"></i>
                        <span>Hà Nội, Việt Nam</span>
                    </div>

                    <div class="contact-item">
                        <i class="fas fa-envelope"></i>
                        <span>contact@tctvocab.com</span>
                    </div>

                    <div class="contact-item">
                        <i class="fas fa-phone"></i>
                        <span>+84 123 456 789</span>
                    </div>

                    <div class="contact-item">
                        <i class="fas fa-globe"></i>
                        <span>tctvocabulary.com</span>
                    </div>

                </div>

            </div>

            <!-- LINKS -->
            <div class="footer-links">

                <h4>Khám phá</h4>

                <a href="#">Giới thiệu</a>
                <a href="#">Blog</a>
                <a href="#">Điều khoản</a>
                <a asp-controller="Home" asp-action="Contact">Liên hệ</a>

            </div>
            <div class="footer-links">
                <h5>Học tập</h5>
                <a href="#">Flashcards</a>
                <a href="#">Ôn tập SRS</a>
                <a href="#">Lớp học</a>
                <a href="#">Thư mục</a>
            </div>
            <!-- SOCIAL -->
            <div class="footer-social">

                <h4>Kết nối</h4>

                <div class="social-icons">

                    <a href="#"><i class="fab fa-facebook-f"></i></a>

                    <a href="#"><i class="fab fa-youtube"></i></a>

                    <a href="#"><i class="fab fa-github"></i></a>

                </div>

            </div>

        </div>

        <div class="footer-bottom">
            © 2026 TCT Vocabulary. All rights reserved.
        </div>

    </footer>
    <!-- ================= CREATE FOLDER MODAL ================= -->
    <div id="folderModal" class="modal-overlay">
        <div class="tct-modal">
            <h3 class="modal-title">Create new folder</h3>

            <form asp-controller="Home"
                  asp-action="CreateFolder"
                  method="post">

                <input type="text"
                       name="folderName"
                       class="modal-input"
                       placeholder="Folder name"
                       required />

                <div class="modal-actions">
                    <button type="button"
                            class="btn-decline"
                            id="cancelFolderBtn">
                        Decline
                    </button>

                    <button type="submit"
                            class="btn-confirm">
                        Confirm
                    </button>
                </div>
            </form>
        </div>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
        <script src="~/js/user-activity.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
