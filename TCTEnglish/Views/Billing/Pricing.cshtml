@model TCTEnglish.ViewModels.Billing.PricingViewModel
@{
    ViewData["Title"] = "Nâng cấp Premium";
    var vnpayReady = Model.ProviderReadiness.TryGetValue("vnpay", out var vnpayConfigured) && vnpayConfigured;
    var momoReady = Model.ProviderReadiness.TryGetValue("momo", out var momoConfigured) && momoConfigured;
}

@section Styles {
    <style>
        .pricing-plan-col {
            max-width: 400px;
        }

        .pricing-plan-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .pricing-plan-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.1) !important;
        }
    </style>
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Tận hưởng sức mạnh của <span class="text-primary">TCT Premium</span></h1>
        <p class="lead text-muted">Mở khóa đầy đủ tính năng luyện nói, viết và nghe với trí tuệ nhân tạo.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            @if (Model.CurrentAccess.IsPremium)
                            {
                                <div class="bg-success text-white rounded-circle p-3">
                                    <i class="bi bi-star-fill fs-4"></i>
                                </div>
                            }
                            else
                            {
                                <div class="bg-secondary text-white rounded-circle p-3">
                                    <i class="bi bi-person-fill fs-4"></i>
                                </div>
                            }
                        </div>
                        <div class="ms-4">
                            <h5 class="mb-1">
                                Trạng thái tài khoản:
                                <span class="@(Model.CurrentAccess.IsPremium ? "text-success" : "text-muted")">
                                    @(Model.CurrentAccess.IsPremium ? "Premium" : "Standard")
                                </span>
                            </h5>
                            @if (Model.CurrentAccess.IsPremium && Model.CurrentAccess.PremiumEndsAtUtc.HasValue)
                            {
                                <p class="mb-0 text-muted">
                                    Thời hạn đến: @Model.CurrentAccess.PremiumEndsAtUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </p>
                            }
                            else if (Model.CurrentAccess.IsAdmin)
                            {
                                <p class="mb-0 text-muted">Bạn có quyền truy cập Premium vĩnh viễn (Admin).</p>
                            }
                            else
                            {
                                <p class="mb-0 text-muted">Nâng cấp để truy cập các tính năng AI nâng cao.</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 justify-content-center">
        @foreach (var plan in Model.Plans)
        {
            <div class="col pricing-plan-col">
                <div class="card pricing-plan-card h-100 border-0 shadow-sm @(plan.DurationDays >= 365 ? "border border-primary border-2" : string.Empty)">
                    @if (plan.DurationDays >= 365)
                    {
                        <div class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-primary px-3">
                            Tiết kiệm nhất
                        </div>
                    }
                    <div class="card-body p-5 text-center">
                        <h3 class="fw-bold mb-4">@plan.Name</h3>
                        <div class="mb-4">
                            <span class="display-5 fw-bold">@plan.PriceVnd.ToString("N0")</span>
                            <span class="text-muted">₫</span>
                        </div>
                        <p class="text-muted mb-5">@plan.Description</p>

                        <ul class="list-unstyled text-start mb-5">
                            <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i> Luyện viết với AI không giới hạn</li>
                            <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i> Shadowing và video riêng tư</li>
                            <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i> Dịch transcript và AI Quiz cho Listening</li>
                            <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i> Không có quảng cáo</li>
                        </ul>

                        @if (vnpayReady)
                        {
                            <form asp-action="Checkout" method="post">
                                <input type="hidden" name="PlanCode" value="@plan.Code" />
                                <input type="hidden" name="Provider" value="vnpay" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-pill shadow-sm">
                                    <i class="bi bi-credit-card-2-front me-2"></i> Thanh toán VNPay
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary w-100 py-3 rounded-pill opacity-50" disabled
                                    title="Cổng thanh toán VNPay chưa được cấu hình. Vui lòng liên hệ quản trị viên.">
                                <i class="bi bi-credit-card-2-front me-2"></i> VNPay chưa khả dụng/chưa cấu hình
                            </button>
                        }

                        <div class="mt-3">
                            @if (momoReady)
                            {
                                <form asp-action="Checkout" method="post">
                                    <input type="hidden" name="PlanCode" value="@plan.Code" />
                                    <input type="hidden" name="Provider" value="momo" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger w-100 py-2 rounded-pill fw-semibold">
                                        <i class="bi bi-wallet2 me-2"></i> Thanh toán MoMo QR
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary w-100 py-2 rounded-pill opacity-50" disabled
                                        title="Cổng thanh toán MoMo chưa được cấu hình.">
                                    <i class="bi bi-wallet2 me-2"></i> MoMo chưa khả dụng/chưa cấu hình
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-5 text-center">
        <p class="text-muted">Bạn đã mua gói trước đó? <a asp-action="History" class="text-decoration-none">Xem lịch sử đơn hàng</a></p>
    </div>
</div>
