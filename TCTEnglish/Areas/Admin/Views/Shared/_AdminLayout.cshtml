@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var adminName = User.Identity?.Name ?? "Admin";
    var avatarUrl = User.Claims.FirstOrDefault(c => c.Type == "AvatarUrl")?.Value;
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TCT Admin</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
          crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          rel="stylesheet" />

    <!-- Admin-specific CSS (minimal, only for sidebar width variable) -->
    <style>
        :root { --sidebar-width: 260px; }

        .admin-sidebar {
            width: var(--sidebar-width);
            min-height: 100vh;
            transition: all 0.3s;
        }

        .admin-main {
            margin-left: var(--sidebar-width);
            transition: all 0.3s;
            min-height: 100vh;
        }

        .nav-link.active {
            background-color: rgba(255, 255, 255, 0.1) !important;
            border-left: 3px solid #fff;
        }

        .nav-link:hover {
            background-color: rgba(255, 255, 255, 0.05) !important;
        }

        @@media (max-width: 992px) {
            .admin-sidebar { margin-left: calc(var(--sidebar-width) * -1); position: fixed; z-index: 1050; }
            .admin-sidebar.show { margin-left: 0; }
            .admin-main { margin-left: 0; }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-light">

    <!-- =============== SIDEBAR =============== -->
    <aside class="admin-sidebar bg-dark text-white position-fixed top-0 start-0 d-flex flex-column" id="adminSidebar">
        <!-- Brand -->
        <div class="p-3 border-bottom border-secondary">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
               class="text-white text-decoration-none d-flex align-items-center gap-2">
                <i class="bi bi-shield-lock-fill fs-4"></i>
                <span class="fw-bold fs-5">TCT Admin</span>
            </a>
        </div>

        <!-- Navigation -->
        <nav class="flex-grow-1 p-3">
            <ul class="nav flex-column gap-1">
                <!-- Dashboard -->
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                       class="nav-link text-white rounded-2 px-3 py-2 @(currentController == "Dashboard" ? "active" : "")">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </a>
                </li>

                <!-- Divider: Content Management -->
                <li class="mt-3 mb-1">
                    <span class="text-uppercase text-secondary small fw-semibold px-3">Quản lý nội dung</span>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="UserManagement" asp-action="Index"
                       class="nav-link text-white rounded-2 px-3 py-2 @(currentController == "UserManagement" ? "active" : "")">
                        <i class="bi bi-people-fill me-2"></i> Users
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="ClassManagement" asp-action="Index"
                       class="nav-link text-white rounded-2 px-3 py-2 @(currentController == "ClassManagement" ? "active" : "")">
                        <i class="bi bi-collection-fill me-2"></i> Classes
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="SetManagement" asp-action="Index"
                       class="nav-link text-white rounded-2 px-3 py-2 @(currentController == "SetManagement" ? "active" : "")">
                        <i class="bi bi-journals me-2"></i> Vocabulary Sets
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="SpeakingManagement" asp-action="Index"
                       class="nav-link text-white rounded-2 px-3 py-2 @(currentController == "SpeakingManagement" ? "active" : "")">
                        <i class="bi bi-mic-fill me-2"></i> Speaking Videos
                    </a>
                </li>

                <!-- Divider: System -->
                <li class="mt-3 mb-1">
                    <span class="text-uppercase text-secondary small fw-semibold px-3">Hệ thống</span>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="MessageManagement" asp-action="Index"
                       class="nav-link text-white rounded-2 px-3 py-2 @(currentController == "MessageManagement" ? "active" : "")">
                        <i class="bi bi-chat-dots-fill me-2"></i> Messages
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Sidebar Footer — Back to Main Site -->
        <div class="p-3 border-top border-secondary">
            <a asp-controller="Home" asp-action="Index" asp-area=""
               class="btn btn-outline-light btn-sm w-100">
                <i class="bi bi-box-arrow-left me-1"></i> Về trang chính
            </a>
        </div>
    </aside>

    <!-- =============== MAIN CONTENT =============== -->
    <div class="admin-main d-flex flex-column">
        <!-- Top Navbar -->
        <nav class="navbar navbar-expand bg-white shadow-sm px-4 sticky-top">
            <!-- Mobile toggle -->
            <button class="btn btn-outline-secondary d-lg-none me-3" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>

            <span class="navbar-brand fw-semibold text-muted d-none d-md-block">
                @ViewData["Title"]
            </span>

            <div class="ms-auto d-flex align-items-center gap-3">
                <!-- Admin profile badge -->
                <div class="dropdown">
                    <a class="d-flex align-items-center text-decoration-none dropdown-toggle"
                       href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        @if (!string.IsNullOrEmpty(avatarUrl))
                        {
                            <img src="@avatarUrl" alt="avatar" class="rounded-circle me-2" width="32" height="32" />
                        }
                        else
                        {
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2"
                                 style="width:32px;height:32px;">
                                <i class="bi bi-person-fill"></i>
                            </div>
                        }
                        <span class="fw-medium text-dark">@adminName</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Profile" asp-area="">
                                <i class="bi bi-person me-2"></i>Hồ sơ
                            </a>
                        </li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout" asp-area="">
                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Page Content -->
        <main class="flex-grow-1 p-4">
            @Html.AntiForgeryToken()
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="text-center text-muted small py-3 border-top bg-white">
            &copy; @DateTime.Now.Year TCT English — Admin Panel
        </footer>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
            crossorigin="anonymous"></script>

    <!-- Sidebar Toggle Script -->
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', function () {
            document.getElementById('adminSidebar').classList.toggle('show');
        });
    </script>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
