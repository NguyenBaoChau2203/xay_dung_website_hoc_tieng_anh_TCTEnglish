@model TCTVocabulary.Areas.Admin.ViewModels.WritingExerciseCreateViewModel
@{
    ViewData["Title"] = "Thêm Writing Exercise";
    ViewData["FormAction"] = "Create";
    ViewData["SubmitText"] = "Lưu bài viết";
    ViewData["SubmitIcon"] = "fa-solid fa-floppy-disk";
    ViewData["FormHeading"] = "Thêm Writing Exercise";
    ViewData["FormDescription"] = "Dán nguyên full text tiếng Việt và tiếng Anh. Hệ thống sẽ tự tách câu theo dấu câu để learner làm từng dòng ở màn practice.";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-writing-exercise.css" asp-append-version="true" />
}

<div class="container-fluid py-4 admin-writing-page">
    <div class="row justify-content-center">
        <div class="col-xl-11">
            <div class="d-flex align-items-start gap-3 mb-4">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-3">
                    <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                </a>
                <div>
                    <div class="text-uppercase text-muted small fw-semibold mb-2">Content Builder</div>
                    <h2 class="mb-1 text-dark fw-bold">Thêm Writing Exercise</h2>
                    <p class="text-muted mb-0">
                        Nhập bài viết theo dạng full text giống màn learner. Khi lưu, hệ thống sẽ tự nhận diện câu và paragraph từ passage bạn dán vào.
                    </p>
                </div>
            </div>

            <partial name="_ExerciseForm" model="Model" />
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_ExerciseFormScripts" model="Model" />
}
