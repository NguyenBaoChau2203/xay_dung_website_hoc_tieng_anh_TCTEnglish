@model TCTVocabulary.Areas.Admin.ViewModels.SetCardsViewModel
@{
    ViewData["Title"] = "Cards";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <a asp-action="Index" class="text-decoration-none mb-3 d-inline-block">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Cards — @Model.SetName</h1>
            @if (!string.IsNullOrEmpty(Model.FolderName))
            {
                <p class="text-muted small mb-0">Folder: @Model.FolderName</p>
            }
        </div>
        <div class="d-flex align-items-center gap-3">
            <a asp-action="AddCard" asp-route-setId="@Model.SetId" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i> Thêm thẻ
            </a>
            <span class="badge bg-primary px-3 py-2">@Model.Cards.Count thẻ</span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4" style="width: 50px;">#</th>
                        <th style="min-width: 150px;">Term</th>
                        <th style="min-width: 200px;">Definition</th>
                        <th>Phonetic</th>
                        <th>Image</th>
                        <th>Topic</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Cards.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-card-list fs-1 d-block mb-2"></i>
                                Học phần này chưa có thẻ nào.
                            </td>
                        </tr>
                    }
                    @{ int i = 1; }
                    @foreach (var item in Model.Cards)
                    {
                        <tr>
                            <td class="ps-4">@i</td>
                            <td class="fw-bold">@item.Term</td>
                            <td>
                                @if (item.Definition?.Length > 60)
                                {
                                    <span title="@item.Definition">@item.Definition.Substring(0, 60)...</span>
                                }
                                else
                                {
                                    @item.Definition
                                }
                            </td>
                            <td class="small text-muted">@(item.Phonetic ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" width="40" height="40" class="rounded shadow-sm" style="object-fit: cover;" />
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Topic))
                                {
                                    <span class="badge bg-secondary-subtle text-secondary rounded-pill px-2">@item.Topic</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="EditCard" asp-route-id="@item.CardId"
                                       class="btn btn-outline-primary btn-sm" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="DeleteCard" method="post" class="d-inline"
                                          onsubmit="return confirm('Xóa thẻ này?')">
                                        <input type="hidden" name="cardId" value="@item.CardId" />
                                        <input type="hidden" name="setId" value="@Model.SetId" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
