@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Quản lý Speaking Video";
}

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="mb-0 text-dark fw-bold">Quản lý Speaking Video</h2>
            <p class="text-muted mb-0">Quản lý các video luyện nói và phụ đề</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4">
                <i class="fa-solid fa-plus me-2"></i> Thêm Video Mới
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i><strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 border-0 text-muted" style="width: 120px;">Thumbnail</th>
                            <th class="border-0 text-muted">Video</th>
                            <th class="border-0 text-muted">YouTube ID</th>
                            <th class="border-0 text-muted">Level / Topic</th>
                            <th class="border-0 text-muted text-center" style="width: 150px;">Số câu thoại</th>
                            <th class="pe-4 border-0 text-muted text-center" style="width: 100px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="fa-solid fa-video-slash fa-3x mb-3 text-secondary opacity-50"></i>
                                        <h5>Chưa có video nào</h5>
                                        <p>Hãy thêm video đầu tiên của bạn.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <img src="@item.ThumbnailUrl" alt="Thumbnail" class="img-fluid rounded-3 shadow-sm" style="width: 100px; height: 56px; object-fit: cover;">
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark text-truncate" style="max-width: 300px;" title="@item.Title">
                                            @item.Title
                                        </div>
                                        <div class="text-muted small">
                                            <i class="fa-regular fa-clock me-1"></i> @(item.Duration ?? "--:--")
                                        </div>
                                    </td>
                                    <td>
                                        <a href="https://youtube.com/watch?v=@item.YoutubeId" target="_blank" class="text-decoration-none badge bg-danger text-white rounded-pill">
                                            <i class="fa-brands fa-youtube me-1"></i> @item.YoutubeId
                                        </a>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column gap-1 align-items-start">
                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                                                Level @item.Level
                                            </span>
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25">
                                                @item.Topic
                                            </span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success rounded-pill px-3 py-2">
                                            @item.SentenceCount câu
                                        </span>
                                    </td>
                                    <td class="pe-4 text-center">
                                        <div class="btn-group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Sửa">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa video này? Mọi câu thoại và lịch sử học liên quan cũng sẽ bị xóa theo.');">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
