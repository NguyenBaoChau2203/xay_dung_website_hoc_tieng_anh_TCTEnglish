@model IEnumerable<TCTVocabulary.Areas.Admin.ViewModels.SpeakingVideoListItemViewModel>
@{
    ViewData["Title"] = "Quan ly Speaking Video";
    var videos = Model?.ToList() ?? new List<TCTVocabulary.Areas.Admin.ViewModels.SpeakingVideoListItemViewModel>();
}

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="mb-0 text-dark fw-bold">Quan ly Speaking Video</h2>
            <p class="text-muted mb-0">Quan ly cac video luyen noi va phu de</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4">
                <i class="fa-solid fa-plus me-2"></i> Them Video Moi
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i><strong>Thanh cong!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-4" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>Loi!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 border-0 text-muted" style="width: 120px;">Thumbnail</th>
                            <th class="border-0 text-muted">Video</th>
                            <th class="border-0 text-muted">YouTube ID</th>
                            <th class="border-0 text-muted">Level / Topic</th>
                            <th class="border-0 text-muted text-center" style="width: 150px;">So cau thoai</th>
                            <th class="pe-4 border-0 text-muted text-center" style="width: 120px;">Thao tac</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!videos.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="fa-solid fa-video-slash fa-3x mb-3 text-secondary opacity-50"></i>
                                        <h5>Chua co video nao</h5>
                                        <p>Hay them video dau tien cua ban.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in videos)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <img src="@(string.IsNullOrWhiteSpace(item.ThumbnailUrl) ? $"https://img.youtube.com/vi/{item.YoutubeId}/hqdefault.jpg" : item.ThumbnailUrl)"
                                             alt="Thumbnail"
                                             class="img-fluid rounded-3 shadow-sm"
                                             style="width: 100px; height: 56px; object-fit: cover;" />
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark text-truncate" style="max-width: 300px;" title="@item.Title">
                                            @item.Title
                                        </div>
                                        <div class="text-muted small">
                                            <i class="fa-regular fa-clock me-1"></i> @(item.Duration ?? "--:--")
                                        </div>
                                    </td>
                                    <td>
                                        <a href="https://youtube.com/watch?v=@item.YoutubeId" target="_blank" rel="noopener noreferrer"
                                           class="text-decoration-none badge bg-danger text-white rounded-pill">
                                            <i class="fa-brands fa-youtube me-1"></i> @item.YoutubeId
                                        </a>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column gap-1 align-items-start">
                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                                                Level @item.Level
                                            </span>
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25">
                                                @item.Topic
                                            </span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success rounded-pill px-3 py-2">
                                            @item.SentenceCount cau
                                        </span>
                                    </td>
                                    <td class="pe-4 text-center">
                                        <form asp-action="Delete" method="post" class="d-inline"
                                              onsubmit="return confirm('Ban co chac chan muon xoa video nay? Moi cau thoai lien quan cung se bi xoa.');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xoa">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
