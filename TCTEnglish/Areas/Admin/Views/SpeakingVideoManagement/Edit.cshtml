@model TCTVocabulary.Areas.Admin.ViewModels.SpeakingVideoEditViewModel
@{
    ViewData["Title"] = "Chỉnh sửa Speaking Video";
    var thumb = string.IsNullOrEmpty(Model.ThumbnailUrl)
        ? $"https://img.youtube.com/vi/{Model.YoutubeId}/hqdefault.jpg"
        : Model.ThumbnailUrl;
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="d-flex align-items-center mb-4 gap-3">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-3">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
                <h2 class="mb-0 text-dark fw-bold">Chỉnh sửa Video</h2>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-4 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @* Video preview card *@
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex gap-4 align-items-center flex-wrap">
                        <img src="@thumb" alt="Thumbnail" class="rounded-3 shadow-sm admin-video-thumb-lg" />
                        <div class="flex-grow-1">
                            <p class="text-muted small mb-1">YouTube ID</p>
                            <a href="https://youtube.com/watch?v=@Model.YoutubeId" target="_blank" rel="noopener noreferrer"
                               class="badge bg-danger text-white text-decoration-none rounded-pill fs-6 mb-2">
                                <i class="bi bi-youtube me-1"></i> @Model.YoutubeId
                            </a>
                            <p class="text-muted small mb-0 mt-2">
                                <i class="bi bi-chat-left-text me-1"></i>
                                <strong>@Model.SentenceCount</strong> câu thoại đã được trích xuất
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            @* Edit form *@
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4" role="alert"></div>

                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4">
                            <div class="col-md-12">
                                <label asp-for="Title" class="form-label fw-bold">
                                    Tiêu đề bài học <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề hiển thị cho học viên" />
                                <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Level" class="form-label fw-bold">
                                    Trình độ <span class="text-danger">*</span>
                                </label>
                                <select asp-for="Level" class="form-select">
                                    <option value="">-- Chọn trình độ --</option>
                                    <option value="A1">A1 (Beginner)</option>
                                    <option value="A2">A2 (Pre-Intermediate)</option>
                                    <option value="B1">B1 (Intermediate)</option>
                                    <option value="B2">B2 (Upper-Intermediate)</option>
                                    <option value="C1">C1 (Advanced)</option>
                                    <option value="C2">C2 (Proficient)</option>
                                </select>
                                <span asp-validation-for="Level" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Topic" class="form-label fw-bold">Chủ đề</label>
                                <input asp-for="Topic" class="form-control" placeholder="Ví dụ: Business, Daily Life, Vlogs..." />
                                <span asp-validation-for="Topic" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="PlaylistId" class="form-label fw-bold">Playlist</label>
                                <select asp-for="PlaylistId" class="form-select">
                                    <option value="0">-- Mặc định (General) --</option>
                                    @foreach (var playlist in Model.Playlists)
                                    {
                                        <option value="@playlist.Id">@playlist.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="PlaylistId" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <hr class="my-5 opacity-10" />

                        <div class="d-flex justify-content-end gap-3">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary shadow-sm rounded-pill px-4">
                                <i class="bi bi-check-lg me-1"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
