@{
    ViewData["Title"] = "Thêm Speaking Video";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-link text-decoration-none text-muted p-0 me-3">
                    <i class="fa-solid fa-arrow-left fa-lg"></i>
                </a>
                <h2 class="mb-0 text-dark fw-bold">Thêm Video Mới</h2>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div asp-validation-summary="All" class="text-danger alert alert-danger rounded-3" role="alert"></div>

                    <form asp-action="Create" method="post" id="createVideoForm">
                        @Html.AntiForgeryToken()

                        <div class="row g-4">
                            <!-- YouTube ID -->
                            <div class="col-md-12">
                                <label for="youtubeId" class="form-label fw-bold">YouTube Video ID <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fa-brands fa-youtube text-danger"></i></span>
                                    <input type="text" class="form-control" id="youtubeId" name="youtubeId" required placeholder="Ví dụ: dQw4w9WgXcQ">
                                </div>
                                <div class="form-text text-muted mt-2">
                                    <i class="fa-solid fa-circle-info me-1"></i> Chỉ nhập <strong>Video ID</strong> (chuỗi ~11 ký tự nằm sau `v=` trên link YouTube). Hệ thống sẽ tự động lấy video và trích xuất phụ đề.
                                </div>
                            </div>

                            <!-- Title -->
                            <div class="col-md-12">
                                <label for="title" class="form-label fw-bold">Tiêu đề bài học <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="title" name="title" required placeholder="Nhập tiêu đề hiển thị cho học viên">
                            </div>

                            <!-- Level -->
                            <div class="col-md-6">
                                <label for="level" class="form-label fw-bold">Trình độ <span class="text-danger">*</span></label>
                                <select class="form-select" id="level" name="level" required>
                                    <option value="">-- Chọn trình độ --</option>
                                    <option value="A1">A1 (Beginner)</option>
                                    <option value="A2">A2 (Pre-Intermediate)</option>
                                    <option value="B1">B1 (Intermediate)</option>
                                    <option value="B2">B2 (Upper-Intermediate)</option>
                                    <option value="C1">C1 (Advanced)</option>
                                    <option value="C2">C2 (Proficient)</option>
                                </select>
                            </div>

                            <!-- Topic -->
                            <div class="col-md-6">
                                <label for="topic" class="form-label fw-bold">Chủ đề</label>
                                <input type="text" class="form-control" id="topic" name="topic" value="General" placeholder="Ví dụ: Business, Daily Life, Vlogs...">
                            </div>

                            <!-- Playlist -->
                            <div class="col-md-12">
                                <label for="playlistId" class="form-label fw-bold">Thêm vào Playlist (Tùy chọn)</label>
                                <select class="form-select" id="playlistId" name="playlistId">
                                    <option value="0">-- Mặc định (Không thuộc Playlist nào) --</option>
                                    @if(ViewBag.Playlists != null)
                                    {
                                        foreach (var pl in ViewBag.Playlists)
                                        {
                                            <option value="@pl.Id">@pl.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <hr class="my-5 opacity-10">

                        <div class="d-flex justify-content-end gap-3">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary shadow-sm rounded-pill px-4" id="btnSubmit">
                                <span class="d-none spinner-border spinner-border-sm me-2" role="status" aria-hidden="true" id="submitSpinner"></span>
                                <i class="fa-solid fa-cloud-arrow-down me-2" id="submitIcon"></i> Trích xuất & Lưu Video
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="alert alert-info mt-4 rounded-4 shadow-sm border-0 d-flex gap-3">
                <i class="fa-solid fa-robot fa-2x text-info"></i>
                <div>
                    <h6 class="fw-bold mb-1">Quy trình tự động hóa</h6>
                    <p class="mb-0 small">Sau khi bấm Lưu, hệ thống sẽ thực hiện theo 2 bước: 
                        <br/>1. (Nhanh) Thử lấy <strong>Closed Captions</strong> tiếng Anh có sẵn trên YouTube.
                        <br/>2. (Chậm) Nếu không có, tự động tải Audio và gọi <strong>AI (Whisper)</strong> để nhận diện giọng nói và dịch thành phụ đề chuẩn xác. Vui lòng kiên nhẫn nếu video quá dài.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('createVideoForm').addEventListener('submit', function (e) {
            // Không chặn form submit mặc định, chỉ đổi trạng thái UI của nút Submit
            const btn = document.getElementById('btnSubmit');
            const spinner = document.getElementById('submitSpinner');
            const icon = document.getElementById('submitIcon');
            
            // Xóa validation errors cũ nếu có
            const errorAlert = document.querySelector('.validation-summary-errors');
            if (errorAlert) {
                errorAlert.style.display = 'none';
            }

            // Đổi trạng thái UI
            btn.classList.add('disabled');
            icon.classList.add('d-none');
            spinner.classList.remove('d-none');
            
            // Thay đổi text chữ
            btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Đang xử lý... (Có thể mất 1-2 phút)`;
        });
    </script>
}
