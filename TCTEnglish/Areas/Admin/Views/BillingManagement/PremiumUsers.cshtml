@model TCTVocabulary.Areas.Admin.ViewModels.Billing.AdminPremiumUsersViewModel
@{
    ViewData["Title"] = "Quản lý Premium";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var hasFilter = (!string.IsNullOrWhiteSpace(Model.Filter) && Model.Filter != "all") || !string.IsNullOrWhiteSpace(Model.SearchQuery);

    string FilterLabel(string key) => key switch
    {
        "all" => "Tất cả",
        "active" => "Đang Premium",
        "standard" => "Tài khoản thường",
        "expiring_soon" => "Sắp hết hạn (7 ngày)",
        "expired" => "Đã hết hạn",
        "revoked" => "Đã thu hồi",
        "manual" => "Cấp thủ công",
        "vnpay" => "Từ VNPay",
        "momo" => "Từ MoMo",
        _ => key
    };
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div>
        <h1 class="h4 fw-bold mb-1"><i class="bi bi-gem me-2 text-primary"></i>Quản lý Premium</h1>
        <p class="text-muted small mb-0">Theo dõi tài khoản Premium/Standard theo UserSubscription.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-area="Admin" asp-controller="BillingManagement" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-credit-card me-1"></i>Đơn thanh toán
        </a>
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#grantPremiumModal">
            <i class="bi bi-plus-circle me-1"></i>Cấp Premium
        </button>
    </div>
</div>

@if (TempData["Success"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

<div class="row g-2 mb-3">
    <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100"><div class="card-body p-3"><div class="small text-muted">Premium đang hoạt động</div><div class="h5 mb-0 fw-bold">@Model.Dashboard.ActivePremiumCount</div></div></div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100"><div class="card-body p-3"><div class="small text-muted">Tài khoản thường</div><div class="h5 mb-0 fw-bold">@Model.Dashboard.StandardCount</div></div></div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100"><div class="card-body p-3"><div class="small text-muted">Sắp hết hạn 7 ngày</div><div class="h5 mb-0 fw-bold">@Model.Dashboard.ExpiringSoonCount</div></div></div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100"><div class="card-body p-3"><div class="small text-muted">Premium đã hết hạn</div><div class="h5 mb-0 fw-bold">@Model.Dashboard.ExpiredCount</div></div></div>
    </div>
    <div class="col-12 col-xl-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body p-3"><div class="small text-muted">Doanh thu tháng này (đơn Paid)</div><div class="h5 mb-0 fw-bold">@Model.Dashboard.RevenueThisMonthVnd.ToString("N0") VND</div></div></div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <form method="get" asp-area="Admin" asp-controller="BillingManagement" asp-action="PremiumUsers" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-semibold mb-1">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="q" value="@Model.SearchQuery" class="form-control" placeholder="UserId, email, tên, mã đơn..." />
                </div>
            </div>
            <div class="col-md-5">
                <label class="form-label small fw-semibold mb-1">Bộ lọc</label>
                <select name="filter" class="form-select form-select-sm">
                    @foreach (var filter in Model.Filters)
                    {
                        <option value="@filter" selected="@(Model.Filter == filter ? "selected" : null)">@FilterLabel(filter)</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-grow-1"><i class="bi bi-funnel me-1"></i>Lọc</button>
                @if (hasFilter)
                {
                    <a asp-area="Admin" asp-controller="BillingManagement" asp-action="PremiumUsers" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-lg"></i></a>
                }
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
        <h2 class="h6 fw-semibold mb-0">Danh sách người dùng <span class="badge bg-secondary ms-1">@Model.TotalFilteredCount</span></h2>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Người dùng</th>
                        <th>Tài khoản</th>
                        <th>Gói / trạng thái</th>
                        <th>Thời hạn</th>
                        <th>Đơn kích hoạt</th>
                        <th>Cảnh báo dữ liệu</th>
                        <th class="text-end pe-3">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Users.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Không có dữ liệu phù hợp.</td></tr>
                    }
                    @foreach (var row in Model.Users)
                    {
                        var revokeModalId = $"revokePremiumModal-{row.UserId}";
                        <tr>
                            <td class="ps-3">
                                <div class="fw-semibold">#@row.UserId - @row.FullName</div>
                                <div class="small text-muted">@row.Email</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">@row.AccountType</span>
                                <div class="small text-muted mt-1">Nguồn: @(row.IsManualSubscription ? "Thủ công" : "Thanh toán")</div>
                            </td>
                            <td>
                                <div class="fw-semibold">@(row.PlanName ?? "-")</div>
                                <span class="@row.SubscriptionBadgeClass">@row.SubscriptionStatus</span>
                            </td>
                            <td>
                                <div class="small">Bắt đầu: @(row.StartsAtUtc?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                                <div class="small">Kết thúc: @(row.EndsAtUtc?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                                <div class="small text-muted">Còn lại: @(row.DaysRemaining?.ToString() ?? "-") ngày</div>
                            </td>
                            <td>
                                <div class="small">Mã đơn: @(row.ActivatedByOrderCode ?? "-")</div>
                                <div class="small text-muted">Cổng: @(row.Provider ?? "-")</div>
                            </td>
                            <td>
                                @if (row.RolePremiumWithoutActiveSubscription)
                                {
                                    <div><span class="badge bg-warning text-dark mb-1">Role Premium nhưng không active</span></div>
                                }
                                @if (row.ActiveSubscriptionButRoleNotPremium)
                                {
                                    <div><span class="badge bg-danger mb-1">Subscription active nhưng role chưa Premium</span></div>
                                }
                                @if (row.PaidOrderNotActivated)
                                {
                                    <div><span class="badge bg-info text-dark">Order paid chưa activate</span></div>
                                }
                                @if (!row.RolePremiumWithoutActiveSubscription && !row.ActiveSubscriptionButRoleNotPremium && !row.PaidOrderNotActivated)
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                <a asp-area="Admin" asp-controller="BillingManagement" asp-action="PremiumUserDetails" asp-route-userId="@row.UserId" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye me-1"></i>Chi tiết
                                </a>
                                @if (row.IsActiveSubscription)
                                {
                                    <button type="button" class="btn btn-outline-danger btn-sm ms-1" data-bs-toggle="modal" data-bs-target="#@revokeModalId">
                                        <i class="bi bi-x-circle me-1"></i>Thu hồi
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-white border-top py-2">
            <nav aria-label="Phân trang Premium Users">
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="PremiumUsers" asp-route-filter="@Model.Filter" asp-route-q="@Model.SearchQuery" asp-route-page="@(Model.CurrentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    @for (var pageNumber = Math.Max(1, Model.CurrentPage - 2); pageNumber <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); pageNumber++)
                    {
                        <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="PremiumUsers" asp-route-filter="@Model.Filter" asp-route-q="@Model.SearchQuery" asp-route-page="@pageNumber">@pageNumber</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="PremiumUsers" asp-route-filter="@Model.Filter" asp-route-q="@Model.SearchQuery" asp-route-page="@(Model.CurrentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@foreach (var row in Model.Users.Where(x => x.IsActiveSubscription))
{
    var revokeModalId = $"revokePremiumModal-{row.UserId}";
    <div class="modal fade" id="@revokeModalId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form asp-area="Admin" asp-controller="BillingManagement" asp-action="Revoke" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="UserId" value="@row.UserId" />
                    <div class="modal-header border-bottom bg-danger bg-opacity-10">
                        <h2 class="modal-title h5 fw-semibold text-danger"><i class="bi bi-x-circle-fill me-2"></i>Thu hồi Premium</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-2">Thu hồi Premium của <strong>@row.FullName</strong> (<span class="text-muted">@row.Email</span>).</p>
                        <label class="form-label fw-semibold">Lý do</label>
                        <textarea name="Reason" rows="3" maxlength="500" class="form-control" required></textarea>
                    </div>
                    <div class="modal-footer border-top">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger">Xác nhận thu hồi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="grantPremiumModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-area="Admin" asp-controller="BillingManagement" asp-action="Grant" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header border-bottom">
                    <h2 class="modal-title h5 fw-semibold"><i class="bi bi-gem me-2"></i>Cấp Premium thủ công</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="UserLookup">Người dùng</label>
                        <input id="UserLookup" name="UserLookup" class="form-control" placeholder="Email hoặc user ID" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="PlanId">Gói Premium</label>
                        <select id="PlanId" name="PlanId" class="form-select">
                            <option value="">Chọn gói</option>
                            @foreach (var plan in Model.Plans)
                            {
                                <option value="@plan.Id">@plan.Name - @plan.DurationDays ngày - @plan.PriceVnd.ToString("N0") VND</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="DurationDays">Thời hạn tùy chỉnh (không bắt buộc)</label>
                        <input id="DurationDays" name="DurationDays" type="number" min="1" max="3650" class="form-control" />
                    </div>
                    <div>
                        <label class="form-label fw-semibold" for="GrantReason">Lý do</label>
                        <textarea id="GrantReason" name="Reason" rows="3" maxlength="500" class="form-control" required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Cấp Premium</button>
                </div>
            </form>
        </div>
    </div>
</div>
