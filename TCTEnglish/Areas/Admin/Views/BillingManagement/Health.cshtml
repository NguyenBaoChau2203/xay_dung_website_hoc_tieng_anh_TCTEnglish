@model TCTEnglish.ViewModels.Billing.PaymentHealthViewModel
@{
    ViewData["Title"] = "Payment Provider Health";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h1 class="h4 fw-bold mb-1">
            <i class="bi bi-heart-pulse-fill text-danger me-2"></i>Payment Provider Health
        </h1>
        <p class="text-muted small mb-0">
            Trạng thái cấu hình của các cổng thanh toán và background workers.
            <strong class="text-danger">Giá trị secret không bao giờ được hiển thị ở đây.</strong>
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-area="Admin"
           asp-controller="BillingManagement"
           asp-action="Index"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
    </div>
</div>

@* ── Provider cards ────────────────────────────────────────────────────── *@
<div class="row g-4 mb-5">
    @foreach (var provider in Model.Providers)
    {
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h2 class="h6 fw-semibold mb-0">
                        <i class="bi bi-credit-card me-1 text-primary"></i>@provider.DisplayName
                    </h2>
                    <span class="@provider.StatusBadgeClass">@provider.Status</span>
                </div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <tbody>
                        <tr>
                            <td class="text-muted small">Enabled</td>
                            <td>
                                @if (provider.Enabled)
                                {
                                    <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">true</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary-emphasis border">false</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted small">Configured</td>
                            <td>
                                @if (provider.Configured)
                                {
                                    <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle">No</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted small">BaseUrl</td>
                            <td>@PresenceBadge(provider.HasBaseUrl)</td>
                        </tr>
                        <tr>
                            <td class="text-muted small">ReturnUrl</td>
                            <td>@PresenceBadge(provider.HasReturnUrl)</td>
                        </tr>
                        <tr>
                            <td class="text-muted small">IPN / Webhook URL</td>
                            <td>@PresenceBadge(provider.HasIpnUrl)</td>
                        </tr>
                        <tr>
                            <td class="text-muted small">Merchant / TmnCode</td>
                            <td>@PresenceBadge(provider.HasMerchantCode)</td>
                        </tr>
                        <tr>
                            <td class="text-muted small">Secret key</td>
                            <td>@PresenceBadge(provider.HasSecret)</td>
                        </tr>
                        </tbody>
                    </table>

                    @if (provider.MissingFields.Count > 0)
                    {
                        <div class="alert alert-warning py-2 px-3 mt-3 mb-0 small">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>
                            <strong>Thiếu:</strong> @string.Join(", ", provider.MissingFields)
                        </div>
                    }
                    @if (provider.Status == "Disabled")
                    {
                        <div class="alert alert-secondary py-2 px-3 mt-3 mb-0 small">
                            <i class="bi bi-info-circle me-1"></i>Provider này chưa được kích hoạt.
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@* ── Background workers ────────────────────────────────────────────────── *@
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3">
        <h2 class="h6 fw-semibold mb-0">
            <i class="bi bi-gear-wide-connected me-1 text-secondary"></i>Billing Background Workers
        </h2>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
            <tr>
                <th class="ps-4">Worker</th>
                <th>Mô tả</th>
                <th>Trạng thái</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var worker in Model.Workers)
            {
                <tr>
                    <td class="ps-4 fw-medium">@worker.WorkerName</td>
                    <td class="text-muted small">@worker.Description</td>
                    <td><span class="@worker.StatusBadgeClass">@worker.StatusLabel</span></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@* ── Setup guide ───────────────────────────────────────────────────────── *@
<div class="card border-warning border-0 shadow-sm mt-4">
    <div class="card-header bg-warning-subtle py-3">
        <h2 class="h6 fw-semibold mb-0 text-warning-emphasis">
            <i class="bi bi-shield-lock-fill me-1"></i>Hướng dẫn cấu hình an toàn
        </h2>
    </div>
    <div class="card-body">
        <p class="small text-muted mb-2">
            Không bao giờ đặt secret trực tiếp vào <code>appsettings.json</code>.
            Sử dụng một trong các phương pháp sau:
        </p>
        <ul class="small mb-2">
            <li>
                <strong>Development — dotnet user-secrets:</strong>
                <code>dotnet user-secrets set "VNPay:TmnCode" "abc"</code>
            </li>
            <li>
                <strong>Production — Environment variables:</strong>
                <code>VNPay__TmnCode=abc</code>, <code>VNPay__HashSecret=xyz</code>, <code>VNPay__Enabled=true</code>
            </li>
        </ul>
        <p class="small text-muted mb-0">
            Xem file <code>SECRETS.md</code> tại root của repo để biết danh sách đầy đủ các biến cần set.
        </p>
    </div>
</div>

@functions {
    static Microsoft.AspNetCore.Html.IHtmlContent PresenceBadge(bool present)
    {
        return present
            ? new Microsoft.AspNetCore.Html.HtmlString("<span class=\"badge bg-success-subtle text-success-emphasis border border-success-subtle\">Present</span>")
            : new Microsoft.AspNetCore.Html.HtmlString("<span class=\"badge bg-danger-subtle text-danger-emphasis border border-danger-subtle\">Missing</span>");
    }
}
