@model TCTVocabulary.Areas.Admin.ViewModels.Billing.AdminPremiumUserDetailsViewModel
@{
    ViewData["Title"] = "Chi tiết Premium";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div>
        <h1 class="h4 fw-bold mb-1"><i class="bi bi-person-badge-fill me-2 text-primary"></i>Chi tiết người dùng Premium</h1>
        <p class="text-muted small mb-0">Thông tin người dùng, subscription hiện tại và lịch sử thanh toán.</p>
    </div>
    <a asp-area="Admin" asp-controller="BillingManagement" asp-action="PremiumUsers" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <div class="row g-2">
            <div class="col-md-3"><div class="small text-muted">UserId</div><div class="fw-semibold">#@Model.UserId</div></div>
            <div class="col-md-3"><div class="small text-muted">Email</div><div class="fw-semibold">@Model.Email</div></div>
            <div class="col-md-3"><div class="small text-muted">Họ tên</div><div class="fw-semibold">@Model.FullName</div></div>
            <div class="col-md-3"><div class="small text-muted">Loại tài khoản</div><div><span class="badge bg-light text-dark border">@Model.AccountType</span></div></div>
        </div>
        <div class="mt-2 d-flex flex-wrap gap-2">
            @if (Model.RolePremiumWithoutActiveSubscription)
            {
                <span class="badge bg-warning text-dark">Role Premium nhưng không active</span>
            }
            @if (Model.ActiveSubscriptionButRoleNotPremium)
            {
                <span class="badge bg-danger">Subscription active nhưng role chưa Premium</span>
            }
            @if (Model.PaidOrderNotActivated)
            {
                <span class="badge bg-info text-dark">Order paid chưa activate</span>
            }
            @if (!Model.RolePremiumWithoutActiveSubscription && !Model.ActiveSubscriptionButRoleNotPremium && !Model.PaidOrderNotActivated)
            {
                <span class="text-muted small">Không có cảnh báo dữ liệu.</span>
            }
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white py-2"><h2 class="h6 fw-semibold mb-0">Subscription hiện tại</h2></div>
    <div class="card-body py-3">
        @if (Model.CurrentSubscription == null)
        {
            <p class="text-muted mb-0">Chưa có dữ liệu subscription.</p>
        }
        else
        {
            <div class="row g-2">
                <div class="col-md-3"><div class="small text-muted">Gói</div><div class="fw-semibold">@Model.CurrentSubscription.PlanName</div></div>
                <div class="col-md-3"><div class="small text-muted">Trạng thái</div><div><span class="@Model.CurrentSubscription.SubscriptionBadgeClass">@Model.CurrentSubscription.SubscriptionStatus</span></div></div>
                <div class="col-md-3"><div class="small text-muted">Bắt đầu</div><div class="fw-semibold">@(Model.CurrentSubscription.StartsAtUtc?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div></div>
                <div class="col-md-3"><div class="small text-muted">Kết thúc</div><div class="fw-semibold">@(Model.CurrentSubscription.EndsAtUtc?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div></div>
                <div class="col-md-3"><div class="small text-muted">Còn lại</div><div class="fw-semibold">@(Model.CurrentSubscription.DaysRemaining?.ToString() ?? "-") ngày</div></div>
                <div class="col-md-3"><div class="small text-muted">Mã đơn kích hoạt</div><div class="fw-semibold">@(Model.CurrentSubscription.ActivatedByOrderCode ?? "-")</div></div>
                <div class="col-md-3"><div class="small text-muted">Cổng thanh toán</div><div class="fw-semibold">@(Model.CurrentSubscription.Provider ?? "-")</div></div>
                <div class="col-md-3"><div class="small text-muted">Nguồn</div><div class="fw-semibold">@(Model.CurrentSubscription.IsManualSubscription ? "Thủ công" : "Thanh toán")</div></div>
            </div>
        }
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white py-2"><h2 class="h6 fw-semibold mb-0">Lịch sử subscription</h2></div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Gói</th>
                        <th>Trạng thái</th>
                        <th>Thời hạn</th>
                        <th>Mã đơn</th>
                        <th>Cổng</th>
                        <th>Lý do hủy</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.SubscriptionHistory.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Không có lịch sử subscription.</td></tr>
                    }
                    @foreach (var item in Model.SubscriptionHistory)
                    {
                        <tr>
                            <td class="ps-3">#@item.Id</td>
                            <td>@item.PlanName</td>
                            <td><span class="badge bg-light text-dark border">@item.Status</span></td>
                            <td>
                                <div class="small">@item.StartsAtUtc.ToString("dd/MM/yyyy HH:mm")</div>
                                <div class="small text-muted">đến @item.EndsAtUtc.ToString("dd/MM/yyyy HH:mm")</div>
                            </td>
                            <td>@(item.ActivatedByOrderCode ?? "-")</td>
                            <td>@(item.Provider ?? (item.IsManual ? "manual" : "-"))</td>
                            <td>@(item.CancelReason ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-2"><h2 class="h6 fw-semibold mb-0">Lịch sử Payment Order</h2></div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Mã đơn</th>
                        <th>Cổng</th>
                        <th class="text-end">Số tiền</th>
                        <th>Trạng thái</th>
                        <th>Tạo lúc</th>
                        <th>Thanh toán lúc</th>
                        <th>Cảnh báo</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.PaymentOrders.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Không có payment order.</td></tr>
                    }
                    @foreach (var item in Model.PaymentOrders)
                    {
                        <tr>
                            <td class="ps-3">@item.OrderCode</td>
                            <td>@item.Provider</td>
                            <td class="text-end">@item.AmountVnd.ToString("N0") VND</td>
                            <td><span class="badge bg-light text-dark border">@item.Status</span></td>
                            <td>@item.CreatedAtUtc.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(item.PaidAtUtc?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td>
                                @if (item.IsPaidButNotActivated)
                                {
                                    <span class="badge bg-info text-dark">Paid nhưng chưa activate</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
